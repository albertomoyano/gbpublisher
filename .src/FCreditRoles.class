' Gambas class file

' ARRAY DE REFERENCIAS A LOS CHECKBOXES DEL DISEÑADOR
Private aChk As CheckBox[]

Public Sub Form_Open()

  ' --- 1. Título del formulario ---
  Me.Text = "Roles CRediT"

  ' --- 2. Cargar referencias a los checkboxes del diseñador en el array ---
  aChk = New CheckBox[]
  aChk.Add(CheckBox1)
  aChk.Add(CheckBox2)
  aChk.Add(CheckBox3)
  aChk.Add(CheckBox4)
  aChk.Add(CheckBox5)
  aChk.Add(CheckBox6)
  aChk.Add(CheckBox7)
  aChk.Add(CheckBox8)
  aChk.Add(CheckBox9)
  aChk.Add(CheckBox10)
  aChk.Add(CheckBox11)
  aChk.Add(CheckBox12)
  aChk.Add(CheckBox13)
  aChk.Add(CheckBox14)

  ' --- 3. Asignar texto oficial CRediT a cada checkbox ---
  aChk[0].Text = "Conceptualization"
  aChk[1].Text = "Methodology"
  aChk[2].Text = "Software"
  aChk[3].Text = "Validation"
  aChk[4].Text = "Formal analysis"
  aChk[5].Text = "Investigation"
  aChk[6].Text = "Resources"
  aChk[7].Text = "Data curation"
  aChk[8].Text = "Writing – original draft"
  aChk[9].Text = "Writing – review && editing"
  aChk[10].Text = "Visualization"
  aChk[11].Text = "Supervision"
  aChk[12].Text = "Project administration"
  aChk[13].Text = "Funding acquisition"

  ' --- 4. Pre-seleccionar roles existentes desde la BD ---
  CargarSeleccionActual(m_Constantes.sCreditSeleccionado)

End

' ============================================
' Función   : CargarSeleccionActual
' Propósito : Marca los checkboxes que corresponden a los
'             roles ya guardados en la BD para este autor/artículo
' Parámetros: sCredit As String — roles separados por ;
' Retorna   : (ninguno)
' ============================================
Private Sub CargarSeleccionActual(sCredit As String)

  ' --- 1. Inicialización ---
  Dim aActivos As String[]
  Dim sRol As String
  Dim i As Integer

  ' --- 2. Limpiar selección previa ---
  For i = 0 To aChk.Max
    aChk[i].Value = False
  Next

  ' --- 3. Salir si no hay nada guardado ---
  If Trim(sCredit) = "" Then Return

  ' --- 4. Parsear los roles activos ---
  aActivos = Split(sCredit, ";")

  ' --- 5. Marcar cada checkbox que coincida ---
  For Each sRol In aActivos
    sRol = Trim(sRol)
    For i = 0 To aChk.Max
      ' NORMALIZAR && → & PARA COMPARAR CON EL VALOR DE LA BD
      If Replace(aChk[i].Text, "&&", "&") = sRol Then
        aChk[i].Value = True
        Break
      Endif
    Next
  Next

End

' ============================================
' Función   : btnAplicar_Click
' Propósito : Construye el string de roles seleccionados
'             separados por ; y lo escribe en
'             m_Constantes.sCreditSeleccionado antes de cerrar
' Parámetros: (ninguno)
' Retorna   : (ninguno)
' ============================================
Public Sub btnAplicar_Click()

  ' --- 1. Inicialización ---
  Dim sResultado As String = ""
  Dim i As Integer
  Dim bPrimero As Boolean = True

  ' --- 2. Recorrer checkboxes y construir el string ---
  For i = 0 To aChk.Max
    If aChk[i].Value = True Then
      If Not bPrimero Then sResultado &= "; "
      ' NORMALIZAR && → & ANTES DE GUARDAR EN LA BD
      sResultado &= Replace(aChk[i].Text, "&&", "&")
      bPrimero = False
    Endif
  Next

  ' --- 3. Escribir resultado en variable pública del módulo ---
  ' EL LLAMADOR LEE ESTE VALOR DESPUÉS DE ShowModal()
  m_Constantes.sCreditSeleccionado = sResultado

  ' --- 4. Cerrar el formulario ---
  Me.Close

End

' ============================================
' Función   : btnCancelar_Click
' Propósito : Cierra sin modificar m_Constantes.sCreditSeleccionado
'             El llamador detecta cancelación comparando con
'             el valor que tenía antes de abrir el modal
' Parámetros: (ninguno)
' Retorna   : (ninguno)
' ============================================
Public Sub btnCancelar_Click()

  Me.Close

End
