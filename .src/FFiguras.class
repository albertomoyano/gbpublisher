' Gambas class file

' ============================================
' Formulario : FFiguras
' Propósito  : Visualizador y gestor de figuras para artículos
'              académicos. El grid muestra los datos del CSV
'              seleccionado en modo solo lectura. La edición
'              completa se delega a FFigurasEditar.
'              Acciones disponibles: cargar, editar, borrar.
' ============================================

Private sNombreBase As String   ' NOMBRE BASE DEL ARTÍCULO ACTIVO (SIN PREFIJO a-)
Private sRutaMedia As String   ' RUTA ABSOLUTA A LA CARPETA /media DEL PROYECTO
Private iNumFigura As Integer  ' NÚMERO DE FIGURA SIGUIENTE DISPONIBLE
Private sCSVActual As String   ' RUTA DEL CSV ACTUALMENTE CARGADO EN EL GRID

' ============================================
' Función   : Form_Open
' Propósito : Inicializa el formulario verificando artículo
'             activo, configura el grid en modo solo lectura
'             y carga los archivos fd* existentes en el combo
' ============================================
Public Sub Form_Open()

  ' --- 1. Verificar artículo activo ---
  Dim sArchivoActivo As String = File.Name(FMain.cmbArticulosRevista.Text)

  If Not (sArchivoActivo Begins "a-") Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay un artículo activo válido.")
    Me.Close
    Return
  Endif

  ' --- 2. Derivar nombre base del artículo ---
  ' a-02-revistaAlgo-v01-n01.md → 02-revistaAlgo-v01-n01
  sNombreBase = Mid(File.BaseName(sArchivoActivo), 3)
  sRutaMedia = File.Dir(FMain.txtProyecto.Text) &/ "media"

  ' --- 3. Mostrar artículo activo en el label ---
  lblArticulo.Text = "Figuras asociadas al artículo: " & sArchivoActivo

  ' --- 4. Configurar tipos de gráfico ---
  cmbTipoGrafico.Clear
  cmbTipoGrafico.Add("Barras verticales")
  cmbTipoGrafico.Add("Barras horizontales")
  cmbTipoGrafico.Add("Líneas")
  cmbTipoGrafico.Add("Dispersión")
  cmbTipoGrafico.Add("Torta")
  cmbTipoGrafico.Add("Dona")
  cmbTipoGrafico.Index = 0

  ' --- 5. Configurar tipo de datos y paletas ColorBrewer ---
  cmbTipoDatos.Clear
  cmbTipoDatos.Add("Cualitativa")
  cmbTipoDatos.Add("Secuencial")
  cmbTipoDatos.Add("Divergente")
  cmbTipoDatos.Index = 0
  CargarPaletasPorTipo()

  ' --- 6. Configurar GridView en modo solo lectura ---
  gvDatos.Header = GridView.Both
  gvDatos.Mode = Select.None

  ' --- 7. Cargar archivos fd* existentes en el combo ---
  CargarComboFiguras()

  ' --- 8. Calcular número de figura siguiente ---
  iNumFigura = ContarFiguras(sRutaMedia, sNombreBase) + 1

  ' --- 9. Inicializar WebView con página en blanco ---
  wvFigura.URL = "about:blank"

  ' --- 10. Estado inicial ---
  sCSVActual = ""
  ActualizarBotones()

End Sub

' ============================================
' Función   : ActualizarBotones
' Propósito : Gestiona la visibilidad de los botones que
'             dependen de si hay un CSV cargado en el grid
' ============================================
Private Sub ActualizarBotones()

  Dim bHayCSV As Boolean = (sCSVActual <> "")

  btnBorrarArchivoCSV.Visible = bHayCSV
  btnEditarCSV.Visible = bHayCSV
  btnEditarCSVconOffice.Visible = bHayCSV

End Sub

' ============================================
' Función   : CargarComboFiguras
' Propósito : Puebla cmbCargarDatos con los fd*-nombrebase.csv
'             existentes en /media para el artículo activo
' ============================================
Private Sub CargarComboFiguras()

  cmbCargarDatos.Clear

  If Not Exist(sRutaMedia) Then Return

  Dim aArchivos As String[] = Dir(sRutaMedia, "fd*-" & sNombreBase & ".csv")
  If Not aArchivos Then Return
  aArchivos.Sort()

  Dim s As String
  For Each s In aArchivos
    cmbCargarDatos.Add(s)
  Next

End Sub

' ============================================
' Función   : ContarFiguras
' Propósito : Cuenta los fd*-nombrebase.csv existentes
'             para determinar el número de figura siguiente
' Parámetros: sRutaMedia  As String — ruta a /media
'             sNombreBase As String — nombre base del artículo
' Retorna   : Integer — cantidad de figuras existentes
' ============================================
Private Function ContarFiguras(sRutaMedia As String, sNombreBase As String) As Integer

  If Not Exist(sRutaMedia) Then Return 0
  Dim aArchivos As String[] = Dir(sRutaMedia, "fd*-" & sNombreBase & ".csv")
  If Not aArchivos Then Return 0
  Return aArchivos.Count

End Function

' ============================================
' Función   : cmbCargarDatos_Click
' Propósito : Carga automáticamente el CSV seleccionado
'             en el grid al cambiar la selección del combo
' ============================================
Public Sub cmbCargarDatos_Click()

  If cmbCargarDatos.Index < 0 Then Return

  Dim sRutaCSV As String = sRutaMedia &/ cmbCargarDatos.Text
  CargarCSVEnGrid(sRutaCSV)

End Sub

' ============================================
' Función   : CargarCSVEnGrid
' Propósito : Lee un CSV y puebla el gvDatos en modo
'             solo lectura. Actualiza sCSVActual.
' Parámetros: sRutaCSV As String — ruta absoluta al archivo CSV
' ============================================
Private Sub CargarCSVEnGrid(sRutaCSV As String)

  If Not Exist(sRutaCSV) Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el archivo:" & Chr(10) & sRutaCSV)
    Return
  Endif

  Dim sContenido As String = File.Load(sRutaCSV)
  Dim aLineas As String[] = Split(Trim(sContenido), Chr(10))

  If aLineas.Count = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("El archivo CSV está vacío.")
    Return
  Endif

  ' --- LIMPIAR Y CONFIGURAR COLUMNAS ---
  gvDatos.Clear()
  Dim aEncabezados As String[] = Split(aLineas[0], ",")
  Dim nCols As Integer = aEncabezados.Count

  ' COLUMNAS DE DATOS + COLUMNA FANTASMA
  gvDatos.Columns.Count = nCols + 1
  Dim iCol As Integer
  For iCol = 0 To nCols - 1
    gvDatos.Columns[iCol].Text = Trim(aEncabezados[iCol])
    gvDatos.Columns[iCol].Width = If(iCol = 0, 150, 100)
  Next
  gvDatos.Columns[nCols].Text = ""
  gvDatos.Columns[nCols].Width = 10

  ' --- CARGAR FILAS DE DATOS ---
  gvDatos.Rows.Count = aLineas.Count - 1
  Dim iRow As Integer
  For iRow = 1 To aLineas.Count - 1
    Dim aCeldas As String[] = Split(aLineas[iRow], ",")
    For iCol = 0 To nCols - 1
      Dim sCelda As String = ""
      If iCol < aCeldas.Count Then
        sCelda = Trim(aCeldas[iCol])
        If sCelda Begins Chr(34) And sCelda Ends Chr(34) Then
          sCelda = Mid(sCelda, 2, Len(sCelda) - 2)
        Endif
      Endif
      gvDatos[iRow - 1, iCol].Text = sCelda
    Next
  Next

  ' --- ACTUALIZAR ESTADO ---
  sCSVActual = sRutaCSV
  ActualizarBotones()

End Sub

' ============================================
' Función   : btnEditarCSV_Click
' Propósito : Abre FFigurasEditar con el CSV activo para
'             edición avanzada en texto plano. Al cerrar,
'             refresca el combo y el grid con los cambios.
' ============================================
Public Sub btnEditarCSV_Click()

  If sCSVActual = "" Or Not Exist(sCSVActual) Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay un archivo CSV activo para editar.")
    Return
  Endif

  ' --- PASAR CONTEXTO AL EDITOR ---
  FFigurasEditar.sRutaCSV = sCSVActual
  FFigurasEditar.sRutaMedia = sRutaMedia
  FFigurasEditar.sNombreBase = sNombreBase
  FFigurasEditar.iNumFigura = iNumFigura

  FFigurasEditar.ShowModal()

  ' --- AL VOLVER: REFRESCAR SIN LEER DEL FORMULARIO CERRADO ---
  iNumFigura = ContarFiguras(sRutaMedia, sNombreBase) + 1
  CargarComboFiguras()

  ' RECARGAR EL GRID DESDE EL ARCHIVO CONOCIDO EN DISCO
  If sCSVActual <> "" And Exist(sCSVActual) Then
    CargarCSVEnGrid(sCSVActual)
  Endif

End Sub

' ============================================
' Función   : btnBorrarArchivoCSV_Click
' Propósito : Elimina el CSV actualmente cargado en el grid
'             junto con los archivos de figura asociados
'             (fi0N-*.png y fh0N-*.html), y limpia el grid
' ============================================
Public Sub btnBorrarArchivoCSV_Click()

  If sCSVActual = "" Or Not Exist(sCSVActual) Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay un archivo CSV activo para eliminar.")
    Return
  Endif

  ' --- CONFIRMAR LA OPERACIÓN ---
  m_Sonido.sonar("Question")
  If Message.Question(
      "¿Eliminar el archivo y todas las figuras asociadas?" & Chr(10) & Chr(10) &
      File.Name(sCSVActual) & Chr(10) &
      "(también se eliminarán el PNG y el HTML generados)" & Chr(10) & Chr(10) &
      "Esta acción no se puede deshacer.",
      "Sí", "No") <> 1 Then Return

    ' --- EXTRAER NÚMERO Y CONSTRUIR RUTAS ASOCIADAS ---
    Dim sNombreCSV As String = File.Name(sCSVActual)
    Dim sNumero As String = Mid(sNombreCSV, 3, 2)
    Dim sRutaPNG As String = sRutaMedia &/ "fi" & sNumero & "-" & sNombreBase & ".png"
    Dim sRutaHTML As String = sRutaMedia &/ "fh" & sNumero & "-" & sNombreBase & ".html"

    ' --- ELIMINAR ARCHIVOS ---
    Try Kill sCSVActual
    If Exist(sRutaPNG) Then Try Kill sRutaPNG
    If Exist(sRutaHTML) Then Try Kill sRutaHTML

    ' --- LIMPIAR ESTADO ---
    gvDatos.Clear()
    gvDatos.Rows.Count = 0
    sCSVActual = ""
    iNumFigura = ContarFiguras(sRutaMedia, sNombreBase) + 1

    CargarComboFiguras()
    ActualizarBotones()
    wvFigura.URL = "about:blank"

    m_Sonido.sonar("Info")
    Message.Info("Archivos eliminados correctamente.")

End Sub

' ============================================
' Función   : btnDibujar_Click
' Propósito : Lee el CSV activo y renderiza el gráfico
'             en el WebView usando chart.js
' ============================================
Public Sub btnDibujar_Click()

  If sCSVActual = "" Or Not Exist(sCSVActual) Then
    m_Sonido.sonar("Warning")
    Message.Warning("Primero cargá un archivo de datos." & Chr(10) &
      "El gráfico se genera desde el CSV activo.")
    Return
  Endif

  ' --- LEER CSV ---
  Dim sContenido As String = File.Load(sCSVActual)
  Dim aLineas As String[] = Split(Trim(sContenido), Chr(10))
  If aLineas.Count < 2 Then
    m_Sonido.sonar("Warning")
    Message.Warning("El CSV no tiene datos suficientes.")
    Return
  Endif

  ' --- PARSEAR ENCABEZADOS Y DATOS ---
  Dim aEncabezados As String[] = Split(aLineas[0], ",")
  Dim nCols As Integer = aEncabezados.Count

  ' ETIQUETAS — PRIMERA COLUMNA
  Dim sLabels As String = ""
  Dim iRow As Integer
  For iRow = 1 To aLineas.Count - 1
    Dim aCeldas As String[] = Split(aLineas[iRow], ",")
    If iRow > 1 Then sLabels &= ","
    sLabels &= Chr(34) & Trim(aCeldas[0]) & Chr(34)
  Next

  ' DATASETS — COLUMNAS 1 A N
  Dim sDatasets As String = ""
  Dim sColores As String = ObtenerPaleta(cmbColorPaleta.Text)
  Dim aColores As String[] = Split(sColores, "|")
  Dim iCol As Integer

  For iCol = 1 To nCols - 1
    Dim sValores As String = ""
    For iRow = 1 To aLineas.Count - 1
      Dim aCeldas2 As String[] = Split(aLineas[iRow], ",")
      If iRow > 1 Then sValores &= ","
      Dim sVal As String = ""
      If iCol < aCeldas2.Count Then sVal = Trim(aCeldas2[iCol])
      If sVal = "" Then sVal = "0"
      sValores &= sVal
    Next
    Dim sColor As String = aColores[(iCol - 1) Mod aColores.Count]
    If iCol > 1 Then sDatasets &= ","
    sDatasets &= "{" &
      Chr(34) & "label" & Chr(34) & ":" & Chr(34) & Trim(aEncabezados[iCol]) & Chr(34) & "," &
      Chr(34) & "data" & Chr(34) & ":[" & sValores & "]," &
      Chr(34) & "backgroundColor" & Chr(34) & ":" & Chr(34) & sColor & Chr(34) & "," &
      Chr(34) & "borderColor" & Chr(34) & ":" & Chr(34) & sColor & Chr(34) & "," &
      Chr(34) & "borderWidth" & Chr(34) & ":1" &
      "}"
  Next

  ' --- CONSTRUIR Y MOSTRAR HTML ---
  Dim sTipo As String = ObtenerTipoChartJS(cmbTipoGrafico.Text)
  Dim sChartJS As String = User.Home &/ ".gbpublisher/chart/chart.min.js"
  Dim sScriptJS As String = File.Load(sChartJS)
  Dim sTitulo As String = Trim(txtNombreFigura.Text)
  Dim sHTML As String = GenerarHTMLChart(sTipo, sLabels, sDatasets, sTitulo, sScriptJS, chkLeyenda.Value)

  Dim sTmp As String = "/tmp/gbpublisher-figura-preview.html"
  File.Save(sTmp, sHTML)
  wvFigura.URL = "file://" & sTmp

End Sub

' ============================================
' Función   : ObtenerTipoChartJS
' Propósito : Convierte el texto del combo al tipo chart.js
' Parámetros: sTipo As String — texto seleccionado en el combo
' Retorna   : String — identificador de tipo chart.js
' ============================================
Private Function ObtenerTipoChartJS(sTipo As String) As String

  Select Case sTipo
    Case "Barras verticales"
      Return "bar"
    Case "Barras horizontales"
      Return "bar"
    Case "Líneas"
      Return "line"
    Case "Dispersión"
      Return "scatter"
    Case "Torta"
      Return "pie"
    Case "Dona"
      Return "doughnut"
    Case Else
      Return "bar"
  End Select

End Function

' ============================================
' Función   : ObtenerPaleta
' Propósito : Devuelve colores ColorBrewer separados por |
' Parámetros: sPaleta As String — nombre de la paleta
' Retorna   : String — colores hex separados por |
' ============================================
Private Function ObtenerPaleta(sPaleta As String) As String

  Select Case sPaleta
      ' --- CUALITATIVA ---
    Case "Set1"
      Return "#e41a1c|#377eb8|#4daf4a|#984ea3|#ff7f00|#ffff33|#a65628|#f781bf"
    Case "Set2"
      Return "#66c2a5|#fc8d62|#8da0cb|#e78ac3|#a6d854|#ffd92f|#e5c494|#b3b3b3"
    Case "Set3"
      Return "#8dd3c7|#ffffb3|#bebada|#fb8072|#80b1d3|#fdb462|#b3de69|#fccde5"
    Case "Paired"
      Return "#a6cee3|#1f78b4|#b2df8a|#33a02c|#fb9a99|#e31a1c|#fdbf6f|#ff7f00"
    Case "Dark2"
      Return "#1b9e77|#d95f02|#7570b3|#e7298a|#66a61e|#e6ab02|#a6761d|#666666"
    Case "Accent"
      Return "#7fc97f|#beaed4|#fdc086|#ffff99|#386cb0|#f0027f|#bf5b17|#666666"
    Case "Pastel1"
      Return "#fbb4ae|#b3cde3|#ccebc5|#decbe4|#fed9a6|#ffffcc|#e5d8bd|#fddaec"
    Case "Pastel2"
      Return "#b3e2cd|#fdcdac|#cbd5e8|#f4cae4|#e6f5c9|#fff2ae|#f1e2cc|#cccccc"
      ' --- SECUENCIAL ---
    Case "Blues"
      Return "#f7fbff|#deebf7|#c6dbef|#9ecae1|#6baed6|#4292c6|#2171b5|#084594"
    Case "Greens"
      Return "#f7fcf5|#e5f5e0|#c7e9c0|#a1d99b|#74c476|#41ab5d|#238b45|#005a32"
    Case "Reds"
      Return "#fff5f0|#fee0d2|#fcbba1|#fc9272|#fb6a4a|#ef3b2c|#cb181d|#99000d"
    Case "Purples"
      Return "#fcfbfd|#efedf5|#dadaeb|#bcbddc|#9e9ac8|#807dba|#6a51a3|#4a1486"
    Case "Oranges"
      Return "#fff5eb|#fee6ce|#fdd0a2|#fdae6b|#fd8d3c|#f16913|#d94801|#8c2d04"
    Case "YlOrRd"
      Return "#ffffcc|#ffeda0|#fed976|#feb24c|#fd8d3c|#fc4e2a|#e31a1c|#800026"
    Case "YlGnBu"
      Return "#ffffd9|#edf8b1|#c7e9b4|#7fcdbb|#41b6c4|#1d91c0|#225ea8|#0c2c84"
    Case "BuGn"
      Return "#f7fcfd|#e5f5f9|#ccece6|#99d8c9|#66c2a4|#41ae76|#238b45|#005824"
      ' --- DIVERGENTE ---
    Case "RdBu"
      Return "#b2182b|#d6604d|#f4a582|#fddbc7|#d1e5f0|#92c5de|#4393c3|#2166ac"
    Case "RdYlBu"
      Return "#d73027|#f46d43|#fdae61|#fee090|#e0f3f8|#abd9e9|#74add1|#4575b4"
    Case "RdYlGn"
      Return "#d73027|#f46d43|#fdae61|#fee08b|#d9ef8b|#a6d96a|#66bd63|#1a9850"
    Case "Spectral"
      Return "#d53e4f|#f46d43|#fdae61|#fee08b|#e6f598|#abdda4|#66c2a5|#3288bd"
    Case "PiYG"
      Return "#c51b7d|#de77ae|#f1b6da|#fde0ef|#e6f5d0|#b8e186|#7fbc41|#4d9221"
    Case "PRGn"
      Return "#762a83|#9970ab|#c2a5cf|#e7d4e8|#d9f0d3|#a6dba0|#5aae61|#1b7837"
    Case "BrBG"
      Return "#8c510a|#bf812d|#dfc27d|#f6e8c3|#c7eae5|#80cdc1|#35978f|#01665e"
    Case "PuOr"
      Return "#b35806|#e08214|#fdb863|#fee0b6|#d8daeb|#b2abd2|#8073ac|#542788"
    Case Else
      Return "#e41a1c|#377eb8|#4daf4a|#984ea3|#ff7f00|#ffff33|#a65628|#f781bf"
  End Select

End Function

' ============================================
' Función   : GenerarHTMLChart
' Propósito : Construye el HTML standalone con chart.js
'             embebido. Válido para preview y para exportar
'             como fh0N-*.html
' ============================================
Private Function GenerarHTMLChart(sTipo As String, sLabels As String, sDatasets As String, sTitulo As String, sScriptJS As String, bLeyenda As Boolean) As String

  Dim sIndexAxis As String = If(sTipo = "bar" And cmbTipoGrafico.Text = "Barras horizontales",
    "'indexAxis':'y',", "")

  Dim sHTML As String
  sHTML = "<!DOCTYPE html>" & Chr(10)
  sHTML &= "<html lang='es'><head>" & Chr(10)
  sHTML &= "<meta charset='UTF-8'>" & Chr(10)
  sHTML &= "<meta name='viewport' content='width=device-width, initial-scale=1.0'>" & Chr(10)
  sHTML &= "<title>" & sTitulo & "</title>" & Chr(10)
  sHTML &= "<style>" & Chr(10)
  sHTML &= "  body { margin:0; padding:12px; font-family:'IBM Plex Sans',sans-serif; background:#fff; color:#000; }" & Chr(10)
  sHTML &= "  .chart-container { width:100%; }" & Chr(10)
  sHTML &= "  h2 { font-size:1.1rem; font-family:'IBM Plex Sans',sans-serif; color:#000; text-align:center; margin-bottom:8px; font-weight:600; }" & Chr(10)
  sHTML &= "</style>" & Chr(10)
  sHTML &= "</head><body>" & Chr(10)
  If sTitulo <> "" Then sHTML &= "<h2>" & sTitulo & "</h2>" & Chr(10)
  sHTML &= "<div class='chart-container'><canvas id='gbChart' width='820' height='500'></canvas></div>" & Chr(10)
  sHTML &= "<script>" & Chr(10) & sScriptJS & Chr(10) & "</script>" & Chr(10)
  sHTML &= "<script>" & Chr(10)
  sHTML &= "Chart.defaults.font.family = 'IBM Plex Sans, sans-serif';" & Chr(10)
  sHTML &= "Chart.defaults.font.size = 14;" & Chr(10)
  sHTML &= "Chart.defaults.color = '#000000';" & Chr(10)
  sHTML &= "Chart.defaults.animation = false;" & Chr(10)
  sHTML &= "Chart.defaults.responsive = false;" & Chr(10)
  sHTML &= "const ctx = document.getElementById('gbChart');" & Chr(10)
  sHTML &= "new Chart(ctx, {" & Chr(10)
  sHTML &= "  type: '" & sTipo & "'," & Chr(10)
  sHTML &= "  data: { labels: [" & sLabels & "], datasets: [" & sDatasets & "] }," & Chr(10)
  sHTML &= "  options: {" & Chr(10)
  sHTML &= "    " & sIndexAxis & Chr(10)
  sHTML &= "    responsive: true," & Chr(10)
  sHTML &= "    plugins: {" & Chr(10)
  sHTML &= "      legend: { display: " & If(bLeyenda, "true", "false") & " }," & Chr(10)
  sHTML &= "      tooltip: { enabled: true }" & Chr(10)
  sHTML &= "    }" & Chr(10)
  sHTML &= "  }" & Chr(10)
  sHTML &= "});" & Chr(10)
  sHTML &= "</script>" & Chr(10)
  sHTML &= "</body></html>" & Chr(10)

  Return sHTML

End Function

' ============================================
' Función   : btnGenerar_Click
' Propósito : Genera el PNG (fi0N-*.png) y el HTML standalone
'             (fh0N-*.html) en la carpeta /media del proyecto
' ============================================
Public Sub btnGenerar_Click()

  If sCSVActual = "" Or Not Exist(sCSVActual) Then
    m_Sonido.sonar("Warning")
    Message.Warning("Primero cargá un archivo de datos.")
    Return
  Endif

  Dim sNumero As String = Format(iNumFigura, "00")
  Dim sNombreHTML As String = "fh" & sNumero & "-" & sNombreBase & ".html"
  Dim sNombrePNG As String = "fi" & sNumero & "-" & sNombreBase & ".png"
  Dim sRutaHTML As String = sRutaMedia &/ sNombreHTML
  Dim sRutaPNG As String = sRutaMedia &/ sNombrePNG

  btnDibujar_Click()
  Wait 1

  Dim sTmp As String = "/tmp/gbpublisher-figura-preview.html"
  If Not Exist(sTmp) Then
    m_Sonido.sonar("Error")
    Message.Error("Primero dibujá el gráfico con 'Dibujar'.")
    Return
  Endif

  ' ELIMINAR VERSIÓN ANTERIOR ANTES DE SOBRESCRIBIR
  If Exist(sRutaHTML) Then Try Kill sRutaHTML
  If Exist(sRutaPNG) Then Try Kill sRutaPNG

  Try Copy sTmp To sRutaHTML
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo guardar el HTML:" & Chr(10) & Error.Text)
    Return
  Endif

  Wait 1

  ' --- GENERAR PNG VÍA CHROMIUM HEADLESS ---
  Dim sSentinel As String = "/tmp/gbp-figura-ok"
  If Exist(sSentinel) Then Kill sSentinel

  Shell "chromium --headless --no-sandbox --disable-gpu " &
    "--screenshot='" & sRutaPNG & "' --window-size=844,560 " &
    "'file://" & sTmp & "' 2>/dev/null && " &
    "touch " & sSentinel Wait

  If Not Exist(sSentinel) Then
    m_Sonido.sonar("Warning")
    Message.Warning("El HTML se generó pero falló la captura PNG." & Chr(10) &
      "Verificá que chromium esté instalado:" & Chr(10) &
      "sudo apt install chromium")
  Else
    Kill sSentinel
    m_Sonido.sonar("Info")
    Message.Info("Figuras generadas correctamente:" & Chr(10) &
      "  " & sNombrePNG & Chr(10) &
      "  " & sNombreHTML)
  Endif

End Sub

' ============================================
' Función   : cmbTipoDatos_Click
' Propósito : Actualiza las paletas disponibles según
'             el tipo de datos seleccionado
' ============================================
Public Sub cmbTipoDatos_Click()

  CargarPaletasPorTipo()

End Sub

' ============================================
' Función   : CargarPaletasPorTipo
' Propósito : Puebla cmbColorPaleta con las paletas
'             ColorBrewer del tipo seleccionado en
'             cmbTipoDatos
' ============================================
Private Sub CargarPaletasPorTipo()

  cmbColorPaleta.Clear

  Select Case cmbTipoDatos.Text
    Case "Cualitativa"
      cmbColorPaleta.Add("Set1")
      cmbColorPaleta.Add("Set2")
      cmbColorPaleta.Add("Set3")
      cmbColorPaleta.Add("Paired")
      cmbColorPaleta.Add("Dark2")
      cmbColorPaleta.Add("Accent")
      cmbColorPaleta.Add("Pastel1")
      cmbColorPaleta.Add("Pastel2")
    Case "Secuencial"
      cmbColorPaleta.Add("Blues")
      cmbColorPaleta.Add("Greens")
      cmbColorPaleta.Add("Reds")
      cmbColorPaleta.Add("Purples")
      cmbColorPaleta.Add("Oranges")
      cmbColorPaleta.Add("YlOrRd")
      cmbColorPaleta.Add("YlGnBu")
      cmbColorPaleta.Add("BuGn")
    Case "Divergente"
      cmbColorPaleta.Add("RdBu")
      cmbColorPaleta.Add("RdYlBu")
      cmbColorPaleta.Add("RdYlGn")
      cmbColorPaleta.Add("Spectral")
      cmbColorPaleta.Add("PiYG")
      cmbColorPaleta.Add("PRGn")
      cmbColorPaleta.Add("BrBG")
      cmbColorPaleta.Add("PuOr")
  End Select

  cmbColorPaleta.Index = 0

End Sub

' ============================================
' Función   : btnCerrar_Click
' Propósito : Cierra el formulario
' ============================================
Public Sub btnCerrar_Click()

  Me.Close

End Sub
