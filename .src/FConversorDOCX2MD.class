' Gambas class file

' ============================================
' Formulario: FConversorDOCX2MD
' Propósito : Convertir archivos DOCX y ODT a Markdown
'             usando Pandoc, organizando los archivos
'             en la estructura del proyecto según el
'             tipo de pieza (frontmatter / cuerpo / backmatter)
' ============================================

' ============================================
' Función   : btnBuscar_Click
' Propósito : Seleccionar archivo DOCX u ODT de origen
' ============================================
Public Sub btnBuscar_Click()

  ' --- 1. ABRIR DIÁLOGO DE SELECCIÓN DE ARCHIVO ---
  m_Sonido.sonar("Info")
  Dialog.Title = "Seleccionar archivo DOCX u ODT"
  Dialog.Filter = ["*.docx;*.odt", "Documentos (DOCX, ODT)", "*.docx", "Archivos Word", "*.odt", "Archivos LibreOffice", "*", "Todos los archivos"]
  Dialog.AutoExt = True
  Dialog.Path = User.Home
  If Dialog.OpenFile() Then
    Return
  Endif

  ' --- 2. MOSTRAR RUTA SELECCIONADA ---
  txtArchivoOrigen.Text = Dialog.Path

  ' --- 3. HABILITAR CONVERSIÓN SI YA HAY CARPETA DESTINO ---
  btnCONVERTIR.Visible = (Trim(txtCarpetaDestino.Text) <> "")

Catch
  m_Sonido.sonar("Error")
  Message.Error("No se pudo abrir el archivo")

End

' ============================================
' Función   : btnProyecto_Click
' Propósito : Seleccionar carpeta de proyecto destino
' ============================================
Public Sub btnProyecto_Click()

  ' --- 1. ABRIR DIÁLOGO DE SELECCIÓN DE CARPETA ---
  Dialog.Title = "Seleccionar carpeta del proyecto"
  Dialog.Path = User.Home
  If Dialog.SelectDirectory() Then
    Return
  Endif

  ' --- 2. MOSTRAR RUTA SELECCIONADA ---
  txtCarpetaDestino.Text = Dialog.Path

  ' --- 3. HABILITAR CONVERSIÓN SI YA HAY ARCHIVO ORIGEN ---
  btnCONVERTIR.Visible = (Trim(txtArchivoOrigen.Text) <> "")

End

' ============================================
' Función   : btnCONVERTIR_Click
' Propósito : Validar entradas, determinar prefijo y carpeta
'             según el tipo de pieza (FM / cuerpo / BM)
'             y ejecutar la conversión
' ============================================
Public Sub btnCONVERTIR_Click()

  Dim sRutaOrigen As String
  Dim sCarpetaProyecto As String
  Dim sNombreDestino As String
  Dim sExtension As String
  Dim sFormato As String
  Dim sPrefijo As String
  Dim sCarpetaTexto As String

  ' --- 1. OBTENER VALORES DE LA INTERFAZ ---
  sRutaOrigen = Trim(txtArchivoOrigen.Text)
  sCarpetaProyecto = Trim(txtCarpetaDestino.Text)
  sNombreDestino = Trim(txtArchivoDestino.Text)

  ' --- 2. VALIDAR QUE TODOS LOS CAMPOS ESTÉN COMPLETOS ---
  If sRutaOrigen = "" Then
    m_Sonido.sonar("Error")
    Message.Error("Debe seleccionar un archivo de origen.")
    Return
  Endif

  If sCarpetaProyecto = "" Then
    m_Sonido.sonar("Error")
    Message.Error("Debe seleccionar una carpeta de proyecto.")
    Return
  Endif

  If sNombreDestino = "" Then
    m_Sonido.sonar("Error")
    Message.Error("El campo de nombre de archivo no puede estar vacío.")
    Return
  Endif

  ' --- 3. VALIDAR PATRÓN NN- EN EL NOMBRE DE DESTINO ---
  ' DEFENSA EN PROFUNDIDAD: AUNQUE EL KEYPRESS YA LO IMPIDE,
  ' VERIFICAMOS QUE EL NOMBRE TENGA AL MENOS NN- SEGUIDO DE UN CUERPO
  If String.Len(sNombreDestino) < 4 Or
      String.Mid(sNombreDestino, 1, 1) < "0" Or String.Mid(sNombreDestino, 1, 1) > "9" Or
      String.Mid(sNombreDestino, 2, 1) < "0" Or String.Mid(sNombreDestino, 2, 1) > "9" Or
      String.Mid(sNombreDestino, 3, 1) <> "-" Then
    m_Sonido.sonar("Error")
    Message.Error("El nombre debe comenzar con dos dígitos seguidos de un guion, por ejemplo 01-introduccion.")
    Return
  Endif

  ' --- 4. VERIFICAR QUE EL ARCHIVO ORIGEN EXISTE ---
  If Not Exist(sRutaOrigen) Then
    m_Sonido.sonar("Error")
    Message.Error("El archivo de origen no existe: " & sRutaOrigen)
    Return
  Endif

  ' --- 5. DETERMINAR FORMATO SEGÚN EXTENSIÓN ---
  sExtension = LCase(File.Ext(sRutaOrigen))
  Select Case sExtension
    Case "docx"
      sFormato = "docx"
    Case "odt"
      sFormato = "odt"
    Case Else
      m_Sonido.sonar("Error")
      Message.Error("Formato no soportado. Use archivos DOCX u ODT.")
      Return
  End Select

  ' --- 6. DETERMINAR PREFIJO Y CARPETA SEGÚN RADIO SELECCIONADO ---
  ' RBMAIN ES EL DEFAULT DEL FORMULARIO Y CAE EN EL CASE ELSE
  Select Case True
    Case rbFront.Value
      sPrefijo = "fm-"
      sCarpetaTexto = "frontmatter"
    Case rbBack.Value
      sPrefijo = "bm-"
      sCarpetaTexto = "backmatter"
    Case Else
      sPrefijo = "a-"
      sCarpetaTexto = "articulos"
  End Select

  ' --- 7. EJECUTAR CONVERSIÓN ---
  If ConvertirAMarkdown(sRutaOrigen, sFormato, sCarpetaProyecto, sNombreDestino, sPrefijo, sCarpetaTexto) Then
    m_Sonido.sonar("Info")
    Message.Info("Conversión completada con éxito.")
    ' --- 8. ACTUALIZAR INTERFAZ ---
    btnCerrar.Visible = True
    btnCONVERTIR.Visible = False
    txtArchivoOrigen.Text = ""
    txtCarpetaDestino.Text = ""
    txtArchivoDestino.Text = ""
  Endif

End

' ============================================
' Función   : ConvertirAMarkdown
' Propósito : Ejecutar Pandoc para convertir DOCX/ODT a MD,
'             ubicarlo en la subcarpeta que corresponde a su tipo
'             (frontmatter / articulos / backmatter) y mover el
'             original a /originales con el prefijo correcto
' Parámetros: sRutaOrigen      As String — ruta completa del archivo fuente
'             sFormato         As String — "docx" u "odt"
'             sCarpetaProyecto As String — carpeta raíz del proyecto
'             sNombreDestino   As String — nombre sin prefijo, ya con NN-
'             sPrefijo         As String — "fm-", "a-" o "bm-"
'             sCarpetaTexto    As String — subcarpeta destino del .md
' Retorna   : Boolean — True si la conversión fue exitosa
' ============================================
Private Function ConvertirAMarkdown(sRutaOrigen As String, sFormato As String, sCarpetaProyecto As String, sNombreDestino As String, sPrefijo As String, sCarpetaTexto As String) As Boolean

  Dim sCarpetaTextos As String
  Dim sCarpetaOriginales As String
  Dim sCarpetaMedia As String
  Dim sArchivoMD As String
  Dim sComando As String

  ' --- 1. DEFINIR RUTAS DE DESTINO ---
  ' LA SUBCARPETA DEL .MD DEPENDE DEL TIPO DE PIEZA ELEGIDO EN EL FORMULARIO
  sCarpetaTextos = sCarpetaProyecto & "/" & sCarpetaTexto
  sCarpetaOriginales = sCarpetaProyecto & "/originales"
  sCarpetaMedia = sCarpetaProyecto & "/media"
  sArchivoMD = sCarpetaTextos & "/" & sPrefijo & sNombreDestino & ".md"

  ' --- 2. CREAR SUBDIRECTORIOS SI NO EXISTEN ---
  ' /ORIGINALES ES ÚNICA PARA TODA LA REVISTA O LIBRO;
  ' /MEDIA TAMBIÉN ES ÚNICA Y LA POBLA PANDOC
  If Not Exist(sCarpetaTextos) Then
    Mkdir sCarpetaTextos
  Endif
  If Not Exist(sCarpetaOriginales) Then
    Mkdir sCarpetaOriginales
  Endif
  If Not Exist(sCarpetaMedia) Then
    Mkdir sCarpetaMedia
  Endif

  ' --- 3. VERIFICAR QUE NO EXISTA UN MD CON EL MISMO NOMBRE ---
  If Exist(sArchivoMD) Then
    If Message.Question("Ya existe el archivo: " & File.Name(sArchivoMD) & Chr(10) & "¿Desea sobrescribirlo?", "Sí", "No") = 2 Then
      Return False
    Endif
  Endif

  ' --- 4. CONSTRUIR Y EJECUTAR COMANDO PANDOC ---
  ' --EXTRACT-MEDIA DEPOSITA LAS IMÁGENES EN <PROYECTO>/MEDIA POR CONVENCIÓN DE PANDOC
  sComando = "pandoc " & Quote$(sRutaOrigen) &
    " -o " & Quote$(sArchivoMD) &
    " --from=" & sFormato & " --to=markdown" &
    " --wrap=none" &
    " --extract-media=" & Quote$(sCarpetaProyecto)

  Try Shell sComando Wait
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al ejecutar Pandoc: " & Error.Text)
    Return False
  Endif

  ' --- 5. VERIFICAR QUE EL MD SE GENERÓ ---
  If Not Exist(sArchivoMD) Then
    m_Sonido.sonar("Error")
    Message.Error("Pandoc no generó el archivo: " & sArchivoMD)
    Return False
  Endif

  ' --- 6. MOVER Y RENOMBRAR ARCHIVO ORIGEN A /originales ---
  ' EL ORIGINAL CONSERVA EL MISMO PREFIJO QUE EL .MD PARA TRAZABILIDAD
  Try Move sRutaOrigen To sCarpetaOriginales & "/" & sPrefijo & sNombreDestino & "." & sFormato
  If Error Then
    ' EL MOVE PUEDE FALLAR POR PERMISOS, DISCO DIFERENTE O RECURSO DE RED
    m_Sonido.sonar("Warning")
    Message.Warning("La conversión a Markdown se completó correctamente y las figuras fueron extraídas." & Chr(10) & Chr(10) & "Sin embargo, no se pudo mover el archivo original a la carpeta /originales:" & Chr(10) & Error.Text & Chr(10) & Chr(10) & "Deberá copiarlo manualmente.")
  Endif

  Return True

End

' ============================================
' Función   : txtArchivoDestino_KeyPress
' Propósito : Filtrar caracteres permitidos y forzar
'             que el nombre comience con el patrón NN-
' ============================================
Public Sub txtArchivoDestino_KeyPress()

  Dim iPos As Integer

  ' --- 1. PERMITIR TECLAS DE CONTROL ---
  If Key.Code = Key.BackSpace Or Key.Code = Key.Delete Or
      Key.Code = Key.Left Or Key.Code = Key.Right Or
      Key.Code = Key.Tab Or Key.Code = Key.Enter Or
      Key.Code = Key.Home Or Key.Code = Key.End Then
    Return
  Endif

  ' --- 2. VALIDAR LONGITUD MÁXIMA (INCLUYE EL PREFIJO NN-) ---
  If String.Len(txtArchivoDestino.Text) >= 24 Then
    m_Sonido.sonar("Warning")
    Message.Warning("El nombre del archivo no puede tener más de 24 caracteres.")
    Stop Event
    Return
  Endif

  ' --- 3. FORZAR PATRÓN POSICIONAL NN- EN LAS PRIMERAS TRES POSICIONES ---
  ' POS ES 0-INDEXED: 0 Y 1 SON LOS DOS DÍGITOS, 2 ES EL GUION
  iPos = txtArchivoDestino.Pos

  If iPos = 0 Or iPos = 1 Then
    ' LAS DOS PRIMERAS POSICIONES SOLO ACEPTAN DÍGITOS
    If Key.Text < "0" Or Key.Text > "9" Then
      m_Sonido.sonar("Warning")
      Stop Event
      Return
    Endif
    Return
  Endif

  If iPos = 2 Then
    ' LA TERCERA POSICIÓN SOLO ACEPTA EL GUION
    If Key.Text <> "-" Then
      m_Sonido.sonar("Warning")
      Stop Event
      Return
    Endif
    Return
  Endif

  ' --- 4. POSICIÓN 4 EN ADELANTE: NÚMEROS, LETRAS Y GUION ---
  If Key.Text = "-" Or
      (Key.Text >= "0" And Key.Text <= "9") Or
      (Key.Text >= "A" And Key.Text <= "Z") Or
      (Key.Text >= "a" And Key.Text <= "z") Then
    Return
  Endif

  ' --- 5. BLOQUEAR CUALQUIER OTRO CARÁCTER ---
  Stop Event

End

' ============================================
' Función   : txtArchivoDestino_KeyRelease
' Propósito : Forzar mayúsculas y validar longitud
' ============================================
Public Sub txtArchivoDestino_KeyRelease()

  Dim sTexto As String
  Dim iPosicionCursor As Integer

  ' --- 1. GUARDAR POSICIÓN DEL CURSOR ---
  iPosicionCursor = txtArchivoDestino.Pos

  ' --- 2. CONVERTIR A MAYÚSCULAS ---
  sTexto = UCase(txtArchivoDestino.Text)

  ' --- 3. VALIDAR LONGITUD MÁXIMA ---
  If String.Len(sTexto) > 24 Then
    sTexto = String.Left(sTexto, 24)
    m_Sonido.sonar("Warning")
    Message.Warning("El nombre del archivo no puede tener más de 24 caracteres.")
    iPosicionCursor = 24
  Endif

  ' --- 4. ACTUALIZAR TEXTO Y RESTAURAR CURSOR ---
  txtArchivoDestino.Text = sTexto
  txtArchivoDestino.Pos = iPosicionCursor

End

' FLAG PARA PERMITIR EL CIERRE DESDE EL BOTÓN
Private bCierrePermitido As Boolean

Public Sub btnCerrar_Click()
  ' HABILITAR EL CIERRE Y CERRAR

  bCierrePermitido = True
  Me.Close()

End

Public Sub Form_Close()
  ' SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO

  If bCierrePermitido Then Return
  ' BLOQUEAR EL CIERRE DESDE LA X DEL SISTEMA
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End