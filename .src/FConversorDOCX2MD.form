# Gambas Form File 3.0

{ Form Form
  Move(0,0,963,324)
  #Scaled = False
  #Translate = False
  Expand = True
  Text = "Conversión de MSWord (.docx) y Libre Office (.odt) a Markdown"
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  Spacing = True
  Margin = True
  Padding = 4
  { HBox2 HBox
    Move(9,45,720,36)
    #Translate = False
    NoTabFocus = True
    { Label1 Label
      Move(9,0,144,36)
      #Translate = False
      NoTabFocus = True
      Alignment = Align.Right
      Text = "Origen: "
    }
    { btnBuscar Button
      Move(297,0,36,36)
      #Translate = False
      NoTabFocus = True
      Picture = Picture["iconos/abrirBuscar.png"]
    }
    { txtArchivoOrigen TextBox
      Move(369,0,216,36)
      #Translate = False
      Background = Color.Background
      Foreground = Color.Blue
      NoTabFocus = True
      Expand = True
      ReadOnly = True
    }
  }
  { HBox4 HBox
    Move(9,81,720,36)
    #Translate = False
    NoTabFocus = True
    { Label3 Label
      Move(9,0,144,36)
      #Translate = False
      NoTabFocus = True
      Alignment = Align.Right
      Text = "Proyecto: "
    }
    { btnProyecto Button
      Move(297,0,36,36)
      #Translate = False
      NoTabFocus = True
      Picture = Picture["iconos/abrirBuscar.png"]
    }
    { txtCarpetaDestino TextBox
      Move(369,0,216,36)
      #Translate = False
      Background = Color.Background
      Foreground = Color.Blue
      NoTabFocus = True
      Expand = True
      ReadOnly = True
    }
  }
  { HBox3 HBox
    Move(9,162,720,36)
    #Translate = False
    NoTabFocus = True
    { Label2 Label
      Move(0,0,144,36)
      #Translate = False
      NoTabFocus = True
      Alignment = Align.Right
      Text = "Nombre: "
    }
    { txtArchivoDestino TextBox
      Move(477,0,135,36)
      #Translate = False
      NoTabFocus = True
      Expand = True
      Placeholder = "permitidos: -0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    }
  }
  { HBox7 HBox
    Move(9,198,720,36)
    #Translate = False
    { Spring1 Spring
      Move(81,0,117,36)
      #Translate = False
    }
    { btnCONVERTIR Button
      Move(369,0,144,36)
      #Translate = False
      Visible = False
      Font = Font["Bold"]
      Background = &H9FFF7F
      NoTabFocus = True
      Text = "Convertir"
      Picture = Picture["iconos/enviar.png"]
    }
    { btnCerrar Button
      Move(513,0,144,36)
      #Translate = False
      NoTabFocus = True
      Text = "Cerrar"
      Picture = Picture["iconos/salir.png"]
    }
  }
}
