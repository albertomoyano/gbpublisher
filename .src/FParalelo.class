' Gambas class file

Public Sub Form_Open()

  CargarListaArticulosMD()

End

' ============================================
' Función   : CargarListaArticulosMD
' Propósito : Puebla cmbSoloArticulosRevista con todos los
'             archivos Markdown del proyecto activo.
' ============================================
Public Sub CargarListaArticulosMD()

  ' --- 1. Verificar que hay un proyecto abierto ---
  If FMain.txtProyecto.Text = "" Then Return

  Dim sRutaProyecto As String = File.Dir(FMain.txtProyecto.Text)
  Dim sNombreProyecto As String = File.Name(FMain.txtProyecto.Text)

  ' --- 2. Limpiar el combobox ---
  cmbSoloArticulosRevista.Clear()

  ' --- 3. Cargar artículos ---
  Dim sRutaArticulos As String = sRutaProyecto &/ "articulos"
  If Exist(sRutaArticulos) Then
    Dim aArt As String[] = Dir(sRutaArticulos, "a-*.md")
    If aArt Then
      aArt.Sort()
      Dim sA As String
      For Each sA In aArt
        cmbSoloArticulosRevista.Add("articulos/" & sA)
      Next
    Endif
  Endif

  ' --- 4. Seleccionar el archivo principal por defecto ---
  cmbSoloArticulosRevista.Index = 0

End Sub
