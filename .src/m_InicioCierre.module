' Gambas module file

' ==============================================================================
' Módulo    : m_InicioCierre
' Propósito : Setup inicial y teardown de la aplicación. Mantiene el estado
'             de sesión (UsuarioEnCurso e IdUsuarioEnCurso) y centraliza:
'             - Creación de directorios y copia de recursos al ~/.gbpublisher
'             - Verificación e instalación de fuentes IBM Plex
'             - Carga del TableView de usuarios conectados
'             - Carga del ComboBox de scripts disponibles
'             - Cierre de proyecto y cierre total de la aplicación
'             - Utility: ruta de recursos, mapeo de estilos CSL
' Dependencias: m_ConexionBD, m_Sonido, m_Timer, m_Bibtex, m_Siglas,
'             m_FuncionesGenericas, FMain.
' ==============================================================================

' --- ESTADO DE SESIÓN ACTIVA AL SERVIDOR ---
' SE ASIGNAN AL VALIDAR CREDENCIALES EN FLogin.btnConectarServer_Click Y
' SE LIMPIAN AL DESCONECTAR O CERRAR LA APP. SIRVEN COMO IDENTIDAD DEL
' USUARIO LOGUEADO PARA VALIDACIONES DE AUTORÍA EN TODA LA APP
Public UsuarioEnCurso As String
Public IdUsuarioEnCurso As Integer
Public IdArticuloEnCurso As Integer
Public IdCapituloEnCurso As Integer

' ============================================
' Función   : DirectorioOcultoApp
' Propósito : Crea el directorio oculto ~/.gbpublisher con sus subcarpetas
'             de recursos, copia los archivos base desde el paquete instalado
'             (o desde .hidden/ si se ejecuta desde el IDE), crea el archivo
'             de IPs y asegura la existencia del buscador.py.
'             Esta función se llama una vez al inicio de la app.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub DirectorioOcultoApp()

  Dim sBase As String
  Dim carpetas As String[]
  Dim carpeta As String
  Dim sRutaIPs As String

  ' --- 1. CREAR DIRECTORIO BASE SI NO EXISTE ---
  sBase = User.Home &/ ".gbpublisher"
  If Not Exist(sBase) Then
    Try Mkdir sBase
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("No se pudo crear el directorio base de la aplicación:" & Chr(10) & sBase)
      Return
    Endif
  Endif

  ' --- 2. COPIAR CONTENIDO DE CARPETAS DEL SISTEMA ---
  carpetas = ["biblatex", "chart", "csl", "dtd", "filters",
    "fonts", "github", "media", "ott", "schemas",
    "schematron", "scripts", "sonido", "xslt"]

  For Each carpeta In carpetas
    CopiarDirectorio(RutaRecursos() & "/" & carpeta, User.Home & "/.gbpublisher/" & carpeta)
    ' DESPUÉS DE COPIAR LA CARPETA fonts, AJUSTAR EL COLOR DE LOS ICONOS SVG
    If carpeta = "fonts" Then CopiarIconosSVG()
  Next

  ' --- 3. CREAR DIRECTORIO DE RESPALDO ---
  If Not Exist(User.Home & "/.gbpublisher/respaldo") Then
    Try Mkdir User.Home & "/.gbpublisher/respaldo"
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("Error al crear el directorio de respaldo.")
    Endif
  Endif

  ' --- 4. VERIFICAR Y CREAR ARCHIVO DE IPS SI NO EXISTE ---
  sRutaIPs = User.Home &/ ".gbpublisher/.ips.txt"
  If Not Exist(sRutaIPs) Then
    Try File.Save(sRutaIPs, "127.0.0.1" & Chr(10))
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("No se pudo crear el archivo de IPs:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- 5. VERIFICAR Y CREAR BUSCADOR.PY SI NO EXISTE ---
  If Not m_FuncionesGenericas.CrearBuscadorPy() Then Return

End

' ============================================
' Función   : CopiarIconosSVG
' Propósito : Copia los archivos .svg de la carpeta de recursos al directorio
'             del usuario reemplazando el color "currentColor" por el azul
'             institucional de la app. Útil para que los iconos hereden el
'             color de la app sin depender del navegador.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CopiarIconosSVG()

  Dim srcDir As String
  Dim dstDir As String
  Dim f As String
  Dim sContenido As String

  ' --- 1. RUTAS ORIGEN Y DESTINO ---
  srcDir = RutaRecursos() &/ "fonts"
  dstDir = User.Home &/ ".gbpublisher" &/ "fonts"

  ' --- 2. PROCESAR CADA ARCHIVO SVG ---
  For Each f In Dir(srcDir, "*.svg")

    ' LEER CONTENIDO DEL SVG ORIGINAL
    Try sContenido = File.Load(srcDir &/ f)
    If Error Then Continue

    ' REEMPLAZAR COLOR DE RELLENO POR azulrevista
    sContenido = Replace(sContenido, "currentColor", "#2D5A8E")

    ' ESCRIBIR SVG COLOREADO EN DESTINO
    Try File.Save(dstDir &/ f, sContenido)
    If Error Then
      Message.Error("Error guardando: " & f & Chr(10) & Error.Text)
    Endif

  Next

End

' ============================================
' Función   : CopiarDirectorio
' Propósito : Copia recursivamente el contenido de un directorio hacia un
'             destino, preservando la estructura de subdirectorios y omitiendo
'             archivos ya existentes.
' Parámetros: srcDir As String — ruta absoluta del directorio origen
'             dstDir As String — ruta absoluta del directorio destino
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CopiarDirectorio(srcDir As String, dstDir As String)

  Dim f As String

  ' --- 1. VERIFICAR QUE EL DIRECTORIO ORIGEN EXISTE ---
  If Not Exist(srcDir) Then
    ' DIAGNÓSTICO: REGISTRAR QUÉ DIRECTORIO ORIGEN FALTA EN LA TERMINAL
    FMain.TerminalViewProyecto.Input("echo 'FALTA srcDir: " & srcDir & "'" & Chr(10))
    Return
  Endif

  ' --- 2. CREAR CARPETA DESTINO SI NO EXISTE ---
  If Not Exist(dstDir) Then
    Mkdir dstDir
  Endif

  ' --- 3. PRIMERA PASADA: COPIAR SUBDIRECTORIOS RECURSIVAMENTE ---
  For Each f In Dir(srcDir, "*", gb.Directory)
    CopiarDirectorio(srcDir & "/" & f, dstDir & "/" & f)
  Next

  ' --- 4. SEGUNDA PASADA: COPIAR ARCHIVOS ---
  For Each f In Dir(srcDir, "*.*")
    If Not Exist(dstDir & "/" & f) Then
      Copy srcDir & "/" & f To dstDir & "/" & f
    Endif
  Next

End

' ============================================
' Función   : CargarUsuarios
' Propósito : Pobla el TableViewUsuarios de FMain con los usuarios activos
'             del sistema, mostrando "Conectado" en la columna en_linea para
'             los que tienen sesión activa.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CargarUsuarios()

  Dim rUsuarios As Result
  Dim iRow As Integer
  Dim iCol As Integer

  ' --- 1. CONSULTAR USUARIOS ACTIVOS, ORDENADOS POR ESTADO Y NOMBRE ---
  Try rUsuarios = m_ConexionBD.mConn.Exec(
    "SELECT usuario, en_linea FROM usuarios WHERE activo = 1 ORDER BY en_linea DESC, usuario ASC")
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudieron cargar los usuarios:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 2. LIMPIAR EL GRID ---
  FMain.TableViewUsuarios.Clear

  ' --- 3. SI NO HAY DATOS, DEJAR EL GRID VACÍO Y SALIR ---
  ' NULL CHECK ANIDADO PORQUE Or NO ES SHORT-CIRCUIT EN GAMBAS
  If rUsuarios = Null Then
    FMain.TableViewUsuarios.Rows.Count = 0
    FMain.TableViewUsuarios.Columns.Count = 0
    Return
  Endif
  If rUsuarios.Count = 0 Then
    FMain.TableViewUsuarios.Rows.Count = 0
    FMain.TableViewUsuarios.Columns.Count = 0
    Return
  Endif

  ' --- 4. CONFIGURAR COLUMNAS Y FILAS ---
  FMain.TableViewUsuarios.Columns.Count = rUsuarios.Fields.Count
  FMain.TableViewUsuarios.Rows.Count = rUsuarios.Count
  FMain.TableViewUsuarios.MoveTo(0, 0)

  ' --- 5. POBLAR LAS CELDAS ---
  iRow = 0
  For Each rUsuarios
    For iCol = 0 To rUsuarios.Fields.Count - 1
      If IsNull(rUsuarios[iCol]) Then
        FMain.TableViewUsuarios[iRow, iCol].Text = ""
      Else
        ' COLUMNA en_linea (ÍNDICE 1): MOSTRAR "Conectado" SI ES TRUE
        If iCol = 1 Then
          FMain.TableViewUsuarios[iRow, iCol].Text = IIf(CBool(rUsuarios[iCol]), "Conectado", "")
        Else
          FMain.TableViewUsuarios[iRow, iCol].Text = rUsuarios[iCol]
        Endif
      Endif
    Next
    iRow += 1
  Next

End

' ============================================
' Función   : DisenarTableViewUsuarios
' Propósito : Configura el aspecto del TableView de usuarios: tres columnas
'             (Usuario, Estado, Proyecto) con anchos predefinidos.
' Parámetros: grid As GridView — control TableView a configurar
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub DisenarTableViewUsuarios(grid As GridView)

  ' --- 1. CONFIGURACIÓN BÁSICA Y NÚMERO DE COLUMNAS ---
  With grid
    .Header = True
    .Grid = True
    .Columns.Count = 3

    ' --- 2. TÍTULOS Y ANCHOS DE COLUMNAS ---
    For i As Integer = 0 To 2
      Select Case i
        Case 0
          .Columns[i].Title = "Usuario"
          .Columns[i].Width = 150
        Case 1
          .Columns[i].Title = "Estado"
          .Columns[i].Width = 150
        Case 2
          .Columns[i].Title = "Proyecto"
          .Columns[i].Width = 300
      End Select
    Next
  End With

End

' ============================================
' Función   : CargarScripts
' Propósito : Carga el ComboBox de scripts disponibles desde ~/.gbpublisher/scripts.
'             Soporta extensiones .py, .lua, .sh, .pl, .R. La descripción se
'             extrae de la primera línea de comentario del archivo (salteando
'             el shebang si existe).
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CargarScripts()

  Dim rutaScripts As String
  Dim archivos As String[]
  Dim archivo As String
  Dim linea As String
  Dim descripcion As String
  Dim archivoBase As String
  Dim hFile As File
  Dim extension As String
  Dim extensionOriginal As String
  Dim prefijo As String
  Dim extensiones As String[]
  Dim todosArchivos As New String[]
  Dim rutaCompleta As String

  rutaScripts = User.Home &/ ".gbpublisher/scripts"

  ' --- 1. VERIFICAR QUE EL DIRECTORIO EXISTE ---
  If Not Exist(rutaScripts) Then
    m_Sonido.sonar("Error")
    Message.Error("El directorio de scripts no existe: " & rutaScripts)
    Return
  Endif

  FMain.ComboBoxScripts.Clear

  ' --- 2. RECOPILAR ARCHIVOS DE TODAS LAS EXTENSIONES SOPORTADAS ---
  extensiones = ["*.py", "*.lua", "*.sh", "*.pl", "*.R"]
  For Each extension In extensiones
    archivos = Dir(rutaScripts, extension)
    If Not Error Then
      For Each archivo In archivos
        todosArchivos.Add(archivo)
      Next
    Endif
  Next

  ' --- 3. SALIR SI NO HAY ARCHIVOS ---
  If todosArchivos.Count = 0 Then
    m_Sonido.sonar("Info")
    Message.Info("No se encontraron scripts en el directorio")
    Return
  Endif

  ' --- 4. PROCESAR CADA ARCHIVO Y EXTRAER SU DESCRIPCIÓN ---
  For Each archivo In todosArchivos
    descripcion = "Sin descripción"

    ' EXTENSIÓN ORIGINAL (PRESERVA CAPITALIZACIÓN, EJ. ".R")
    extensionOriginal = File.Ext(archivo)
    extension = LCase(extensionOriginal)

    ' PREFIJO DE COMENTARIO SEGÚN EL LENGUAJE
    Select Case extension
      Case "py"
        prefijo = "#"
      Case "lua"
        prefijo = "--"
      Case "sh"
        prefijo = "#"
      Case "pl"
        prefijo = "#"
      Case "r"
        prefijo = "#"
      Default
        prefijo = "#"
    End Select

    rutaCompleta = rutaScripts &/ archivo

    ' --- 5. LEER LA PRIMERA LÍNEA DE COMENTARIO PARA OBTENER DESCRIPCIÓN ---
    Try hFile = Open rutaCompleta For Read
    If Error Then
      descripcion = "Error al leer archivo"
    Else
      Try Line Input #hFile, linea
      If Not Error And If linea <> "" Then
        linea = Trim(linea)
        ' SALTAR SHEBANG (#!/...) SI ESTÁ EN LA PRIMERA LÍNEA
        If Left(linea, 2) = "#!" Then
          If Not Eof(hFile) Then
            Try Line Input #hFile, linea
            If Not Error Then
              linea = Trim(linea)
            Else
              linea = ""
            Endif
          Else
            linea = ""
          Endif
        Endif
        ' SI LA LÍNEA EMPIEZA CON EL PREFIJO DE COMENTARIO, EXTRAER DESCRIPCIÓN
        If linea <> "" And If Left(linea, Len(prefijo)) = prefijo Then
          If Len(linea) > Len(prefijo) Then
            descripcion = Trim(Mid(linea, Len(prefijo) + 1))
          Endif
        Endif
      Endif
      Close #hFile
    Endif

    ' --- 6. AGREGAR AL COMBOBOX CON DESCRIPCIÓN Y NOMBRE DE ARCHIVO ---
    archivoBase = File.BaseName(archivo) & "." & extensionOriginal
    FMain.ComboBoxScripts.Add(descripcion & " [" & archivoBase & "]")
  Next

End

' ============================================
' Función   : RutaRecursos
' Propósito : Devuelve la ruta base de los recursos del paquete. Si se está
'             ejecutando desde el IDE de Gambas, los recursos están en
'             .hidden/ dentro del proyecto. Si se está ejecutando instalado,
'             están en /usr/share/gbpublisher/.
' Parámetros: (ninguno)
' Retorna   : String — ruta absoluta a la carpeta de recursos
' ============================================
Public Function RutaRecursos() As String

  ' --- IDE DE GAMBAS: LOS RECURSOS ESTÁN EN .hidden/ DEL PROYECTO ---
  If Exist(Application.Path &/ ".hidden" &/ "fonts") Then
    Return Application.Path &/ ".hidden"
  Endif

  ' --- INSTALADO: LOS RECURSOS ESTÁN EN /usr/share/gbpublisher/ ---
  Return "/usr/share/gbpublisher"

End

' ============================================
' Función   : LeerTipoCSL
' Propósito : Mapea el nombre de un archivo CSL a su identificador interno
'             de estilo. gbpublisher soporta exactamente 4 estilos con nombres
'             fijos. Si el archivo no coincide con ninguno, avisa al usuario
'             y devuelve cadena vacía.
'             Nota: para soporte de CSLs personalizados habría que leer el
'             citation-format del XML del archivo, no solo el nombre.
' Parámetros: sRutaCSL As String — ruta al archivo .csl
' Retorna   : String — identificador del estilo ("apa", "ieee", "vancouver",
'             "iso690") o "" si no se reconoce
' ============================================
Public Function LeerTipoCSL(sRutaCSL As String) As String

  Select Case Lower(File.Name(sRutaCSL))
    Case "apa.csl"
      Return "apa"
    Case "ieee.csl"
      Return "ieee"
    Case "vancouver.csl"
      Return "vancouver"
    Case "iso690-author-date-es.csl"
      Return "iso690"
    Case Else
      m_Sonido.sonar("Error")
      Message.Error("Estilo de cita no reconocido: " & File.Name(sRutaCSL) & Chr(10) &
        "Los estilos soportados son: apa.csl, ieee.csl, vancouver.csl, iso690-author-date-es.csl")
      Return ""
  End Select

End

' ============================================
' Función   : VerificarFuentesIBMPlex
' Propósito : Verifica que las fuentes IBM Plex estén instaladas en el
'             directorio de fuentes del usuario. Si faltan, las copia desde
'             los recursos del paquete. Si la fuente de recursos no existe,
'             informa el problema de instalación y cierra. Si se copian
'             fuentes nuevas, registra y pide reinicio.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub VerificarFuentesIBMPlex()

  Dim sFontDst As String
  Dim sFontSrc As String
  Dim aFuentes As String[]
  Dim sFuente As String
  Dim iCopiadas As Integer
  Dim iEsperadas As Integer
  Dim aFaltantes As New String[]
  Dim sMensaje As String

  ' --- 1. VERIFICAR PRESENCIA DE LA FUENTE CENTINELA ---
  ' SI YA ESTÁ INSTALADA NO HAY NADA QUE HACER
  sFontDst = User.Home &/ ".local/share/fonts/gbpublisher"
  If Exist(sFontDst &/ "IBMPlexSans-Regular.otf") Then Return

  ' --- 2. VERIFICAR QUE EL DIRECTORIO FUENTE DEL PAQUETE EXISTE ---
  ' SI FALTA, EL PAQUETE ESTÁ MAL INSTALADO — ES UN ERROR DE INSTALACIÓN, NO DE USO
  sFontSrc = RutaRecursos() &/ "fonts"
  If Not Exist(sFontSrc) Then
    m_Sonido.sonar("Error")
    Message.Error(
      "No se encontró el directorio de fuentes del paquete:" & Chr(10) &
      sFontSrc & Chr(10) & Chr(10) &
      "La instalación de gbpublisher puede estar incompleta." & Chr(10) &
      "Reinstale el paquete e intente nuevamente.")
    Quit
  Endif

  ' --- 3. CREAR DIRECTORIO DE DESTINO SI NO EXISTE ---
  If Not Exist(sFontDst) Then
    Try Mkdir sFontDst
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error(
        "No se pudo crear el directorio de fuentes del usuario:" & Chr(10) &
        sFontDst & Chr(10) & Chr(10) &
        "Verifique los permisos de escritura en su directorio personal.")
      Quit
    Endif
  Endif

  ' --- 4. COPIAR FUENTES DISPONIBLES Y CONTABILIZAR ---
  aFuentes = [
    "IBMPlexSans-Regular.otf", "IBMPlexSans-Bold.otf",
    "IBMPlexSans-Italic.otf", "IBMPlexSans-BoldItalic.otf",
    "IBMPlexMono-Regular.otf", "IBMPlexMono-Bold.otf",
    "IBMPlexMono-Italic.otf", "IBMPlexMono-BoldItalic.otf"
  ]
  iCopiadas = 0
  iEsperadas = aFuentes.Count

  For Each sFuente In aFuentes
    If Exist(sFontSrc &/ sFuente) Then
      Try Copy sFontSrc &/ sFuente To sFontDst &/ sFuente
      If Error Then
        aFaltantes.Add(sFuente)
      Else
        Inc iCopiadas
      Endif
    Else
      aFaltantes.Add(sFuente)
    Endif
  Next

  ' --- 5. EVALUAR RESULTADO DE LA COPIA ---
  ' SI NO SE COPIÓ NINGUNA FUENTE, EL PROBLEMA ES DE INSTALACIÓN
  If iCopiadas = 0 Then
    m_Sonido.sonar("Error")
    Message.Error(
      "No se encontraron fuentes IBM Plex en el paquete instalado." & Chr(10) & Chr(10) &
      "Directorio buscado:" & Chr(10) &
      sFontSrc & Chr(10) & Chr(10) &
      "La instalación de gbpublisher puede estar incompleta." & Chr(10) &
      "Reinstale el paquete e intente nuevamente.")
    Quit
  Endif

  ' --- 6. REGISTRAR FUENTES COPIADAS EN EL SISTEMA ---
  Shell "fc-cache -f '" & sFontDst & "'" Wait

  ' --- 7. INFORMAR RESULTADO Y SOLICITAR REINICIO ---
  ' ADVERTENCIA ADICIONAL SI FALTAN ALGUNAS FUENTES (INSTALACIÓN PARCIAL)
  If aFaltantes.Count > 0 Then
    sMensaje =
      "Se instalaron " & CStr(iCopiadas) & " de " & CStr(iEsperadas) & " fuentes IBM Plex." & Chr(10) & Chr(10) &
      "Las siguientes fuentes no pudieron copiarse:" & Chr(10) &
      aFaltantes.Join(Chr(10)) & Chr(10) & Chr(10) &
      "La interfaz puede no visualizarse correctamente." & Chr(10) & Chr(10) &
      "Cierre y vuelva a abrir la aplicación para continuar."
  Else
    sMensaje =
      "Su sistema no tenía instalada la familia tipográfica IBM Plex." & Chr(10) & Chr(10) &
      "Las fuentes se instalaron correctamente en:" & Chr(10) &
      sFontDst & Chr(10) & Chr(10) &
      "Cierre la aplicación y vuelva a abrirla para continuar."
  Endif
  m_Sonido.sonar("Info")
  Message.Info(sMensaje)
  Quit

End

' ============================================
' Función   : DetenerProcesoBash
' Propósito : Helper privado que detiene el proceso bash asociado al proyecto
'             (FMain.$Bash). Intenta primero con Kill (hasta 20 intentos con
'             pausas de 50ms) y como fallback usa Terminate. Anula la
'             referencia al final.
'             DEUDA TÉCNICA: acceso directo a FMain.$Bash (variable privada
'             por convención $ en Gambas). Cuando se refactorice FMain,
'             mover esta lógica a una función pública FMain.DetenerBashEnCurso().
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Private Sub DetenerProcesoBash()

  Dim tries As Integer

  ' --- 1. VALIDAR QUE EXISTE Y ESTÁ CORRIENDO ---
  If Not FMain.$Bash Then Return
  If Not Object.IsValid(FMain.$Bash) Then
    FMain.$Bash = Null
    Return
  Endif
  If FMain.$Bash.State <> Process.Running Then
    FMain.$Bash = Null
    Return
  Endif

  ' --- 2. INTENTAR DETENER CON Kill HASTA 20 VECES ---
  tries = 0
  While FMain.$Bash.State = Process.Running And tries < 20
    FMain.$Bash.Kill
    Wait 0.05
    tries = tries + 1
  Wend

  ' --- 3. FALLBACK CON Terminate SI Kill NO ALCANZÓ ---
  If FMain.$Bash.State = Process.Running Then
    FMain.$Bash.Terminate
    Wait 0.2
    If FMain.$Bash.State = Process.Running Then
      m_Sonido.sonar("Warning")
      Message.Warning("El proceso bash no pudo ser detenido.")
    Endif
  Endif

  ' --- 4. ANULAR LA REFERENCIA ---
  FMain.$Bash = Null

End

' ============================================
' Función   : LimpiarTerminalProyecto
' Propósito : Helper privado que envía un comando "clear" a la terminal
'             embebida de FMain con una pequeña espera para que se procese.
'             Centraliza el patrón que aparecía duplicado en CerrarProyecto
'             y CerrarTodoMySQL.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Private Sub LimpiarTerminalProyecto()

  Try FMain.TerminalViewProyecto.Input("clear" & Chr(10))
  Wait 0.2

End

' ============================================
' Función   : CerrarProyecto
' Propósito : Libera el proyecto actualmente abierto: marca como no-ocupado
'             en BD, detiene timers, mata el proceso bash, limpia la UI
'             de FMain. NO pregunta al usuario — la decisión debe tomarla
'             el caller antes de invocar esta función. Tampoco toca
'             usuarios.en_linea — eso es responsabilidad del flujo de
'             desconexión, no del cierre de proyecto.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CerrarProyecto()

  ' --- 1. SIN PROYECTO ABIERTO: NADA QUE HACER ---
  If FMain.txtProyecto.Text = "" Then Return

  ' --- 2. LIBERAR EL PROYECTO EN BD ---
  ' UPDATE ATÓMICO QUE COMBINA OWNER Y FLAG DE OCUPADO EN UNA SOLA SENTENCIA
  Try m_ConexionBD.mConn.Exec(
    "UPDATE proyectos SET usuario_propietario = NULL, ocupado = 0 WHERE id = &1",
    FMain.id_proyecto.Value)
  If Error Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se pudo liberar el proyecto en la base de datos:" & gb.NewLine &
      Error.Text & gb.NewLine & gb.NewLine &
      "El cierre continúa, pero el proyecto puede quedar marcado como ocupado.")
  Else
    Try m_ConexionBD.mConn.Commit
  Endif

  ' --- 3. DETENER TIMERS Y CONTADORES ---
  m_Timer.DetenerContador()
  FMain.DetenerTimerArchivosXML()
  FMain.DetenerTimerArchivosProyecto()

  ' --- 4. LIMPIAR TERMINAL EMBEBIDA Y DETENER PROCESO BASH ---
  LimpiarTerminalProyecto()
  DetenerProcesoBash()

  ' --- 5. LIMPIAR FORMULARIOS DE BIBTEX Y SIGLAS ---
  m_Bibtex.LimpiarTextboxBibtex()
  m_Siglas.LimpiarTextboxSigla()

  ' --- 6. RESETEAR UI DE FMain Y CONTADORES VISUALES ---
  FMain.TimerHOY.Delay = 1000
  FMain.TimerHOY.Stop
  FMain.TextHoraParcial.Text = "00:00:00"
  FMain.TextHoraTotal.Text = ""
  FMain.txtProyecto.Text = ""
  FMain.id_proyecto.Value = ""
  FMain.DirViewProyecto.Root = User.Home
  FMain.SplitterPrincipal.Visible = False
  FMain.SpringTemporal.Visible = True

End

' ============================================
' Función   : CerrarTodoMySQL
' Propósito : Cierra completamente la aplicación: pregunta al usuario, libera
'             al usuario en BD (en_linea = 0), libera el proyecto si lo había,
'             detiene timers y proceso bash, cierra la conexión a la BD,
'             limpia el estado de sesión y termina el proceso con Quit.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CerrarTodoMySQL()

  ' --- 1. CONFIRMACIÓN DE SALIDA ---
  m_Sonido.sonar("Question")
  If Message.Question("¿Está seguro que desea salir de la aplicación?", "Sí", "No") <> 1 Then Return

  ' --- 2. LIBERAR EL USUARIO Y EL PROYECTO EN BD ---
  ' SE USAN UPDATEs SEPARADOS PORQUE TIENEN FILTROS DISTINTOS (usuario vs id_proyecto)
  Try m_ConexionBD.mConn.Exec("UPDATE usuarios SET en_linea = 0 WHERE usuario = &1", UsuarioEnCurso)
  If Error Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se pudo liberar al usuario en la base de datos:" & gb.NewLine & Error.Text)
  Endif

  Try m_ConexionBD.mConn.Exec(
    "UPDATE proyectos SET usuario_propietario = NULL, ocupado = 0 WHERE id = &1",
    FMain.id_proyecto.Value)
  If Error Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se pudo liberar el proyecto en la base de datos:" & gb.NewLine & Error.Text)
  Endif

  Try m_ConexionBD.mConn.Commit

  ' --- 3. DETENER TIMERS Y CONTADORES ---
  m_Timer.DetenerContador()
  FMain.DetenerTimerArchivosXML()
  FMain.DetenerTimerArchivosProyecto()

  ' --- 4. LIMPIAR TERMINAL EMBEBIDA Y DETENER PROCESO BASH ---
  LimpiarTerminalProyecto()
  DetenerProcesoBash()

  ' --- 5. LIMPIAR UI DE FMain ---
  FMain.txtProyecto.Clear
  FMain.DirViewProyecto.Root = User.Home
  FMain.TextBoxUsuario.Clear
  FMain.TextBoxServidor.Clear

  ' --- 6. CERRAR LA CONEXIÓN A LA BD SI ESTÁ ABIERTA ---
  If Not IsNull(m_ConexionBD.mConn) Then
    If m_ConexionBD.mConn.Opened Then
      Try m_ConexionBD.mConn.Close()
    Endif
    m_ConexionBD.mConn = Null
  Endif

  ' --- 7. LIMPIAR ESTADO DE SESIÓN ---
  UsuarioEnCurso = ""
  IdUsuarioEnCurso = 0
  IdArticuloEnCurso = 0
  IdCapituloEnCurso = 0

  ' --- 8. FORZAR SALIDA PARA NO QUEDAR EN ESTADO INCONSISTENTE ---
  Quit

End
