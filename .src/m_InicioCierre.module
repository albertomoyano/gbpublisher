' Gambas module file

Public UsuarioEnCurso As String
Public IdUsuarioEnCurso As Integer

Public Sub DirectorioOcultoApp()

  ' --- 1. Crear directorio base si no existe ---
  Dim sBase As String = User.Home &/ ".gbpublisher"

  If Not Exist(sBase) Then
    Try Mkdir sBase
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("No se pudo crear el directorio base de la aplicación:" & Chr(10) & sBase)
      Return
    Endif
  Endif

  ' --- COPIAR CONTENIDO DE CARPETAS DEL SISTEMA ---
  Dim carpetas As String[] = ["biblatex", "chart", "csl", "dtd", "filters",
    "fonts", "github", "media", "ott", "schemas",
    "schematron", "scripts", "sonido", "xslt"]

  Dim carpeta As String
  For Each carpeta In carpetas
    CopiarDirectorio(RutaRecursos() & "/" & carpeta, User.Home & "/.gbpublisher/" & carpeta)
    ' DESPUÉS DE FUENTES, COPIAR ICONOS SVG CON COLOR AJUSTADO
    If carpeta = "fonts" Then CopiarIconosSVG()
  Next

  If Not Exist(User.Home & "/.gbpublisher/respaldo") Then
    Try Mkdir User.Home & "/.gbpublisher/respaldo"
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("Error al crear el directorio de respaldo.")
    Endif
  Endif

  ' --- VERIFICAR Y CREAR ARCHIVO DE IPS SI NO EXISTE ---
  Dim sRutaIPs As String = User.Home &/ ".gbpublisher/.ips.txt"

  If Not Exist(sRutaIPs) Then
    Try File.Save(sRutaIPs, "127.0.0.1" & Chr(10))
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("No se pudo crear el archivo de IPs:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- VERIFICAR Y CREAR BUSCADOR.PY SI NO EXISTE ---
  If Not m_FuncionesGenericas.CrearBuscadorPy() Then Return

End

Public Sub CopiarIconosSVG()

  Dim srcDir As String
  Dim dstDir As String
  Dim f As String
  Dim sContenido As String

  srcDir = RutaRecursos() &/ "fonts"
  dstDir = User.Home &/ ".gbpublisher" &/ "fonts"

  For Each f In Dir(srcDir, "*.svg")

    ' LEER CONTENIDO DEL SVG ORIGINAL
    Try sContenido = File.Load(srcDir &/ f)
    If Error Then Continue

    ' REEMPLAZAR COLOR DE RELLENO POR azulrevista
    sContenido = Replace(sContenido, "currentColor", "#2D5A8E")

    ' ESCRIBIR SVG COLOREADO EN DESTINO
    Try File.Save(dstDir &/ f, sContenido)
    If Error Then
      Message.Error("Error guardando: " & f & Chr(10) & Error.Text)
    Endif

  Next

End Sub

' ============================================
' Función   : CopiarDirectorio
' Propósito : Copia recursivamente el contenido de un directorio
'             hacia un destino, preservando la estructura de
'             subdirectorios y omitiendo archivos ya existentes
' Parámetros: srcDir As String — ruta absoluta del directorio origen
'             dstDir As String — ruta absoluta del directorio destino
' Retorna   : (ninguno)
' ============================================
Public Sub CopiarDirectorio(srcDir As String, dstDir As String)

  ' --- 1. Inicialización de variables ---
  Dim f As String

  ' --- 2. Verificar que el directorio origen existe ---
  If Not Exist(srcDir) Then
    ' DIAGNÓSTICO: REGISTRAR QUÉ DIRECTORIO ORIGEN FALTA
    FMain.TerminalViewProyecto.Input("echo 'FALTA srcDir: " & srcDir & "'" & Chr(10))
    Return
  Endif
  ' --- 3. Crear carpeta destino si no existe ---
  If Not Exist(dstDir) Then
    Mkdir dstDir
  Endif

  ' --- 4. Primera pasada: subdirectorios ---
  For Each f In Dir(srcDir, "*", gb.Directory)
    CopiarDirectorio(srcDir & "/" & f, dstDir & "/" & f)
  Next

  ' --- 5. Segunda pasada: archivos ---
  For Each f In Dir(srcDir, "*.*")
    If Not Exist(dstDir & "/" & f) Then
      Copy srcDir & "/" & f To dstDir & "/" & f
    Endif
  Next

End

Public Sub CargarUsuarios()

  Dim rUsuarios As Result
  Dim iRow As Integer
  Dim iCol As Integer

  rUsuarios = m_ConexionBD.mConn.Exec("SELECT usuario, en_linea FROM usuarios WHERE activo = 1 ORDER BY en_linea DESC, usuario ASC")

  ' LIMPIAR EL GRIDVIEW
  FMain.TableViewUsuarios.Clear

  ' SI NO HAY DATOS, ESTABLECER EL GRID VACÍO Y SALIR
  If rUsuarios = Null Or rUsuarios.Count = 0 Then
    FMain.TableViewUsuarios.Rows.Count = 0
    FMain.TableViewUsuarios.Columns.Count = 0
    Return
  Endif

  ' CONFIGURAR COLUMNAS Y FILAS
  FMain.TableViewUsuarios.Columns.Count = rUsuarios.Fields.Count
  FMain.TableViewUsuarios.Rows.Count = rUsuarios.Count
  FMain.TableViewUsuarios.MoveTo(0, 0)

  ' POBLAR LOS DATOS DEL RESULTADO EN EL GRIDVIEW
  iRow = 0
  For Each rUsuarios
    For iCol = 0 To rUsuarios.Fields.Count - 1
      If IsNull(rUsuarios[iCol]) Then
        FMain.TableViewUsuarios[iRow, iCol].Text = ""
      Else
        ' SI ES LA COLUMNA "EN_LINEA" (ÍNDICE 1), MOSTRAR TEXTO
        If iCol = 1 Then
          FMain.TableViewUsuarios[iRow, iCol].Text = IIf(CBool(rUsuarios[iCol]), "Conectado", "")
        Else
          FMain.TableViewUsuarios[iRow, iCol].Text = rUsuarios[iCol]
        End If
      Endif
    Next
    iRow += 1
  Next

End

Public Sub DisenarTableViewUsuarios(grid As GridView)

  With grid
    .Header = True
    .Grid = True
    .Columns.Count = 3

    ' CONFIGURACIÓN DE COLUMNAS
    For i As Integer = 0 To 2
      Select Case i
        Case 0
          .Columns[i].Title = "Usuario"
          .Columns[i].Width = 150
        Case 1
          .Columns[i].Title = "Estado"
          .Columns[i].Width = 150
        Case 2
          .Columns[i].Title = "Proyecto"
          .Columns[i].Width = 300
      End Select
    Next
  End With

End

Public Sub CargarScripts()

  Dim rutaScripts As String = User.Home &/ ".gbpublisher/scripts"
  Dim archivos As String[]
  Dim archivo As String
  Dim linea As String
  Dim descripcion As String
  Dim archivoBase As String
  Dim hFile As File
  Dim extension As String
  Dim extensionOriginal As String
  Dim prefijo As String

  ' VERIFICAR QUE EL DIRECTORIO EXISTE
  If Not Exist(rutaScripts) Then
    m_Sonido.sonar("Error")
    Message.Error("El directorio de scripts no existe: " & rutaScripts)
    Return
  Endif

  FMain.ComboBoxScripts.Clear

  ' DEFINIR LAS EXTENSIONES SOPORTADAS
  Dim extensiones As String[] = ["*.py", "*.lua", "*.sh", "*.pl", "*.R"]
  Dim todosArchivos As New String[]

  ' OBTENER ARCHIVOS DE TODAS LAS EXTENSIONES
  For Each extension In extensiones
    archivos = Dir(rutaScripts, extension)
    If Not Error Then
      For Each archivo In archivos
        todosArchivos.Add(archivo)
      Next
    Endif
  Next

  ' VERIFICAR SI HAY ARCHIVOS
  If todosArchivos.Count = 0 Then
    m_Sonido.sonar("Info")
    Message.Info("No se encontraron scripts en el directorio")
    Return
  Endif

  ' PROCESAR CADA ARCHIVO
  For Each archivo In todosArchivos
    descripcion = "Sin descripción"

    ' OBTENER EXTENSIÓN ORIGINAL SIN CONVERTIR
    extensionOriginal = File.Ext(archivo)

    ' CONVERTIR SOLO PARA LA COMPARACIÓN
    extension = LCase(extensionOriginal)

    ' DETERMINAR EL PREFIJO DE COMENTARIO SEGÚN LA EXTENSIÓN
    Select Case extension
      Case "py"
        prefijo = "#"
      Case "lua"
        prefijo = "--"
      Case "sh"
        prefijo = "#"
      Case "pl"
        prefijo = "#"
      Case "r"
        prefijo = "#"
      Default
        prefijo = "#"
    End Select

    ' CONSTRUIR RUTA COMPLETA DEL ARCHIVO
    Dim rutaCompleta As String = rutaScripts &/ archivo

    ' INTENTAR LEER LA PRIMERA LÍNEA DEL ARCHIVO PARA OBTENER DESCRIPCIÓN
    hFile = Open rutaCompleta For Read
    If Not Error Then
      Line Input #hFile, linea
      If Not Error And linea <> "" Then
        linea = Trim(linea)
        ' SALTAR SHEBANG SI EXISTE (#!/...)
        If Left(linea, 2) = "#!" Then
          If Not Eof(hFile) Then
            Line Input #hFile, linea
            linea = Trim(linea)
          Else
            linea = ""
          Endif
        Endif
        ' VERIFICAR SI LA LÍNEA COMIENZA CON EL PREFIJO DE COMENTARIO
        If linea <> "" And Left(linea, Len(prefijo)) = prefijo Then
          ' EXTRAER DESCRIPCIÓN, ELIMINANDO EL PREFIJO Y ESPACIOS
          If Len(linea) > Len(prefijo) Then
            descripcion = Trim(Mid(linea, Len(prefijo) + 1))
          Endif
        Endif
      Endif
      Close #hFile
    Else
      descripcion = "Error al leer archivo"
    Endif

    ' AGREGAR AL COMBOBOX CON LA EXTENSIÓN ORIGINAL
    archivoBase = File.BaseName(archivo) & "." & extensionOriginal
    FMain.ComboBoxScripts.Add(descripcion & " [" & archivoBase & "]")
  Next

End

' FUNCIÓN AUXILIAR PARA FORMATEAR LÍNEAS CON ESPACIOS NO-BREAKING
Private Function FormatearLinea(columna1 As String, columna2 As String) As String

  Dim linea As String
  Dim espacios As String
  Dim i As Integer
  Dim anchoCol1 As Integer = 30
  Dim anchoCol2 As Integer = 10

  ' COLUMNA 1: ALINEADA A LA IZQUIERDA
  espacios = ""
  For i = 1 To anchoCol1 - Len(columna1)
    espacios &= "&nbsp;"
  Next
  linea = columna1 & espacios & " | "

  ' COLUMNA 2: ALINEADA A LA DERECHA
  espacios = ""
  For i = 1 To anchoCol2 - Len(columna2)
    espacios &= "&nbsp;"
  Next
  linea &= espacios & columna2 & "\n"

  Return linea

End

' FUNCIÓN PARA FORMATEAR NÚMEROS CON SEPARADOR DE MILES
Private Function FormatearNumero(numero As Long) As String

  Dim resultado As String
  Dim strNumero As String
  Dim i As Integer
  Dim contador As Integer

  strNumero = Str(numero)
  resultado = ""
  contador = 0

  ' RECORRER EL NÚMERO DE DERECHA A IZQUIERDA
  For i = Len(strNumero) To 1 Step -1
    If contador = 3 Then
      resultado = "." & resultado
      contador = 0
    Endif
    resultado = Mid(strNumero, i, 1) & resultado
    contador += 1
  Next

  Return resultado

End

Public Function RutaRecursos() As String

  ' EN EL IDE: LAS CARPETAS ESTÁN EN .hidden/ DENTRO DEL PROYECTO
  If Exist(Application.Path &/ ".hidden" &/ "fonts") Then
    Return Application.Path &/ ".hidden"
  Endif

  ' INSTALADO: LOS ARCHIVOS ESTÁN EN /usr/share/gbpublisher/
  Return "/usr/share/gbpublisher"

End

Public Function LeerTipoCSL(sRutaCSL As String) As String

  ' MAPEO DIRECTO: nombre de archivo CSL → identificador de estilo
  ' gbpublisher SOPORTA EXACTAMENTE 4 ESTILOS CON NOMBRES FIJOS
  Select Case Lower(File.Name(sRutaCSL))
    Case "apa.csl"
      Return "apa"
    Case "ieee.csl"
      Return "ieee"
    Case "vancouver.csl"
      Return "vancouver"
    Case "iso690-author-date-es.csl"
      Return "iso690"
    Case Else
      Message.Error("Estilo de cita no reconocido: " & File.Name(sRutaCSL) & Chr(10) &
        "Los estilos soportados son: apa.csl, ieee.csl, vancouver.csl, iso690-author-date-es.csl")
      Return ""
  End Select

Catch
  Return "apa"

End Function

Public Sub CerrarTodoMySQL()

  ' CONFIRMACIÓN DE SALIDA
  m_Sonido.sonar("Question")
  If Message.Question("¿Está seguro que desea salir de la aplicación?") = 2 Then ' Usuario eligió 2 = Cancelar
    Return
  Endif

  m_ConexionBD.mConn.Exec("UPDATE usuarios SET en_linea = 0 WHERE usuario = &1", UsuarioEnCurso)
  m_ConexionBD.mConn.Exec("UPDATE proyectos SET usuario_propietario = NULL WHERE id = &1", FMain.id_proyecto.Value)
  m_ConexionBD.mConn.Exec("UPDATE proyectos SET ocupado = 0 WHERE id = &1", FMain.id_proyecto.Value)

  m_ConexionBD.mConn.Commit
  m_Timer.DetenerContador()

  'DETENEMOS EL CONTADOR PARA ARCHIVOS XML
  FMain.DetenerTimerArchivosXML()

  ' DETENEMOS EL CONTADOR PARA ARCHIVOS MD
  FMain.DetenerTimerArchivosProyecto()

  ' LIMPIAR TERMINAL Y PROCESOS
  Try FMain.TerminalViewProyecto.Input("rm -rf " & User.Home & "/.local/share/org.gambas.*" & "\n")
  Try FMain.TerminalViewProyecto.Input("clear" & "\n")
  Wait 0.2

  ' DETIENE EL PROCESO BASH
  If FMain.$Bash Then
    If Object.IsValid(FMain.$Bash) Then
      If FMain.$Bash.State = Process.Running Then
        Dim tries As Integer = 0
        While FMain.$Bash.State = Process.Running And tries < 20
          FMain.$Bash.Kill
          Wait 0.05
          tries = tries + 1
        Wend
        ' FALLBACK: SI KILL NO ALCANZÓ, INTENTAR TERMINATE
        If FMain.$Bash.State = Process.Running Then
          FMain.$Bash.Terminate
          Wait 0.2
          If FMain.$Bash.State = Process.Running Then
            m_Sonido.sonar("Warning")
            Message.Warning("El proceso no pudo ser detenido.")
          Endif
        Endif
      Endif
    Endif
    FMain.$Bash = Null
  Endif

  ' LIMPIAR INTERFAZ
  FMain.txtProyecto.Clear
  FMain.DirViewProyecto.Root = User.Home
  FMain.TextBoxUsuario.Clear
  FMain.TextBoxServidor.Clear

  ' CIERRA LA CONEXIÓN A LA BBDD SI EXISTE Y ESTÁ ABIERTA
  If Not IsNull(m_ConexionBD.mConn) Then
    If m_ConexionBD.mConn.Opened Then
      m_ConexionBD.mConn.Close()
    Endif
    m_ConexionBD.mConn = Null
  Endif

  ' --- LIMPIAR ESTADO DE SESIÓN ---
  UsuarioEnCurso = ""
  IdUsuarioEnCurso = 0

  ' FORZAMOS SALIDA PARA NO QUEDAR EN ESTADO INCONSISTENTE
  Quit

End

' ============================================
' Función   : VerificarFuentesIBMPlex
' Propósito : Verifica que las fuentes IBM Plex estén instaladas en el
'             directorio de fuentes del usuario. Si faltan, las copia desde
'             los recursos del paquete. Si la fuente de recursos no existe,
'             informa el problema de instalación y cierra. Si se copian
'             fuentes nuevas, registra y pide reinicio.
' ============================================
Public Sub VerificarFuentesIBMPlex()

  ' --- 1. Verificar presencia de la fuente centinela ---
  ' SI YA ESTÁ INSTALADA NO HAY NADA QUE HACER
  Dim sFontDst As String = User.Home &/ ".local/share/fonts/gbpublisher"

  If Exist(sFontDst &/ "IBMPlexSans-Regular.otf") Then Return

  ' --- 2. Verificar que el directorio fuente del paquete existe ---
  ' SI FALTA, EL PAQUETE ESTÁ MAL INSTALADO — ES UN ERROR DE INSTALACIÓN, NO DE USO
  Dim sFontSrc As String = RutaRecursos() &/ "fonts"
  If Not Exist(sFontSrc) Then
    m_Sonido.sonar("Error")
    Message.Error(
      "No se encontró el directorio de fuentes del paquete:" & Chr(10) &
      sFontSrc & Chr(10) & Chr(10) &
      "La instalación de gbpublisher puede estar incompleta." & Chr(10) &
      "Reinstale el paquete e intente nuevamente.")
    Quit
  Endif

  ' --- 3. Crear directorio de destino si no existe ---
  If Not Exist(sFontDst) Then
    Try Mkdir sFontDst
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error(
        "No se pudo crear el directorio de fuentes del usuario:" & Chr(10) &
        sFontDst & Chr(10) & Chr(10) &
        "Verifique los permisos de escritura en su directorio personal.")
      Quit
    Endif
  Endif

  ' --- 4. Copiar fuentes disponibles y contabilizar ---
  Dim aFuentes As String[] = [
    "IBMPlexSans-Regular.otf", "IBMPlexSans-Bold.otf",
    "IBMPlexSans-Italic.otf", "IBMPlexSans-BoldItalic.otf",
    "IBMPlexMono-Regular.otf", "IBMPlexMono-Bold.otf",
    "IBMPlexMono-Italic.otf", "IBMPlexMono-BoldItalic.otf"
  ]
  Dim sFuente As String
  Dim iCopiadas As Integer = 0
  Dim iEsperadas As Integer = aFuentes.Count
  Dim aFaltantes As New String[]

  For Each sFuente In aFuentes
    If Exist(sFontSrc &/ sFuente) Then
      Try Copy sFontSrc &/ sFuente To sFontDst &/ sFuente
      If Error Then
        aFaltantes.Add(sFuente)
      Else
        Inc iCopiadas
      Endif
    Else
      aFaltantes.Add(sFuente)
    Endif
  Next

  ' --- 5. Evaluar resultado de la copia ---
  ' SI NO SE COPIÓ NINGUNA FUENTE, EL PROBLEMA ES DE INSTALACIÓN
  If iCopiadas = 0 Then
    m_Sonido.sonar("Error")
    Message.Error(
      "No se encontraron fuentes IBM Plex en el paquete instalado." & Chr(10) & Chr(10) &
      "Directorio buscado:" & Chr(10) &
      sFontSrc & Chr(10) & Chr(10) &
      "La instalación de gbpublisher puede estar incompleta." & Chr(10) &
      "Reinstale el paquete e intente nuevamente.")
    Quit
  Endif

  ' --- 6. Registrar fuentes copiadas en el sistema ---
  Shell "fc-cache -f '" & sFontDst & "'" Wait

  ' --- 7. Informar resultado y solicitar reinicio ---
  ' ADVERTENCIA ADICIONAL SI FALTAN ALGUNAS FUENTES (INSTALACIÓN PARCIAL)
  Dim sMensaje As String
  If aFaltantes.Count > 0 Then
    sMensaje =
      "Se instalaron " & CStr(iCopiadas) & " de " & CStr(iEsperadas) & " fuentes IBM Plex." & Chr(10) & Chr(10) &
      "Las siguientes fuentes no pudieron copiarse:" & Chr(10) &
      aFaltantes.Join(Chr(10)) & Chr(10) & Chr(10) &
      "La interfaz puede no visualizarse correctamente." & Chr(10) & Chr(10) &
      "Cierre y vuelva a abrir la aplicación para continuar."
  Else
    sMensaje =
      "Su sistema no tenía instalada la familia tipográfica IBM Plex." & Chr(10) & Chr(10) &
      "Las fuentes se instalaron correctamente en:" & Chr(10) &
      sFontDst & Chr(10) & Chr(10) &
      "Cierre la aplicación y vuelva a abrirla para continuar."
  Endif
  m_Sonido.sonar("Info")
  Message.Info(sMensaje)
  Quit

End Sub

' ============================================
' Función   : CerrarProyecto
' Propósito : Libera el proyecto actualmente abierto: marca como no-ocupado
'             en BD, detiene timers, mata el proceso bash de la terminal,
'             limpia la UI de FMain. NO pregunta al usuario — la decisión
'             debe tomarla el caller antes de invocar esta función.
'             Tampoco toca usuarios.en_linea — eso es responsabilidad del
'             flujo de desconexión, no del cierre de proyecto.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub CerrarProyecto()

  ' --- 1. SIN PROYECTO ABIERTO: NADA QUE HACER ---
  If FMain.txtProyecto.Text = "" Then Return

  ' --- 2. LIBERAR EL PROYECTO EN BD ---
  ' UPDATE ATÓMICO QUE COMBINA OWNER Y FLAG DE OCUPADO EN UNA SOLA SENTENCIA
  Try m_ConexionBD.mConn.Exec(
    "UPDATE proyectos SET usuario_propietario = NULL, ocupado = 0 WHERE id = &1",
    FMain.id_proyecto.Value)
  If Error Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se pudo liberar el proyecto en la base de datos:" & gb.NewLine &
      Error.Text & gb.NewLine & gb.NewLine &
      "El cierre continúa, pero el proyecto puede quedar marcado como ocupado.")
  Else
    Try m_ConexionBD.mConn.Commit
  Endif

  ' --- 3. DETENER TIMERS Y CONTADORES ---
  m_Timer.DetenerContador()
  FMain.DetenerTimerArchivosXML()
  FMain.DetenerTimerArchivosProyecto()

  ' --- 4. LIMPIAR LA TERMINAL EMBEBIDA ---
  Try FMain.TerminalViewProyecto.Input("clear" & Chr(10))
  Wait 0.2

  ' --- 5. DETENER EL PROCESO BASH ASOCIADO ---
  ' NOTA: ACCESO DIRECTO A FMain.$Bash. DEUDA TÉCNICA — MOVER A UNA FUNCIÓN
  ' PÚBLICA EN FMain (DetenerBashEnCurso) CUANDO SE REFACTORICE FMain
  If FMain.$Bash Then
    If Object.IsValid(FMain.$Bash) Then
      If FMain.$Bash.State = Process.Running Then
        Dim tries As Integer = 0
        While FMain.$Bash.State = Process.Running And tries < 20
          FMain.$Bash.Kill
          Wait 0.05
          tries = tries + 1
        Wend
        ' FALLBACK: SI KILL NO ALCANZÓ, INTENTAR TERMINATE
        If FMain.$Bash.State = Process.Running Then
          FMain.$Bash.Terminate
          Wait 0.2
          If FMain.$Bash.State = Process.Running Then
            m_Sonido.sonar("Warning")
            Message.Warning("El proceso bash no pudo ser detenido.")
          Endif
        Endif
      Endif
    Endif
    FMain.$Bash = Null
  Endif

  ' --- 6. LIMPIAR FORMULARIOS DE BIBTEX Y SIGLAS ---
  m_Bibtex.LimpiarTextboxBibtex()
  m_Siglas.LimpiarTextboxSigla()

  ' --- 7. RESETEAR UI DE FMain Y CONTADORES VISUALES ---
  FMain.TimerHOY.Delay = 1000
  FMain.TimerHOY.Stop
  FMain.TextHoraParcial.Text = "00:00:00"
  FMain.TextHoraTotal.Text = ""
  FMain.txtProyecto.Text = ""
  FMain.id_proyecto.Value = ""
  FMain.DirViewProyecto.Root = User.Home
  FMain.SplitterPrincipal.Visible = False
  FMain.SpringTemporal.Visible = True

End
