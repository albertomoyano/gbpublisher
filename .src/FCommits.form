# Gambas Form File 3.0

{ Form Form
  Move(0,0,600,250)
  #Scaled = False
  Resizable = False
  Arrangement = Arrange.Vertical
  Spacing = True
  Margin = True
  Padding = 4
  { txtCommit TextArea
    Move(9,9,369,180)
    Expand = True
  }
  { HBox1 HBox
    Move(9,198,585,36)
    { Spring1 Spring
      Move(9,0,27,36)
    }
    { btnEmpujar Button
      Move(288,0,144,36)
      Font = Font["Bold"]
      Background = &H9FFF7F
      Text = ("Empujar")
      Picture = Picture["iconos/gitremoto.png"]
    }
    { btnCancelar Button
      Move(432,0,144,36)
      Text = ("Cancelar")
      Picture = Picture["iconos/salir.png"]
    }
  }
}
