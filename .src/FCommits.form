# Gambas Form File 3.0

{ Form Form
  Move(0,0,740,600)
  #Scaled = False
  Resizable = False
  Arrangement = Arrange.Vertical
  Spacing = True
  Margin = True
  Padding = 4
  { txtCommit TextArea
    Move(45,351,369,180)
    Expand = True
  }
  { HBox1 HBox
    Move(18,540,495,36)
    { Spring1 Spring
      Move(36,0,126,36)
    }
    { btnEmpujar Button
      Move(171,0,144,36)
      Font = Font["Bold"]
      Background = &H9FFF7F
      Text = ("Empujar")
      Picture = Picture["iconos/gitremoto.png"]
    }
    { btnCancelar Button
      Move(315,0,144,36)
      Text = ("Cancelar")
      Picture = Picture["iconos/salir.png"]
    }
  }
}
