' Gambas module file

' =====================================================
' MÓDULO: m_XML
' =====================================================
' PROPÓSITO:
'   Concentra toda la lógica de generación, transformación
'   y validación de archivos XML del pipeline editorial:
'
'   — Generación de fragmentos JATS 1.4:
'       front.xml   (GenerarFrontXML)
'       body.xml    (GenerarBodyXML)
'       reflist.xml (GenerarRefListXML)
'
'   — Exportación desde .bib a JATS:
'       ExportarJATSdesdeBIB / GenerarElementCitationDesdeBib
'
'   — Enriquecimiento del canónico (EnriquecerCanonico)
'
'   — Generación y envío a DOAJ:
'       GenerarJsonDoaj / EnviarJsonDoaj
'
'   — Validación de archivos para indexadores:
'       ValidarArchivoDoaj / ValidarArchivoRedalyc
'
'   — Pipeline completo LaTeX → PDF:
'       GenerarTeXBodyDesdeCanonico / EnsamblarTeX
'       CompilarPDF / GenerarPDF
'
' DEPENDENCIAS:
'   m_ConexionBD   — conexión activa a MySQL/MariaDB
'   m_Sonido       — feedback auditivo
'   FMain          — terminal integrada + valuebox de proyecto
'
' CONVENCIÓN DE ARCHIVOS:
'   a-*  → nombre_archivo en BD (sin extensión)
'   c-*  → canónico JATS (jats/)
'   d-*  → DOAJ XML/JSON (jats/)
'   r-*  → Redalyc/Marcalyc (jats/)
'   b-*  → body LaTeX (latex/)
'   l-*  → documento LaTeX completo (latex/)
'   s-*  → SciELO
'   o-*  → CrossRef
'
' NOTA DTD JATS 1.4 — related-article:
'   Los atributos publication-year, fpage y lpage NO están
'   declarados en la DTD JATS 1.4. Solo vol e issue son válidos.
'   La posición correcta dentro de article-meta es:
'   después de <permissions> y antes de <abstract>.
' =====================================================

' =====================================================
' FUNCIÓN AUXILIAR: ConvertirTipoJATS
' =====================================================
' DESCRIPCIÓN: CONVIERTE TIPO DE ENTRADA BIBTEX A TIPO JATS
' PARÁMETROS: sTipoBibTeX — TIPO DE ENTRADA BIBTEX
' RETORNA:    String — TIPO DE PUBLICACIÓN JATS
' =====================================================
Private Function ConvertirTipoJATS(sTipoBibTeX As String) As String

  Dim mapeo As New Collection

  ' MAPEO DE TIPOS BIBTEX/BIBLATEX A JATS
  mapeo["article"] = "journal"
  mapeo["book"] = "book"
  mapeo["inbook"] = "book"
  mapeo["incollection"] = "book"
  mapeo["inproceedings"] = "confproc"
  mapeo["conference"] = "confproc"
  mapeo["proceedings"] = "confproc"
  mapeo["thesis"] = "thesis"
  mapeo["phdthesis"] = "thesis"
  mapeo["mastersthesis"] = "thesis"
  mapeo["techreport"] = "report"
  mapeo["manual"] = "report"
  mapeo["booklet"] = "book"
  mapeo["unpublished"] = "other"
  mapeo["misc"] = "other"
  mapeo["online"] = "web"
  mapeo["patent"] = "patent"
  mapeo["report"] = "report"
  mapeo["software"] = "software"
  mapeo["dataset"] = "dataset"

  If mapeo.Exist(Lower(sTipoBibTeX)) Then
    Return mapeo[Lower(sTipoBibTeX)]
  Else
    Return "other"
  Endif

End

' =====================================================
' FUNCIÓN AUXILIAR: GenerarPaginas
' =====================================================
' DESCRIPCIÓN: GENERA ELEMENTOS <fpage> Y <lpage> DESDE CAMPO pages
' PARÁMETROS: sPages — STRING CON PÁGINAS (ej: "45-67" o "45--67")
' RETORNA:    String — XML CON FPAGE Y LPAGE
' =====================================================
Private Function GenerarPaginas(sPages As String) As String

  Dim sXML As String
  Dim sPaginaInicio As String
  Dim sPaginaFin As String

  sXML = ""

  ' NORMALIZAR SEPARADORES DE PÁGINA
  sPages = Replace(sPages, "--", "-")

  If InStr(sPages, "-") > 0 Then
    sPaginaInicio = TrimUTF8(Split(sPages, "-")[0])
    sPaginaFin = TrimUTF8(Split(sPages, "-")[1])
    sXML &= "      <fpage>" & sPaginaInicio & "</fpage>\n"
    sXML &= "      <lpage>" & sPaginaFin & "</lpage>\n"
  Else
    sXML &= "      <fpage>" & TrimUTF8(sPages) & "</fpage>\n"
  Endif

  Return sXML

End

' =====================================================
' FUNCIÓN AUXILIAR: EscaparXML
' =====================================================
' DESCRIPCIÓN: ESCAPA CARACTERES ESPECIALES PARA XML
' PARÁMETROS: sTexto — TEXTO A ESCAPAR
' RETORNA:    String — TEXTO ESCAPADO
' =====================================================
Public Function EscaparXML(sTexto As String) As String

  Dim sResultado As String

  sResultado = sTexto
  sResultado = Replace(sResultado, "&", "&amp;")
  sResultado = Replace(sResultado, "<", "&lt;")
  sResultado = Replace(sResultado, ">", "&gt;")
  sResultado = Replace(sResultado, "\"", "&quot;")
  sResultado = Replace(sResultado, "'", "&apos;")

  Return sResultado

End

' =====================================================
' FUNCIÓN AUXILIAR: ExtraerAnio
' =====================================================
' DESCRIPCIÓN: EXTRAE EL AÑO DE UNA FECHA EN FORMATO ISO (YYYY-MM-DD)
' PARÁMETROS: sFecha — STRING CON FECHA
' RETORNA:    String — AÑO EXTRAÍDO
' =====================================================
Private Function ExtraerAnio(sFecha As String) As String

  If InStr(sFecha, "-") > 0 Then
    Return Split(sFecha, "-")[0]
  Else
    Return sFecha
  Endif

End

' =====================================================
' FUNCIÓN AUXILIAR: ConvertirMarcaLatex
' =====================================================
' DESCRIPCIÓN: CONVIERTE UNA MARCA LATEX {CONTENIDO} A MARCAS XML
' PARÁMETROS: sTexto       — TEXTO COMPLETO
'             sMarcaLatex  — MARCA LATEX (ej: "\\emph")
'             sMarcaApertura — MARCA XML APERTURA (ej: "<italic>")
'             sMarcaCierre   — MARCA XML CIERRE (ej: "</italic>")
' RETORNA:    String — TEXTO CON MARCAS CONVERTIDAS
' =====================================================
Private Function ConvertirMarcaLatex(sTexto As String, sMarcaLatex As String, sMarcaApertura As String, sMarcaCierre As String) As String

  Dim sResultado As String
  Dim posInicio As Integer
  Dim posFin As Integer
  Dim contenido As String

  sResultado = sTexto

  While InStr(sResultado, sMarcaLatex & "{") > 0
    posInicio = InStr(sResultado, sMarcaLatex & "{")
    posFin = EncontrarLlaveCorrespondiente(sResultado, posInicio + Len(sMarcaLatex) + 1)

    If posFin > 0 Then
      contenido = Mid(sResultado, posInicio + Len(sMarcaLatex) + 1, posFin - posInicio - Len(sMarcaLatex) - 1)
      sResultado = Left(sResultado, posInicio - 1) & sMarcaApertura & contenido & sMarcaCierre & Mid(sResultado, posFin + 1)
    Else
      sResultado = Replace(sResultado, sMarcaLatex & "{", "", 1)
    Endif
  Wend

  Return sResultado

End

' =====================================================
' FUNCIÓN AUXILIAR: EncontrarLlaveCorrespondiente
' =====================================================
' DESCRIPCIÓN: ENCUENTRA LA LLAVE DE CIERRE } CORRESPONDIENTE
'              A UNA LLAVE DE APERTURA { EN sTexto
' PARÁMETROS: sTexto     — TEXTO COMPLETO
'             iPosInicio — POSICIÓN DESDE LA QUE BUSCAR
' RETORNA:    Integer — POSICIÓN DE LA LLAVE DE CIERRE, -1 SI NO SE ENCUENTRA
' =====================================================
Private Function EncontrarLlaveCorrespondiente(sTexto As String, iPosInicio As Integer) As Integer

  Dim nivel As Integer = 1
  Dim i As Integer
  Dim caracter As String

  For i = iPosInicio To Len(sTexto)
    caracter = Mid(sTexto, i, 1)
    If caracter = "{" Then
      nivel += 1
    Else If caracter = "}" Then
      nivel -= 1
      If nivel = 0 Then Return i
    Endif
  Next

  Return -1

End

' =====================================================
' FUNCIÓN: GenerarPersonGroup
' =====================================================
' DESCRIPCIÓN: GENERA <person-group> DESDE STRING DE AUTORES BIBTEX
' PARÁMETROS: sNombres — String con autores
'                        (Apellido, Nombre and Apellido2, Nombre2)
'             sTipo    — Tipo de grupo (author, editor, translator)
' RETORNA:    String XML con <person-group>
' =====================================================
Private Function GenerarPersonGroup(sNombres As String, sTipo As String) As String

  Dim sXML As String
  Dim aNombres As String[]
  Dim nombreCompleto As String
  Dim apellido As String
  Dim nombre As String
  Dim posComa As Integer
  Dim i As Integer

  sXML = "      <person-group person-group-type=\"" & sTipo & "\">\n"

  ' --- 1. Normalizar espacios ---
  sNombres = Replace(sNombres, Chr(9), " ")
  sNombres = Replace(sNombres, Chr(160), " ")
  While InStr(sNombres, "  ")
    sNombres = Replace(sNombres, "  ", " ")
  Wend
  sNombres = TrimUTF8(sNombres)

  ' --- 2. Separar autores por " and " ---
  sNombres = Replace(sNombres, " and ", "|||")
  aNombres = Split(sNombres, "|||")

  ' --- 3. Procesar cada autor ---
  For i = 0 To aNombres.Max
    nombreCompleto = TrimUTF8(aNombres[i])
    If Len(nombreCompleto) = 0 Then Continue

    ' AUTORES COLECTIVOS (et al.)
    If nombreCompleto = "others" Or nombreCompleto = "et al" Or nombreCompleto = "et al." Then
      sXML &= "        <etal/>\n"
      Continue
    Endif

    ' FORMATO BIBTEX: Apellido, Nombre
    posComa = InStr(nombreCompleto, ",")
    If posComa > 0 Then
      apellido = TrimUTF8(Left(nombreCompleto, posComa - 1))
      nombre = TrimUTF8(Mid(nombreCompleto, posComa + 1))
    Else
      apellido = nombreCompleto
      nombre = ""
    Endif

    sXML &= "        <name>\n"
    sXML &= "          <surname>" & EscaparXML(apellido) & "</surname>\n"
    If Len(nombre) > 0 Then
      sXML &= "          <given-names>" & EscaparXML(nombre) & "</given-names>\n"
    Endif
    sXML &= "        </name>\n"
  Next

  sXML &= "      </person-group>\n"

  Return sXML

End Function

' =====================================================
' FUNCIÓN: LimpiarMarcasLatex
' =====================================================
' DESCRIPCIÓN: LIMPIA MARCAS LATEX Y APLICA FORMATO XML
'              USADO INTERNAMENTE POR LAS FUNCIONES DE EXPORTACIÓN BIB
' RETORNA:    String — TEXTO LIMPIO Y MAPEADO A XML
' =====================================================
Private Function LimpiarMarcasLatex(sTexto As String) As String

  Dim sResultado As String
  Dim comillaAbre As String
  Dim comillaCierra As String

  comillaAbre = Chr(34)
  comillaCierra = Chr(34)
  sResultado = sTexto

  ' --- 1. Escapar caracteres XML del texto original ---
  sResultado = Replace(sResultado, "&", "&amp;")
  sResultado = Replace(sResultado, "<", "&lt;")
  sResultado = Replace(sResultado, ">", "&gt;")

  ' --- 2. Acentos agudos ---
  sResultado = Replace(sResultado, "\\'{a}", "á")
  sResultado = Replace(sResultado, "\\'{e}", "é")
  sResultado = Replace(sResultado, "\\'{i}", "í")
  sResultado = Replace(sResultado, "\\'{o}", "ó")
  sResultado = Replace(sResultado, "\\'{u}", "ú")
  sResultado = Replace(sResultado, "\\'{A}", "Á")
  sResultado = Replace(sResultado, "\\'{E}", "É")
  sResultado = Replace(sResultado, "\\'{I}", "Í")
  sResultado = Replace(sResultado, "\\'{O}", "Ó")
  sResultado = Replace(sResultado, "\\'{U}", "Ú")

  ' --- 3. Acentos graves ---
  sResultado = Replace(sResultado, "\\`{a}", "à")
  sResultado = Replace(sResultado, "\\`{e}", "è")
  sResultado = Replace(sResultado, "\\`{i}", "ì")
  sResultado = Replace(sResultado, "\\`{o}", "ò")
  sResultado = Replace(sResultado, "\\`{u}", "ù")

  ' --- 4. Diéresis ---
  sResultado = Replace(sResultado, "\\\"{a}", "ä")
  sResultado = Replace(sResultado, "\\\"{e}", "ë")
  sResultado = Replace(sResultado, "\\\"{i}", "ï")
  sResultado = Replace(sResultado, "\\\"{o}", "ö")
  sResultado = Replace(sResultado, "\\\"{u}", "ü")
  sResultado = Replace(sResultado, "\\\"{y}", "ÿ")

  ' --- 5. Tilde y circunflejo ---
  sResultado = Replace(sResultado, "\\~{n}", "ñ")
  sResultado = Replace(sResultado, "\\~{N}", "Ñ")
  sResultado = Replace(sResultado, "\\~{a}", "ã")
  sResultado = Replace(sResultado, "\\~{o}", "õ")
  sResultado = Replace(sResultado, "\\^{a}", "â")
  sResultado = Replace(sResultado, "\\^{e}", "ê")
  sResultado = Replace(sResultado, "\\^{i}", "î")
  sResultado = Replace(sResultado, "\\^{o}", "ô")
  sResultado = Replace(sResultado, "\\^{u}", "û")

  ' --- 6. Cedilla ---
  sResultado = Replace(sResultado, "\\c{c}", "ç")
  sResultado = Replace(sResultado, "\\c{C}", "Ç")

  ' --- 7. Caracteres escapados de LaTeX ---
  sResultado = Replace(sResultado, "\\&", "&")
  sResultado = Replace(sResultado, "\\%", "%")
  sResultado = Replace(sResultado, "\\$", "$")
  sResultado = Replace(sResultado, "\\_", "_")
  sResultado = Replace(sResultado, "\\#", "#")
  sResultado = Replace(sResultado, "\\textasciitilde", "~")
  sResultado = Replace(sResultado, "\\textbackslash", "\\")

  ' --- 8. Énfasis e itálica → <italic> ---
  sResultado = ConvertirMarcaLatex(sResultado, "\\emph", "<italic>", "</italic>")
  sResultado = ConvertirMarcaLatex(sResultado, "\\textit", "<italic>", "</italic>")

  ' --- 9. Negrita → <bold> ---
  sResultado = ConvertirMarcaLatex(sResultado, "\\textbf", "<bold>", "</bold>")

  ' --- 10. Comillas ---
  sResultado = ConvertirMarcaLatex(sResultado, "\\enquote", comillaAbre, comillaCierra)

  ' --- 11. Guiones tipográficos ---
  sResultado = Replace(sResultado, "---", "—")
  sResultado = Replace(sResultado, "--", "–")

  ' --- 12. Espacios especiales ---
  sResultado = Replace(sResultado, "~", " ")
  sResultado = Replace(sResultado, "\\ ", " ")

  ' --- 13. Limpiar llaves ---
  sResultado = Replace(sResultado, "{{", "")
  sResultado = Replace(sResultado, "}}", "")
  sResultado = Replace(sResultado, "{", "")
  sResultado = Replace(sResultado, "}", "")

  Return sResultado

End Function

' =====================================================
' FUNCIÓN: ExportarJATSdesdeBIB
' =====================================================
' DESCRIPCIÓN: EXPORTA TODAS LAS REFERENCIAS DEL .bib A UN
'              ARCHIVO XML-JATS COMPLETO (ref-*.xml)
'              DIFERENTE DE GenerarRefListXML() QUE FILTRA
'              POR CITEKEYS DEL ARTÍCULO ACTIVO
' RETORNA:    Boolean — TRUE SI SE EXPORTÓ EXITOSAMENTE
' =====================================================
Public Function ExportarJATSdesdeBIB() As Boolean

  Dim sBibFile As String
  Dim sBibContent As String
  Dim sXML As String
  Dim outputFile As String
  Dim aEntries As String[]
  Dim sEntry As String
  Dim sCitekey As String
  Dim sType As String
  Dim iPosLlave As Integer
  Dim iPosComa As Integer
  Dim dictEntries As New Collection
  Dim dictTypes As New Collection

  ' --- 1. Verificar y leer el .bib ---
  sBibFile = File.Dir(FMain.txtProyecto.Text) & "/referencias/ref-" & File.BaseName(FMain.txtProyecto.Text) & ".bib"

  If Not Exist(sBibFile) Then
    Message.Error("El archivo .bib no existe. Exporte primero las referencias.")
    Return False
  Endif

  sBibContent = File.Load(sBibFile)

  ' --- 2. Primera pasada: almacenar entradas para resolver crossref ---
  aEntries = Split(sBibContent, "@", "", True)

  For Each sEntry In aEntries
    If TrimUTF8(sEntry) = "" Then Continue
    iPosLlave = InStr(sEntry, "{")
    iPosComa = InStr(sEntry, ",")
    If iPosLlave = 0 Or iPosComa = 0 Then Continue
    sType = TrimUTF8(Left(sEntry, iPosLlave - 1))
    If Lower(sType) = "comment" Or Lower(sType) = "string" Then Continue
    sCitekey = TrimUTF8(Mid(sEntry, iPosLlave + 1, iPosComa - iPosLlave - 1))
    dictEntries[sCitekey] = sEntry
    dictTypes[sCitekey] = sType
  Next

  ' --- 3. Segunda pasada: generar XML ---
  sXML = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  sXML &= "<ref-list>\n"

  For Each sEntry In aEntries
    If TrimUTF8(sEntry) = "" Then Continue
    iPosLlave = InStr(sEntry, "{")
    iPosComa = InStr(sEntry, ",")
    If iPosLlave = 0 Or iPosComa = 0 Then Continue
    sType = TrimUTF8(Left(sEntry, iPosLlave - 1))
    If Lower(sType) = "comment" Or Lower(sType) = "string" Then Continue
    sCitekey = TrimUTF8(Mid(sEntry, iPosLlave + 1, iPosComa - iPosLlave - 1))
    sXML &= "  <ref id=\"" & EscaparXML(sCitekey) & "\">\n"
    sXML &= GenerarElementCitationDesdeBib(sEntry, sType, dictEntries, dictTypes)
    sXML &= "  </ref>\n"
  Next

  sXML &= "</ref-list>\n"

  ' --- 4. Guardar y postprocesar ---
  outputFile = File.Dir(FMain.txtProyecto.Text) & "/referencias/ref-" & File.BaseName(FMain.txtProyecto.Text) & ".xml"
  File.Save(outputFile, sXML)

  If Not AplicarReglasPostproceso(outputFile) Then
    Message.Error("Error en el postproceso del archivo XML")
    Return False
  Endif

  Return Exist(outputFile)

End

' =====================================================
' FUNCIÓN: GenerarElementCitationDesdeBib
' =====================================================
' DESCRIPCIÓN: GENERA <element-citation> COMPLETO DESDE ENTRADA BIB
' PARÁMETROS: sEntry      — TEXTO COMPLETO DE LA ENTRADA BIBTEX
'             sType       — TIPO DE ENTRADA (@article, @book, etc.)
'             dictEntries — DICCIONARIO CON TODAS LAS ENTRADAS
'             dictTypes   — DICCIONARIO CON TIPOS DE ENTRADAS
' RETORNA:    String — XML DE <element-citation>
' =====================================================
Private Function GenerarElementCitationDesdeBib(sEntry As String, sType As String, dictEntries As Collection, dictTypes As Collection) As String

  Dim sXML As String = ""
  Dim sPubType As String
  Dim sAuthor As String
  Dim sEditor As String
  Dim sEditorType As String
  Dim sEditorA As String
  Dim sEditorAType As String
  Dim sEditorB As String
  Dim sEditorBType As String
  Dim sEditorC As String
  Dim sEditorCType As String
  Dim sTranslator As String
  Dim sTitle As String
  Dim sSubtitle As String
  Dim sJournal As String
  Dim sBookTitle As String
  Dim sBookSubtitle As String
  Dim sYear As String
  Dim sDate As String
  Dim sVolume As String
  Dim sNumber As String
  Dim sPages As String
  Dim sPublisher As String
  Dim sAddress As String
  Dim sDoi As String
  Dim sIsbn As String
  Dim sIssn As String
  Dim sUrl As String
  Dim sEdition As String
  Dim sSchool As String
  Dim sInstitution As String
  Dim sNote As String
  Dim sEid As String
  Dim sEprint As String
  Dim sEprintType As String
  Dim sSeries As String
  Dim sVersion As String
  Dim sHolder As String
  Dim sMaintitle As String
  Dim sMainsubtitle As String
  Dim sBookauthor As String
  Dim aPages As String[]
  Dim sFinalYear As String
  Dim sTituloCompleto As String
  Dim sBookTitleCompleto As String
  Dim sCrossref As String
  Dim sEntryBase As String

  ' --- 0. Resolver crossref si existe ---
  sCrossref = ParsearCampoBib(sEntry, "crossref")

  If sCrossref <> "" And dictEntries.Exist(sCrossref) Then
    sEntryBase = dictEntries[sCrossref]
    If Lower(TrimUTF8(sType)) = "incollection" Then
      sEntryBase = Replace(sEntryBase, "  title ", "  booktitle ", gb.IgnoreCase)
    Endif
    sEntry = FusionarEntradas(sEntryBase, sEntry)
  Endif

  ' --- 1. Mapear tipo BibTeX → JATS publication-type ---
  Select Case Lower(TrimUTF8(sType))
    Case "periodical"
      sPubType = "newspaper"
    Case "article"
      sPubType = "journal"
    Case "book"
      sPubType = "book"
    Case "incollection", "inbook", "bookinbook", "collection"
      sPubType = "book"
    Case "phdthesis", "mastersthesis", "thesis"
      sPubType = "thesis"
    Case "misc", "online"
      Dim sHowTemp As String = Lower(Trim(ParsearCampoBib(sEntry, "howpublished")))
      Select Case sHowTemp
        Case "carta manuscrita", "carta mecanografiada", "carta", "telegrama"
          sPubType = "letter"
        Case "carta documento", "notificación oficial", "decreto", "resolución", "oficio"
          sPubType = "legal-doc"
        Case "comunicación oficial", "memorándum", "memorando"
          sPubType = "commun"
        Case Else
          If InStr(sHowTemp, "http") > 0 Or InStr(sHowTemp, "www") > 0 Then
            sPubType = "web"
          Else
            sPubType = "other"
          Endif
      End Select
    Case "conference", "inproceedings"
      sPubType = "confproc"
    Case "unpublished"
      Dim sNoteTemp As String = ParsearCampoBib(sEntry, "note")
      If InStr(Lower(sNoteTemp), "congreso") > 0 Or
          InStr(Lower(sNoteTemp), "workshop") > 0 Or
          InStr(Lower(sNoteTemp), "conferencia") > 0 Or
          InStr(Lower(sNoteTemp), "ponencia") > 0 Or
          InStr(Lower(sNoteTemp), "conference") > 0 Then
        sPubType = "confproc"
      Else
        sPubType = "other"
      Endif
    Case "report", "techreport"
      sPubType = "report"
    Case "patent"
      sPubType = "patent"
    Case "manual"
      sPubType = "book"
    Case Else
      sPubType = "other"
  End Select

  ' --- 2. Extraer campos del .bib ---
  sAuthor = ParsearCampoBib(sEntry, "author")
  sEditor = ParsearCampoBib(sEntry, "editor")
  sEditorType = ParsearCampoBib(sEntry, "editortype")
  sEditorA = ParsearCampoBib(sEntry, "editora")
  sEditorAType = ParsearCampoBib(sEntry, "editoratype")
  sEditorB = ParsearCampoBib(sEntry, "editorb")
  sEditorBType = ParsearCampoBib(sEntry, "editorbtype")
  sEditorC = ParsearCampoBib(sEntry, "editorc")
  sEditorCType = ParsearCampoBib(sEntry, "editorctype")
  sTranslator = ParsearCampoBib(sEntry, "translator")
  sTitle = ParsearCampoBib(sEntry, "title")
  sSubtitle = ParsearCampoBib(sEntry, "subtitle")

  ' JOURNAL: PRIORIZAR journaltitle SOBRE journal
  sJournal = ParsearCampoBib(sEntry, "journaltitle")
  If sJournal = "" Then sJournal = ParsearCampoBib(sEntry, "journal")

  sBookTitle = ParsearCampoBib(sEntry, "booktitle")
  sBookSubtitle = ParsearCampoBib(sEntry, "booksubtitle")

  ' AÑO: PRIORIZAR date SOBRE year
  sDate = ParsearCampoBib(sEntry, "date")
  sYear = ParsearCampoBib(sEntry, "year")
  If sDate <> "" Then
    sFinalYear = ExtraerAnio(sDate)
  Else If sYear <> "" Then
    sFinalYear = sYear
  Else
    sFinalYear = ""
  Endif

  sVolume = ParsearCampoBib(sEntry, "volume")
  sNumber = ParsearCampoBib(sEntry, "number")
  sPages = ParsearCampoBib(sEntry, "pages")
  sPublisher = ParsearCampoBib(sEntry, "publisher")

  ' LOCATION (BibLaTeX) o ADDRESS (BibTeX)
  sAddress = ParsearCampoBib(sEntry, "location")
  If sAddress = "" Then sAddress = ParsearCampoBib(sEntry, "address")

  sDoi = ParsearCampoBib(sEntry, "doi")
  sIsbn = ParsearCampoBib(sEntry, "isbn")
  sIssn = ParsearCampoBib(sEntry, "issn")
  sUrl = ParsearCampoBib(sEntry, "url")
  sEdition = ParsearCampoBib(sEntry, "edition")
  sSchool = ParsearCampoBib(sEntry, "school")
  sInstitution = ParsearCampoBib(sEntry, "institution")
  sNote = ParsearCampoBib(sEntry, "note")
  sEid = ParsearCampoBib(sEntry, "eid")
  sEprint = ParsearCampoBib(sEntry, "eprint")
  sEprintType = ParsearCampoBib(sEntry, "eprinttype")
  sSeries = ParsearCampoBib(sEntry, "series")
  sVersion = ParsearCampoBib(sEntry, "version")
  sHolder = ParsearCampoBib(sEntry, "holder")
  sMaintitle = ParsearCampoBib(sEntry, "maintitle")
  sMainsubtitle = ParsearCampoBib(sEntry, "mainsubtitle")
  sBookauthor = ParsearCampoBib(sEntry, "bookauthor")

  ' --- 3. Abrir <element-citation> ---
  sXML &= "    <element-citation publication-type=\"" & sPubType & "\">\n"

  ' --- 4. Person-groups ---
  If sAuthor <> "" Then sXML &= GenerarPersonGroup(sAuthor, "author")

  If sEditor <> "" Then
    Dim sTipoEditor As String = MapearTipoEditor(sEditorType)
    sXML &= GenerarPersonGroup(sEditor, sTipoEditor)
  Endif
  If sEditorA <> "" Then
    Dim sTipoEditorA As String = MapearTipoEditor(sEditorAType)
    sXML &= GenerarPersonGroup(sEditorA, sTipoEditorA)
  Endif
  If sEditorB <> "" Then
    Dim sTipoEditorB As String = MapearTipoEditor(sEditorBType)
    sXML &= GenerarPersonGroup(sEditorB, sTipoEditorB)
  Endif
  If sEditorC <> "" Then
    Dim sTipoEditorC As String = MapearTipoEditor(sEditorCType)
    sXML &= GenerarPersonGroup(sEditorC, sTipoEditorC)
  Endif
  If sTranslator <> "" Then sXML &= GenerarPersonGroup(sTranslator, "translator")

  ' --- 5. Títulos ---
  sTituloCompleto = If(sSubtitle <> "", sTitle & ": " & sSubtitle, sTitle)
  sBookTitleCompleto = If(sBookSubtitle <> "", sBookTitle & ": " & sBookSubtitle, sBookTitle)

  If sBookTitleCompleto <> "" Then
    If sTituloCompleto <> "" Then
      sXML &= "      <chapter-title>" & sTituloCompleto & "</chapter-title>\n"
    Endif
    sXML &= "      <source>" & sBookTitleCompleto & "</source>\n"
  Else
    If sTituloCompleto <> "" Then
      Select Case sPubType
        Case "journal", "newspaper"
          sXML &= "      <article-title>" & sTituloCompleto & "</article-title>\n"
        Case Else
          sXML &= "      <source>" & sTituloCompleto & "</source>\n"
      End Select
    Endif
  Endif

  If sJournal <> "" And (sPubType = "journal" Or sPubType = "newspaper") Then
    sXML &= "      <source>" & sJournal & "</source>\n"
  Endif

  If sSeries <> "" And (sPubType = "book" Or InStr(Lower(sType), "collection") > 0) Then
    sXML &= "      <series>" & sSeries & "</series>\n"
  Endif

  ' --- 6. Publisher y ubicación ---
  If sPublisher <> "" Then sXML &= "      <publisher-name>" & sPublisher & "</publisher-name>\n"
  If sAddress <> "" Then sXML &= "      <publisher-loc>" & sAddress & "</publisher-loc>\n"

  ' --- 7. Año, volumen, número ---
  If sFinalYear <> "" Then sXML &= "      <year>" & sFinalYear & "</year>\n"
  If sVolume <> "" Then sXML &= "      <volume>" & sVolume & "</volume>\n"

  If sNumber <> "" Then
    Select Case sPubType
      Case "patent"
        sXML &= "      <patent>" & sNumber & "</patent>\n"
      Case "report"
        sXML &= "      <pub-id pub-id-type=\"report-number\">" & sNumber & "</pub-id>\n"
      Case Else
        sXML &= "      <issue>" & sNumber & "</issue>\n"
    End Select
  Endif

  ' --- 8. Paginación o elocation-id ---
  If sEid <> "" Then
    sXML &= "      <elocation-id>" & sEid & "</elocation-id>\n"
  Else If sPages <> "" Then
    If InStr(sPages, "--") > 0 Then
      aPages = Split(sPages, "--")
    Else If InStr(sPages, "-") > 0 Then
      aPages = Split(sPages, "-")
    Else
      sXML &= "      <fpage>" & TrimUTF8(sPages) & "</fpage>\n"
      sXML &= "      <lpage>" & TrimUTF8(sPages) & "</lpage>\n"
      aPages = Null
    Endif
    If aPages Then
      If aPages.Count >= 2 Then
        sXML &= "      <fpage>" & TrimUTF8(aPages[0]) & "</fpage>\n"
        sXML &= "      <lpage>" & TrimUTF8(aPages[1]) & "</lpage>\n"
      Else If aPages.Count = 1 Then
        sXML &= "      <fpage>" & TrimUTF8(aPages[0]) & "</fpage>\n"
        sXML &= "      <lpage>" & TrimUTF8(aPages[0]) & "</lpage>\n"
      Endif
    Endif
  Endif

  ' --- 9. Edición, institución, nota ---
  If sEdition <> "" Then sXML &= "      <edition>" & sEdition & "</edition>\n"

  If sPubType = "thesis" Or sPubType = "report" Then
    If sInstitution <> "" Then
      sXML &= "      <institution>" & sInstitution & "</institution>\n"
    Else If sSchool <> "" Then
      sXML &= "      <institution>" & sSchool & "</institution>\n"
    Endif
  Endif

  If sNote <> "" Then sXML &= "      <comment>" & sNote & "</comment>\n"
  If sVersion <> "" And sPubType = "web" Then
    sXML &= "      <comment>Version " & sVersion & "</comment>\n"
  Endif

  If sHolder <> "" And sPubType = "patent" Then
    Dim sHolderLimpio As String
    sHolderLimpio = Replace(sHolder, "{{", "")
    sHolderLimpio = Replace(sHolderLimpio, "}}", "")
    sHolderLimpio = Replace(sHolderLimpio, "{", "")
    sHolderLimpio = Replace(sHolderLimpio, "}", "")
    sHolderLimpio = Replace(sHolderLimpio, " and ", ", ")
    sXML &= "      <comment>Patent holder: " & sHolderLimpio & "</comment>\n"
  Endif

  ' --- 10. Identificadores ---
  If sIsbn <> "" Then sXML &= "      <isbn>" & sIsbn & "</isbn>\n"
  If sIssn <> "" Then sXML &= "      <issn>" & sIssn & "</issn>\n"
  If sDoi <> "" Then sXML &= "      <pub-id pub-id-type=\"doi\">" & sDoi & "</pub-id>\n"
  If sEprint <> "" Then
    If sEprintType <> "" Then sEprintType = Lower(sEprintType)
    sXML &= "      <pub-id pub-id-type=\"" & sEprintType & "\">" & sEprint & "</pub-id>\n"
  Endif
  If sUrl <> "" Then
    sXML &= "      <ext-link ext-link-type=\"uri\" xlink:href=\"" & sUrl & "\">" & sUrl & "</ext-link>\n"
  Endif

  sXML &= "    </element-citation>\n"

  Return sXML

End

' =====================================================
' FUNCIÓN: ParsearCampoBib
' =====================================================
' DESCRIPCIÓN: EXTRAE EL VALOR DE UN CAMPO DEL BIB SIN LIMPIAR
' PARÁMETROS: sEntry — TEXTO COMPLETO DE LA ENTRADA BIBTEX
'             sCampo — NOMBRE DEL CAMPO A EXTRAER
' RETORNA:    String — VALOR DEL CAMPO (vacío si no existe)
' =====================================================
Private Function ParsearCampoBib(sEntry As String, sCampo As String) As String

  Dim iStart As Integer
  Dim iEnd As Integer
  Dim sValor As String = ""
  Dim sPatron As String

  ' PATRÓN 1: campo = {valor}
  sPatron = sCampo & " = {"
  iStart = InStr(sEntry, sPatron)

  ' PATRÓN 2: campo={valor}
  If iStart = 0 Then
    sPatron = sCampo & "={"
    iStart = InStr(sEntry, sPatron)
  Endif

  ' PATRÓN 3: buscar por líneas (algunos formatos no estándar)
  If iStart = 0 Then
    Dim aLineas As String[] = Split(sEntry, "\n")
    Dim sLinea As String

    For Each sLinea In aLineas
      sLinea = TrimUTF8(sLinea)
      If Left(sLinea, Len(sCampo)) = sCampo Then
        iStart = InStr(sLinea, "{")
        If iStart > 0 Then
          iEnd = EncontrarLlaveCorrespondiente(sLinea, iStart + 1)
          If iEnd > 0 Then
            sValor = Mid(sLinea, iStart + 1, iEnd - iStart - 1)
            Return TrimUTF8(sValor)
          Endif
        Endif
      Endif
    Next
    Return ""
  Endif

  iStart = iStart + Len(sPatron)
  iEnd = EncontrarLlaveCorrespondiente(sEntry, iStart)
  If iEnd = 0 Then Return ""

  sValor = Mid(sEntry, iStart, iEnd - iStart)
  Return TrimUTF8(sValor)

End

' =====================================================
' FUNCIÓN: FusionarEntradas
' =====================================================
' DESCRIPCIÓN: FUSIONA DOS ENTRADAS BIB PARA RESOLVER crossref.
'              LOS CAMPOS DE sEntryActual TIENEN PRIORIDAD.
' PARÁMETROS: sEntryBase   — ENTRADA BASE (referenciada)
'             sEntryActual — ENTRADA ACTUAL (tiene prioridad)
' RETORNA:    String — ENTRADA FUSIONADA
' =====================================================
Private Function FusionarEntradas(sEntryBase As String, sEntryActual As String) As String

  Dim aLineasBase As String[]
  Dim aLineasActual As String[]
  Dim dictCampos As New Collection
  Dim sLinea As String
  Dim sCampo As String
  Dim iPosIgual As Integer
  Dim sResultado As String
  Dim sPrimeraLinea As String
  Dim i As Integer

  ' --- 1. Parsear entrada base ---
  aLineasBase = Split(sEntryBase, "\n")
  For i = 0 To aLineasBase.Max
    sLinea = aLineasBase[i]
    If Len(Trim(sLinea)) = 0 Then Continue
    If Trim(sLinea) = "}" Then Continue
    iPosIgual = InStr(sLinea, "=")
    If iPosIgual = 0 Then Continue
    sCampo = Trim(Left(sLinea, iPosIgual - 1))
    If InStr(sCampo, "{") > 0 Then Continue
    sCampo = Lower(sCampo)
    dictCampos[sCampo] = sLinea
  Next

  ' --- 2. Parsear entrada actual y sobrescribir ---
  aLineasActual = Split(sEntryActual, "\n")
  sPrimeraLinea = aLineasActual[0]

  For i = 0 To aLineasActual.Max
    sLinea = aLineasActual[i]
    If Len(Trim(sLinea)) = 0 Then Continue
    If Trim(sLinea) = "}" Then Continue
    iPosIgual = InStr(sLinea, "=")
    If iPosIgual = 0 Then Continue
    sCampo = Trim(Left(sLinea, iPosIgual - 1))
    If InStr(sCampo, "{") > 0 Then Continue
    sCampo = Lower(sCampo)
    If sCampo = "crossref" Then Continue
    dictCampos[sCampo] = sLinea
  Next

  ' --- 3. Reconstruir entrada ---
  sResultado = sPrimeraLinea & "\n"
  Dim aKeys As String[] = dictCampos.Keys
  For i = 0 To aKeys.Max
    sCampo = aKeys[i]
    sResultado &= dictCampos[sCampo] & "\n"
  Next
  sResultado &= "}\n"

  Return sResultado

End

' =====================================================
' FUNCIÓN: AplicarReglasPostproceso
' =====================================================
' DESCRIPCIÓN: EJECUTA EL SCRIPT PYTHON DE POSTPROCESO SOBRE
'              EL ARCHIVO XML EXPORTADO
' PARÁMETROS: sXmlFile — RUTA COMPLETA AL ARCHIVO XML
' RETORNA:    Boolean — True si exitoso
' =====================================================
Public Function AplicarReglasPostproceso(sXmlFile As String) As Boolean

  Dim sScriptPython As String
  Dim sComando As String

  If Not Exist(sXmlFile) Then
    Message.Error("El archivo XML no existe: " & sXmlFile)
    Return False
  Endif

  sScriptPython = User.Home &/ ".gbpublisher/filters/postprocesar_jats.py"

  If Not Exist(sScriptPython) Then
    Message.Warning("No se encontró el script de postproceso: " & sScriptPython & "\nNo se aplicará postproceso.")
    Return True
  Endif

  sComando = "python3 '" & sScriptPython & "' '" & sXmlFile & "'" & "\n"
  FMain.TerminalViewProyecto.Input(sComando)
  Wait 0.5
  FMain.TerminalViewProyecto.Input("clear" & "\n")

  Return True

Catch
  Message.Error("Error en postproceso:\n" & Error.Text)
  Return False

End Function

' =====================================================
' FUNCIÓN: TrimUTF8
' =====================================================
' DESCRIPCIÓN: ELIMINA ESPACIOS ASCII (0x20) AL INICIO Y FINAL
'              SIN CORROMPER CARACTERES UTF-8 MULTIBYTE.
'              Trim() DE GAMBAS ELIMINA BYTES 0xA0 QUE SON PARTE
'              DE SECUENCIAS UTF-8 VÁLIDAS (ej: à = 0xC3 0xA0)
' PARÁMETROS: sTexto — CADENA A PROCESAR
' RETORNA:    String — CADENA SIN ESPACIOS ASCII AL INICIO/FINAL
' =====================================================
Public Function TrimUTF8(sTexto As String) As String

  Dim iStart As Integer
  Dim iEnd As Integer
  Dim iByte As Integer

  If Not sTexto Then Return ""

  iStart = 1
  iEnd = Len(sTexto)

  While iStart <= iEnd
    iByte = Asc(Mid(sTexto, iStart, 1))
    If iByte <> 32 Then Break
    iStart += 1
  Wend

  While iEnd >= iStart
    iByte = Asc(Mid(sTexto, iEnd, 1))
    If iByte <> 32 Then Break
    iEnd -= 1
  Wend

  If iStart > iEnd Then
    Return ""
  Else
    Return Mid(sTexto, iStart, iEnd - iStart + 1)
  Endif

End Function

' =====================================================
' FUNCIÓN AUXILIAR: MapearTipoEditor
' =====================================================
' DESCRIPCIÓN: MAPEA TIPOS DE EDITOR BIBLATEX A JATS
' PARÁMETROS: sTipoBibLaTeX — TIPO DE EDITOR EN BIBLATEX
' RETORNA:    String — TIPO DE PERSON-GROUP EN JATS
' =====================================================
Private Function MapearTipoEditor(sTipoBibLaTeX As String) As String

  If sTipoBibLaTeX = "" Then Return "editor"

  Select Case Lower(sTipoBibLaTeX)
    Case "editor"
      Return "editor"
    Case "compiler"
      Return "compiler"
    Case "translator"
      Return "translator"
    Case "organizer"
      Return "editor"
    Case Else
      Return "editor"
  End Select

End

' =====================================================
' FUNCIÓN AUXILIAR PRIVADA: ConvertirMesANumero
' =====================================================
' DESCRIPCIÓN: CONVIERTE NOMBRE DE MES (ESPAÑOL O NÚMERO) A
'              CADENA NUMÉRICA DE DOS DÍGITOS PARA XML-JATS
' PARÁMETROS: sMes — Nombre del mes, abreviatura, o número
' RETORNA:    String — "01".."12", vacío si no reconoce
' =====================================================
Private Function ConvertirMesANumero(sMes As String) As String

  Dim sLower As String = Lower(TrimUTF8(sMes))

  Select Case sLower
    Case "enero", "january", "jan"
      Return "01"
    Case "febrero", "february", "feb"
      Return "02"
    Case "marzo", "march", "mar"
      Return "03"
    Case "abril", "april", "apr"
      Return "04"
    Case "mayo", "may"
      Return "05"
    Case "junio", "june", "jun"
      Return "06"
    Case "julio", "july", "jul"
      Return "07"
    Case "agosto", "august", "aug"
      Return "08"
    Case "septiembre", "setiembre", "september", "sep", "sept"
      Return "09"
    Case "octubre", "october", "oct"
      Return "10"
    Case "noviembre", "november", "nov"
      Return "11"
    Case "diciembre", "december", "dec"
      Return "12"
    Case Else
      If Val(sMes) >= 1 And Val(sMes) <= 12 Then
        Return Right("0" & CStr(Int(Val(sMes))), 2)
      Endif
      Return ""
  End Select

End Function

' =====================================================
' FUNCIÓN AUXILIAR PRIVADA: GenerarElementoFecha
' =====================================================
' DESCRIPCIÓN: GENERA UN ELEMENTO <date date-type="..."> PARA
'              EL BLOQUE <history> DE JATS 1.4
' PARÁMETROS: sTipo  — Valor del atributo date-type
'             sFecha — Fecha en formato ISO "YYYY-MM-DD"
' RETORNA:    String — elemento XML completo
' =====================================================
Private Function GenerarElementoFecha(sTipo As String, sFecha As String) As String

  Dim sXML As String
  Dim aPartes As String[]

  sFecha = TrimUTF8(sFecha)
  If sFecha = "" Then Return ""

  aPartes = Split(sFecha, "-")

  sXML = "      <date date-type=\"" & sTipo & "\">\n"

  ' ORDEN CORRECTO SEGÚN DTD JATS 1.4: day? month? year?
  If aPartes.Count >= 3 Then
    If TrimUTF8(aPartes[2]) <> "" Then
      sXML &= "        <day>" & TrimUTF8(aPartes[2]) & "</day>\n"
    Endif
  Endif
  If aPartes.Count >= 2 Then
    If TrimUTF8(aPartes[1]) <> "" Then
      sXML &= "        <month>" & TrimUTF8(aPartes[1]) & "</month>\n"
    Endif
  Endif
  If aPartes.Count >= 1 Then
    If TrimUTF8(aPartes[0]) <> "" Then
      sXML &= "        <year>" & TrimUTF8(aPartes[0]) & "</year>\n"
    Endif
  Endif

  sXML &= "      </date>\n"

  Return sXML

End Function

' =====================================================
' FUNCIÓN AUXILIAR PRIVADA: GenerarKwdGroup
' =====================================================
' DESCRIPCIÓN: GENERA UN BLOQUE <kwd-group> JATS A PARTIR DE
'              UNA CADENA DE PALABRAS CLAVE SEPARADAS POR , O ;
' PARÁMETROS: sKwds   — cadena con palabras clave
'             sIdioma — código ISO de idioma (ej: "es", "en")
' RETORNA:    String — bloque <kwd-group> completo
' =====================================================
Private Function GenerarKwdGroup(sKwds As String, sIdioma As String) As String

  Dim sXML As String
  Dim aKwds As String[]
  Dim sKwd As String

  sKwds = TrimUTF8(sKwds)
  If sKwds = "" Then Return ""

  ' NORMALIZAR SEPARADOR
  sKwds = Replace(sKwds, ";", ",")
  aKwds = Split(sKwds, ",")
  If aKwds.Count = 0 Then Return ""

  sXML = "    <kwd-group xml:lang=\"" & sIdioma & "\" kwd-group-type=\"author-generated\">\n"

  For Each sKwd In aKwds
    sKwd = TrimUTF8(sKwd)
    If sKwd <> "" Then
      sXML &= "      <kwd>" & EscaparXML(sKwd) & "</kwd>\n"
    Endif
  Next

  sXML &= "    </kwd-group>\n"

  Return sXML

End Function

' =====================================================
' FUNCIÓN: ObtenerIdRevista
' =====================================================
' DESCRIPCIÓN: OBTIENE EL id_revista CORRESPONDIENTE A UN
'              PROYECTO (RELACIÓN 1 A 1 proyecto → número de revista)
' PARÁMETROS: iIdProyecto — ID DEL PROYECTO A CONSULTAR
' RETORNA:    Integer > 0 si se encontró, 0 si no tiene revista
' =====================================================
Public Function ObtenerIdRevista(iIdProyecto As Integer) As Integer

  Dim hResult As Result

  Try hResult = m_ConexionBD.mConn.Exec(
    "SELECT id_revista FROM revistas_md WHERE id_proyecto = &1 LIMIT 1",
    iIdProyecto)

  If Error Then
    Message.Error("Error al obtener la revista del proyecto:" & Chr(10) & Error.Text)
    Return 0
  Endif

  If hResult.Available Then
    Return hResult["id_revista"]
  Endif

  Return 0

Catch
  Message.Error("Error inesperado en ObtenerIdRevista:" & Chr(10) & Error.Text)
  Return 0

End Function

' ============================================
' Función   : GenerarRelatedArticle
' Propósito : Genera el elemento <related-article> de JATS 1.4
'             a partir de los campos related_article_* de articulos.
'
'             POSICIÓN EN article-meta SEGÚN DTD JATS 1.4:
'             después de <permissions> y antes de <abstract>.
'             GenerarFrontXML() lo llama en el Paso 5.8b.
'
'             ATRIBUTOS VÁLIDOS EN DTD JATS 1.4:
'             related-article-type, xlink:href, ext-link-type,
'             journal-id, journal-id-type, vol, issue.
'             publication-year, fpage y lpage NO están declarados
'             en la DTD y causan error de validación — se omiten.
'
' Parámetros: hArticulo As Result — datos del artículo (SELECT *)
' Retorna   : String — elemento XML, vacío si no hay tipo relacionado
' ============================================
Private Function GenerarRelatedArticle(hArticulo As Result) As String

  Dim sType As String
  Dim sDoi As String
  Dim sJournal As String
  Dim sVolume As String
  Dim sIssue As String
  Dim sXML As String
  Dim sAtributos As String

  ' --- 1. Leer campos — solo los válidos en DTD JATS 1.4 ---
  sType = If(IsNull(hArticulo["related_article_type"]), "", TrimUTF8(hArticulo["related_article_type"]))
  sDoi = If(IsNull(hArticulo["related_article_doi"]), "", TrimUTF8(hArticulo["related_article_doi"]))
  sJournal = If(IsNull(hArticulo["related_article_journal"]), "", TrimUTF8(hArticulo["related_article_journal"]))
  sVolume = If(IsNull(hArticulo["related_article_volume"]), "", TrimUTF8(hArticulo["related_article_volume"]))
  sIssue = If(IsNull(hArticulo["related_article_issue"]), "", TrimUTF8(hArticulo["related_article_issue"]))

  ' NOTA: related_article_anio, related_article_fpage y related_article_lpage
  ' SE CONSERVAN EN LA BD PARA USO EDITORIAL INTERNO PERO NO SE EMITEN
  ' AL XML PORQUE publication-year, fpage y lpage NO SON ATRIBUTOS
  ' VÁLIDOS DE related-article EN LA DTD JATS 1.4

  ' --- 2. Sin tipo no hay elemento ---
  If sType = "" Then Return ""

  ' --- 3. Construir atributos válidos ---
  sAtributos = "related-article-type=\"" & EscaparXML(sType) & "\""

  ' DOI → xlink:href + ext-link-type
  If sDoi <> "" Then
    sAtributos &= " xlink:href=\"https://doi.org/" & EscaparXML(sDoi) & "\""
    sAtributos &= " ext-link-type=\"doi\""
  Endif

  ' REVISTA EXTERNA → journal-id + journal-id-type
  If sJournal <> "" Then
    sAtributos &= " journal-id=\"" & EscaparXML(sJournal) & "\""
    sAtributos &= " journal-id-type=\"custom\""
  Endif

  ' DATOS BIBLIOGRÁFICOS VÁLIDOS EN DTD JATS 1.4
  If sVolume <> "" Then sAtributos &= " vol=\"" & EscaparXML(sVolume) & "\""
  If sIssue <> "" Then sAtributos &= " issue=\"" & EscaparXML(sIssue) & "\""

  ' --- 4. Elemento vacío (JATS spec: related-article no tiene contenido) ---
  sXML = "    <related-article " & sAtributos & "/>\n"

  Return sXML

End Function

' =====================================================
' FUNCIÓN PRINCIPAL: GenerarFrontXML
' =====================================================
' DESCRIPCIÓN:
'   Genera el fragmento <front> de JATS 1.4 para un artículo,
'   consultando las tablas revistas_md, articulos, articulo_autor
'   y autores. El archivo resultante se escribe en:
'     {proyecto}/tmp/front-{nombre}.xml
'   y es consumido por ensamblar-canonico.xsl.
'
'   ESTRUCTURA DE article-meta (orden DTD JATS 1.4):
'     article-id → article-categories → title-group →
'     contrib-group → pub-date → volume → issue →
'     fpage/lpage → history → permissions →
'     related-article → abstract → trans-abstract →
'     kwd-group → funding-group → custom-meta-group
'
'   NOTA SOBRE id EN <contrib>:
'     Cada <contrib> recibe id="a{id_autor}" (prefijo 'a'
'     obligatorio porque XML ID no puede empezar con dígito).
'     Este atributo permite que GenerarMetaArticuloXML()
'     cruce autores entre el JATS y el XML auxiliar de metadatos
'     por identificador en lugar de por posición.
'
' RETORNA: True si front.xml se generó y existe en disco
' =====================================================
Public Function GenerarFrontXML(iIdArticulo As Integer, iIdRevista As Integer) As Boolean

  ' ====================================================
  ' DECLARACIÓN DE TODAS LAS VARIABLES
  ' ====================================================

  Dim hRevista As Result
  Dim hArticulo As Result
  Dim hAutores As Result
  Dim sXML As String
  Dim sDirTmp As String
  Dim sFilePath As String
  Dim sNombreBase As String

  ' VARIABLES PARA DATOS DE REVISTA
  Dim sEditorial As String
  Dim sLocPublisher As String

  ' VARIABLES PARA DATOS DE ARTÍCULO
  Dim sIdiomaPrincipal As String
  Dim sFechaPub As String
  Dim aFechaPub As String[]
  Dim sMesPub As String
  Dim bTieneHistory As Boolean
  Dim sCopyrightYear As String
  Dim sCopyrightHolder As String
  Dim sLicencia As String
  Dim sUrlLicencia As String

  ' VARIABLES PARA EL LOOP DE AUTORES
  Dim sContribType As String
  Dim sAfil As String
  Dim sDept As String
  Dim sCiudadAfil As String
  Dim sPaisAfil As String
  Dim sEmail As String

  ' IDs LEÍDOS DIRECTAMENTE DESDE LOS VALUEBOX DE FMain
  iIdRevista = CInt(FMain.id_revista.Value)
  iIdArticulo = CInt(FMain.id_articulo.Value)

  ' ====================================================
  ' PASO 0: PREPARAR DIRECTORIO TEMPORAL
  ' ====================================================
  sDirTmp = File.Dir(FMain.txtProyecto.Text) & "/tmp"

  ' ====================================================
  ' PASO 1: CONSULTAR DATOS DE LA REVISTA
  ' ====================================================
  Try hRevista = m_ConexionBD.mConn.Exec(
    "SELECT * FROM revistas_md WHERE id_revista = &1 LIMIT 1", iIdRevista)

  If Error Then
    Message.Error("Error al consultar la revista:" & Chr(10) & Error.Text)
    Return False
  Endif

  If Not hRevista.Available Then
    Message.Error("No se encontraron datos para la revista id=" & CStr(iIdRevista))
    Return False
  Endif

  ' ====================================================
  ' PASO 2: CONSULTAR DATOS DEL ARTÍCULO
  ' LAS FECHAS SE PIDEN EN FORMATO ISO YYYY-MM-DD
  ' MEDIANTE DATE_FORMAT() PARA EVITAR PROBLEMAS DE
  ' LOCALIZACIÓN EN LA CONVERSIÓN DE GAMBAS
  ' ====================================================
  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT *, " &
    "DATE_FORMAT(fecha_publicacion_completa, '%Y-%m-%d') AS fecha_pub_iso, " &
    "DATE_FORMAT(fecha_recepcion,            '%Y-%m-%d') AS fecha_rec_iso, " &
    "DATE_FORMAT(fecha_revision,             '%Y-%m-%d') AS fecha_rev_iso, " &
    "DATE_FORMAT(fecha_aceptacion,           '%Y-%m-%d') AS fecha_ace_iso, " &
    "DATE_FORMAT(fecha_publicacion_online,   '%Y-%m-%d') AS fecha_online_iso " &
    "FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif

  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  ' ====================================================
  ' NOMBRE DEL ARCHIVO DE SALIDA
  ' "a-01-revista-v19-n37" → "front-01-revista-v19-n37"
  ' ====================================================
  sNombreBase = TrimUTF8(hArticulo["nombre_archivo"])
  sNombreBase = "front-" & Mid(sNombreBase, 3)
  sFilePath = sDirTmp & "/" & sNombreBase & ".xml"

  ' ====================================================
  ' PASO 3: CONSULTAR AUTORES
  ' JOIN articulo_autor + autores CON PRIORIDAD _momento
  ' SOBRE DATOS ACTUALES DEL AUTOR
  ' ====================================================
  Try hAutores = m_ConexionBD.mConn.Exec(
    "SELECT a.id_autor, a.apellidos, a.nombre, a.sufijo, a.orcid, " &
    "a.afiliacion_actual, a.departamento, a.ciudad_afiliacion, a.pais_afiliacion, " &
    "a.email_principal, a.email_correspondencia, " &
    "aa.orden_autoria, aa.rol_autor, aa.es_autor_correspondencia, " &
    "aa.afiliacion_momento, aa.departamento_momento, aa.ciudad_momento, " &
    "aa.pais_momento, aa.email_momento " &
    "FROM autores a " &
    "INNER JOIN articulo_autor aa ON a.id_autor = aa.id_autor " &
    "WHERE aa.id_articulo = &1 " &
    "ORDER BY aa.orden_autoria ASC",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar autores del artículo:" & Chr(10) & Error.Text)
    Return False
  Endif

  ' ====================================================
  ' PASO 4: DETERMINAR IDIOMA PRINCIPAL
  ' NORMALIZAR VALORES LIBRES A CÓDIGOS ISO 639-1
  ' ====================================================
  sIdiomaPrincipal = "es"
  If Not IsNull(hArticulo["idioma_principal"]) Then
    Select Case Lower(TrimUTF8(hArticulo["idioma_principal"]))
      Case "es", "spa", "español", "spanish", "castellano"
        sIdiomaPrincipal = "es"
      Case "en", "eng", "inglés", "ingles", "english"
        sIdiomaPrincipal = "en"
      Case "pt", "por", "portugués", "portugues", "portuguese"
        sIdiomaPrincipal = "pt"
      Case "fr", "fra", "francés", "frances", "french"
        sIdiomaPrincipal = "fr"
      Case Else
        If Len(TrimUTF8(hArticulo["idioma_principal"])) > 0 Then
          sIdiomaPrincipal = TrimUTF8(hArticulo["idioma_principal"])
        Endif
    End Select
  Endif

  ' ====================================================
  ' PASO 5: CONSTRUIR XML
  ' ====================================================
  sXML = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  sXML &= "<front xmlns:xlink=\"http://www.w3.org/1999/xlink\">\n"

  ' --------------------------------------------------
  ' PASO 5.1: JOURNAL-META
  ' --------------------------------------------------
  sXML &= "  <journal-meta>\n"

  If Not IsNull(hRevista["e_issn"]) Then
    If Len(TrimUTF8(hRevista["e_issn"])) > 0 Then
      sXML &= "    <journal-id journal-id-type=\"publisher-id\">" & EscaparXML(TrimUTF8(hRevista["e_issn"])) & "</journal-id>\n"
    Endif
  Endif

  sXML &= "    <journal-title-group>\n"
  sXML &= "      <journal-title>" & EscaparXML(TrimUTF8(hRevista["titulo_revista"])) & "</journal-title>\n"
  If Not IsNull(hRevista["titulo_abreviado"]) Then
    If Len(TrimUTF8(hRevista["titulo_abreviado"])) > 0 Then
      sXML &= "      <abbrev-journal-title abbrev-type=\"publisher\">" & EscaparXML(TrimUTF8(hRevista["titulo_abreviado"])) & "</abbrev-journal-title>\n"
    Endif
  Endif
  sXML &= "    </journal-title-group>\n"

  If Not IsNull(hRevista["issn_impreso"]) Then
    If Len(TrimUTF8(hRevista["issn_impreso"])) > 0 Then
      sXML &= "    <issn pub-type=\"ppub\">" & EscaparXML(TrimUTF8(hRevista["issn_impreso"])) & "</issn>\n"
    Endif
  Endif
  If Not IsNull(hRevista["e_issn"]) Then
    If Len(TrimUTF8(hRevista["e_issn"])) > 0 Then
      sXML &= "    <issn pub-type=\"epub\">" & EscaparXML(TrimUTF8(hRevista["e_issn"])) & "</issn>\n"
    Endif
  Endif

  sXML &= "    <publisher>\n"

  ' NOMBRE: PRIORIZAR editorial SOBRE institucion_editora
  sEditorial = ""
  If Not IsNull(hRevista["editorial"]) Then
    If Len(TrimUTF8(hRevista["editorial"])) > 0 Then
      sEditorial = TrimUTF8(hRevista["editorial"])
    Endif
  Endif
  If sEditorial = "" Then
    If Not IsNull(hRevista["institucion_editora"]) Then
      If Len(TrimUTF8(hRevista["institucion_editora"])) > 0 Then
        sEditorial = TrimUTF8(hRevista["institucion_editora"])
      Endif
    Endif
  Endif
  If sEditorial <> "" Then
    sXML &= "      <publisher-name>" & EscaparXML(sEditorial) & "</publisher-name>\n"
  Endif

  sLocPublisher = ""
  If Not IsNull(hRevista["ciudad_publicacion"]) Then
    If Len(TrimUTF8(hRevista["ciudad_publicacion"])) > 0 Then
      sLocPublisher = TrimUTF8(hRevista["ciudad_publicacion"])
    Endif
  Endif
  If Not IsNull(hRevista["pais_publicacion"]) Then
    If Len(TrimUTF8(hRevista["pais_publicacion"])) > 0 Then
      If sLocPublisher <> "" Then
        sLocPublisher &= ", " & TrimUTF8(hRevista["pais_publicacion"])
      Else
        sLocPublisher = TrimUTF8(hRevista["pais_publicacion"])
      Endif
    Endif
  Endif
  If sLocPublisher <> "" Then
    sXML &= "      <publisher-loc>" & EscaparXML(sLocPublisher) & "</publisher-loc>\n"
  Endif

  sXML &= "    </publisher>\n"
  sXML &= "  </journal-meta>\n"

  ' --------------------------------------------------
  ' PASO 5.2: ARTICLE-META — IDENTIFICADORES
  ' --------------------------------------------------
  sXML &= "  <article-meta>\n"

  If Not IsNull(hArticulo["doi"]) Then
    If Len(TrimUTF8(hArticulo["doi"])) > 0 Then
      sXML &= "    <article-id pub-id-type=\"doi\">" & EscaparXML(TrimUTF8(hArticulo["doi"])) & "</article-id>\n"
    Endif
  Endif
  If Not IsNull(hArticulo["pmid"]) Then
    If Len(TrimUTF8(hArticulo["pmid"])) > 0 Then
      sXML &= "    <article-id pub-id-type=\"pmid\">" & EscaparXML(TrimUTF8(hArticulo["pmid"])) & "</article-id>\n"
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.3: ARTICLE-CATEGORIES
  ' --------------------------------------------------
  If Not IsNull(hArticulo["tipo_articulo"]) Then
    If Len(TrimUTF8(hArticulo["tipo_articulo"])) > 0 Then
      sXML &= "    <article-categories>\n"
      sXML &= "      <subj-group subj-group-type=\"heading\">\n"
      sXML &= "        <subject>" & EscaparXML(TrimUTF8(hArticulo["tipo_articulo"])) & "</subject>\n"
      sXML &= "      </subj-group>\n"
      sXML &= "    </article-categories>\n"
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.4: TITLE-GROUP
  ' --------------------------------------------------
  sXML &= "    <title-group>\n"
  sXML &= "      <article-title>" & EscaparXML(TrimUTF8(hArticulo["titulo_articulo"])) & "</article-title>\n"

  If Not IsNull(hArticulo["subtitulo"]) Then
    If Len(TrimUTF8(hArticulo["subtitulo"])) > 0 Then
      sXML &= "      <subtitle>" & EscaparXML(TrimUTF8(hArticulo["subtitulo"])) & "</subtitle>\n"
    Endif
  Endif

  If Not IsNull(hArticulo["titulo_traducido"]) Then
    If Len(TrimUTF8(hArticulo["titulo_traducido"])) > 0 Then
      Dim sIdiomaTraducido As String = ""
      If Not IsNull(hArticulo["idioma_titulo_traducido"]) Then
        sIdiomaTraducido = TrimUTF8(hArticulo["idioma_titulo_traducido"])
      Endif
      If sIdiomaTraducido <> "" Then
        sXML &= "      <trans-title-group xml:lang=\"" & sIdiomaTraducido & "\">\n"
        sXML &= "        <trans-title>" & EscaparXML(TrimUTF8(hArticulo["titulo_traducido"])) & "</trans-title>\n"
        sXML &= "      </trans-title-group>\n"
      Endif
    Endif
  Endif

  sXML &= "    </title-group>\n"

  ' --------------------------------------------------
  ' PASO 5.5: CONTRIB-GROUP (autores)
  ' CADA <contrib> RECIBE id="a{id_autor}" PARA QUE
  ' GenerarMetaArticuloXML() PUEDA CRUZAR POR IDENTIFICADOR
  ' EL PREFIJO 'a' ES OBLIGATORIO: XML ID NO PUEDE EMPEZAR CON DÍGITO
  ' --------------------------------------------------
  If hAutores.Available Then
    sXML &= "    <contrib-group>\n"

    While hAutores.Available

      ' TIPO DE CONTRIBUCIÓN
      sContribType = "author"
      If Not IsNull(hAutores["rol_autor"]) Then
        Select Case TrimUTF8(hAutores["rol_autor"])
          Case "editor"
            sContribType = "editor"
          Case "traductor"
            sContribType = "translator"
          Case Else
            sContribType = "author"
        End Select
      Endif

      ' ATRIBUTOS DEL <contrib>
      ' Chr(34) GARANTIZA COMILLAS ASCII — LA CONCATENACIÓN CON """
      ' FALLA EN LÍNEAS MÚLTIPLES EN GAMBAS
      Dim q As String = Chr(34)
      Dim sIdAutor As String = "a" & CStr(hAutores["id_autor"])

      If hAutores["es_autor_correspondencia"] = True Then
        sXML &= "      <contrib contrib-type=" & q & sContribType & q &
          " id=" & q & sIdAutor & q &
          " corresp=" & q & "yes" & q & ">\n"
      Else
        sXML &= "      <contrib contrib-type=" & q & sContribType & q &
          " id=" & q & sIdAutor & q & ">\n"
      Endif

      ' NOMBRE
      sXML &= "        <name>\n"
      sXML &= "          <surname>" & EscaparXML(TrimUTF8(hAutores["apellidos"])) & "</surname>\n"
      sXML &= "          <given-names>" & EscaparXML(TrimUTF8(hAutores["nombre"])) & "</given-names>\n"
      If Not IsNull(hAutores["sufijo"]) Then
        If Len(TrimUTF8(hAutores["sufijo"])) > 0 Then
          sXML &= "          <suffix>" & EscaparXML(TrimUTF8(hAutores["sufijo"])) & "</suffix>\n"
        Endif
      Endif
      sXML &= "        </name>\n"

      ' ORCID
      If Not IsNull(hAutores["orcid"]) Then
        If Len(TrimUTF8(hAutores["orcid"])) > 0 Then
          sXML &= "        <contrib-id contrib-id-type=\"orcid\" authenticated=\"true\">" &
            "https://orcid.org/" & EscaparXML(TrimUTF8(hAutores["orcid"])) &
            "</contrib-id>\n"
        Endif
      Endif

      ' AFILIACIÓN: PRIORIDAD _momento → DATO ACTUAL DEL AUTOR
      sAfil = ""
      sDept = ""
      sCiudadAfil = ""
      sPaisAfil = ""

      If Not IsNull(hAutores["afiliacion_momento"]) Then
        If Len(TrimUTF8(hAutores["afiliacion_momento"])) > 0 Then
          sAfil = TrimUTF8(hAutores["afiliacion_momento"])
        Endif
      Endif
      If sAfil = "" Then
        If Not IsNull(hAutores["afiliacion_actual"]) Then
          If Len(TrimUTF8(hAutores["afiliacion_actual"])) > 0 Then
            sAfil = TrimUTF8(hAutores["afiliacion_actual"])
          Endif
        Endif
      Endif

      If Not IsNull(hAutores["departamento_momento"]) Then
        If Len(TrimUTF8(hAutores["departamento_momento"])) > 0 Then
          sDept = TrimUTF8(hAutores["departamento_momento"])
        Endif
      Endif
      If sDept = "" Then
        If Not IsNull(hAutores["departamento"]) Then
          If Len(TrimUTF8(hAutores["departamento"])) > 0 Then
            sDept = TrimUTF8(hAutores["departamento"])
          Endif
        Endif
      Endif

      If Not IsNull(hAutores["ciudad_momento"]) Then
        If Len(TrimUTF8(hAutores["ciudad_momento"])) > 0 Then
          sCiudadAfil = TrimUTF8(hAutores["ciudad_momento"])
        Endif
      Endif
      If sCiudadAfil = "" Then
        If Not IsNull(hAutores["ciudad_afiliacion"]) Then
          If Len(TrimUTF8(hAutores["ciudad_afiliacion"])) > 0 Then
            sCiudadAfil = TrimUTF8(hAutores["ciudad_afiliacion"])
          Endif
        Endif
      Endif

      If Not IsNull(hAutores["pais_momento"]) Then
        If Len(TrimUTF8(hAutores["pais_momento"])) > 0 Then
          sPaisAfil = TrimUTF8(hAutores["pais_momento"])
        Endif
      Endif
      If sPaisAfil = "" Then
        If Not IsNull(hAutores["pais_afiliacion"]) Then
          If Len(TrimUTF8(hAutores["pais_afiliacion"])) > 0 Then
            sPaisAfil = TrimUTF8(hAutores["pais_afiliacion"])
          Endif
        Endif
      Endif

      If sAfil <> "" Or sDept <> "" Or sCiudadAfil <> "" Or sPaisAfil <> "" Then
        sXML &= "        <aff>\n"
        If sDept <> "" Then
          sXML &= "          <institution content-type=\"dept\">" & EscaparXML(sDept) & "</institution>,\n"
        Endif
        If sAfil <> "" Then
          sXML &= "          <institution>" & EscaparXML(sAfil) & "</institution>"
          If sCiudadAfil <> "" Or sPaisAfil <> "" Then
            sXML &= ",\n"
          Else
            sXML &= "\n"
          Endif
        Endif
        If sCiudadAfil <> "" Then
          sXML &= "          <city>" & EscaparXML(sCiudadAfil) & "</city>"
          If sPaisAfil <> "" Then sXML &= ",\n" Else sXML &= "\n"
        Endif
        If sPaisAfil <> "" Then
          sXML &= "          <country>" & EscaparXML(sPaisAfil) & "</country>\n"
        Endif
        sXML &= "        </aff>\n"
      Endif

      ' EMAIL: SOLO PARA AUTOR DE CORRESPONDENCIA
      ' PRIORIDAD: email_correspondencia → email_momento → email_principal
      sEmail = ""
      If hAutores["es_autor_correspondencia"] = True Then
        If Not IsNull(hAutores["email_correspondencia"]) Then
          If Len(TrimUTF8(hAutores["email_correspondencia"])) > 0 Then
            sEmail = TrimUTF8(hAutores["email_correspondencia"])
          Endif
        Endif
        If sEmail = "" Then
          If Not IsNull(hAutores["email_momento"]) Then
            If Len(TrimUTF8(hAutores["email_momento"])) > 0 Then
              sEmail = TrimUTF8(hAutores["email_momento"])
            Endif
          Endif
        Endif
        If sEmail = "" Then
          If Not IsNull(hAutores["email_principal"]) Then
            If Len(TrimUTF8(hAutores["email_principal"])) > 0 Then
              sEmail = TrimUTF8(hAutores["email_principal"])
            Endif
          Endif
        Endif
        If sEmail <> "" Then
          sXML &= "        <email>" & EscaparXML(sEmail) & "</email>\n"
        Endif
      Endif

      sXML &= "      </contrib>\n"
      hAutores.MoveNext
    Wend

    sXML &= "    </contrib-group>\n"
  Endif

  ' AUTHOR-NOTES
  If Not IsNull(hArticulo["author_notes"]) Then
    If Len(TrimUTF8(hArticulo["author_notes"])) > 0 Then
      sXML &= "    <author-notes>\n"
      sXML &= "      <notes>" & EscaparXML(TrimUTF8(hArticulo["author_notes"])) & "</notes>\n"
      sXML &= "    </author-notes>\n"
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.6: PUB-DATE
  ' PRIORIDAD: fecha_pub_iso > ano_publicacion + mes_publicacion
  ' --------------------------------------------------
  sFechaPub = ""
  If Not IsNull(hArticulo["fecha_pub_iso"]) Then
    If Len(CStr(hArticulo["fecha_pub_iso"])) > 0 Then
      sFechaPub = CStr(hArticulo["fecha_pub_iso"])
    Endif
  Endif

  If sFechaPub <> "" Then
    aFechaPub = Split(sFechaPub, "-")
    sXML &= "    <pub-date pub-type=\"epub-ppub\">\n"
    If aFechaPub.Count >= 1 Then
      If TrimUTF8(aFechaPub[0]) <> "" Then
        sXML &= "      <year>" & TrimUTF8(aFechaPub[0]) & "</year>\n"
      Endif
    Endif
    If aFechaPub.Count >= 2 Then
      If TrimUTF8(aFechaPub[1]) <> "" And TrimUTF8(aFechaPub[1]) <> "00" Then
        sXML &= "      <month>" & TrimUTF8(aFechaPub[1]) & "</month>\n"
      Endif
    Endif
    If aFechaPub.Count >= 3 Then
      If TrimUTF8(aFechaPub[2]) <> "" And TrimUTF8(aFechaPub[2]) <> "00" Then
        sXML &= "      <day>" & TrimUTF8(aFechaPub[2]) & "</day>\n"
      Endif
    Endif
    sXML &= "    </pub-date>\n"

  Else If Not IsNull(hArticulo["ano_publicacion"]) Then
    If Len(CStr(hArticulo["ano_publicacion"])) > 0 Then
      sXML &= "    <pub-date pub-type=\"epub-ppub\">\n"

      sMesPub = ""
      If Not IsNull(hArticulo["mes_publicacion"]) Then
        sMesPub = ConvertirMesANumero(TrimUTF8(hArticulo["mes_publicacion"]))
      Endif
      If sMesPub = "" Then
        If Not IsNull(hRevista["mes_publicacion"]) Then
          sMesPub = ConvertirMesANumero(TrimUTF8(hRevista["mes_publicacion"]))
        Endif
      Endif

      If sMesPub <> "" Then sXML &= "      <month>" & sMesPub & "</month>\n"
      sXML &= "      <year>" & CStr(hArticulo["ano_publicacion"]) & "</year>\n"
      sXML &= "    </pub-date>\n"
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.7: VOLUMEN, NÚMERO, SUPLEMENTO
  ' --------------------------------------------------
  If Not IsNull(hRevista["volumen"]) Then
    If Len(TrimUTF8(hRevista["volumen"])) > 0 Then
      sXML &= "    <volume>" & EscaparXML(TrimUTF8(hRevista["volumen"])) & "</volume>\n"
    Endif
  Endif
  If Not IsNull(hRevista["numero"]) Then
    If Len(TrimUTF8(hRevista["numero"])) > 0 Then
      sXML &= "    <issue>" & EscaparXML(TrimUTF8(hRevista["numero"])) & "</issue>\n"
    Endif
  Endif
  If Not IsNull(hRevista["suplemento"]) Then
    If Len(TrimUTF8(hRevista["suplemento"])) > 0 Then
      sXML &= "    <supplement>" & EscaparXML(TrimUTF8(hRevista["suplemento"])) & "</supplement>\n"
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.8: PAGINACIÓN
  ' elocation-id TIENE PRIORIDAD SOBRE fpage/lpage
  ' --------------------------------------------------
  If Not IsNull(hArticulo["elocation_id"]) Then
    If Len(TrimUTF8(hArticulo["elocation_id"])) > 0 Then
      sXML &= "    <elocation-id>" & EscaparXML(TrimUTF8(hArticulo["elocation_id"])) & "</elocation-id>\n"
    Else
      If Not IsNull(hArticulo["pagina_inicio"]) Then
        If Len(TrimUTF8(hArticulo["pagina_inicio"])) > 0 Then
          sXML &= "    <fpage>" & EscaparXML(TrimUTF8(hArticulo["pagina_inicio"])) & "</fpage>\n"
        Endif
      Endif
      If Not IsNull(hArticulo["pagina_fin"]) Then
        If Len(TrimUTF8(hArticulo["pagina_fin"])) > 0 Then
          sXML &= "    <lpage>" & EscaparXML(TrimUTF8(hArticulo["pagina_fin"])) & "</lpage>\n"
        Endif
      Endif
    Endif
  Else
    If Not IsNull(hArticulo["pagina_inicio"]) Then
      If Len(TrimUTF8(hArticulo["pagina_inicio"])) > 0 Then
        sXML &= "    <fpage>" & EscaparXML(TrimUTF8(hArticulo["pagina_inicio"])) & "</fpage>\n"
      Endif
    Endif
    If Not IsNull(hArticulo["pagina_fin"]) Then
      If Len(TrimUTF8(hArticulo["pagina_fin"])) > 0 Then
        sXML &= "    <lpage>" & EscaparXML(TrimUTF8(hArticulo["pagina_fin"])) & "</lpage>\n"
      Endif
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.9: HISTORY (FECHAS DEL PROCESO EDITORIAL)
  ' --------------------------------------------------
  bTieneHistory = False
  If Not IsNull(hArticulo["fecha_rec_iso"]) Then
    If Len(CStr(hArticulo["fecha_rec_iso"])) > 0 Then bTieneHistory = True
  Endif
  If Not IsNull(hArticulo["fecha_rev_iso"]) Then
    If Len(CStr(hArticulo["fecha_rev_iso"])) > 0 Then bTieneHistory = True
  Endif
  If Not IsNull(hArticulo["fecha_ace_iso"]) Then
    If Len(CStr(hArticulo["fecha_ace_iso"])) > 0 Then bTieneHistory = True
  Endif
  If Not IsNull(hArticulo["fecha_online_iso"]) Then
    If Len(CStr(hArticulo["fecha_online_iso"])) > 0 Then bTieneHistory = True
  Endif

  If bTieneHistory Then
    sXML &= "    <history>\n"
    If Not IsNull(hArticulo["fecha_rec_iso"]) Then
      If Len(CStr(hArticulo["fecha_rec_iso"])) > 0 Then
        sXML &= GenerarElementoFecha("received", CStr(hArticulo["fecha_rec_iso"]))
      Endif
    Endif
    If Not IsNull(hArticulo["fecha_rev_iso"]) Then
      If Len(CStr(hArticulo["fecha_rev_iso"])) > 0 Then
        sXML &= GenerarElementoFecha("rev-recd", CStr(hArticulo["fecha_rev_iso"]))
      Endif
    Endif
    If Not IsNull(hArticulo["fecha_ace_iso"]) Then
      If Len(CStr(hArticulo["fecha_ace_iso"])) > 0 Then
        sXML &= GenerarElementoFecha("accepted", CStr(hArticulo["fecha_ace_iso"]))
      Endif
    Endif
    If Not IsNull(hArticulo["fecha_online_iso"]) Then
      If Len(CStr(hArticulo["fecha_online_iso"])) > 0 Then
        sXML &= GenerarElementoFecha("pub", CStr(hArticulo["fecha_online_iso"]))
      Endif
    Endif
    sXML &= "    </history>\n"
  Endif

  ' --------------------------------------------------
  ' PASO 5.10: PERMISSIONS (COPYRIGHT Y LICENCIA)
  ' --------------------------------------------------
  sXML &= "    <permissions>\n"

  ' AÑO DE COPYRIGHT: campo específico → año de publicación
  sCopyrightYear = ""
  If Not IsNull(hArticulo["copyright_year"]) Then
    If Len(CStr(hArticulo["copyright_year"])) > 0 Then
      sCopyrightYear = CStr(hArticulo["copyright_year"])
    Endif
  Endif
  If sCopyrightYear = "" Then
    If Not IsNull(hArticulo["ano_publicacion"]) Then
      If Len(CStr(hArticulo["ano_publicacion"])) > 0 Then
        sCopyrightYear = CStr(hArticulo["ano_publicacion"])
      Endif
    Endif
  Endif
  If sCopyrightYear <> "" Then
    sXML &= "      <copyright-year>" & sCopyrightYear & "</copyright-year>\n"
  Endif

  sCopyrightHolder = ""
  If Not IsNull(hArticulo["copyright_holder"]) Then
    If Len(TrimUTF8(hArticulo["copyright_holder"])) > 0 Then
      sCopyrightHolder = TrimUTF8(hArticulo["copyright_holder"])
    Endif
  Endif
  If sCopyrightHolder <> "" Then
    sXML &= "      <copyright-holder>" & EscaparXML(sCopyrightHolder) & "</copyright-holder>\n"
  Endif

  ' LICENCIA: PRIORIZAR ARTÍCULO SOBRE DEFECTO DE REVISTA
  sLicencia = ""
  sUrlLicencia = ""

  If Not IsNull(hArticulo["licencia"]) Then
    If Len(TrimUTF8(hArticulo["licencia"])) > 0 Then
      sLicencia = TrimUTF8(hArticulo["licencia"])
      If Not IsNull(hArticulo["url_licencia"]) Then
        sUrlLicencia = TrimUTF8(hArticulo["url_licencia"])
      Endif
    Endif
  Endif

  If sLicencia = "" Then
    If Not IsNull(hRevista["licencia_defecto"]) Then
      If Len(TrimUTF8(hRevista["licencia_defecto"])) > 0 Then
        sLicencia = TrimUTF8(hRevista["licencia_defecto"])
        If Not IsNull(hRevista["url_licencia"]) Then
          sUrlLicencia = TrimUTF8(hRevista["url_licencia"])
        Endif
      Endif
    Endif
  Endif

  If sLicencia <> "" Then
    If sUrlLicencia <> "" Then
      sXML &= "      <license license-type=\"open-access\" xlink:href=\"" & EscaparXML(sUrlLicencia) & "\">\n"
    Else
      sXML &= "      <license license-type=\"open-access\">\n"
    Endif
    sXML &= "        <license-p>" & EscaparXML(sLicencia) & "</license-p>\n"
    sXML &= "      </license>\n"
  Endif

  sXML &= "    </permissions>\n"

  ' --------------------------------------------------
  ' PASO 5.10b: RELATED-ARTICLE
  ' POSICIÓN CORRECTA SEGÚN DTD JATS 1.4:
  ' DESPUÉS DE permissions Y ANTES DE abstract
  ' --------------------------------------------------
  sXML &= GenerarRelatedArticle(hArticulo)

  ' --------------------------------------------------
  ' PASO 5.11: ABSTRACT — TRES PARES resumen/idioma
  ' EL PRIMER PAR → <abstract>, LOS SIGUIENTES → <trans-abstract>
  ' --------------------------------------------------
  Dim i As Integer
  Dim sResumen As String
  Dim sIdiomaRes As String
  Dim sTag As String

  For i = 1 To 3
    Select Case i
      Case 1
        sResumen = If(IsNull(hArticulo["resumen_1"]), "", TrimUTF8(hArticulo["resumen_1"]))
        sIdiomaRes = If(IsNull(hArticulo["idioma_resumen_1"]), "", TrimUTF8(hArticulo["idioma_resumen_1"]))
      Case 2
        sResumen = If(IsNull(hArticulo["resumen_2"]), "", TrimUTF8(hArticulo["resumen_2"]))
        sIdiomaRes = If(IsNull(hArticulo["idioma_resumen_2"]), "", TrimUTF8(hArticulo["idioma_resumen_2"]))
      Case 3
        sResumen = If(IsNull(hArticulo["resumen_3"]), "", TrimUTF8(hArticulo["resumen_3"]))
        sIdiomaRes = If(IsNull(hArticulo["idioma_resumen_3"]), "", TrimUTF8(hArticulo["idioma_resumen_3"]))
    End Select

    If sResumen = "" Or sIdiomaRes = "" Then Continue

    sTag = If(i = 1, "abstract", "trans-abstract")

    sXML &= "    <" & sTag & " xml:lang=\"" & sIdiomaRes & "\">\n"
    sXML &= "      <p>" & EscaparXML(sResumen) & "</p>\n"
    sXML &= "    </" & sTag & ">\n"
  Next

  ' --------------------------------------------------
  ' PASO 5.12: KWD-GROUP — TRES PARES palabras_clave/idioma
  ' --------------------------------------------------
  Dim sKwd As String
  Dim sIdiomaKwd As String

  For i = 1 To 3
    Select Case i
      Case 1
        sKwd = If(IsNull(hArticulo["palabras_clave_1"]), "", TrimUTF8(hArticulo["palabras_clave_1"]))
        sIdiomaKwd = If(IsNull(hArticulo["idioma_kwd_1"]), "", TrimUTF8(hArticulo["idioma_kwd_1"]))
      Case 2
        sKwd = If(IsNull(hArticulo["palabras_clave_2"]), "", TrimUTF8(hArticulo["palabras_clave_2"]))
        sIdiomaKwd = If(IsNull(hArticulo["idioma_kwd_2"]), "", TrimUTF8(hArticulo["idioma_kwd_2"]))
      Case 3
        sKwd = If(IsNull(hArticulo["palabras_clave_3"]), "", TrimUTF8(hArticulo["palabras_clave_3"]))
        sIdiomaKwd = If(IsNull(hArticulo["idioma_kwd_3"]), "", TrimUTF8(hArticulo["idioma_kwd_3"]))
    End Select

    If sKwd = "" Or sIdiomaKwd = "" Then Continue

    sXML &= GenerarKwdGroup(sKwd, sIdiomaKwd)
  Next

  ' --------------------------------------------------
  ' PASO 5.13: FUNDING-GROUP
  ' PRIORIDAD: funding_statement (TEXTO FORMAL) SOBRE financiamiento
  ' --------------------------------------------------
  If Not IsNull(hArticulo["funding_statement"]) Then
    If Len(TrimUTF8(hArticulo["funding_statement"])) > 0 Then
      sXML &= "    <funding-group>\n"
      sXML &= "      <funding-statement>" & EscaparXML(TrimUTF8(hArticulo["funding_statement"])) & "</funding-statement>\n"
      sXML &= "    </funding-group>\n"
    Else If Not IsNull(hArticulo["financiamiento"]) Then
      If Len(TrimUTF8(hArticulo["financiamiento"])) > 0 Then
        sXML &= "    <funding-group>\n"
        sXML &= "      <funding-statement>" & EscaparXML(TrimUTF8(hArticulo["financiamiento"])) & "</funding-statement>\n"
        sXML &= "    </funding-group>\n"
      Endif
    Endif
  Endif

  ' --------------------------------------------------
  ' PASO 5.14: CUSTOM-META — IDIOMA PRINCIPAL
  ' USADO POR ensamblar-canonico.xsl CUANDO NO HAY <abstract>
  ' (editoriales, reseñas, obituarios, cartas, etc.)
  ' --------------------------------------------------
  sXML &= "    <custom-meta-group>\n"
  sXML &= "      <custom-meta>\n"
  sXML &= "        <meta-name>xml-lang</meta-name>\n"
  sXML &= "        <meta-value>" & sIdiomaPrincipal & "</meta-value>\n"
  sXML &= "      </custom-meta>\n"
  sXML &= "    </custom-meta-group>\n"

  ' ====================================================
  ' PASO 6: CERRAR ARTICLE-META Y FRONT
  ' ====================================================
  sXML &= "  </article-meta>\n"
  sXML &= "</front>\n"

  ' ====================================================
  ' PASO 7: GUARDAR ARCHIVO EN /tmp
  ' ====================================================
  Try File.Save(sFilePath, sXML)
  If Error Then
    Message.Error("Error al guardar front.xml en " & sFilePath & ":" & Chr(10) & Error.Text)
    Return False
  Endif

  Return Exist(sFilePath)

Catch
  Message.Error("Error inesperado en GenerarFrontXML:" & Chr(10) &
    Error.Text & Chr(10) &
    "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : GenerarBodyXML
' Propósito : Genera el fragmento <body> del artículo invocando
'             pandoc sobre el archivo .md con filtro Lua para
'             convertir citas a xref. El resultado se escribe en
'             {proyecto}/tmp/body-{nombre}.xml
' Parámetros: iIdArticulo As Integer — id del artículo en BD
' Retorna   : Boolean — True si body-*.xml fue generado
' ============================================
Public Function GenerarBodyXML(iIdArticulo As Integer) As Boolean

  Dim hArticulo As Result
  Dim sNombreArchivo As String
  Dim sNombreBase As String
  Dim sRutaProyecto As String
  Dim sRutaMD As String
  Dim sDirTmp As String
  Dim sFileBody As String
  Dim iEspera As Integer

  iIdArticulo = CInt(FMain.id_articulo.Value)

  ' --- 1. Obtener nombre_archivo ---
  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo FROM articulos WHERE id_articulo = &1 LIMIT 1", iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif

  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  sNombreArchivo = TrimUTF8(hArticulo["nombre_archivo"])

  If sNombreArchivo = "" Then
    Message.Error("El artículo id=" & CStr(iIdArticulo) & " no tiene nombre de archivo registrado.")
    Return False
  Endif

  ' --- 2. Construir rutas ---
  sRutaProyecto = File.Dir(FMain.txtProyecto.Text)
  sNombreBase = "body-" & Mid(sNombreArchivo, 3)
  sDirTmp = sRutaProyecto & "/tmp"
  sRutaMD = sRutaProyecto & "/articulos/" & sNombreArchivo & ".md"
  sFileBody = sDirTmp & "/" & sNombreBase & ".xml"

  If Not Exist(sRutaMD) Then
    Message.Error("No se encontró el archivo del artículo:" & Chr(10) & sRutaMD)
    Return False
  Endif

  ' --- 3. Eliminar fragmento anterior ---
  If Exist(sFileBody) Then
    Shell "rm '" & sFileBody & "'" Wait
  Endif

  ' --- 4. Invocar pandoc ---
  FMain.TerminalViewProyecto.Input(
    "{ echo '<body xmlns:xlink=" & Chr(34) & "http://www.w3.org/1999/xlink" & Chr(34) & ">'; pandoc '" & sRutaMD & "' " &
    "--from markdown --to jats --no-highlight --wrap=none " &
    "--lua-filter ~/.gbpublisher/filters/cite-to-xref.lua --output -; " &
    "echo '</body>'; } > '" & sFileBody & "'" & Chr(10))

  ' --- 5. Esperar hasta que el archivo exista (máximo 30 s) ---
  iEspera = 0
  While Not Exist(sFileBody) And iEspera < 300
    Wait 0.1
    Inc iEspera
  Wend

  If Not Exist(sFileBody) Then
    Message.Error("Pandoc no generó el fragmento body en el tiempo esperado." & Chr(10) &
      "Verifique que pandoc está instalado y el archivo .md es válido." & Chr(10) &
      "Ruta MD: " & sRutaMD)
    Return False
  Endif

  Wait 0.3

  If File.Load(sFileBody) = "" Then
    Message.Error("El fragmento body generado está vacío." & Chr(10) &
      "Verifique que el archivo .md tiene contenido válido.")
    Return False
  Endif

  Return True

Catch
  Message.Error("Error inesperado en GenerarBodyXML:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : GenerarRefListXML
' Propósito : Genera el fragmento <ref-list> de JATS 1.4 filtrando
'             solo las entradas del .bib cuyos citekeys aparecen
'             en articulos.referencias_citadas.
'             Artículos sin referencias (editorial, carta, reseña,
'             necrológica) generan un <ref-list/> vacío y retornan
'             True — el XSLT omite <back> si no hay <ref>.
' Parámetros: iIdArticulo As Integer — id del artículo en BD
' Retorna   : Boolean — True si reflist-*.xml fue generado
' ============================================
Public Function GenerarRefListXML(iIdArticulo As Integer) As Boolean

  Dim hArticulo As Result
  Dim sNombreArchivo As String
  Dim sReferenciasCSV As String
  Dim aCitekeys As String[]
  Dim colCitekeys As New Collection
  Dim sBibFile As String
  Dim sBibContent As String
  Dim sEntry As String
  Dim aEntries As String[]
  Dim sType As String
  Dim sCitekey As String
  Dim iPosLlave As Integer
  Dim iPosComa As Integer
  Dim dictEntries As New Collection
  Dim dictTypes As New Collection
  Dim sXML As String
  Dim sDirTmp As String
  Dim sNombreBase As String
  Dim sFilePath As String
  Dim sCk As String

  iIdArticulo = CInt(FMain.id_articulo.Value)

  ' --- 1. Obtener nombre_archivo y referencias_citadas ---
  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo, referencias_citadas FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif

  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  sNombreArchivo = TrimUTF8(hArticulo["nombre_archivo"])
  sDirTmp = File.Dir(FMain.txtProyecto.Text) & "/tmp"
  sNombreBase = "reflist-" & Mid(sNombreArchivo, 3)
  sFilePath = sDirTmp & "/" & sNombreBase & ".xml"

  ' --- 2. Sin referencias → ref-list vacío ---
  If IsNull(hArticulo["referencias_citadas"]) Or
      TrimUTF8(hArticulo["referencias_citadas"]) = "" Then
    Try File.Save(sFilePath, "<ref-list/>" & Chr(10))
    If Error Then
      Message.Error("Error al guardar reflist vacío en " & sFilePath & ":" & Chr(10) & Error.Text)
      Return False
    Endif
    Return True
  Endif

  sReferenciasCSV = TrimUTF8(hArticulo["referencias_citadas"])

  ' --- 3. Construir colección de citekeys esperados ---
  aCitekeys = Split(sReferenciasCSV, ",")
  For Each sCk In aCitekeys
    sCk = TrimUTF8(sCk)
    If sCk <> "" Then colCitekeys[sCk] = True
  Next

  If colCitekeys.Count = 0 Then
    Message.Warning("No se encontraron citekeys válidos en referencias_citadas.")
    Return False
  Endif

  ' --- 4. Verificar .bib ---
  sBibFile = File.Dir(FMain.txtProyecto.Text) & "/referencias/ref-" &
    File.BaseName(FMain.txtProyecto.Text) & ".bib"

  If Not Exist(sBibFile) Then
    Message.Error("No se encontró el archivo de referencias:" & Chr(10) & sBibFile & Chr(10) &
      "Exporte primero las referencias desde la base de datos.")
    Return False
  Endif

  ' --- 5. Leer el .bib ---
  Try sBibContent = File.Load(sBibFile)
  If Error Then
    Message.Error("Error al leer el archivo .bib:" & Chr(10) & Error.Text)
    Return False
  Endif

  ' --- 6. Primera pasada: almacenar entradas para crossref ---
  aEntries = Split(sBibContent, "@", "", True)

  For Each sEntry In aEntries
    If TrimUTF8(sEntry) = "" Then Continue
    iPosLlave = InStr(sEntry, "{")
    iPosComa = InStr(sEntry, ",")
    If iPosLlave = 0 Or iPosComa = 0 Then Continue
    sType = TrimUTF8(Left(sEntry, iPosLlave - 1))
    If Lower(sType) = "comment" Or Lower(sType) = "string" Then Continue
    sCitekey = TrimUTF8(Mid(sEntry, iPosLlave + 1, iPosComa - iPosLlave - 1))
    If sCitekey = "" Then Continue
    dictEntries[sCitekey] = sEntry
    dictTypes[sCitekey] = sType
  Next

  ' --- 7. Segunda pasada: generar XML en el orden de referencias_citadas ---
  sXML = "<ref-list>" & Chr(10)

  For Each sCk In aCitekeys
    sCk = TrimUTF8(sCk)
    If sCk = "" Then Continue

    If Not dictEntries.Exist(sCk) Then
      sXML &= "  <!-- ADVERTENCIA: citekey '" & sCk & "' no encontrado en el .bib -->" & Chr(10)
      Continue
    Endif

    sEntry = dictEntries[sCk]
    sType = dictTypes[sCk]

    sXML &= "  <ref id=" & Chr(34) & "bib-" & EscaparXML(sCk) & Chr(34) & ">" & Chr(10)
    sXML &= GenerarElementCitationDesdeBib(sEntry, sType, dictEntries, dictTypes)
    sXML &= "  </ref>" & Chr(10)
  Next

  sXML &= "</ref-list>" & Chr(10)

  ' --- 8. Guardar ---
  Try File.Save(sFilePath, sXML)
  If Error Then
    Message.Error("Error al guardar reflist xml en " & sFilePath & ":" & Chr(10) & Error.Text)
    Return False
  Endif

  Return Exist(sFilePath)

Catch
  Message.Error("Error inesperado en GenerarRefListXML:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : GenerarMetaArticuloXML
' Propósito : Genera el XML auxiliar m-*.xml con datos de la BD
'             que complementan el canónico JATS para el pipeline
'             de metadatos HTML (Highwire Press, Dublin Core,
'             Open Graph, Schema.org JSON-LD).
'
'             El archivo se escribe en:
'               {proyecto}/tmp/m-{nombre}.xml
'             y es consumido por jats-to-html.xsl vía parámetro
'             de ruta antes de llamar a Saxon.
'
'             CRUCE CON EL CANÓNICO:
'             <autor ref="a{id_autor}"> coincide con
'             <contrib id="a{id_autor}"> en el JATS, permitiendo
'             al XSLT vincular por identificador y no por posición.
'
'             CASCADA ROR DE AFILIACIÓN:
'             articulo_autor.ror_afiliacion_momento → autores.ror_afiliacion_actual
'
' Parámetros: iIdArticulo As Integer — id del artículo en BD
'             iIdRevista  As Integer — id de la revista en BD
' Retorna   : Boolean — True si m-*.xml fue generado y existe
' ============================================
Public Function GenerarMetaArticuloXML(iIdArticulo As Integer, iIdRevista As Integer) As Boolean

  ' --- 1. Declaración de variables ---
  Dim hArticulo As Result
  Dim hRevista As Result
  Dim hAutores As Result
  Dim sXML As String
  Dim sDirTmp As String
  Dim sNombreBase As String
  Dim sFilePath As String

  ' VARIABLES PARA IDENTIDAD Y URLs
  Dim sDoi As String
  Dim sUrlHtml As String
  Dim sUrlArt As String
  Dim sUrlPdf As String
  Dim sUrlFinal As String

  ' VARIABLES PARA REVISTA
  Dim sRorEditorial As String

  ' VARIABLES PARA AUTORES
  Dim sRefAutor As String
  Dim sCredit As String
  Dim sRorMomento As String
  Dim sRorActual As String
  Dim sRorFinal As String

  sDirTmp = File.Dir(FMain.txtProyecto.Text) & "/tmp"

  ' --- 2. Consultar datos del artículo ---
  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo, doi, url_html, url_articulo, url_pdf " &
    "FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif

  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  ' NOMBRE DEL ARCHIVO: "a-01-revista-v01-n01" → "m-01-revista-v01-n01"
  sNombreBase = TrimUTF8(hArticulo["nombre_archivo"])
  sNombreBase = "m-" & Mid(sNombreBase, 3)
  sFilePath = sDirTmp & "/" & sNombreBase & ".xml"

  ' --- 3. Consultar datos de la revista ---
  Try hRevista = m_ConexionBD.mConn.Exec(
    "SELECT ror_editorial FROM revistas_md WHERE id_revista = &1 LIMIT 1",
    iIdRevista)

  If Error Then
    Message.Error("Error al consultar la revista:" & Chr(10) & Error.Text)
    Return False
  Endif

  ' --- 4. Consultar autores con credit y ROR ---
  ' SE TRAE ror_afiliacion_momento DE articulo_autor Y
  ' ror_afiliacion_actual DE autores PARA IMPLEMENTAR LA CASCADA
  Try hAutores = m_ConexionBD.mConn.Exec(
    "SELECT a.id_autor, aa.taxonomia_credit, " &
    "aa.ror_afiliacion_momento, a.ror_afiliacion_actual " &
    "FROM autores a " &
    "INNER JOIN articulo_autor aa ON a.id_autor = aa.id_autor " &
    "WHERE aa.id_articulo = &1 " &
    "ORDER BY aa.orden_autoria ASC",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar autores para meta XML:" & Chr(10) & Error.Text)
    Return False
  Endif

  ' --- 5. Construir XML ---
  sXML = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  sXML &= "<meta-articulo>\n"

  ' --------------------------------------------------
  ' BLOQUE identidad: DOI + URL del texto completo
  ' CASCADA URL: url_html → url_articulo → url_pdf
  ' --------------------------------------------------
  sDoi = If(IsNull(hArticulo["doi"]), "", TrimUTF8(hArticulo["doi"]))
  sUrlHtml = If(IsNull(hArticulo["url_html"]), "", TrimUTF8(hArticulo["url_html"]))
  sUrlArt = If(IsNull(hArticulo["url_articulo"]), "", TrimUTF8(hArticulo["url_articulo"]))
  sUrlPdf = If(IsNull(hArticulo["url_pdf"]), "", TrimUTF8(hArticulo["url_pdf"]))

  If sUrlHtml <> "" Then
    sUrlFinal = sUrlHtml
  Else If sUrlArt <> "" Then
    sUrlFinal = sUrlArt
  Else
    sUrlFinal = sUrlPdf
  Endif

  sXML &= "  <identidad>\n"
  If sDoi <> "" Then
    sXML &= "    <doi>" & EscaparXML(sDoi) & "</doi>\n"
  Endif
  If sUrlFinal <> "" Then
    sXML &= "    <url-texto-completo>" & EscaparXML(sUrlFinal) & "</url-texto-completo>\n"
  Endif
  sXML &= "  </identidad>\n"

  ' --------------------------------------------------
  ' BLOQUE revista: ROR del editor
  ' --------------------------------------------------
  sRorEditorial = ""
  If hRevista.Available Then
    If Not IsNull(hRevista["ror_editorial"]) Then
      sRorEditorial = TrimUTF8(hRevista["ror_editorial"])
    Endif
  Endif

  sXML &= "  <revista>\n"
  If sRorEditorial <> "" Then
    sXML &= "  <revista>\n"
    sXML &= "    <ror-editorial>" & EscaparXML(sRorEditorial) & "</ror-editorial>\n"
    sXML &= "  </revista>\n"
  Endif
  sXML &= "  </revista>\n"

  ' --------------------------------------------------
  ' BLOQUE autores: credit y ROR por autor
  ' ref="a{id_autor}" CRUZA CON <contrib id="a{id_autor}">
  ' EN EL CANÓNICO JATS
  ' --------------------------------------------------
  sXML &= "  <autores>\n"

  While hAutores.Available

    sRefAutor = "a" & CStr(hAutores["id_autor"])

    ' CREDIT: DECLARACIÓN FORMAL POR ARTÍCULO (taxonomia_credit)
    sCredit = If(IsNull(hAutores["taxonomia_credit"]), "", TrimUTF8(hAutores["taxonomia_credit"]))

    ' ROR DE AFILIACIÓN: CASCADA _momento → _actual
    sRorMomento = If(IsNull(hAutores["ror_afiliacion_momento"]), "", TrimUTF8(hAutores["ror_afiliacion_momento"]))
    sRorActual = If(IsNull(hAutores["ror_afiliacion_actual"]), "", TrimUTF8(hAutores["ror_afiliacion_actual"]))

    If sRorMomento <> "" Then
      sRorFinal = sRorMomento
    Else
      sRorFinal = sRorActual
    Endif

    ' SOLO EMITIR EL NODO SI HAY AL MENOS UN DATO QUE APORTAR
    If sCredit <> "" Or sRorFinal <> "" Then
      sXML &= "    <autor ref=\"" & sRefAutor & "\">\n"
      If sCredit <> "" Then
        sXML &= "      <credit>" & EscaparXML(sCredit) & "</credit>\n"
      Endif
      If sRorFinal <> "" Then
        sXML &= "      <ror-afiliacion>" & EscaparXML(sRorFinal) & "</ror-afiliacion>\n"
      Endif
      sXML &= "    </autor>\n"
    Endif

    hAutores.MoveNext
  Wend

  sXML &= "  </autores>\n"
  sXML &= "</meta-articulo>\n"

  ' --- 6. Guardar en tmp/ ---
  Try File.Save(sFilePath, sXML)
  If Error Then
    Message.Error("Error al guardar meta XML en " & sFilePath & ":" & Chr(10) & Error.Text)
    Return False
  Endif

  Return Exist(sFilePath)

Catch
  Message.Error("Error inesperado en GenerarMetaArticuloXML:" & Chr(10) &
    Error.Text & Chr(10) &
    "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : MostrarArchivosDOAJ
' Propósito : Lista archivos d-*.xml y d-*.json del directorio
'             jats/ en el listbox lbDOAJ de FMain.
'             XML primero, luego JSON, ambos ordenados.
' ============================================
Public Sub MostrarArchivosDOAJ()

  Dim sRutaJats As String = File.Dir(FMain.txtProyecto.Text) &/ "jats"
  Dim aXml As New String[]
  Dim aJson As New String[]
  Dim sArch As String

  FMain.lbDOAJ.Clear

  If Not Exist(sRutaJats) Then Return

  For Each sArch In Dir(sRutaJats, "d-*.xml")
    aXml.Add(File.Name(sArch))
  Next
  For Each sArch In Dir(sRutaJats, "d-*.json")
    aJson.Add(File.Name(sArch))
  Next

  aXml.Sort()
  aJson.Sort()

  Dim s As String
  For Each s In aXml
    FMain.lbDOAJ.Add(s)
  Next
  For Each s In aJson
    FMain.lbDOAJ.Add(s)
  Next

End Sub

' ============================================
' Función   : NombreArchivoDoajANombreBD
' Propósito : Convierte nombre de archivo d-* al nombre_archivo BD
'             Ejemplo: d-02-revista-v01-n01.xml → a-02-revista-v01-n01
' Parámetros: sArchivoDoaj As String
' Retorna   : String
' ============================================
Public Function NombreArchivoDoajANombreBD(sArchivoDoaj As String) As String

  Dim sBase As String = Left(sArchivoDoaj, Len(sArchivoDoaj) - 4)

  If Left(sBase, 2) = "d-" Then Return "a-" & Mid(sBase, 3)
  Return sBase

End Function

' ============================================
' Función   : ObtenerIdArticuloPorNombre
' Propósito : Busca el id_articulo por nombre_archivo (prefijo a-)
' Parámetros: sNombreArchivo As String
' Retorna   : Integer — id_articulo, o 0 si no se encuentra
' ============================================
Public Function ObtenerIdArticuloPorNombre(sNombreArchivo As String) As Integer

  Dim hRS As Result

  Try hRS = m_ConexionBD.mConn.Exec(
    "SELECT id_articulo FROM articulos WHERE nombre_archivo = &1 LIMIT 1",
    sNombreArchivo)

  If Error Then Return 0
  If hRS.Count = 0 Then Return 0

  Return hRS!id_articulo

End Function

' ============================================
' Función   : ValidarArchivoDoaj
' Propósito : Lee el archivo d-*.xml y consulta la BD para
'             verificar los requisitos del schema DOAJ.
'             Carga los resultados en FMain.gvDOAJ con
'             colores por estado: OK / ERROR / ADVERTENCIA.
' Parámetros: sArchivo    As String  — nombre del archivo (con .xml)
'             idArticulo  As Integer — id_articulo en la BD
' Retorna   : Boolean — True si no hay errores bloqueantes
' ============================================
Public Function ValidarArchivoDoaj(sArchivo As String, idArticulo As Integer) As Boolean

  Dim sRuta As String
  Dim xDoc As New XmlDocument
  Dim bValido As Boolean = True

  ' --- 1. Preparar GridView ---
  FMain.gvDOAJ.Clear
  FMain.gvDOAJ.Rows.Count = 0
  FMain.gvDOAJ.Columns.Count = 4
  FMain.gvDOAJ.Columns[0].Text = "Estado"
  FMain.gvDOAJ.Columns[0].Width = 120
  FMain.gvDOAJ.Columns[1].Text = "Campo DOAJ"
  FMain.gvDOAJ.Columns[1].Width = 200
  FMain.gvDOAJ.Columns[2].Text = "Valor encontrado"
  FMain.gvDOAJ.Columns[2].Width = 300
  FMain.gvDOAJ.Columns[3].Text = "Acción requerida"
  FMain.gvDOAJ.Columns[3].Width = 800

  ' --- 2. Cargar XML ---
  sRuta = FMain.RutaProyecto &/ "jats" &/ sArchivo

  If Not Exist(sRuta) Then
    AgregarFilaGv(FMain.gvDOAJ, "ERROR", "archivo", "(no encontrado)", "Regenerar desde el canónico", True)
    Return False
  Endif

  Try xDoc.Open(sRuta)
  If Error Then
    AgregarFilaGv(FMain.gvDOAJ, "ERROR", "archivo", "XML malformado: " & Error.Text, "Verificar el XSLT", True)
    Return False
  Endif

  ' --- 3. Validar campos obligatorios ---
  Dim sPublisher As String = ObtenerNodoXml(xDoc, "publisher")
  If Not AgregarFilaGv(FMain.gvDOAJ, If(sPublisher <> "", "OK", "ERROR"),
      "publisher", If(sPublisher <> "", sPublisher, "(vacío)"),
      If(sPublisher = "", "Completar editorial en FMetadatosRevista", ""), True) Then
      bValido = False
    Endif

    Dim sJTitle As String = ObtenerNodoXml(xDoc, "journalTitle")
    If Not AgregarFilaGv(FMain.gvDOAJ, If(sJTitle <> "", "OK", "ERROR"),
        "journalTitle", If(sJTitle <> "", sJTitle, "(vacío)"),
        If(sJTitle = "", "Completar título de revista en FMetadatosRevista", ""), True) Then
        bValido = False
      Endif

      Dim sPubDate As String = ObtenerNodoXml(xDoc, "publicationDate")
      If Not AgregarFilaGv(FMain.gvDOAJ, If(sPubDate <> "", "OK", "ERROR"),
          "publicationDate", If(sPubDate <> "", sPubDate, "(vacío)"),
          If(sPubDate = "", "Completar fecha publicación en FMetadatosArticulos", ""), True) Then
          bValido = False
        Endif

        Dim sTitulo As String = ObtenerNodoXml(xDoc, "title")
        If Not AgregarFilaGv(FMain.gvDOAJ, If(sTitulo <> "", "OK", "ERROR"),
            "title", If(sTitulo <> "", sTitulo, "(vacío)"),
            If(sTitulo = "", "Completar título en FMetadatosArticulos", ""), True) Then
            bValido = False
          Endif

          Dim sEissn As String = ObtenerNodoXml(xDoc, "eissn")
          Dim sIssn As String = ObtenerNodoXml(xDoc, "issn")
          Dim sIssnMostrar As String = If(sEissn <> "", "eissn: " & sEissn, If(sIssn <> "", "issn: " & sIssn, "(ninguno)"))
          Dim bTieneIssn As Boolean = (sEissn <> "" Or sIssn <> "")
          If Not AgregarFilaGv(FMain.gvDOAJ, If(bTieneIssn, "OK", "ERROR"),
              "issn / eissn", sIssnMostrar,
              If(Not bTieneIssn, "Completar ISSN en FMetadatosRevista", ""), True) Then
              bValido = False
            Endif

            Dim sUrlFull As String = ""
            If idArticulo > 0 Then sUrlFull = ObtenerUrlTextoCompleto(idArticulo)
            If Not AgregarFilaGv(FMain.gvDOAJ, If(sUrlFull <> "", "OK", "ERROR"),
                "fullTextUrl", If(sUrlFull <> "", sUrlFull, "(vacío)"),
                If(sUrlFull = "", "Completar url_html / url_articulo en FMetadatosArticulos", ""), True) Then
                bValido = False
              Endif

              ' --- 4. Campos opcionales recomendados ---
              Dim sDoi As String = ObtenerNodoXml(xDoc, "doi")
              AgregarFilaGv(FMain.gvDOAJ, If(sDoi <> "", "OK", "ADVERTENCIA"),
                "doi", If(sDoi <> "", sDoi, "(ausente)"),
                If(sDoi = "", "Recomendado — completar DOI en FMetadatosArticulos", ""), False)

                Dim aAbstracts As XmlElement[] = xDoc.GetElementsByTagName("abstract")
                Dim sAbstract As String = If(aAbstracts.Count > 0, ObtenerNodoXml(xDoc, "abstract"), "")
                AgregarFilaGv(FMain.gvDOAJ, If(aAbstracts.Count > 0, "OK", "ADVERTENCIA"),
                  "abstract", If(aAbstracts.Count > 0, Left(sAbstract, 60) & "...", "(ausente)"),
                  If(aAbstracts.Count = 0, "Recomendado — completar resumen en FMetadatosArticulos", ""), False)

                  Dim aAutores As XmlElement[] = xDoc.GetElementsByTagName("author")
                  Dim sAutor As String = If(aAutores.Count > 0, ObtenerNodoXml(xDoc, "name"), "")
                  AgregarFilaGv(FMain.gvDOAJ, If(aAutores.Count > 0, "OK", "ADVERTENCIA"),
                    "authors", If(aAutores.Count > 0, sAutor & " (" & CStr(aAutores.Count) & ")", "(ausente)"),
                    If(aAutores.Count = 0, "Recomendado — vincular autores al artículo", ""), False)

                    Dim aKwds As XmlElement[] = xDoc.GetElementsByTagName("keyword")
                    AgregarFilaGv(FMain.gvDOAJ, If(aKwds.Count > 0, "OK", "ADVERTENCIA"),
                      "keywords", If(aKwds.Count > 0, ObtenerNodoXml(xDoc, "keyword") & " (" & CStr(aKwds.Count) & ")", "(ausente)"),
                      If(aKwds.Count = 0, "Recomendado — completar palabras clave", ""), False)

                      ' --- 5. Estado global ---
                      Dim i As Integer
                      For i = 0 To FMain.gvDOAJ.Rows.Count - 1
                        If FMain.gvDOAJ[i, 0].Text = "ERROR" Then
                          bValido = False
                          Break
                        Endif
                      Next

                      ' --- 6. Fila de resumen ---
                      Dim iUlt As Integer = FMain.gvDOAJ.Rows.Count
                      FMain.gvDOAJ.Rows.Count = iUlt + 1
                      FMain.gvDOAJ[iUlt, 0].Text = If(bValido, "APTO", "NO APTO")
                      FMain.gvDOAJ[iUlt, 2].Text = If(bValido, "El archivo puede subirse a DOAJ", "Corregir errores antes de subir")
                      Dim colorResumen As Integer = If(bValido, Color.RGB(200, 230, 201), Color.RGB(255, 205, 210))
                      Dim j As Integer
                      For j = 0 To 3
                        FMain.gvDOAJ[iUlt, j].Background = colorResumen
                        FMain.gvDOAJ[iUlt, j].Font.Bold = True
                      Next

                      Return bValido

End Function

' ============================================
' Función   : AgregarFilaGv
' Propósito : Agrega una fila a un GridView con color según estado.
'             Usado por ValidarArchivoDoaj, ValidarArchivoRedalyc
'             y ValidarArchivoLatex con el mismo patrón.
' Parámetros: gv           As GridView
'             sEstado      As String  — "OK" | "ERROR" | "ADVERTENCIA"
'             sCampo       As String  — nombre del campo
'             sValor       As String  — valor encontrado
'             sAccion      As String  — instrucción al editor
'             bObligatorio As Boolean — determina si un vacío es ERROR
' Retorna   : Boolean — True si el campo está OK o ADVERTENCIA
' ============================================
Public Function AgregarFilaGv(gv As GridView, sEstado As String, sCampo As String, sValor As String, sAccion As String, bObligatorio As Boolean) As Boolean

  Dim colorFondo As Integer

  Select Case sEstado
    Case "OK"
      colorFondo = Color.RGB(232, 245, 233)
    Case "ERROR"
      colorFondo = Color.RGB(255, 235, 238)
    Case "ADVERTENCIA"
      colorFondo = Color.RGB(255, 253, 231)
    Case Else
      colorFondo = Color.White
  End Select

  Dim iRow As Integer = gv.Rows.Count
  gv.Rows.Count = iRow + 1
  gv[iRow, 0].Text = sEstado
  gv[iRow, 1].Text = sCampo
  gv[iRow, 2].Text = sValor
  gv[iRow, 3].Text = sAccion

  Dim j As Integer
  For j = 0 To 3
    gv[iRow, j].Background = colorFondo
  Next

  Return (sEstado = "OK" Or sEstado = "ADVERTENCIA")

End Function

' ============================================
' Función   : ObtenerNodoXml
' Propósito : Devuelve el texto del primer nodo que coincide
'             con sTag en el documento ya cargado
' Parámetros: xDoc As XmlDocument, sTag As String
' Retorna   : String — texto del nodo, o cadena vacía
' ============================================
Private Function ObtenerNodoXml(xDoc As XmlDocument, sTag As String) As String

  Dim xNodo As XmlNode

  Try xNodo = xDoc.GetElementsByTagName(sTag)[0]
  If Error Or xNodo = Null Then Return ""

  Return Trim(xNodo.TextContent)

End Function

' ============================================
' Función   : ObtenerUrlTextoCompleto
' Propósito : Consulta la BD para obtener la mejor URL
'             disponible para fullTextUrl en DOAJ.
'             Cascada: url_html → url_articulo → url_pdf
' Parámetros: idArticulo As Integer
' Retorna   : String — URL encontrada, o cadena vacía
' ============================================
Public Function ObtenerUrlTextoCompleto(idArticulo As Integer) As String

  Dim hRS As Result

  Try hRS = m_ConexionBD.mConn.Exec(
    "SELECT url_html, url_articulo, url_pdf FROM articulos WHERE id_articulo = &1 LIMIT 1",
    idArticulo)

  If Error Then Return ""
  If hRS.Count = 0 Then Return ""

  If hRS!url_html <> Null Then
    If Trim(CStr(hRS!url_html)) <> "" Then Return Trim(CStr(hRS!url_html))
  Endif
  If hRS!url_articulo <> Null Then
    If Trim(CStr(hRS!url_articulo)) <> "" Then Return Trim(CStr(hRS!url_articulo))
  Endif
  If hRS!url_pdf <> Null Then
    If Trim(CStr(hRS!url_pdf)) <> "" Then Return Trim(CStr(hRS!url_pdf))
  Endif

  Return ""

End Function

' ============================================
' Función   : EnriquecerCanonico
' Propósito : Inyecta fullTextUrl como custom-meta en el canónico
'             JATS usando XmlDocument (gb.xml). Opera sobre el árbol
'             DOM sin manipulación de strings, preservando UTF-8.
' Parámetros: sRutaCanonico As String, idArticulo As Integer
' Retorna   : Boolean — True si el enriquecimiento fue exitoso
' ============================================
Public Function EnriquecerCanonico(sRutaCanonico As String, idArticulo As Integer) As Boolean

  Dim hRS As Result

  Try hRS = m_ConexionBD.mConn.Exec(
    "SELECT url_html, url_articulo, url_pdf FROM articulos WHERE id_articulo = &1 LIMIT 1",
    idArticulo)
  If Error Or Not hRS.Available Then Return False

  Dim sUrl As String = ""
  If Not IsNull(hRS!url_html) Then
    If Trim(CStr(hRS!url_html)) <> "" Then sUrl = Trim(CStr(hRS!url_html))
  Endif
  If sUrl = "" Then
    If Not IsNull(hRS!url_articulo) Then
      If Trim(CStr(hRS!url_articulo)) <> "" Then sUrl = Trim(CStr(hRS!url_articulo))
    Endif
  Endif
  If sUrl = "" Then
    If Not IsNull(hRS!url_pdf) Then
      If Trim(CStr(hRS!url_pdf)) <> "" Then sUrl = Trim(CStr(hRS!url_pdf))
    Endif
  Endif
  If sUrl = "" Then Return False

  Dim hDoc As XmlDocument = New XmlDocument
  Try hDoc.Open(sRutaCanonico)
  If Error Then Return False

  ' VERIFICAR SI YA FUE INYECTADO
  Dim aMetaNames As XmlElement[]
  aMetaNames = hDoc.GetElementsByTagName("meta-name")
  Dim hNode As XmlElement
  For Each hNode In aMetaNames
    If hNode.Value = "fullTextUrl" Then Return True
  Next

  Dim hMeta As XmlElement = hDoc.CreateElement("custom-meta")
  hMeta.NewElement("meta-name", "fullTextUrl")
  hMeta.NewElement("meta-value", sUrl)

  Dim aGrupo As XmlElement[]
  aGrupo = hDoc.GetElementsByTagName("custom-meta-group")

  If aGrupo.Count > 0 Then
    aGrupo[0].AppendChild(hMeta)
  Else
    Dim aArticleMeta As XmlElement[]
    aArticleMeta = hDoc.GetElementsByTagName("article-meta")
    If aArticleMeta.Count = 0 Then Return False
    Dim hGrupo As XmlElement = hDoc.CreateElement("custom-meta-group")
    hGrupo.AppendChild(hMeta)
    aArticleMeta[0].AppendChild(hGrupo)
  Endif

  Try hDoc.Save(sRutaCanonico)
  If Error Then Return False

  Return True

End Function

' ============================================
' Función   : GenerarJsonDoaj
' Propósito : Construye el JSON BibJSON para la API de DOAJ
'             leyendo datos de la BD. Guarda como d-*.json en jats/.
' Parámetros: sRutaCanonico As String — ruta al canónico JATS
'             idArticulo    As Integer — id del artículo en BD
' Retorna   : Boolean — True si el JSON se generó correctamente
' ============================================
Public Function GenerarJsonDoaj(sRutaCanonico As String, idArticulo As Integer) As Boolean

  ' --- 1. Inicialización de variables ---
  Dim hRes As Result
  Dim sJson As String
  Dim sRutaJson As String
  Dim q As String = Chr(34)  ' COMILLA DOBLE — USADA EN TODO EL JSON
  Dim n As String = Chr(10)  ' SALTO DE LÍNEA

  If Not Exist(sRutaCanonico) Then
    Message.Error("No se encuentra el canónico:" & Chr(10) & sRutaCanonico)
    Return False
  Endif

  ' --- 2. Consulta principal a la BD ---
  Try hRes = m_ConexionBD.mConn.Exec(
    "SELECT a.titulo_articulo, a.resumen_1, a.idioma_resumen_1, " &
    "a.palabras_clave_1, a.doi, " &
    "a.pagina_inicio, a.pagina_fin, " &
    "a.url_html, a.url_articulo, a.url_pdf, " &
    "a.id_doaj, a.nombre_archivo, " &
    "a.ano_publicacion, a.mes_publicacion, " &
    "r.titulo_revista, r.editorial, " &
    "r.issn_impreso, r.e_issn AS issn_electronico, " &
    "r.volumen, r.numero " &
    "FROM articulos a " &
    "JOIN revistas_md r ON a.id_revista = r.id_revista " &
    "WHERE a.id_articulo = &1 LIMIT 1",
    idArticulo)
  If Error Then
    Message.Error("Error al consultar la BD:" & Chr(10) & Error.Text)
    Return False
  Endif
  If Not hRes.Available Then
    Message.Error("No se encontró el artículo ID " & CStr(idArticulo))
    Return False
  Endif

  ' --- 3. Construir ruta del JSON ---
  sRutaJson = File.Dir(sRutaCanonico) &/ "d-" & Mid(File.BaseName(sRutaCanonico), 3) & ".json"

  ' --- 4. Bloque de autores ---
  Dim sAutores As String = ""
  Dim hAutores As Result
  Dim bPrimero As Boolean = True

  Try hAutores = m_ConexionBD.mConn.Exec(
    "SELECT a.nombre, a.apellidos, a.orcid, aa.afiliacion_momento " &
    "FROM autores a " &
    "JOIN articulo_autor aa ON a.id_autor = aa.id_autor " &
    "WHERE aa.id_articulo = &1 " &
    "AND aa.rol_autor IN ('autor', 'coautor', 'autor_correspondencia') " &
    "ORDER BY aa.orden_autoria",
    idArticulo)
  If Not Error Then
    While hAutores.Available
      Dim sNombreA As String = EscaparJson(
        Trim(hAutores["apellidos"]) & ", " & Trim(hAutores["nombre"]))
      Dim sOrcid As String = If(IsNull(hAutores["orcid"]), "",
        Trim(CStr(hAutores["orcid"])))
      Dim sAff As String = EscaparJson(If(IsNull(hAutores["afiliacion_momento"]), "",
        Trim(CStr(hAutores["afiliacion_momento"]))))

      If Not bPrimero Then sAutores &= ","
      sAutores &= n & "      {"
      sAutores &= n & "        " & q & "name" & q & ": " & q & sNombreA & q
      If sAff <> "" Then
        sAutores &= "," & n & "        " & q & "affiliation" & q & ": " & q & sAff & q
      Endif
      If sOrcid <> "" Then
        If Not (sOrcid Begins "https://") Then sOrcid = "https://orcid.org/" & sOrcid
        sAutores &= "," & n & "        " & q & "orcid_id" & q & ": " & q & sOrcid & q
      Endif
      sAutores &= n & "      }"
      bPrimero = False
      hAutores.MoveNext()
    Wend
  Endif

  ' --- 5. Bloque de identificadores ---
  Dim sIdentificadores As String = ""
  Dim bPrimeroId As Boolean = True

  If Not IsNull(hRes["issn_electronico"]) And Trim(CStr(hRes["issn_electronico"])) <> "" Then
    sIdentificadores &= n & "      {" & q & "type" & q & ": " & q & "eissn" & q &
      ", " & q & "id" & q & ": " & q & EscaparJson(Trim(CStr(hRes["issn_electronico"]))) & q & "}"
    bPrimeroId = False
  Endif
  If Not IsNull(hRes["issn_impreso"]) And Trim(CStr(hRes["issn_impreso"])) <> "" Then
    If Not bPrimeroId Then sIdentificadores &= ","
    sIdentificadores &= n & "      {" & q & "type" & q & ": " & q & "pissn" & q &
      ", " & q & "id" & q & ": " & q & EscaparJson(Trim(CStr(hRes["issn_impreso"]))) & q & "}"
    bPrimeroId = False
  Endif
  If Not IsNull(hRes["doi"]) And Trim(CStr(hRes["doi"])) <> "" Then
    If Not bPrimeroId Then sIdentificadores &= ","
    sIdentificadores &= n & "      {" & q & "type" & q & ": " & q & "doi" & q &
      ", " & q & "id" & q & ": " & q & EscaparJson(Trim(CStr(hRes["doi"]))) & q & "}"
  Endif

  ' --- 6. URL texto completo (cascada url_articulo → url_html → url_pdf) ---
  Dim sUrl As String = ""
  If Not IsNull(hRes["url_articulo"]) And Trim(CStr(hRes["url_articulo"])) <> "" Then
    sUrl = Trim(CStr(hRes["url_articulo"]))
  Else If Not IsNull(hRes["url_html"]) And Trim(CStr(hRes["url_html"])) <> "" Then
    sUrl = Trim(CStr(hRes["url_html"]))
  Else If Not IsNull(hRes["url_pdf"]) And Trim(CStr(hRes["url_pdf"])) <> "" Then
    sUrl = Trim(CStr(hRes["url_pdf"]))
  Endif

  ' --- 7. Palabras clave ---
  Dim sKeywords As String = ""
  Dim bPrimeroKw As Boolean = True

  If Not IsNull(hRes["palabras_clave_1"]) And Trim(CStr(hRes["palabras_clave_1"])) <> "" Then
    Dim aKwRaw As String[] = Split(Trim(CStr(hRes["palabras_clave_1"])), ",")
    Dim sKw As String
    For Each sKw In aKwRaw
      sKw = Trim(sKw)
      If sKw = "" Then Continue
      If Not bPrimeroKw Then sKeywords &= ","
      sKeywords &= n & "      " & q & EscaparJson(sKw) & q
      bPrimeroKw = False
    Next
  Endif

  ' --- 8. Construcción del JSON ---
  sJson = "{"
  sJson &= n & "  " & q & "bibjson" & q & ": {"
  sJson &= n & "    " & q & "title" & q & ": " & q & EscaparJson(Trim(CStr(hRes["titulo_articulo"]))) & q & ","

  If Not IsNull(hRes["resumen_1"]) And Trim(CStr(hRes["resumen_1"])) <> "" Then
    sJson &= n & "    " & q & "abstract" & q & ": " & q & EscaparJson(Trim(CStr(hRes["resumen_1"]))) & q & ","
  Endif

  sJson &= n & "    " & q & "year" & q & ": " & q & CStr(hRes["ano_publicacion"]) & q & ","

  If Not IsNull(hRes["mes_publicacion"]) And Trim(CStr(hRes["mes_publicacion"])) <> "" Then
    sJson &= n & "    " & q & "month" & q & ": " & q & Trim(CStr(hRes["mes_publicacion"])) & q & ","
  Endif

  If sKeywords <> "" Then
    sJson &= n & "    " & q & "keywords" & q & ": [" & sKeywords & n & "    ],"
  Endif

  If sAutores <> "" Then
    sJson &= n & "    " & q & "author" & q & ": [" & sAutores & n & "    ],"
  Endif

  sJson &= n & "    " & q & "identifier" & q & ": [" & sIdentificadores & n & "    ],"

  ' JOURNAL
  sJson &= n & "    " & q & "journal" & q & ": {"
  sJson &= n & "      " & q & "title" & q & ": " & q & EscaparJson(Trim(CStr(hRes["titulo_revista"]))) & q & ","
  sJson &= n & "      " & q & "publisher" & q & ": " & q & EscaparJson(Trim(CStr(hRes["editorial"]))) & q & ","
  sJson &= n & "      " & q & "volume" & q & ": " & q & Trim(CStr(hRes["volumen"])) & q & ","
  sJson &= n & "      " & q & "number" & q & ": " & q & Trim(CStr(hRes["numero"])) & q
  If Not IsNull(hRes["pagina_inicio"]) And Trim(CStr(hRes["pagina_inicio"])) <> "" Then
    sJson &= "," & n & "      " & q & "start_page" & q & ": " & q & Trim(CStr(hRes["pagina_inicio"])) & q
  Endif
  If Not IsNull(hRes["pagina_fin"]) And Trim(CStr(hRes["pagina_fin"])) <> "" Then
    sJson &= "," & n & "      " & q & "end_page" & q & ": " & q & Trim(CStr(hRes["pagina_fin"])) & q
  Endif
  sJson &= n & "    },"

  ' LINK
  If sUrl <> "" Then
    sJson &= n & "    " & q & "link" & q & ": ["
    sJson &= n & "      {"
    sJson &= n & "        " & q & "type" & q & ": " & q & "fulltext" & q & ","
    sJson &= n & "        " & q & "url" & q & ": " & q & EscaparJson(sUrl) & q & ","
    sJson &= n & "        " & q & "content_type" & q & ": " & q & "text/html" & q
    sJson &= n & "      }"
    sJson &= n & "    ]"
  Else
    ' ELIMINAR COMA FINAL SI NO HAY LINK
    If sJson Ends "," Then sJson = Left(sJson, Len(sJson) - 1)
  Endif

  sJson &= n & "  }"
  sJson &= n & "}"

  ' --- 9. Guardar ---
  Try File.Save(sRutaJson, sJson)
  If Error Then
    Message.Error("No se pudo guardar el JSON:" & Chr(10) & sRutaJson & Chr(10) & Error.Text)
    Return False
  Endif

  Return True

End Function

' ============================================
' Función   : EscaparJson
' Propósito : Escapa caracteres especiales en cadenas JSON
'             según RFC 8259
' Parámetros: s As String
' Retorna   : String — cadena escapada
' ============================================
Public Function EscaparJson(s As String) As String

  s = Replace(s, "\\", "\\\\")
  s = Replace(s, "" "", "\\" "")
  s = Replace(s, Chr(10), "\\n")
  s = Replace(s, Chr(13), "")
  s = Replace(s, Chr(9), "\\t")
  Return s

End Function

' ============================================
' Función   : EnviarJsonDoaj
' Propósito : Envía el JSON a la API de DOAJ via POST (primer envío)
'             o PUT (actualización si ya existe id_doaj en la BD).
'             El ID DOAJ devuelto se graba en articulos.id_doaj.
' Parámetros: sRutaJson  As String  — ruta al archivo d-*.json
'             sApiKey    As String  — clave API del publicador
'             idArticulo As Integer — ID del artículo en BD
' Retorna   : String — ID DOAJ si tuvo éxito, "" si falló
' ============================================
Public Function EnviarJsonDoaj(sRutaJson As String, sApiKey As String, idArticulo As Integer) As String

  If Not Exist(sRutaJson) Then
    Message.Error("No se encuentra el archivo JSON:\n" & sRutaJson)
    Return ""
  Endif
  If Trim(sApiKey) = "" Then
    Message.Error("La API key no puede estar vacía.")
    Return ""
  Endif

  Dim hRes As Result
  Dim sIdDoaj As String = ""
  Dim sMetodo As String = "POST"
  Dim sUrlApi As String

  Try hRes = m_ConexionBD.mConn.Exec(
    "SELECT id_doaj FROM articulos WHERE id_articulo = " & CStr(idArticulo))
  If Not Error Then
    If hRes.Count > 0 Then
      If Not IsNull(hRes["id_doaj"]) Then sIdDoaj = Trim(CStr(hRes["id_doaj"]))
    Endif
  Endif

  If sIdDoaj <> "" Then
    sMetodo = "PUT"
    sUrlApi = "https://doaj.org/api/articles/" & sIdDoaj & "?api_key=" & Trim(sApiKey)
  Else
    sMetodo = "POST"
    sUrlApi = "https://doaj.org/api/articles?api_key=" & Trim(sApiKey)
  Endif

  Dim sJson As String
  Dim hFile As File
  Try hFile = Open sRutaJson For Input
  If Error Then
    Message.Error("Error al abrir el JSON:\n" & Error.Text)
    Return ""
  Endif
  Try sJson = Read #hFile, Lof(hFile)
  Try Close #hFile

  Dim sTmpBody As String = "/tmp/doaj_body_" & CStr(idArticulo) & ".json"
  Dim sTmpResp As String = "/tmp/doaj_resp_" & CStr(idArticulo) & ".json"

  Try hFile = Open sTmpBody For Output
  Try Print #hFile, sJson
  Try Close #hFile

  Dim sCmd As String = "curl -s -o " & Shell(sTmpResp) &
    " -w " "%{http_code}" "" &
    " -X " & sMetodo &
    " -H " "Content-Type: application/json" "" &
    " --data-binary @" & Shell(sTmpBody) &
    " " "" & sUrlApi & "" ""

  Dim sHttpCode As String
  Shell sCmd To sHttpCode
  Wait
  If Error Then
    Message.Error("Error al ejecutar curl:\n" & Error.Text)
    Return ""
  Endif
  sHttpCode = Trim(sHttpCode)

  Dim sRespuesta As String
  Try hFile = Open sTmpResp For Input
  If Not Error Then
    Try sRespuesta = Read #hFile, Lof(hFile)
    Try Close #hFile
  Endif

  Try Kill sTmpBody
  Try Kill sTmpResp

  If sHttpCode = "201" Or sHttpCode = "200" Then
    Dim iInicio As Integer = InStr(sRespuesta, "" "id" ": " "")
    If iInicio > 0 Then
      iInicio += Len("" "id" ": " "")
      Dim iFin As Integer = InStr(iInicio, sRespuesta, "" "")
      If iFin > 0 Then sIdDoaj = Mid(sRespuesta, iInicio, iFin - iInicio)
    Endif

    If sIdDoaj = "" Then sIdDoaj = "OK-" & sHttpCode

    Try m_ConexionBD.mConn.Exec(
      "UPDATE articulos SET id_doaj = " & m_ConexionBD.mConn.Quote(sIdDoaj) &
      " WHERE id_articulo = " & CStr(idArticulo))
    If Error Then
      Message.Warning("Artículo aceptado por DOAJ pero no se pudo guardar el ID en la BD." &
        Chr(10) & "ID DOAJ: " & sIdDoaj &
        Chr(10) & "Anotalo manualmente para futuras actualizaciones.")
    Endif

    Return sIdDoaj

  Else
    Message.Error("DOAJ rechazó el artículo (HTTP " & sHttpCode & "):" & Chr(10) & sRespuesta)
    Return ""
  Endif

End Function

' ============================================
' Función   : NombreArchivoRedalycANombreBD
' Propósito : Convierte nombre de archivo r-* al nombre_archivo BD
'             Ejemplo: r-02-revista-v01-n01.xml → a-02-revista-v01-n01
' Parámetros: sArchivoRedalyc As String
' Retorna   : String
' ============================================
Public Function NombreArchivoRedalycANombreBD(sArchivoRedalyc As String) As String

  Dim sBase As String = Left(sArchivoRedalyc, Len(sArchivoRedalyc) - 4)

  If Left(sBase, 2) = "r-" Then Return "a-" & Mid(sBase, 3)
  Return sBase

End Function

' ============================================
' Función   : ValidarArchivoRedalyc
' Propósito : Lee el archivo r-*.xml y consulta la BD para
'             verificar los requisitos de indexación en Redalyc.
'             Basado en JATS4R + requisitos Marcalyc 4.0.
'             Carga los resultados en FMain.gvRedalyc.
' Parámetros: sArchivo    As String  — nombre del archivo (con .xml)
'             idArticulo  As Integer — id_articulo en la BD
' Retorna   : Boolean — True si no hay errores bloqueantes
' ============================================
Public Function ValidarArchivoRedalyc(sArchivo As String, idArticulo As Integer) As Boolean

  Dim sRuta As String
  Dim xDoc As New XmlDocument
  Dim bValido As Boolean = True
  Dim sTipoArticulo As String
  Dim bRequiereAbstract As Boolean

  ' --- 1. Preparar GridView ---
  FMain.gvRedalyc.Clear
  FMain.gvRedalyc.Rows.Count = 0
  FMain.gvRedalyc.Columns.Count = 4
  FMain.gvRedalyc.Columns[0].Text = "Estado"
  FMain.gvRedalyc.Columns[0].Width = 120
  FMain.gvRedalyc.Columns[1].Text = "Campo Redalyc"
  FMain.gvRedalyc.Columns[1].Width = 200
  FMain.gvRedalyc.Columns[2].Text = "Valor encontrado"
  FMain.gvRedalyc.Columns[2].Width = 300
  FMain.gvRedalyc.Columns[3].Text = "Acción requerida"
  FMain.gvRedalyc.Columns[3].Width = 800

  sRuta = FMain.RutaProyecto &/ "jats" &/ sArchivo

  If Not Exist(sRuta) Then
    AgregarFilaGv(FMain.gvRedalyc, "ERROR", "archivo", "(no encontrado)", "Regenerar desde el canónico", True)
    Return False
  Endif

  Try xDoc.Open(sRuta)
  If Error Then
    AgregarFilaGv(FMain.gvRedalyc, "ERROR", "archivo", "XML malformado: " & Error.Text, "Verificar el XSLT", True)
    Return False
  Endif

  ' ====================================================
  ' BLOQUE A: ERRORES — campos obligatorios
  ' ====================================================

  Dim aArticle As XmlElement[] = xDoc.GetElementsByTagName("article")
  Dim sArticleType As String = ""
  If aArticle.Count > 0 Then sArticleType = Trim(aArticle[0].Attributes["article-type"])

  If Not AgregarFilaGv(FMain.gvRedalyc, If(sArticleType <> "", "OK", "ERROR"),
      "article/@article-type",
      If(sArticleType <> "", sArticleType, "(ausente)"),
        If(sArticleType = "", "Completar tipo de artículo en FMetadatosArticulos", ""), True) Then
        bValido = False
      Endif

      Dim sXmlLang As String = ""
      If aArticle.Count > 0 Then sXmlLang = Trim(aArticle[0].Attributes["xml:lang"])

      If Not AgregarFilaGv(FMain.gvRedalyc, If(sXmlLang <> "", "OK", "ERROR"),
          "article/@xml:lang",
          If(sXmlLang <> "", sXmlLang, "(ausente)"),
            If(sXmlLang = "", "Completar idioma principal en FMetadatosArticulos", ""), True) Then
            bValido = False
          Endif

          Dim sJTitle As String = ObtenerNodoXml(xDoc, "journal-title")
          If Not AgregarFilaGv(FMain.gvRedalyc, If(sJTitle <> "", "OK", "ERROR"),
              "journal-title", If(sJTitle <> "", sJTitle, "(ausente)"),
              If(sJTitle = "", "Completar título de revista en FMetadatosRevista", ""), True) Then
              bValido = False
            Endif

            Dim aIssn As XmlElement[] = xDoc.GetElementsByTagName("issn")
            Dim sIssnVal As String = If(aIssn.Count > 0, Trim(aIssn[0].Value), "")
            Dim bTieneIssn As Boolean = (aIssn.Count > 0 And sIssnVal <> "")
            If Not AgregarFilaGv(FMain.gvRedalyc, If(bTieneIssn, "OK", "ERROR"),
                "issn",
                If(bTieneIssn, sIssnVal & " (" & CStr(aIssn.Count) & " registrado/s)", "(ninguno)"),
                  If(Not bTieneIssn, "Completar ISSN en FMetadatosRevista", ""), True) Then
                  bValido = False
                Endif

                Dim sPublisher As String = ObtenerNodoXml(xDoc, "publisher-name")
                If Not AgregarFilaGv(FMain.gvRedalyc, If(sPublisher <> "", "OK", "ERROR"),
                    "publisher-name", If(sPublisher <> "", sPublisher, "(ausente)"),
                    If(sPublisher = "", "Completar editorial en FMetadatosRevista", ""), True) Then
                    bValido = False
                  Endif

                  Dim sTitle As String = ObtenerNodoXml(xDoc, "article-title")
                  If Not AgregarFilaGv(FMain.gvRedalyc, If(sTitle <> "", "OK", "ERROR"),
                      "article-title",
                      If(sTitle <> "", Left(sTitle, 70) & If(Len(sTitle) > 70, "…", ""), "(ausente)"),
                        If(sTitle = "", "Completar título en FMetadatosArticulos", ""), True) Then
                        bValido = False
                      Endif

                      Dim aPubDate As XmlElement[] = xDoc.GetElementsByTagName("pub-date")
                      Dim sPubYear As String = ""
                      If aPubDate.Count > 0 Then
                        Dim xChild As XmlNode
                        For Each xChild In aPubDate[0].Children
                          If xChild.Name = "year" Then
                            sPubYear = Trim(xChild.Value)
                            Break
                          Endif
                        Next
                      Endif
                      If Not AgregarFilaGv(FMain.gvRedalyc, If(sPubYear <> "", "OK", "ERROR"),
                          "pub-date/year", If(sPubYear <> "", sPubYear, "(ausente)"),
                          If(sPubYear = "", "Completar fecha de publicación en FMetadatosArticulos", ""), True) Then
                          bValido = False
                        Endif

                        Dim aLicense As XmlElement[] = xDoc.GetElementsByTagName("license")
                        Dim sLicenseHref As String = ""
                        Dim bTieneCC As Boolean = False
                        If aLicense.Count > 0 Then
                          sLicenseHref = Trim(aLicense[0].Attributes["xlink:href"])
                          bTieneCC = (InStr(sLicenseHref, "creativecommons.org") > 0)
                        Endif

                        If Not AgregarFilaGv(FMain.gvRedalyc, If(aLicense.Count > 0, "OK", "ERROR"),
                            "permissions/license",
                            If(aLicense.Count > 0, sLicenseHref, "(ausente)"),
                              If(aLicense.Count = 0, "Completar licencia en FMetadatosRevista o FMetadatosArticulos", ""), True) Then
                              bValido = False
                            Endif

                            If aLicense.Count > 0 Then
                              If Not AgregarFilaGv(FMain.gvRedalyc, If(bTieneCC, "OK", "ERROR"),
                                  "license/@xlink:href CC",
                                  If(sLicenseHref <> "", sLicenseHref, "(sin URL)"),
                                    If(Not bTieneCC, "Redalyc requiere licencia Creative Commons — URL debe contener creativecommons.org", ""), True) Then
                                    bValido = False
                                  Endif
                                Endif

                                Dim aSurname As XmlElement[] = xDoc.GetElementsByTagName("surname")
                                Dim bTieneAutores As Boolean = (aSurname.Count > 0)
                                If Not AgregarFilaGv(FMain.gvRedalyc, If(bTieneAutores, "OK", "ERROR"),
                                    "contrib/name/surname",
                                    If(bTieneAutores, Trim(aSurname[0].Value) & " (" & CStr(aSurname.Count) & " autor/es)", "(ninguno)"),
                                      If(Not bTieneAutores, "Vincular autores al artículo en FMetadatosAutores", ""), True) Then
                                      bValido = False
                                    Endif

                                    Dim aMixed As XmlElement[] = xDoc.GetElementsByTagName("mixed-citation")
                                    Dim aElement As XmlElement[] = xDoc.GetElementsByTagName("element-citation")
                                    Dim aRefList As XmlElement[] = xDoc.GetElementsByTagName("ref-list")

                                    If aRefList.Count > 0 And (aMixed.Count > 0 Or aElement.Count > 0) Then
                                      If Not AgregarFilaGv(FMain.gvRedalyc, If(aMixed.Count = 0, "OK", "ERROR"),
                                          "element-citation (JATS4R)",
                                          If(aMixed.Count = 0, CStr(aElement.Count) & " element-citation", CStr(aMixed.Count) & " mixed-citation encontradas"),
                                            If(aMixed.Count > 0, "JATS4R requiere element-citation, no mixed-citation", ""), True) Then
                                            bValido = False
                                          Endif
                                        Endif

                                        ' ====================================================
                                        ' BLOQUE B: ADVERTENCIAS — campos recomendados
                                        ' ====================================================

                                        sTipoArticulo = Lower(sArticleType)
                                        bRequiereAbstract = (sTipoArticulo = "research-article" Or
                                          sTipoArticulo = "review-article" Or
                                          sTipoArticulo = "systematic-review")

                                        Dim aAbstract As XmlElement[] = xDoc.GetElementsByTagName("abstract")
                                        Dim sEstadoAbstract As String
                                        Dim sMensajeAbstract As String

                                        If bRequiereAbstract Then
                                          sEstadoAbstract = If(aAbstract.Count > 0, "OK", "ERROR")
                                          sMensajeAbstract = If(aAbstract.Count = 0,
                                            "Obligatorio para " & sArticleType & " — completar resumen en FMetadatosArticulos", "")
                                          If Not AgregarFilaGv(FMain.gvRedalyc, sEstadoAbstract,
                                              "abstract", If(aAbstract.Count > 0, CStr(aAbstract.Count) & " resumen/s", "(ausente)"),
                                              sMensajeAbstract, True) Then
                                            bValido = False
                                          Endif
                                        Else
                                          AgregarFilaGv(FMain.gvRedalyc, If(aAbstract.Count > 0, "OK", "ADVERTENCIA"),
                                            "abstract", If(aAbstract.Count > 0, CStr(aAbstract.Count) & " resumen/s", "(ausente)"),
                                            If(aAbstract.Count = 0, "Recomendado para " & sArticleType, ""), False)
                                          Endif

                                          If bRequiereAbstract And aAbstract.Count = 1 Then
                                            Dim aTransAbstract As XmlElement[] = xDoc.GetElementsByTagName("trans-abstract")
                                            AgregarFilaGv(FMain.gvRedalyc, If(aTransAbstract.Count > 0, "OK", "ADVERTENCIA"),
                                              "trans-abstract",
                                              If(aTransAbstract.Count > 0, CStr(aTransAbstract.Count) & " traducción/es de resumen", "(solo un idioma)"),
                                                If(aTransAbstract.Count = 0, "Redalyc recomienda resumen en al menos dos idiomas", ""), False)
                                              Endif

                                              Dim aKwdGroup As XmlElement[] = xDoc.GetElementsByTagName("kwd-group")
                                              Dim aKwds As XmlElement[] = xDoc.GetElementsByTagName("kwd")

                                              If bRequiereAbstract Then
                                                If Not AgregarFilaGv(FMain.gvRedalyc, If(aKwdGroup.Count > 0, "OK", "ERROR"),
                                                    "kwd-group",
                                                    If(aKwdGroup.Count > 0, CStr(aKwdGroup.Count) & " grupo/s, " & CStr(aKwds.Count) & " palabra/s clave", "(ausente)"),
                                                      If(aKwdGroup.Count = 0, "Obligatorio para " & sArticleType & " — completar en FMetadatosArticulos", ""), True) Then
                                                      bValido = False
                                                    Endif
                                                  Else
                                                    AgregarFilaGv(FMain.gvRedalyc, If(aKwdGroup.Count > 0, "OK", "ADVERTENCIA"),
                                                      "kwd-group",
                                                      If(aKwdGroup.Count > 0, CStr(aKwdGroup.Count) & " grupo/s, " & CStr(aKwds.Count) & " palabra/s clave", "(ausente)"),
                                                        If(aKwdGroup.Count = 0, "Recomendado — completar en FMetadatosArticulos", ""), False)
                                                      Endif

                                                      Dim aArticleId As XmlElement[] = xDoc.GetElementsByTagName("article-id")
                                                      Dim sDoiVal As String = ""
                                                      Dim xId As XmlElement
                                                      For Each xId In aArticleId
                                                        If Trim(xId.Attributes["pub-id-type"]) = "doi" Then
                                                          sDoiVal = Trim(xId.Value)
                                                          Break
                                                        Endif
                                                      Next
                                                      AgregarFilaGv(FMain.gvRedalyc, If(sDoiVal <> "", "OK", "ADVERTENCIA"),
                                                        "article-id[@pub-id-type='doi']",
                                                        If(sDoiVal <> "", sDoiVal, "(ausente)"),
                                                          If(sDoiVal = "", "Recomendado — completar DOI en FMetadatosArticulos", ""), False)

                                                          Dim aAff As XmlElement[] = xDoc.GetElementsByTagName("aff")
                                                          Dim aContrib As XmlElement[] = xDoc.GetElementsByTagName("contrib")
                                                          AgregarFilaGv(FMain.gvRedalyc, If(aAff.Count > 0, "OK", "ADVERTENCIA"),
                                                            "contrib/aff",
                                                            If(aAff.Count > 0, CStr(aAff.Count) & " afiliación/es para " & CStr(aContrib.Count) & " autor/es", "(sin afiliaciones)"),
                                                              If(aAff.Count = 0, "Redalyc requiere afiliación institucional — completar en FMetadatosAutores", ""), False)

                                                              Dim aOrcid As XmlElement[] = xDoc.GetElementsByTagName("contrib-id")
                                                              Dim iOrcidCount As Integer = 0
                                                              Dim xCid As XmlElement
                                                              For Each xCid In aOrcid
                                                                If Trim(xCid.Attributes["contrib-id-type"]) = "orcid" Then Inc iOrcidCount
                                                              Next
                                                              AgregarFilaGv(FMain.gvRedalyc, If(iOrcidCount > 0, "OK", "ADVERTENCIA"),
                                                                "contrib-id[@orcid]",
                                                                If(iOrcidCount > 0, CStr(iOrcidCount) & " ORCID registrado/s de " & CStr(aContrib.Count) & " autor/es", "(ninguno)"),
                                                                  If(iOrcidCount = 0, "Recomendado — registrar ORCID en FMetadatosAutores", ""), False)

                                                                  Dim sVolume As String = ObtenerNodoXml(xDoc, "volume")
                                                                  Dim sIssue As String = ObtenerNodoXml(xDoc, "issue")
                                                                  AgregarFilaGv(FMain.gvRedalyc, If(sVolume <> "" Or sIssue <> "", "OK", "ADVERTENCIA"),
                                                                    "volume / issue",
                                                                    If(sVolume <> "" Or sIssue <> "",
                                                                      "vol: " & If(sVolume <> "", sVolume, "—") & " / núm: " & If(sIssue <> "", sIssue, "—"),
                                                                      "(ambos ausentes)"),
                                                                      If(sVolume = "" And sIssue = "", "Completar volumen/número en FMetadatosRevista si aplica", ""), False)

                                                                      If bRequiereAbstract Then
                                                                        Dim aRef As XmlElement[] = xDoc.GetElementsByTagName("ref")
                                                                        AgregarFilaGv(FMain.gvRedalyc, If(aRef.Count > 0, "OK", "ADVERTENCIA"),
                                                                          "ref-list/ref",
                                                                          If(aRef.Count > 0, CStr(aRef.Count) & " referencia/s", "(sin referencias)"),
                                                                            If(aRef.Count = 0, "Inusual para " & sArticleType & " — verificar si corresponde", ""), False)
                                                                          Endif

                                                                          ' --- Estado global ---
                                                                          Dim i As Integer
                                                                          For i = 0 To FMain.gvRedalyc.Rows.Count - 1
                                                                            If FMain.gvRedalyc[i, 0].Text = "ERROR" Then
                                                                              bValido = False
                                                                              Break
                                                                            Endif
                                                                          Next

                                                                          ' --- Fila de resumen ---
                                                                          Dim iUlt As Integer = FMain.gvRedalyc.Rows.Count
                                                                          FMain.gvRedalyc.Rows.Count = iUlt + 1
                                                                          FMain.gvRedalyc[iUlt, 0].Text = If(bValido, "APTO", "NO APTO")
                                                                          FMain.gvRedalyc[iUlt, 2].Text = If(bValido,
                                                                            "El archivo puede enviarse a Marcalyc / Redalyc",
                                                                            "Corregir errores antes de enviar")
                                                                          Dim colorResumen As Integer = If(bValido, Color.RGB(200, 230, 201), Color.RGB(255, 205, 210))
                                                                          Dim j As Integer
                                                                          For j = 0 To 3
                                                                            FMain.gvRedalyc[iUlt, j].Background = colorResumen
                                                                            FMain.gvRedalyc[iUlt, j].Font.Bold = True
                                                                          Next

                                                                          Return bValido

End Function

' ============================================
' Función   : MostrarArchivosRedalyc
' Propósito : Lista archivos r-*.xml del directorio jats/
'             en el listbox lbRedalyc de FMain.
' ============================================
Public Sub MostrarArchivosRedalyc()

  Dim sRutaJats As String = File.Dir(FMain.txtProyecto.Text) &/ "jats"
  Dim aXml As New String[]
  Dim sArch As String

  FMain.lbRedalyc.Clear()

  If Not Exist(sRutaJats) Then Return

  For Each sArch In Dir(sRutaJats, "r-*.xml")
    aXml.Add(File.Name(sArch))
  Next

  aXml.Sort()

  Dim s As String
  For Each s In aXml
    FMain.lbRedalyc.Add(s)
  Next

End Sub

' ============================================
' Orden del pipeline LaTeX → PDF:
'   1. ObtenerPreambuloEmbebido()    — Private (auxiliar)
'   2. GenerarTeXBodyDesdeCanonico() — Public
'   3. EnsamblarTeX()                — Public
'   4. CompilarPDF()                 — Public
'   5. GenerarPDF()                  — Public (orquestador)
'   6. MostrarArchivosLatex()        — Public Sub
'
' Convención de archivos generados:
'   /latex/body-{base}.tex     — fragmento Saxon
'   /latex/l-{base}.tex        — documento completo ensamblado
'   /latex/l-{base}.pdf        — PDF intermedio lualatex
'   /salidas/pdf/l-{base}.pdf  — PDF final entregado al editor
' ============================================

' ============================================
' Función   : ObtenerPreambuloEmbebido
' Propósito : Genera el preámbulo LaTeX completo para el ensamblado.
'             El marcador %%BIBRESOURCE%% es reemplazado por
'             EnsamblarTeX() con la ruta real del .bib.
'             Si existe ~/.gbpublisher/gb-pdf-template.tex,
'             ese archivo tiene prioridad sobre este embebido.
' Retorna   : String — preámbulo LaTeX listo para l-*.tex
' ============================================
Private Function ObtenerPreambuloEmbebido(bBorrador As Boolean, sEstilo As String) As String

  FMain.TerminalViewProyecto.Input("echo 'DEBUG preambulo sEstilo: " & sEstilo & "'" & Chr(10))

  Dim s As String
  Dim sRutaProyecto As String = File.Dir(FMain.txtProyecto.Text)

  ' --- 1. Clase y opciones ---
  s = "\\documentclass{article}" & Chr(10) & Chr(10)

  ' --- 2. Fuentes y codificación (LuaLaTeX) ---
  s &= "% --- FUENTES Y CODIFICACIÓN ---" & Chr(10)
  s &= "\\usepackage[final,babel=True]{microtype}" & Chr(10)
  s &= "\\microtypecontext{spacing=nonfrench}" & Chr(10)
  s &= "\\usepackage{fontspec}" & Chr(10)
  s &= "\\usepackage{svg}" & Chr(10)
  s &= "\\svgsetup{inkscapelatex=false,inkscapearea=drawing}" & Chr(10)
  s &= "\\usepackage{unicode-math}" & Chr(10)
  s &= "\\setmathfont{Libertinus Math}[Scale=MatchLowercase]" & Chr(10)
  s &= "\\setsansfont[Scale=MatchLowercase,Ligatures=TeX," & Chr(10)
  s &= "  Extension=.otf,UprightFont=*-Regular,ItalicFont=*-Italic," & Chr(10)
  s &= "  BoldFont=*-SemiBold,BoldItalicFont=*-SemiBoldItalic]{IBMPlexSansCondensed}" & Chr(10)
  s &= "\\setmonofont[Scale=0.91,Extension=.otf,UprightFont=*-Regular," & Chr(10)
  s &= "  ItalicFont=IBMPlexMono-Italic.otf,BoldFont=IBMPlexMono-Bold.otf," & Chr(10)
  s &= "  BoldItalicFont=IBMPlexMono-BoldItalic.otf]{IBMPlexMono.otf}" & Chr(10)
  s &= Chr(10)

  ' --- 3. Idiomas ---
  s &= "% --- IDIOMAS ---" & Chr(10)
  s &= "\\usepackage[english,portuguese,main=spanish]{babel}" & Chr(10)
  s &= "\\usepackage[autostyle=true]{csquotes}" & Chr(10)
  s &= "\\setmainfont[Numbers={OldStyle,Proportional}," & Chr(10)
  s &= "  Ligatures={TeX,Common,Discretionary},Scale=1.18]{Libertinus Serif}" & Chr(10)
  s &= "\\renewcommand{\\normalsize}{\\fontsize{10pt}{13pt}\\selectfont}" & Chr(10)
  s &= Chr(10)
  ' --- 4. Bibliografía ---
  s &= "% --- BIBLIOGRAFÍA ---" & Chr(10)
  Select Case sEstilo
    Case "apa"
      s &= "\\usepackage[style=apa,backref=true,backend=biber]{biblatex}" & Chr(10)
      s &= "\\input{" & User.Home & "/.gbpublisher/biblatex/apa-config.tex}" & Chr(10)
      s &= "%%BIBRESOURCE%%" & Chr(10)
    Case "iso690"
      s &= "\\usepackage[style=iso-authoryear,backref=true,backend=biber]{biblatex}" & Chr(10)
      s &= "\\input{" & User.Home & "/.gbpublisher/biblatex/iso690-config.tex}" & Chr(10)
      s &= "%%BIBRESOURCE%%" & Chr(10)
    Case "ieee"
      s &= "\\usepackage[style=ieee,citestyle=numeric,backref=true,backend=biber]{biblatex}" & Chr(10)
      s &= "\\input{" & User.Home & "/.gbpublisher/biblatex/ieee-config.tex}" & Chr(10)
      s &= "%%BIBRESOURCE%%" & Chr(10)
    Case "vancouver"
      s &= "\\usepackage[nocompress]{cite}" & Chr(10)
      s &= "\\bibliographystyle{vancouver}" & Chr(10)
    Case Else
      s &= "\\usepackage[style=apa,backref=true,backend=biber]{biblatex}" & Chr(10)
      s &= "%%BIBRESOURCE%%" & Chr(10)
  End Select
  s &= Chr(10)
  ' --- 5. Página ---
  ' right=87mm: margen_real(13) + marginparsep(6) + marginparwidth(68) = 87mm
  ' textwidth = 210 - 13 - 87 = 110mm (deducido por geometry)
  ' headheight=29mm: logo(20) + separación(3) + barra(6) = 29mm
  s &= "% --- PÁGINA ---" & Chr(10)
  s &= "\\usepackage[paperwidth=210mm,paperheight=297mm," & Chr(10)
  s &= "  top=13mm,bottom=23mm,left=13mm,right=87mm," & Chr(10)
  s &= "  headsep=0mm,footskip=12mm,headheight=29mm,headsep=10mm," & Chr(10)
  s &= "  marginparsep=6mm,marginparwidth=68mm," & Chr(10)
  If bBorrador Then
    s &= "  includehead,includefoot,showframe]{geometry}" & Chr(10)
  Else
    s &= "  includehead,includefoot]{geometry}" & Chr(10)
  Endif
  s &= "\\setcounter{secnumdepth}{0}" & Chr(10)
  s &= Chr(10)
  ' --- 6. Posicionamiento absoluto ---
  ' \textblockorigin{0mm}{0mm} mide desde la esquina física del papel
  s &= "% --- POSICIONAMIENTO ABSOLUTO ---" & Chr(10)
  s &= "\\usepackage[absolute,overlay]{textpos}" & Chr(10)
  s &= "\\setlength{\\TPHorizModule}{1mm}" & Chr(10)
  s &= "\\setlength{\\TPVertModule}{1mm}" & Chr(10)
  s &= "\\textblockorigin{0mm}{0mm}" & Chr(10)
  s &= "\\newlength{\\gbbloquex}" & Chr(10)
  s &= "\\AtBeginDocument{\\setlength{\\gbbloquex}" &
    "{\\dimexpr 1in+\\hoffset+\\oddsidemargin+\\textwidth+\\marginparsep\\relax}}" & Chr(10)
  s &= Chr(10)
  ' --- 7. Tablas, figuras, varios ---
  s &= "% --- TABLAS Y FIGURAS ---" & Chr(10)
  s &= "\\usepackage{booktabs}" & Chr(10)
  s &= "\\usepackage{graphicx}" & Chr(10)
  s &= "\\usepackage[labelfont=bf,font=small,labelsep=period,format=plain]{caption}" & Chr(10)
  s &= Chr(10)
  s &= "% --- VARIOS ---" & Chr(10)
  s &= "\\newcommand{\\epigraph}[2]{%" & Chr(10)
  s &= "  \\par\\nobreak\\noindent\\par\\nobreak\\vspace{.5\\baselineskip}%" & Chr(10)
  s &= "  \\hfill{%" & Chr(10)
  s &= "    \\small" & Chr(10)
  s &= "    \\begin{tabular}{@{}>{{\\raggedright\\arraybackslash}}m{.65\\textwidth}@{}}%" & Chr(10)
  s &= "      #1 \\\\[1ex]%" & Chr(10)
  s &= "      \\midrule%" & Chr(10)
  s &= "      \\hfill #2%" & Chr(10)
  s &= "    \\end{tabular}%" & Chr(10)
  s &= "  }%" & Chr(10)
  s &= "  \\vspace{.5\\baselineskip}%" & Chr(10)
  s &= "}" & Chr(10)
  s &= "\\usepackage[hidelinks]{hyperref}" & Chr(10)
  s &= "\\usepackage[bottom,stable,hang]{footmisc}" & Chr(10)
  s &= "\\usepackage{scrextend}" & Chr(10)
  s &= "\\usepackage{changepage}" & Chr(10)
  s &= "\\newcommand{\\fullwidthblock}[1]{%" & Chr(10)
  s &= "  \\begin{adjustwidth}{0pt}{-\\dimexpr\\marginparsep+\\marginparwidth\\relax}%" & Chr(10)
  s &= "  \\centering #1%" & Chr(10)
  s &= "  \\end{adjustwidth}%" & Chr(10)
  s &= "}" & Chr(10)
  s &= "\\usepackage{rotating}" & Chr(10)
  ' SEPARACIÓN ENTRE NOTAS
  s &= "\\setlength{\\footnotesep}{10pt}" & Chr(10)
  ' LÍNEA SEPARADORA — SOLO UNA DEFINICIÓN
  s &= "\\renewcommand{\\footnoterule}{%" & Chr(10)
  s &= "  \\kern -3pt%" & Chr(10)
  s &= "  \\hrule height 0.5pt width 0.4\\columnwidth%" & Chr(10)
  s &= "  \\kern 6pt}" & Chr(10)
  ' NUMERACIÓN ENTRE CORCHETES EN SANS SERIF
  s &= "\\renewcommand*{\\thefootnote}{\\scriptsize\\sf{[\\arabic{footnote}]}}" & Chr(10)
  ' TAMAÑO DEL TEXTO DE LA NOTA
  s &= "\\makeatletter" & Chr(10)
  s &= "\\patchcmd{\\@footnotetext}{\\footnotesize}{\\small}{}{}" & Chr(10)
  s &= "\\makeatother" & Chr(10)
  ' POSICIÓN DEL NÚMERO: FUERA DE LA CAJA, ALINEADO A LA DERECHA
  s &= "\\newcommand*\\footnotemarkspace{0em}" & Chr(10)
  s &= "\\deffootnote{\\footnotemarkspace}" & Chr(10)
  s &= "  {\\parindent}" & Chr(10)
  s &= "  {\\makebox[\\footnotemarkspace][r]{\\llap{\\thefootnotemark\\quad}}}" & Chr(10)
  s &= "\\raggedbottom" & Chr(10)
  s &= "\\clubpenalty=10000" & Chr(10)
  s &= "\\widowpenalty=10000" & Chr(10)
  s &= "\\usepackage{siunitx}" & Chr(10)
  s &= "\\usepackage{enumitem}" & Chr(10)
  s &= "\\setlist{nosep,topsep=4pt}" & Chr(10)
  ' --- TÍTULOS DE SECCIÓN (titlesec) ---
  s &= "\\usepackage{titlesec}" & Chr(10)
  s &= "\\titleformat{\\section}[hang]" & Chr(10)
  s &= "  {\\sf\\bfseries\\Large\\color{azulrevista}\\raggedright}" & Chr(10)
  s &= "  {\\thesection}{.5em}{}[]" & Chr(10)
  s &= "\\titlespacing{\\section}" & Chr(10)
  s &= "  {\\parindent}{18pt plus 0.5pt minus 0.5pt}{6.75pt}" & Chr(10)
  s &= "\\titleformat{\\subsection}[hang]" & Chr(10)
  s &= "  {\\sf\\large\\color{azulrevista}\\raggedright}" & Chr(10)
  s &= "  {\\thesubsection}{.5em}{}[]" & Chr(10)
  s &= "\\titlespacing{\\subsection}" & Chr(10)
  s &= "  {\\parindent}{18pt plus 0.5pt minus 0.5pt}{6.75pt}" & Chr(10)
  s &= "\\titleformat{\\subsubsection}[hang]" & Chr(10)
  s &= "  {\\rm\\bfseries\\normalsize\\color{azulrevista}\\raggedright}" & Chr(10)
  s &= "  {\\thesubsubsection}{.5em}{}[]" & Chr(10)
  s &= "\\titlespacing{\\subsubsection}" & Chr(10)
  s &= "  {\\parindent}{18pt plus 0.5pt minus 0.5pt}{6.75pt}" & Chr(10)
  s &= "\\titleformat{\\paragraph}[runin]" & Chr(10)
  s &= "  {\\bfseries\\color{azulrevista}}{}{0em}{}[\\mbox{ --- }]" & Chr(10)
  s &= "\\titlespacing{\\paragraph}" & Chr(10)
  s &= "  {0pt}{6.75pt plus 0.5pt minus 0.5pt}{0pt}" & Chr(10)
  s &= "\\titleformat{\\subparagraph}[hang]" & Chr(10)
  s &= "  {\\sf\\bfseries\\large\\color{azulrevista}\\centering}" & Chr(10)
  s &= "  {\\thesubparagraph}{.5em}{}[]" & Chr(10)
  s &= "\\titlespacing{\\subparagraph}" & Chr(10)
  s &= "  {\\parindent}{18pt plus 0.5pt minus 0.5pt}{6.75pt}" & Chr(10)
  s &= "% --- COLOR ---" & Chr(10)
  s &= "\\usepackage[svgnames]{xcolor}" & Chr(10)
  s &= "\\usepackage{tcolorbox}" & Chr(10)
  s &= "\\definecolor{azulrevista}{HTML}{2d5a8e}" & Chr(10)
  s &= Chr(10)
  s &= "\\usepackage{listings}" & Chr(10)
  s &= "\\lstset{" & Chr(10)
  s &= "  basicstyle=\\ttfamily\\small," & Chr(10)
  s &= "  breaklines=true," & Chr(10)
  s &= "  breakatwhitespace=false," & Chr(10)
  s &= "  frame=single," & Chr(10)
  s &= "  framerule=0pt," & Chr(10)
  s &= "  backgroundcolor=\\color{black!5!white}," & Chr(10)
  s &= "  fillcolor=\\color{black!5!white}," & Chr(10)
  s &= "  rulecolor=\\color{black!5!white}," & Chr(10)
  s &= "  xleftmargin=8pt,xrightmargin=8pt," & Chr(10)
  s &= "  framexleftmargin=8pt,framexrightmargin=8pt," & Chr(10)
  s &= "  framextopmargin=6pt,framexbottommargin=6pt," & Chr(10)
  s &= "  aboveskip=8pt,belowskip=8pt," & Chr(10)
  s &= "  keywordstyle=\\color{blue!70!black}\\bfseries," & Chr(10)
  s &= "  commentstyle=\\color{green!50!black}\\itshape," & Chr(10)
  s &= "  stringstyle=\\color{orange!80!black}," & Chr(10)
  s &= "  showstringspaces=false," & Chr(10)
  s &= "  numbers=none," & Chr(10)
  s &= "  captionpos=b" & Chr(10)
  s &= "}" & Chr(10)
  s &= "\\renewenvironment{quote}" &
    "{\\normalsize\\list{}{\\sf\\leftmargin=14pt\\rightmargin=0pt}" &
    "\\item\\relax}{\\endlist}" & Chr(10)
  s &= Chr(10)
  If bBorrador Then
    s &= "\\usepackage[hyphenation,homeoarchy,homeoarchywordcolor=orange," &
      "homeoarchycharcolor=orange,draft]{impnattypo}" & Chr(10)
  Endif
  s &= Chr(10)

  ' --- 8. ENTORNO verse — bastardilla con sangría 14pt ---
  s &= "\\renewenvironment{verse}" & Chr(10)
  s &= "  {\\normalsize\\list{}{\\leftmargin=14pt\\rightmargin=0pt\\parsep=0pt}" & Chr(10)
  s &= "   \\item\\relax\\itshape}" & Chr(10)
  s &= "  {\\endlist}" & Chr(10)

  ' --- 9. Macro articulotipo (sobreescrita por XSLT) ---
  s &= "\\newcommand{\\articulotipo}{}" & Chr(10)
  s &= Chr(10)

  ' --- 10. Cabecera y pie ---
  ' headwidth = textwidth(110) + marginparsep(6) + marginparwidth(68) = 184mm
  s &= "% --- HEADER / FOOTER ---" & Chr(10)
  s &= "\\usepackage{fancyhdr}" & Chr(10)
  s &= "\\setlength{\\headwidth}{\\textwidth}" & Chr(10)
  s &= "\\addtolength{\\headwidth}{\\marginparsep}" & Chr(10)
  s &= "\\addtolength{\\headwidth}{\\marginparwidth}" & Chr(10)
  s &= Chr(10)

  ' ESTILO PRIMERA PÁGINA
  s &= "\\fancypagestyle{firstpage}{%" & Chr(10)
  s &= "  \\fancyhf{}%" & Chr(10)
  s &= "  \\fancyhead[L]{%" & Chr(10)
  s &= "    \\begin{minipage}[t]{\\headwidth}%" & Chr(10)
  s &= "    \\includegraphics[width=184mm,height=20mm,keepaspectratio=false]{" &
    sRutaProyecto &/ "media" &/ "logo-revista.png" & "}\\\\[3mm]%" & Chr(10)
  s &= "      {\\setlength{\\fboxsep}{0pt}%" & Chr(10)
  s &= "      \\colorbox{azulrevista}{%" & Chr(10)
  s &= "        \\parbox[c][6mm][c]{\\headwidth}{%" & Chr(10)
  s &= "          \\hspace{12pt}\\sffamily\\bfseries\\color{white}\\articulotipo%" & Chr(10)
  s &= "        }%" & Chr(10)
  s &= "      }}%" & Chr(10)
  s &= "    \\end{minipage}%" & Chr(10)
  s &= "  }%" & Chr(10)
  s &= "  \\renewcommand{\\headrulewidth}{0pt}%" & Chr(10)
  s &= "  \\fancyfoot[L]{%" & Chr(10)
  s &= "    \\begin{minipage}[t]{\\headwidth}%" & Chr(10)
  s &= "      \\textcolor{azulrevista}{\\rule{\\headwidth}{1pt}}\\\\[1pt]%" & Chr(10)
  s &= "      \\sffamily\\thepage\\hfill%" & Chr(10)
  s &= "      \\small\\articulorevista{} / e-ISSN: \\texttt{\\articuloissne}" &
    "{} / Vol.~\\articulovolumen{},~n.\\textsuperscript{o}~\\articulonumero{} / \\articulofecha%" & Chr(10)
  s &= "    \\end{minipage}%" & Chr(10)
  s &= "  }%" & Chr(10)
  s &= "  \\renewcommand{\\footrulewidth}{0pt}%" & Chr(10)
  s &= "}%" & Chr(10)
  s &= Chr(10)

  ' ESTILO PÁGINAS 2+
  s &= "\\pagestyle{fancy}" & Chr(10)
  s &= "\\fancyhf{}" & Chr(10)
  s &= "\\fancyhead[L]{%" & Chr(10)
  s &= "  \\raisebox{\\dimexpr\\headheight-7mm\\relax}[0pt][0pt]{%" & Chr(10)
  s &= "    \\begin{minipage}[b]{\\headwidth}%" & Chr(10)
  s &= "      \\sffamily\\thepage\\hfill%" & Chr(10)
  s &= "      \\small\\articulorevista{} / e-ISSN: \\texttt{\\articuloissne}" &
    "{} / Vol.~\\articulovolumen{},~n.\\textsuperscript{o}~\\articulonumero{} / \\articulofecha\\\\[1pt]%" & Chr(10)
  s &= "      \\textcolor{azulrevista}{\\rule{\\headwidth}{1pt}}%" & Chr(10)
  s &= "    \\end{minipage}%" & Chr(10)
  s &= "  }%" & Chr(10)
  s &= "}%" & Chr(10)
  s &= "\\renewcommand{\\headrulewidth}{0pt}" & Chr(10)
  s &= Chr(10)

  ' --- 10. Macros del artículo (sobreescritas por XSLT) ---
  s &= "% --- MACROS DEL ARTÍCULO (SOBREESCRITAS POR EL XSLT) ---" & Chr(10)
  s &= "\\newcommand{\\articulotitulo}{}" & Chr(10)
  s &= "\\newcommand{\\articulosubtitulo}{}" & Chr(10)
  s &= "\\newcommand{\\articulotitulotrans}{}" & Chr(10)
  s &= "\\newcommand{\\articuloautores}{}" & Chr(10)
  s &= "\\newcommand{\\articulodoi}{}" & Chr(10)
  s &= "\\newcommand{\\articuloidiomaxml}{es}" & Chr(10)
  s &= "\\newcommand{\\articulorevista}{}" & Chr(10)
  s &= "\\newcommand{\\articuloissne}{}" & Chr(10)
  s &= "\\newcommand{\\articulovolumen}{}" & Chr(10)
  s &= "\\newcommand{\\articulonumero}{}" & Chr(10)
  s &= "\\newcommand{\\articulofecha}{}" & Chr(10)
  s &= "\\newcommand{\\articulopagina}{0}" & Chr(10)
  s &= Chr(10)

  ' --- 11. Apertura del documento ---
  s &= "\\begin{document}" & Chr(10)

  Return s

End Function

' ============================================
' Función   : GenerarTeXBodyDesdeCanonico
' Propósito : Ejecuta Saxon-HE sobre c-*.xml con jats-to-latex.xsl
'             para generar el fragmento body-*.tex sin preámbulo.
' Parámetros: iIdArticulo As Integer
' Retorna   : Boolean — True si body-*.tex fue generado
' ============================================
Public Function GenerarTeXBodyDesdeCanonico(iIdArticulo As Integer, sEstilo As String) As Boolean

  Dim hArticulo As Result
  Dim sNombreArchivo As String
  Dim sNombreBase As String
  Dim sRutaProyecto As String
  Dim sRutaCanonico As String
  Dim sRutaSaxon As String
  Dim sRutaXSL As String
  Dim sRutaBody As String
  Dim sComando As String
  Dim iEspera As Integer

  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo FROM articulos WHERE id_articulo = &1 LIMIT 1", iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif
  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  sNombreArchivo = TrimUTF8(hArticulo["nombre_archivo"])
  sRutaProyecto = File.Dir(FMain.txtProyecto.Text)
  sNombreBase = Mid(sNombreArchivo, 3)
  sRutaCanonico = sRutaProyecto &/ "jats" &/ "c-" & sNombreBase & ".xml"
  sRutaSaxon = "/opt/Saxon-HE/saxon-he.jar"
  sRutaXSL = User.Home &/ ".gbpublisher" &/ "xslt" &/ "jats-to-latex.xsl"
  sRutaBody = sRutaProyecto &/ "latex" &/ "body-" & sNombreBase & ".tex"

  If Not Exist(sRutaCanonico) Then
    Message.Error("No se encontró el canónico JATS:" & Chr(10) & sRutaCanonico)
    Return False
  Endif
  If Not Exist(sRutaSaxon) Then
    Message.Error("No se encontró Saxon-HE en:" & Chr(10) & sRutaSaxon)
    Return False
  Endif
  If Not Exist(sRutaXSL) Then
    Message.Error("No se encontró la hoja de estilo LaTeX:" & Chr(10) & sRutaXSL)
    Return False
  Endif

  If Exist(sRutaBody) Then
    FMain.TerminalViewProyecto.Input("rm -f '" & sRutaBody & "'" & Chr(10))
    Wait 0.2
  Endif

  ' PRIMERO: leer la URL desde la BD
  Dim hUrl As Result
  Dim sUrlArticulo As String = ""
  Try hUrl = m_ConexionBD.mConn.Exec(
    "SELECT url_html, url_articulo, url_pdf FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)
  If Not Error And hUrl.Available Then
    If Not IsNull(hUrl["url_html"]) Then
      If Trim(CStr(hUrl["url_html"])) <> "" Then sUrlArticulo = Trim(CStr(hUrl["url_html"]))
    Endif
    If sUrlArticulo = "" And Not IsNull(hUrl["url_articulo"]) Then
      If Trim(CStr(hUrl["url_articulo"])) <> "" Then sUrlArticulo = Trim(CStr(hUrl["url_articulo"]))
    Endif
    If sUrlArticulo = "" And Not IsNull(hUrl["url_pdf"]) Then
      If Trim(CStr(hUrl["url_pdf"])) <> "" Then sUrlArticulo = Trim(CStr(hUrl["url_pdf"]))
    Endif
  Endif

  FMain.TerminalViewProyecto.Input("echo '=== LATEX: TRANSFORMANDO CANÓNICO ==='" & Chr(10))
  Dim sRutaCatalogo As String = User.Home &/ ".gbpublisher" &/ "dtd" &/ "catalog-jats-v1-4-no-base.xml"
  sComando =
    "java -jar '" & sRutaSaxon & "' " &
    "-catalog:'" & sRutaCatalogo & "' " &
    "-s:'" & sRutaCanonico & "' " &
    "-xsl:'" & sRutaXSL & "' " &
    "-o:'" & sRutaBody & "' " &
    "estilo_cita='" & sEstilo & "' " &
    "ruta_fonts='" & User.Home & "/.gbpublisher/fonts/' " &
    "url_articulo='" & sUrlArticulo & "'" & Chr(10)
  FMain.TerminalViewProyecto.Input(sComando)

  iEspera = 0
  While Not Exist(sRutaBody) And iEspera < 500
    Wait 0.1
    Inc iEspera
  Wend

  If Not Exist(sRutaBody) Then
    Message.Error("Saxon no generó el body LaTeX en el tiempo esperado.")
    Return False
  Endif

  Wait 0.3

  If File.Load(sRutaBody) = "" Then
    Message.Error("El body LaTeX generado está vacío.")
    Return False
  Endif

  Return True

Catch
  Message.Error("Error inesperado en GenerarTeXBodyDesdeCanonico:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : EnsamblarTeX
' Propósito : Combina preámbulo (gb-pdf-template.tex si existe,
'             o () como fallback) con el
'             body Saxon y genera l-*.tex listo para compilar.
'             Inserta \addbibresource solo si el artículo tiene
'             referencias_citadas y el .bib existe.
' Parámetros: iIdArticulo As Integer
' Retorna   : Boolean — True si l-*.tex fue guardado
' ============================================
Public Function EnsamblarTeX(iIdArticulo As Integer, bBorrador As Boolean, sEstilo As String) As Boolean

  Dim hArticulo As Result
  Dim sNombreArchivo As String
  Dim sNombreBase As String
  Dim sRutaProyecto As String
  Dim sRutaLatex As String
  Dim sRutaBody As String
  Dim sRutaTex As String
  Dim sRutaBib As String
  Dim sPreamble As String
  Dim sBody As String
  Dim sCierre As String
  Dim sTexFinal As String
  Dim sAddbibresource As String
  Dim bTieneReferencias As Boolean

  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo, referencias_citadas FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif
  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  sNombreArchivo = TrimUTF8(hArticulo["nombre_archivo"])
  sRutaProyecto = File.Dir(FMain.txtProyecto.Text)
  sNombreBase = Mid(sNombreArchivo, 3)
  sRutaLatex = sRutaProyecto &/ "latex"

  bTieneReferencias = False
  sRutaBib = sRutaProyecto &/ "referencias" &/ "ref-" & File.BaseName(FMain.txtProyecto.Text) & ".bib"

  If Not IsNull(hArticulo["referencias_citadas"]) Then
    If TrimUTF8(hArticulo["referencias_citadas"]) <> "" Then
      If Exist(sRutaBib) Then bTieneReferencias = True
    Endif
  Endif

  sRutaBody = sRutaProyecto &/ "latex" &/ "body-" & sNombreBase & ".tex"
  sRutaTex = sRutaProyecto &/ "latex" &/ "l-" & sNombreBase & ".tex"

  If Not Exist(sRutaBody) Then
    Message.Error("No se encontró el body LaTeX:" & Chr(10) & sRutaBody)
    Return False
  Endif

  Try sBody = File.Load(sRutaBody)
  If Error Then
    Message.Error("Error al leer el body LaTeX:" & Chr(10) & Error.Text)
    Return False
  Endif

  sPreamble = ObtenerPreambuloEmbebido(bBorrador, sEstilo)

  sAddbibresource = ""
  If bTieneReferencias Then
    If sEstilo <> "vancouver" Then
      sAddbibresource = "\\addbibresource{" & sRutaBib & "}"
    Endif
  Endif
  sPreamble = Replace(sPreamble, "%%BIBRESOURCE%%", sAddbibresource)

  sCierre = ""
  If bTieneReferencias Then
    If sEstilo = "vancouver" Then
      ' BIBTEX NO ACEPTA RUTAS ABSOLUTAS — COPIAR EL .BIB AL
      ' DIRECTORIO /latex/ Y REFERENCIAR SOLO POR NOMBRE BASE SIN EXT
      Shell "cp '" & sRutaBib & "' '" & sRutaLatex & "/'" Wait
      Dim sNombreBibBase As String = File.BaseName(sRutaBib)
      sCierre = "\\bibliography{" & sNombreBibBase & "}" & Chr(10)
    Else
      ' BIBLATEX: \printbibliography
      sCierre = "\\printbibliography" & Chr(10)
    Endif
  Endif
  sCierre &= "\\end{document}" & Chr(10)

  sTexFinal = sPreamble & Chr(10) & sBody & Chr(10) & sCierre

  Try File.Save(sRutaTex, sTexFinal)
  If Error Then
    Message.Error("Error al guardar el .tex ensamblado:" & Chr(10) & sRutaTex & Chr(10) & Error.Text)
    Return False
  Endif

  Return Exist(sRutaTex)

Catch
  Message.Error("Error inesperado en EnsamblarTeX:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : CompilarPDF
' Propósito : Compila l-*.tex con el pipeline LuaLaTeX:
'             CON referencias:   lualatex → biber → lualatex × 2
'             SIN referencias:   lualatex × 2
'             Usa centinela (.compile_done_*) para detectar fin.
'             El PDF se copia a /salidas/pdf/ y los auxiliares
'             de LaTeX se eliminan.
' Parámetros: iIdArticulo As Integer
' Retorna   : Boolean — True si PDF fue generado y copiado
' ============================================
Public Function CompilarPDF(iIdArticulo As Integer, sEstilo As String) As Boolean

  Dim hArticulo As Result
  Dim sNombreArchivo As String
  Dim sNombreBase As String
  Dim sRutaProyecto As String
  Dim sRutaLatex As String
  Dim sRutaTex As String
  Dim sRutaBib As String
  Dim sRutaPdfOrigen As String
  Dim sRutaPdfDestino As String
  Dim sRutaSalidasPdf As String
  Dim sRutaCentinela As String
  Dim sComando As String
  Dim iEspera As Integer
  Dim bTieneReferencias As Boolean

  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo, referencias_citadas FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)

  If Error Then
    Message.Error("Error al consultar el artículo:" & Chr(10) & Error.Text)
    Return False
  Endif
  If Not hArticulo.Available Then
    Message.Error("No se encontraron datos para el artículo id=" & CStr(iIdArticulo))
    Return False
  Endif

  sNombreArchivo = TrimUTF8(hArticulo["nombre_archivo"])
  sRutaProyecto = File.Dir(FMain.txtProyecto.Text)
  sNombreBase = Mid(sNombreArchivo, 3)

  bTieneReferencias = False
  sRutaBib = sRutaProyecto &/ "referencias" &/ "ref-" & File.BaseName(FMain.txtProyecto.Text) & ".bib"
  If Not IsNull(hArticulo["referencias_citadas"]) Then
    If TrimUTF8(hArticulo["referencias_citadas"]) <> "" Then
      If Exist(sRutaBib) Then bTieneReferencias = True
    Endif
  Endif

  sRutaLatex = sRutaProyecto &/ "latex"
  sRutaTex = "l-" & sNombreBase & ".tex"
  sRutaPdfOrigen = sRutaLatex &/ "l-" & sNombreBase & ".pdf"
  sRutaSalidasPdf = sRutaProyecto &/ "salidas" &/ "pdf"
  sRutaPdfDestino = sRutaSalidasPdf &/ "l-" & sNombreBase & ".pdf"
  sRutaCentinela = sRutaLatex &/ ".compile_done_" & sNombreBase

  If Not Exist(sRutaLatex &/ "l-" & sNombreBase & ".tex") Then
    Message.Error("No se encontró el .tex ensamblado:" & Chr(10) &
      sRutaLatex &/ "l-" & sNombreBase & ".tex")
    Return False
  Endif

  If Not Exist(sRutaSalidasPdf) Then
    Shell "mkdir -p '" & sRutaSalidasPdf & "'"
    Wait
  Endif

  FMain.TerminalViewProyecto.Input("rm -f '" & sRutaCentinela & "' '" & sRutaPdfOrigen & "'" & Chr(10))
  Wait 1

  sComando = "cd '" & sRutaLatex & "' && "
  sComando &= "lualatex -shell-escape -interaction=nonstopmode '" & sRutaTex & "'"

  If bTieneReferencias Then
    If sEstilo = "vancouver" Then
      sComando &= " ; bibtex 'l-" & sNombreBase & "'"
      sComando &= " ; lualatex -interaction=nonstopmode '" & sRutaTex & "'"
      FMain.TerminalViewProyecto.Input(
        "echo '=== PDF: lualatex → bibtex → lualatex × 3 ==='" & Chr(10))
    Else
      sComando &= " && biber 'l-" & sNombreBase & "'"
      sComando &= " && lualatex -interaction=nonstopmode '" & sRutaTex & "'"
      FMain.TerminalViewProyecto.Input(
        "echo '=== PDF: lualatex → biber → lualatex × 2 ==='" & Chr(10))
    Endif
    sComando &= " && lualatex -interaction=nonstopmode '" & sRutaTex & "'"
  Else
    FMain.TerminalViewProyecto.Input(
      "echo '=== PDF: lualatex × 2 (sin bibliografía) ==='" & Chr(10))
  Endif

  sComando &= " && lualatex -interaction=nonstopmode '" & sRutaTex & "'"
  sComando &= " ; touch '" & sRutaCentinela & "'"

  FMain.TerminalViewProyecto.Input(sComando & Chr(10))

  ' ESPERAR MÁXIMO 5 MINUTOS (3000 × 0.1s)
  iEspera = 0
  While Not Exist(sRutaCentinela) And iEspera < 3000
    Wait 0.1
    Inc iEspera
  Wend

  If Not Exist(sRutaCentinela) Then
    Message.Error("El pipeline de compilación no finalizó correctamente.")
    Return False
  Endif

  If Not Exist(sRutaPdfOrigen) Then
    Message.Error("lualatex no produjo el PDF:" & Chr(10) & sRutaPdfOrigen)
    Return False
  Endif

  FMain.TerminalViewProyecto.Input("cp -f '" & sRutaPdfOrigen & "' '" & sRutaPdfDestino & "' && " &
    "echo 'OK: PDF copiado'" & Chr(10))
  Wait 3

  ' INYECTAR METADATOS XMP EN EL PDF FINAL
  InyectarMetadatosXMP(iIdArticulo, sEstilo, sRutaPdfDestino)

  If Not Exist(sRutaPdfDestino) Then
    Message.Error("No se pudo copiar el PDF a /salidas/pdf/:" & Chr(10) & sRutaPdfDestino)
    Return False
  Endif

  If Not Exist(sRutaPdfDestino) Then
    Message.Error("No se pudo copiar el PDF a /salidas/pdf/:" & Chr(10) & sRutaPdfDestino)
    Return False
  Endif

  ' LIMPIAR AUXILIARES (conservar .tex y .pdf local como respaldo)
  FMain.TerminalViewProyecto.Input("cd '" & sRutaLatex & "' && " &
    "rm -f *.blg *.aux *.log *.bbl *.bcf *.out *.run.xml *.toc *.fls *.pdf " &
    "'" & sRutaCentinela & "'" & Chr(10))
  Wait 2 '

  FMain.TerminalViewProyecto.Input(
    "echo '=== PDF DISPONIBLE: " & sRutaPdfDestino & " ==='" & Chr(10))

  ' RESTAURAR DIRECTORIO DE TRABAJO
  FMain.TerminalViewProyecto.Input("cd '" & sRutaProyecto & "'" & Chr(10))

  Return True

Catch
  Message.Error("Error inesperado en CompilarPDF:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : GenerarPDF
' Propósito : Orquesta el pipeline completo JATS → LaTeX → PDF:
'             Paso 1: GenerarTeXBodyDesdeCanonico (Saxon → body.tex)
'             Paso 2: EnsamblarTeX (preámbulo + body → l-*.tex)
'             Paso 3: CompilarPDF (lualatex → PDF en /salidas/pdf/)
' Parámetros: iIdArticulo As Integer
' Retorna   : Boolean — True si el PDF final está en /salidas/pdf/
' ============================================
Public Function GenerarPDF(iIdArticulo As Integer, bBorrador As Boolean, sEstilo As String) As Boolean

  FMain.TerminalViewProyecto.Input("echo '=== INICIO PIPELINE PDF ==='" & Chr(10))

  If Not GenerarTeXBodyDesdeCanonico(iIdArticulo, sEstilo) Then
    Message.Error("Falló la transformación XSLT." & Chr(10) & "Pipeline cancelado.")
    Return False
  Endif

  If Not EnsamblarTeX(iIdArticulo, bBorrador, sEstilo) Then
    Message.Error("Falló el ensamblado del .tex." & Chr(10) & "Pipeline cancelado.")
    Return False
  Endif

  If Not CompilarPDF(iIdArticulo, sEstilo) Then
    Message.Error("Falló la compilación." & Chr(10) & "Revise el terminal para más detalles.")
    Return False
  Endif

  FMain.TerminalViewProyecto.Input("echo '=== PIPELINE PDF COMPLETADO ==='" & Chr(10))

  Return True

Catch
  Message.Error("Error inesperado en GenerarPDF:" & Chr(10) &
    Error.Text & Chr(10) & "Donde: " & Error.Where)
  Return False

End Function

' ============================================
' Función   : MostrarArchivosLatex
' Propósito : Lista archivos l-*.tex del directorio latex/
'             en el listbox lbLatex de FMain.
' ============================================
Public Sub MostrarArchivosLatex()

  Dim sRutaLatex As String = File.Dir(FMain.txtProyecto.Text) &/ "latex"
  Dim aTex As New String[]
  Dim sArch As String

  FMain.lbLatex.Clear()

  If Not Exist(sRutaLatex) Then Return

  For Each sArch In Dir(sRutaLatex, "l-*.tex")
    aTex.Add(File.Name(sArch))
  Next

  aTex.Sort()

  Dim s As String
  For Each s In aTex
    FMain.lbLatex.Add(s)
  Next

End Sub

' ============================================
' Función   : ValidarArchivoLatex
' Propósito : Lee el archivo l-*.tex ensamblado y verifica
'             la estructura mínima y el estado de los archivos
'             intermedios y finales del pipeline PDF.
'             Carga los resultados en FMain.gvLatex.
' Parámetros: sArchivo   As String  — nombre del archivo .tex
'             idArticulo As Integer — id_articulo en BD
' Retorna   : Boolean — True si no hay errores bloqueantes
' ============================================
Public Function ValidarArchivoLatex(sArchivo As String, idArticulo As Integer) As Boolean

  Dim sRutaProyecto As String = File.Dir(FMain.txtProyecto.Text)
  Dim sRutaLatex As String = sRutaProyecto &/ "latex"
  Dim sRutaTex As String = sRutaLatex &/ sArchivo
  Dim bValido As Boolean = True

  FMain.gvLatex.Clear
  FMain.gvLatex.Rows.Count = 0
  FMain.gvLatex.Columns.Count = 4
  FMain.gvLatex.Columns[0].Text = "Estado"
  FMain.gvLatex.Columns[0].Width = 120
  FMain.gvLatex.Columns[1].Text = "Componente"
  FMain.gvLatex.Columns[1].Width = 200
  FMain.gvLatex.Columns[2].Text = "Valor encontrado"
  FMain.gvLatex.Columns[2].Width = 300
  FMain.gvLatex.Columns[3].Text = "Acción requerida"
  FMain.gvLatex.Columns[3].Width = 800

  If Not Exist(sRutaTex) Then
    AgregarFilaGv(FMain.gvLatex, "ERROR", "l-*.tex", "(no encontrado)", "Ejecutar el pipeline PDF", True)
    Return False
  Endif

  Dim sTex As String
  Try sTex = File.Load(sRutaTex)
  If Error Then
    AgregarFilaGv(FMain.gvLatex, "ERROR", "l-*.tex", "Error al leer: " & Error.Text, "Verificar permisos", True)
    Return False
  Endif

  ' BLOQUE A: ESTRUCTURA MÍNIMA DEL .tex
  Dim bDocclass As Boolean = (InStr(sTex, "\\documentclass") > 0)
  Dim bBeginDoc As Boolean = (InStr(sTex, "\\begin{document}") > 0)
  Dim bEndDoc As Boolean = (InStr(sTex, "\\end{document}") > 0)
  Dim bTitulo As Boolean = (InStr(sTex, "\\renewcommand{\\articulotitulo}") > 0)

  If Not AgregarFilaGv(FMain.gvLatex, If(bDocclass, "OK", "ERROR"),
      "\\documentclass", If(bDocclass, "presente", "(ausente)"),
      If(Not bDocclass, "Verificar gb-pdf-template.tex", ""), True) Then
      bValido = False
    Endif

    If Not AgregarFilaGv(FMain.gvLatex, If(bBeginDoc, "OK", "ERROR"),
        "\\begin{document}", If(bBeginDoc, "presente", "(ausente)"),
        If(Not bBeginDoc, "Regenerar el pipeline", ""), True) Then
        bValido = False
      Endif

      If Not AgregarFilaGv(FMain.gvLatex, If(bEndDoc, "OK", "ERROR"),
          "\\end{document}", If(bEndDoc, "presente", "(ausente)"),
          If(Not bEndDoc, "Regenerar el pipeline", ""), True) Then
          bValido = False
        Endif

        If Not AgregarFilaGv(FMain.gvLatex, If(bTitulo, "OK", "ERROR"),
            "\\renewcommand{\\articulotitulo}",
            If(bTitulo, "presente (Saxon OK)", "(ausente)"),
              If(Not bTitulo, "La transformación XSLT falló — verificar el canónico JATS", ""), True) Then
              bValido = False
            Endif

            ' BLOQUE B: ARCHIVOS INTERMEDIOS Y FINALES
            Dim sNombreBase As String = Mid(Left(sArchivo, Len(sArchivo) - 4), 3)
            Dim sRutaBody As String = sRutaLatex &/ "body-" & sNombreBase & ".tex"
            Dim bBody As Boolean = Exist(sRutaBody)

            AgregarFilaGv(FMain.gvLatex, If(bBody, "OK", "ADVERTENCIA"),
              "body-*.tex", If(bBody, "presente en /latex/", "(no encontrado)"),
              If(Not bBody, "Archivo intermedio — se regenera en cada ejecución", ""), False)

              Dim bTieneRefsBD As Boolean = False
              If idArticulo > 0 Then
                Dim hRes As Result
                Try hRes = m_ConexionBD.mConn.Exec(
                  "SELECT referencias_citadas FROM articulos WHERE id_articulo = &1 LIMIT 1", idArticulo)
                If Not Error Then
                  If hRes.Available Then
                    If Not IsNull(hRes["referencias_citadas"]) Then
                      If TrimUTF8(hRes["referencias_citadas"]) <> "" Then bTieneRefsBD = True
                    Endif
                  Endif
                Endif
              Endif

              Dim bBibresource As Boolean = (InStr(sTex, "\\addbibresource") > 0)

              If bTieneRefsBD Then
                If Not AgregarFilaGv(FMain.gvLatex, If(bBibresource, "OK", "ERROR"),
                    "\\addbibresource",
                    If(bBibresource, "presente", "(ausente — artículo con referencias)"),
                      If(Not bBibresource, "Verificar el .bib", ""), True) Then
                      bValido = False
                    Endif
                  Else
                    AgregarFilaGv(FMain.gvLatex, If(Not bBibresource, "OK", "ADVERTENCIA"),
                      "\\addbibresource",
                      If(Not bBibresource, "ausente (correcto, sin referencias)", "presente (artículo sin referencias)"),
                        If(bBibresource, "Verificar el ensamblado", ""), False)
                      Endif

                      Dim sRutaPdfLatex As String = sRutaLatex &/ "l-" & sNombreBase & ".pdf"
                      Dim bPdfLatex As Boolean = Exist(sRutaPdfLatex)

                      AgregarFilaGv(FMain.gvLatex, If(bPdfLatex, "OK", "ADVERTENCIA"),
                        "PDF en /latex/", If(bPdfLatex, "presente", "(no generado aún)"),
                        If(Not bPdfLatex, "Ejecutar el pipeline PDF completo", ""), False)

                        Dim sRutaPdfFinal As String = sRutaProyecto &/ "salidas" &/ "pdf" &/ "l-" & sNombreBase & ".pdf"
                        Dim bPdfFinal As Boolean = Exist(sRutaPdfFinal)

                        If Not AgregarFilaGv(FMain.gvLatex, If(bPdfFinal, "OK", "ERROR"),
                            "PDF en /salidas/pdf/",
                            If(bPdfFinal, "l-" & sNombreBase & ".pdf", "(no encontrado)"),
                              If(Not bPdfFinal, "El pipeline no finalizó o no se ejecutó aún", ""), True) Then
                              bValido = False
                            Endif

                            ' BLOQUE C: COMPONENTES OPCIONALES
                            If bTieneRefsBD Then
                              Dim bPrintbib As Boolean = (InStr(sTex, "\\printbibliography") > 0)
                              AgregarFilaGv(FMain.gvLatex, If(bPrintbib, "OK", "ADVERTENCIA"),
                                "\\printbibliography", If(bPrintbib, "presente", "(ausente con referencias)"),
                                If(Not bPrintbib, "Verificar EnsamblarTeX()", ""), False)
                              Endif

                              Dim sRutaTemplate As String = User.Home &/ ".gbpublisher" &/ "gb-pdf-template.tex"
                              Dim bTemplatePersonal As Boolean = Exist(sRutaTemplate)
                              AgregarFilaGv(FMain.gvLatex, "OK",
                                "template",
                                If(bTemplatePersonal, "gb-pdf-template.tex (personalizado)", "preámbulo embebido (fábrica)"),
                                  "", False)

                                ' ESTADO GLOBAL
                                Dim i As Integer
                                For i = 0 To FMain.gvLatex.Rows.Count - 1
                                  If FMain.gvLatex[i, 0].Text = "ERROR" Then
                                    bValido = False
                                    Break
                                  Endif
                                Next

                                ' FILA DE RESUMEN
                                Dim iUlt As Integer = FMain.gvLatex.Rows.Count
                                FMain.gvLatex.Rows.Count = iUlt + 1
                                FMain.gvLatex[iUlt, 0].Text = If(bValido, "APTO", "NO APTO")
                                FMain.gvLatex[iUlt, 2].Text = If(bValido,
                                  "El PDF está generado y disponible en /salidas/pdf/",
                                  "Corregir errores o ejecutar el pipeline PDF")
                                Dim colorResumen As Integer = If(bValido, Color.RGB(200, 230, 201), Color.RGB(255, 205, 210))
                                Dim j As Integer
                                For j = 0 To 3
                                  FMain.gvLatex[iUlt, j].Background = colorResumen
                                  FMain.gvLatex[iUlt, j].Font.Bold = True
                                Next

                                Return bValido

End Function

' ============================================
' Función   : NombreArchivoLatexANombreBD
' Propósito : Convierte nombre de archivo l-*.tex al nombre_archivo BD
'             Ejemplo: l-02-revista-v01-n01.tex → a-02-revista-v01-n01
' Parámetros: sArchivoLatex As String
' Retorna   : String
' ============================================
Public Function NombreArchivoLatexANombreBD(sArchivoLatex As String) As String

  Dim sBase As String = Left(sArchivoLatex, Len(sArchivoLatex) - 4)

  If Left(sBase, 2) = "l-" Then Return "a-" & Mid(sBase, 3)
  Return sBase

End Function

' ============================================
' Función   : InyectarMetadatosXMP
' Propósito : Inyecta metadatos XMP completos en el PDF final
'             usando exiftool. Cubre Dublin Core, XMP básico,
'             PDF, PRISM 3.x e Iptc4xmpExt para ORCID/afiliación.
'             Opera sobre el PDF ya copiado en /salidas/pdf/.
' Parámetros: iIdArticulo As Integer
'             sEstilo     As String
'             sRutaPdf    As String — ruta completa al PDF final
' Retorna   : Boolean — True si exiftool terminó sin error
' ============================================
Public Function InyectarMetadatosXMP(iIdArticulo As Integer, sEstilo As String, sRutaPdf As String) As Boolean

  ' --- 1. Verificar que exiftool está disponible ---
  Dim sCheck As String

  Shell "which exiftool" To sCheck
  Wait
  If Trim(sCheck) = "" Then
    FMain.TerminalViewProyecto.Input(
      "echo 'AVISO: exiftool no encontrado — metadatos XMP omitidos'" & Chr(10))
    Return True  ' NO ES ERROR FATAL — el PDF ya está generado
  Endif

  ' --- 2. Localizar el canónico JATS ---
  Dim hArticulo As Result
  Try hArticulo = m_ConexionBD.mConn.Exec(
    "SELECT nombre_archivo FROM articulos WHERE id_articulo = &1 LIMIT 1",
    iIdArticulo)
  If Error Or Not hArticulo.Available Then Return True

  Dim sNombreArchivo As String = TrimUTF8(hArticulo["nombre_archivo"])
  Dim sNombreBase As String = Mid(sNombreArchivo, 3)
  Dim sRutaProyecto As String = File.Dir(FMain.txtProyecto.Text)
  Dim sRutaCanonico As String = sRutaProyecto &/ "jats" &/ "c-" & sNombreBase & ".xml"

  If Not Exist(sRutaCanonico) Then Return True

  ' --- 3. Parsear el canónico JATS ---
  Dim xDoc As New XmlDocument
  Try xDoc.Open(sRutaCanonico)
  If Error Then Return True

  ' --- 4. Extraer metadatos del canónico ---

  ' METADATOS DEL ARTÍCULO
  Dim sTitulo As String = ObtenerNodoXml(xDoc, "article-title")
  Dim sAbstract As String = ObtenerNodoXml(xDoc, "abstract")
  Dim sDoi As String = ObtenerNodoXml(xDoc, "article-id")

  ' DOI ESPECÍFICO POR ATRIBUTO pub-id-type
  Dim aIds As XmlElement[] = xDoc.GetElementsByTagName("article-id")
  Dim i As Integer
  For i = 0 To aIds.Count - 1
    If Trim(aIds[i].Attributes["pub-id-type"]) = "doi" Then
      sDoi = Trim(aIds[i].TextContent)
      Break
    Endif
  Next

  ' IDIOMA
  Dim aArticle As XmlElement[] = xDoc.GetElementsByTagName("article")
  Dim sLang As String = ""
  If aArticle.Count > 0 Then
    sLang = Trim(aArticle[0].Attributes["xml:lang"])
  Endif

  ' TIPO DE ARTÍCULO
  Dim sArticleType As String = ""
  If aArticle.Count > 0 Then
    sArticleType = Trim(aArticle[0].Attributes["article-type"])
  Endif

  ' METADATOS DE REVISTA
  Dim sJTitle As String = ObtenerNodoXml(xDoc, "journal-title")
  Dim sPublisher As String = ObtenerNodoXml(xDoc, "publisher-name")

  ' ISSN
  Dim sIssnPrint As String = ""
  Dim sIssnElec As String = ""
  Dim aIssn As XmlElement[] = xDoc.GetElementsByTagName("issn")
  For i = 0 To aIssn.Count - 1
    Dim sPubType As String = Trim(aIssn[i].Attributes["pub-type"])
    If sPubType = "ppub" Then sIssnPrint = Trim(aIssn[i].TextContent)
    If sPubType = "epub" Then sIssnElec = Trim(aIssn[i].TextContent)
  Next

  ' VOLUMEN, NÚMERO, PÁGINAS
  Dim sVolumen As String = ObtenerNodoXml(xDoc, "volume")
  Dim sNumero As String = ObtenerNodoXml(xDoc, "issue")
  Dim sFpage As String = ObtenerNodoXml(xDoc, "fpage")
  Dim sLpage As String = ObtenerNodoXml(xDoc, "lpage")

  ' FECHA DE PUBLICACIÓN
  Dim sAnio As String = ObtenerNodoXml(xDoc, "year")
  Dim sMes As String = ObtenerNodoXml(xDoc, "month")
  Dim sDia As String = ObtenerNodoXml(xDoc, "day")
  Dim sFechaISO As String = ""
  If sAnio <> "" Then
    sFechaISO = sAnio
    If sMes <> "" Then
      sFechaISO &= "-" & Format(CInt(sMes), "00")
      If sDia <> "" Then
        sFechaISO &= "-" & Format(CInt(sDia), "00")
      Endif
    Endif
  Endif

  ' PALABRAS CLAVE (primera kwd-group)
  Dim aKwds As XmlElement[] = xDoc.GetElementsByTagName("kwd")
  Dim sKeywords As String = ""
  For i = 0 To aKwds.Count - 1
    If i > 0 Then sKeywords &= ", "
    sKeywords &= Trim(aKwds[i].TextContent)
  Next

  ' LICENCIA
  Dim sLicencia As String = ""
  Dim aLicense As XmlElement[] = xDoc.GetElementsByTagName("license")
  If aLicense.Count > 0 Then
    sLicencia = Trim(aLicense[0].Attributes["xlink:href"])
  Endif

  ' --- 5. Construir lista de autores para dc:creator e Iptc4xmpExt ---
  Dim aContribs As XmlElement[] = xDoc.GetElementsByTagName("contrib")
  Dim sAutores As String = ""
  Dim sIptcAutores As String = ""

  For i = 0 To aContribs.Count - 1
    Dim hContrib As XmlElement = aContribs[i]
    If Trim(hContrib.Attributes["contrib-type"]) <> "author" Then Continue

    ' EXTRAER DATOS NAVEGANDO HIJOS DEL XmlElement
    ' XmlElement NO TIENE GetElementsByTagName — HAY QUE USAR Children
    Dim sGiven As String = ""
    Dim sSurname As String = ""
    Dim sOrcid As String = ""
    Dim sAfiliacion As String = ""

    ' BUSCAR RECURSIVAMENTE EN HIJOS
    sGiven = ObtenerHijoTexto(hContrib, "given-names")
    sSurname = ObtenerHijoTexto(hContrib, "surname")

    ' CONTRIB-ID CON ATRIBUTO orcid
    Dim j As Integer
    For j = 0 To hContrib.Children.Count - 1
      If Object.Type(hContrib.Children[j]) <> "XmlElement" Then Continue
      Dim hEl As XmlElement = hContrib.Children[j]
      If hEl.Name = "contrib-id" Then
        If Trim(hEl.Attributes["contrib-id-type"]) = "orcid" Then
          sOrcid = Trim(hEl.TextContent)
        Endif
      Endif
      If hEl.Name = "aff" Then
        sAfiliacion = ObtenerHijoTexto(hEl, "institution")
      Endif
    Next

    Dim sNombreCompleto As String = Trim(sGiven & " " & sSurname)
    If sNombreCompleto = "" Then Continue

    If sAutores <> "" Then sAutores &= "; "
    sAutores &= sNombreCompleto

    sIptcAutores &= " \"-XMP-iptcExt:PersonInImage+={PersonName=" & sNombreCompleto
    If sOrcid <> "" Then sIptcAutores &= ",PersonId=" & sOrcid
    If sAfiliacion <> "" Then
      sIptcAutores &= ",OrganisationInImageName=" & sAfiliacion
    Endif
    sIptcAutores &= "}\""

  Next

  ' --- 6. Construir el comando exiftool ---
  Dim sCmd As String = "exiftool -overwrite_original"

  ' DUBLIN CORE
  If sTitulo <> "" Then sCmd &= " -XMP-dc:Title=" & ShellQuote(sTitulo)
  If sAutores <> "" Then sCmd &= " -XMP-dc:Creator=" & ShellQuote(sAutores)
  If sAbstract <> "" Then sCmd &= " -XMP-dc:Description=" & ShellQuote(sAbstract)
  If sKeywords <> "" Then sCmd &= " -XMP-dc:Subject=" & ShellQuote(sKeywords)
  If sLang <> "" Then sCmd &= " -XMP-dc:Language=" & ShellQuote(sLang)
  If sDoi <> "" Then
    sCmd &= " -XMP-dc:Identifier=" & ShellQuote("https://doi.org/" & sDoi)
  Endif
  If sLicencia <> "" Then sCmd &= " -XMP-dc:Rights=" & ShellQuote(sLicencia)
  If sPublisher <> "" Then sCmd &= " -XMP-dc:Publisher=" & ShellQuote(sPublisher)

  ' XMP BÁSICO
  sCmd &= " -XMP-xmp:CreatorTool=gbpublisher"
  If sFechaISO <> "" Then
    sCmd &= " -XMP-xmp:CreateDate=" & ShellQuote(sFechaISO)
    sCmd &= " -XMP-xmp:MetadataDate=" & ShellQuote(sFechaISO)
  Endif

  ' PDF BÁSICO
  If sTitulo <> "" Then sCmd &= " -PDF:Title=" & ShellQuote(sTitulo)
  If sAutores <> "" Then sCmd &= " -PDF:Author=" & ShellQuote(sAutores)
  If sKeywords <> "" Then sCmd &= " -PDF:Keywords=" & ShellQuote(sKeywords)

  ' PRISM 3.x
  If sJTitle <> "" Then sCmd &= " -XMP-prism:PublicationName=" & ShellQuote(sJTitle)
  If sIssnElec <> "" Then sCmd &= " -XMP-prism:Eissn=" & ShellQuote(sIssnElec)
  If sIssnPrint <> "" Then sCmd &= " -XMP-prism:Issn=" & ShellQuote(sIssnPrint)
  If sDoi <> "" Then sCmd &= " -XMP-prism:Doi=" & ShellQuote(sDoi)
  If sVolumen <> "" Then sCmd &= " -XMP-prism:Volume=" & ShellQuote(sVolumen)
  If sNumero <> "" Then sCmd &= " -XMP-prism:Number=" & ShellQuote(sNumero)
  If sFpage <> "" Then sCmd &= " -XMP-prism:StartingPage=" & ShellQuote(sFpage)
  If sLpage <> "" Then sCmd &= " -XMP-prism:EndingPage=" & ShellQuote(sLpage)
  If sFechaISO <> "" Then sCmd &= " -XMP-prism:CoverDate=" & ShellQuote(sFechaISO)
  If sArticleType <> "" Then sCmd &= " -XMP-prism:ContentType=" & ShellQuote(sArticleType)
  If sLicencia <> "" Then sCmd &= " -XMP-cc:License=" & ShellQuote(sLicencia)

  ' IPTC4XMPEXT — ORCID Y AFILIACIÓN POR AUTOR
  If sIptcAutores <> "" Then sCmd &= sIptcAutores

  ' PDF A PROCESAR
  sCmd &= " '" & sRutaPdf & "'"

  ' --- 7. Ejecutar en terminal ---
  FMain.TerminalViewProyecto.Input(
    "echo '--- INYECTANDO METADATOS XMP ---'" & Chr(10))
  FMain.TerminalViewProyecto.Input(sCmd & Chr(10))
  Wait 3

  FMain.TerminalViewProyecto.Input(
    "echo 'OK: metadatos XMP inyectados'" & Chr(10))

  Return True

Catch
  FMain.TerminalViewProyecto.Input(
    "echo 'AVISO: error al inyectar metadatos XMP: " & Error.Text & "'" & Chr(10))
  Return True  ' NO ES ERROR FATAL

End Function

' ============================================
' Función   : ShellQuote
' Propósito : Escapa una cadena para uso seguro
'             como argumento de shell entre comillas simples
' Parámetros: s As String
' Retorna   : String entre comillas simples con escapes
' ============================================
Private Function ShellQuote(s As String) As String
  ' EN BASH, DENTRO DE COMILLAS SIMPLES NO HAY ESCAPES POSIBLES
  ' SE CIERRA LA COMILLA, SE PONE LA COMILLA ESCAPADA, SE REABRE

  Return "'" & Replace(s, "'", "'\\''") & "'"

End Function

' ============================================
' Función   : ObtenerHijoTexto
' Propósito : Busca un elemento hijo por nombre dentro de un
'             XmlElement y retorna su TextContent.
'             XmlElement NO tiene GetElementsByTagName —
'             se itera Children manualmente.
' Parámetros: hEl  As XmlElement — elemento raíz de búsqueda
'             sTag As String     — nombre del elemento a buscar
' Retorna   : String — texto del primer hijo encontrado, o ""
' ============================================
Private Function ObtenerHijoTexto(hEl As XmlElement, sTag As String) As String

  Dim i As Integer

  For i = 0 To hEl.Children.Count - 1
    ' Object.Type() DEVUELVE EL NOMBRE DE CLASE COMO STRING
    If Object.Type(hEl.Children[i]) <> "XmlElement" Then Continue
    Dim hHijo As XmlElement = hEl.Children[i]
    If hHijo.Name = sTag Then Return Trim(hHijo.TextContent)
    ' BUSCAR UN NIVEL MÁS PROFUNDO (name/given-names, name/surname)
    Dim sDeep As String = ObtenerHijoTexto(hHijo, sTag)
    If sDeep <> "" Then Return sDeep
  Next

  Return ""

End Function

' ============================================
' Función   : MostrarArchivosScielo
' Propósito : Lista todos los archivos s-*.xml del proyecto activo en FMain.lbSciELO.
' ============================================
Public Sub MostrarArchivosScielo()

  FMain.lbSciELO.Clear()

  Dim sRutaProyecto As String = File.Dir(FMain.txtProyecto.Text)
  Dim sRutaJats As String = sRutaProyecto &/ "jats"

  If Not Exist(sRutaJats) Then Return

  ' --- RECOLECTAR XML Y ZIP EN LISTAS SEPARADAS ---
  Dim aXml As New String[]
  Dim sArch As String

  For Each sArch In Dir(sRutaJats, "s-*.xml")
    aXml.Add(File.Name(sArch))
  Next

  aXml.Sort()

  ' --- CARGAR EN LISTBOX: XML ---
  Dim s As String
  For Each s In aXml
    FMain.lbSciELO.Add(s)
  Next

End Sub
