    { chkZWNJ CheckBox
      MoveScaled(6,0,16,4)
      Expand = True
      Text = ("Zero Width Non-Joiner (U+200C)")
    }
  }
  { HBoxBuscar5 HBox
    MoveScaled(1,17,81.3333,4)
    Spacing = True
    { chkZWJ CheckBox
      MoveScaled(6,0,16,4)
      Expand = True
      Text = ("Zero Width Joiner (U+200D)")
    }
  }
  { HBoxBuscar6 HBox
    MoveScaled(1,21,81.3333,4)
    Spacing = True
    { chkBOM CheckBox
      MoveScaled(6,0,23,4)
      Expand = True
      Text = ("BOM (U+FEFF) — marca de orden de bytes")
    }
  }
  { HBoxBuscar7 HBox
    MoveScaled(1,25,81.3333,4)
    Spacing = True
    { chkVariationSelectors CheckBox
      MoveScaled(6,0,16,4)
      Expand = True
      Text = ("Variation Selectors (U+FE00–U+FE0F)")
    }
  }
  { HBoxBuscar10 HBox
    MoveScaled(1,29,81.3333,4)
    Spacing = True
    { chkNBSP CheckBox
      MoveScaled(6,0,70,4)
      Expand = True
