      Expand = True
      Text = ("Soft Hyphen (U+00AD) — divisores invisibles de palabras")
    }
  }
  { HBoxBuscar2 HBox
    MoveScaled(1,9,81.3333,4)
    Spacing = True
    { chkZWSP CheckBox
      MoveScaled(6,0,16,4)
      Expand = True
      Text = ("Zero Width Space (U+200B) — espacios invisibles")
    }
  }
  { HBoxBuscar4 HBox
    MoveScaled(1,13,81.3333,4)
