# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,105,44)
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  Spacing = True
  Margin = True
  Padding = 4
  { HBoxBuscar9 HBox
    MoveScaled(1,1,81.3333,4)
    Spacing = True
    { Label2 Label
      MoveScaled(4,0,39,4)
      Font = Font["Bold"]
      Expand = True
      Alignment = Align.Center
      Text = ("Seleccione los caracteres invisibles a eliminar de todos los archivos .md del proyecto")
    }
  }
  { HBoxBuscar1 HBox
    MoveScaled(1,5,81.3333,4)
    Spacing = True
    { chkSoftHyphen CheckBox
