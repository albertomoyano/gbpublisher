' Gambas class file

' ============================================
' Función   : Form_Open
' Propósito : Carga la lista de proyectos activos en TableViewModoParcial,
'             configurando columnas, ancho, encabezados, y coloreando la
'             columna "Ocupado" según el estado.
' Parámetros: (Evento de formulario, sin parámetros)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub Form_Open()

  Dim rs As Result
  Dim sSQL As String
  Dim i As Integer

  ' --- 1. CONFIGURACIÓN DEL TABLEVIEW ---
  With TableViewModoParcial
    .Clear
    .Rows.Count = 0
    .Columns.Count = 8
    .Columns[0].Title = "ID"
    .Columns[0].Width = 0
    .Columns[1].Title = "Proyecto"
    .Columns[1].Width = 300
    .Columns[2].Title = "Activo"
    .Columns[2].Width = 0
    .Columns[3].Title = "Ocupado"
    .Columns[3].Width = 80
    .Columns[4].Title = "Tipo"
    .Columns[4].Width = 300
    .Columns[5].Title = ""
    .Columns[5].Width = 0
    .Columns[6].Title = ""
    .Columns[6].Width = 0
    .Columns[7].Title = "Usuario"
    .Columns[7].Width = 300
    .Mode = Select.Single
    .Header = True
  End With

  ' --- 2. CONSULTAR PROYECTOS ACTIVOS EN BD ---
  sSQL = "SELECT * FROM proyectos WHERE activo = 1"
  Try rs = m_ConexionBD.mConn.Exec(sSQL)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudieron obtener los proyectos activos:" & gb.NewLine & Error.Text)
    Return
  Endif

  If Not rs.Available Then Return

  ' --- 3. LLENAR FILAS DEL TABLEVIEW ---
  TableViewModoParcial.Rows.Count = rs.Count
  i = 0
  For Each rs

    ' DATOS BÁSICOS DE LA FILA
    TableViewModoParcial[i, 0].Text = rs["id"]
    TableViewModoParcial[i, 1].Text = rs["nombre"]
    TableViewModoParcial[i, 2].Text = rs["activo"]
    TableViewModoParcial[i, 7].Text = rs["usuario_propietario"]

    ' TIPO DE PROYECTO — USAR CONSTANTES DE m_Constantes, NO VALORES HARDCODED
    Select Case rs["tipo_producto"]
      Case m_Constantes.TIPO_REVISTA_MD
        TableViewModoParcial[i, 4].Text = "Revista en Markdown"
      Case m_Constantes.TIPO_LIBRO_MD
        TableViewModoParcial[i, 4].Text = "Libro en Markdown"
      Case m_Constantes.TIPO_LIBRO_LATEX
        TableViewModoParcial[i, 4].Text = "Libro en LaTeX"
      Default
        TableViewModoParcial[i, 4].Text = "Desconocido"
    End Select

    ' ESTADO "OCUPADO" CON COLOR
    ' RC-GM-01: TINYINT(1) DE MySQL ES Boolean EN GAMBAS, COMPARACIÓN DIRECTA
    If rs["ocupado"] Then
      TableViewModoParcial[i, 3].Text = "SÍ"
      TableViewModoParcial[i, 3].Background = Color.RGB(255, 200, 200)
    Else
      TableViewModoParcial[i, 3].Text = "NO"
      TableViewModoParcial[i, 3].Background = Color.RGB(200, 255, 200)
    Endif

    i += 1
  Next

End

' ============================================
' Función   : ButtonAbrirParcial_Click
' Propósito : Abre el proyecto seleccionado en TableViewModoParcial en modo
'             parcial (solo BBDD, sin editor). Antes libera cualquier proyecto
'             completo previo del usuario y limpia recursos asociados.
' Parámetros: (Evento de botón, sin parámetros)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub ButtonAbrirParcial_Click()

  Dim fila As Integer
  Dim idProyecto As Integer
  Dim nombreProyecto As String
  Dim tipoProyecto As Integer
  Dim sSQL As String
  Dim rs As Result

  ' --- 1. VALIDAR SELECCIÓN EN EL TABLEVIEW ---
  fila = TableViewModoParcial.Row
  If fila < 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar un proyecto de la lista.")
    Return
  Endif

  ' --- 2. LIBERAR PROYECTOS COMPLETOS PREVIOS DEL USUARIO EN BD ---
  ' SE LIBERAN TODOS LOS PROYECTOS DEL USUARIO QUE ESTÉN OCUPADOS,
  ' EN UNA SOLA SENTENCIA ATÓMICA. ASÍ SE CUBREN INCONSISTENCIAS
  ' DONDE FMain.id_proyecto.Value PUDIERA NO COINCIDIR CON EL REAL
  Try m_ConexionBD.mConn.Exec(
    "UPDATE proyectos SET usuario_propietario = NULL, ocupado = 0 WHERE usuario_propietario = &1 AND ocupado = 1",
    m_InicioCierre.UsuarioEnCurso)
  If Error Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se pudo liberar el proyecto completo anterior:" & gb.NewLine &
      Error.Text & gb.NewLine & gb.NewLine &
      "La apertura en modo parcial continúa, pero verificá el estado en BD al cerrar.")
  Else
    Try m_ConexionBD.mConn.Commit
  Endif

  ' --- 3. DETENER LA TERMINAL DE BASH DEL MODO COMPLETO PREVIO ---
  ' NOTA: ACCESO A VARIABLE PRIVADA FMain.$Bash. DEUDA TÉCNICA — MOVER
  ' ESTA LÓGICA A UNA FUNCIÓN PÚBLICA EN FMain (DetenerBashEnCurso)
  If FMain.$Bash Then
    If Object.IsValid(FMain.$Bash) Then
      If FMain.$Bash.State = Process.Running Then
        Try FMain.$Bash.Kill
        Wait 0.2
      Endif
    Endif
    FMain.$Bash = Null
  Endif

  ' --- 4. LEER EL REGISTRO COMPLETO DEL PROYECTO ELEGIDO ---
  idProyecto = Val(TableViewModoParcial[fila, 0].Text)
  sSQL = "SELECT * FROM proyectos WHERE id = &1"
  Try rs = m_ConexionBD.mConn.Exec(sSQL, idProyecto)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo recuperar el proyecto desde la base de datos:" & gb.NewLine & Error.Text)
    Return
  Endif

  If Not rs.Available Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo recuperar el proyecto desde la base de datos.")
    Return
  Endif

  tipoProyecto = rs["tipo_producto"]
  nombreProyecto = rs["nombre"]
  idProyecto = rs["id"]

  ' --- 5. VALIDAR QUE EL PROYECTO ESTÉ ACTIVO (RC-GM-01) ---
  If Not rs["activo"] Then
    m_Sonido.sonar("Warning")
    Message.Warning("El proyecto '" & nombreProyecto & "' está archivado." & gb.NewLine &
      "Debe activarlo antes de trabajar.")
    Return
  Endif

  ' --- 6. ACTUALIZAR EL ESTADO EN EL FORMULARIO PRINCIPAL ---
  FMain.txtProyecto.Text = nombreProyecto
  FMain.id_proyecto.Value = idProyecto

  ' --- 7. LIMPIAR FORMULARIOS DE BIBTEX Y SIGLAS ---
  ' (LA LIMPIEZA DE CACHÉ EN ~/.local/share/org.gambas.* ERA RESIDUO DE LA
  ' ETAPA gtk; YA NO APLICA CON qt5 Y LA CARPETA TARGET NO EXISTE)
  m_Bibtex.LimpiarTextboxBibtex()
  m_Siglas.LimpiarTextboxSigla()

  ' --- 8. CARGAR METADATOS SEGÚN TIPO DE PROYECTO ---
  Select Case tipoProyecto
    Case m_Constantes.TIPO_REVISTA_MD
      m_Metadatos.CargarMetadatosDeRevista
    Case m_Constantes.TIPO_LIBRO_MD
      ' TODO: IMPLEMENTAR m_Metadatos.CargarMetadatosDeLibro CUANDO ESTÉ LISTO
  End Select
  FMain.PictureBox9.Visible = False
  FMain.PictureBox12.Visible = False

  ' --- 9. CARGAR REFERENCIAS BIBTEX E INICIAR CONTADOR ---
  m_Bibtex.ConfigurarTableViewBibtexEnCurso(FMain.gvReferenciasEnCurso)
  m_Bibtex.IniciarBibtex
  m_Timer.IniciarContadorReloj(idProyecto)

  ' --- 10. MARCAR MODO PARCIAL Y CONFIGURAR VISIBILIDAD DE PANELES ---
  FMain.ValueBoxParcial.Value = 1
  FMain.SplitterPrincipal.Visible = True
  FMain.PanelEditorPrincipal.Visible = True
  FMain.Splitter1.Visible = False
  FMain.PanelPrincipalDerecho.Visible = True
  FMain.MenuButtonSalidas.Visible = False
  FMain.SpringTemporal.Visible = False

  ' --- 11. CONFIGURAR BOTONES SEGÚN TIPO DE PROYECTO ---
  m_FuncionesGenericas.BotonesLibroRevista(tipoProyecto = m_Constantes.TIPO_REVISTA_MD)

  ' --- 12. FEEDBACK Y CIERRE DEL FORMULARIO ---
  ' SOLO SONIDO COMO FEEDBACK DE ÉXITO. EL MENSAJE MODAL ANTERIOR ERA REDUNDANTE
  m_Sonido.sonar("Info")
  bCierrePermitido = True
  Me.Close

End

' --- BANDERA QUE PERMITE EL CIERRE DESDE EL BOTÓN Y BLOQUEA EL CIERRE
' --- DESDE LA X DEL SISTEMA. PATRÓN CANÓNICO DEL PROYECTO ---
Private bCierrePermitido As Boolean

' ============================================
' Función   : btnCerrar_Click
' Propósito : Habilita el flag de cierre permitido y cierra el formulario.
' ============================================
Public Sub btnCerrar_Click()

  bCierrePermitido = True
  Me.Close()

End

' ============================================
' Función   : Form_Close
' Propósito : Si el cierre viene del botón, permitirlo. Si viene de la X
'             del sistema, bloquearlo e informar al usuario.
' ============================================
Public Sub Form_Close()

  ' --- 1. SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO ---
  If bCierrePermitido Then Return

  ' --- 2. SI VIENE DE LA X DEL SISTEMA, BLOQUEAR Y AVISAR ---
  m_Sonido.sonar("Info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End
