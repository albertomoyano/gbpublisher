' Gambas module file

' ====================================================
' VARIABLES PRIVADAS DEL MÓDULO
' ====================================================
Private sRutaProyecto As String
Private sArchivoProyecto As String
Private sBaseNombreProyecto As String
Private sNombreArchivo As String
Private sFileCanonico As String
Private sSQL As String
Private rConsulta As Result
Private sComando As String
Private sSaxon As String

' ====================================================
' INICIALIZAR VARIABLES DESDE EL PROYECTO ACTIVO
' SE LLAMA AL INICIO DE CADA FUNCIÓN PÚBLICA
' ====================================================
Private Sub InicializarVariables()

  sSaxon = "/opt/Saxon-HE/saxon-he.jar"
  sRutaProyecto = File.Dir(FMain.txtProyecto.Text)
  sArchivoProyecto = File.Name(FMain.txtProyecto.Text)
  sBaseNombreProyecto = File.BaseName(FMain.txtProyecto.Text)

  ' OBTENER NOMBRE DEL ARCHIVO DEL ARTÍCULO ACTIVO EN EL EDITOR
  ' id_articulo SE ACTUALIZA CADA VEZ QUE SE SELECCIONA UN ARTÍCULO EN EL COMBOBOX
  sSQL = "SELECT nombre_archivo FROM articulos WHERE id_articulo = &1"
  rConsulta = m_ConexionBD.mConn.Exec(sSQL, FMain.id_articulo.Value)
  sNombreArchivo = m_XML.TrimUTF8(rConsulta["nombre_archivo"])

  ' CONSTRUIR RUTA DEL CANÓNICO DESDE EL NOMBRE DEL ARTÍCULO
  ' nombre_archivo = "a-02-revistaAlgo-v01-n01"
  ' sFileCanonico  = /ruta/proyecto/jats/c-02-revistaAlgo-v01-n01.xml
  sFileCanonico = sRutaProyecto &/ "jats" &/ "c-" & Mid(sNombreArchivo, 3) & ".xml"

End

' ====================================================
' GENERAR PDF DESDE LATEX
' ====================================================
Public Sub GenerarPDFdesdeLATEX()

  ' VERIFICAR QUE HAY UN PROYECTO ABIERTO
  If FMain.txtProyecto.Text = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay ningún proyecto abierto")
    Return
  Endif

  ' HACEMOS LAS EXPORTACIONES
  m_Json.ExportarMetadatosJSON2PDF()
  m_Bibtex.ExportarBibTeX()

  ' ASIGNAMOS LAS VARIABLES
  Dim sPreambulo As String = File.Load(File.Dir(FMain.txtProyecto.Text) &/ "files/pdf-preambulo.tex")
  Dim sContenido As String = File.Load(File.Dir(FMain.txtProyecto.Text) &/ File.Name(FMain.txtProyecto.Text))
  Dim sMain As String

  ' CONCATENAR LOS ARCHIVOS
  sMain = sPreambulo & gb.NewLine & gb.NewLine & sContenido

  ' GUARDAR EL ARCHIVO TEMPORAL CON EL CONTENIDO CONCATENADO
  Dim outputFile As String
  outputFile = File.Dir(FMain.txtProyecto.Text) &/ "temporal.tex"
  File.Save(outputFile, sMain)

  ' CONFIRMAMOS ESTAR EN EL DIRECTORIO DE TRABAJO DEL PROYECTO
  FMain.TerminalViewProyecto.Input("cd " & File.Dir(FMain.txtProyecto.Text) & "\n")
  FMain.TerminalViewProyecto.Input("clear" & "\n")

  ' COMPILAR CON LATEXMK USANDO EL PROCESO BASH EXISTENTE
  Dim compilar As String
  compilar = "latexmk -l -f -g --interaction=nonstopmode -pdflatex=lualatex -pdflua temporal.tex"
  FMain.TerminalViewProyecto.Input(compilar & "\n")
  Wait 1

  FMain.TerminalViewProyecto.Input("mv temporal.pdf" & " " &
    File.Dir(FMain.txtProyecto.Text) &/ "salidas/pdf/" &
    sBaseNombreProyecto & ".pdf" & "\n")

  ' LIMPIAMOS LOS ARCHIVOS AUXILIARES
  m_FuncionesGenericas.BorrarArchivosAuxiliares

End

' ====================================================
' GENERAR HTML PARA CONTROL (GITHUB PAGES → /docs)
' ====================================================
Public Sub GenerarHtmlControl()

  ' VERIFICAR QUE HAY UN PROYECTO ABIERTO
  If FMain.txtProyecto.Text = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay ningún proyecto abierto")
    Return
  Endif

  ' VERIFICAR QUE HAY UN ARTÍCULO SELECCIONADO EN EL EDITOR
  If FMain.id_articulo.Value = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay ningún artículo seleccionado en el editor.")
    Return
  Endif

  InicializarVariables()

  ' VERIFICAR QUE EL CANÓNICO EXISTE
  If Not Exist(sFileCanonico) Then
    Message.Error("No se encontró el canónico:" & Chr(10) & sFileCanonico & Chr(10) &
      "Generá primero el canónico (Paso 1.4).")
    Return
  Endif

  ' CONSTRUIR NOMBRE HTML: c-02-....xml → h-02-....html
  Dim sNombreHtml As String = "h" & Mid(File.Name(sFileCanonico), 2)
  sNombreHtml = File.BaseName(sNombreHtml) & ".html"

  ' RUTAS DE SALIDA Y XSLT
  Dim sFileHtml As String = sRutaProyecto &/ "docs" &/ sNombreHtml
  Dim sXslHtml As String = "/home/alberto/.gbpublisher/xslt/jats-to-html.xsl"
  Dim sTapa As String = FMetadatosRevista.imagen_tapa.Text

  FMain.TerminalViewProyecto.Input("echo '--- GENERANDO HTML PARA CONTROL ---'" & Chr(10))

  ' ELIMINAR HTML ANTERIOR SI EXISTE
  If Exist(sFileHtml) Then
    Shell "rm '" & sFileHtml & "'" Wait
  Endif

  ' EJECUTAR SAXON CON ruta_media=media PARA GITHUB PAGES
  FMain.TerminalViewProyecto.Input(
    "java -Djavax.xml.accessExternalDTD=all -jar " & sSaxon & " " &
    "-s:'" & sFileCanonico & "' " &
    "-xsl:'" & sXslHtml & "' " &
    "-o:'" & sFileHtml & "' " &
    "imagen_tapa='" & sTapa & "' " &
    "ruta_media='media'" & Chr(10))

  ' ESPERAR HASTA QUE SAXON GENERE EL HTML (MÁXIMO 60 SEGUNDOS)
  Dim iEspera As Integer = 0
  While Not Exist(sFileHtml) And iEspera < 600
    Wait 0.1
    Inc iEspera
  Wend

  If Not Exist(sFileHtml) Then
    FMain.TerminalViewProyecto.Input("echo 'ERROR: Saxon no generó el HTML'" & Chr(10))
    Message.Error("Saxon-HE no generó el HTML de control." & Chr(10) &
      "Revise los mensajes en la terminal.")
    Return
  Endif

  FMain.TerminalViewProyecto.Input("echo 'OK: HTML control generado'" & Chr(10))
  FMain.TerminalViewProyecto.Input("echo 'Ruta: " & sFileHtml & "'" & Chr(10))

  ' ====================================================
  ' SINCRONIZAR IMÁGENES A docs/media/
  ' GITHUB PAGES SOLO SIRVE LO QUE ESTÁ DENTRO DE /docs
  ' ====================================================
  Dim sRutaDocsMedia As String = sRutaProyecto &/ "docs" &/ "media"

  If Not Exist(sRutaDocsMedia) Then
    Shell "mkdir -p '" & sRutaDocsMedia & "'" Wait
  Endif

  ' COPIAR TODAS LAS IMÁGENES DE /media A /docs/media
  ' rsync SOLO COPIA LAS QUE CAMBIARON (más eficiente que cp)
  FMain.TerminalViewProyecto.Input(
    "rsync -a --update '" & sRutaProyecto &/ "media" & "/' '" &
    sRutaDocsMedia & "/'" & Chr(10))

  FMain.TerminalViewProyecto.Input("echo 'OK: imágenes sincronizadas → docs/media/'" & Chr(10))

  ' REGENERAR ÍNDICE AUTOMÁTICAMENTE
  GenerarIndiceHtml()

End

' ====================================================
' GENERAR HTML PARA OJS + ZIP (→ /salidas/html)
' INCLUYE EL HTML Y LAS IMÁGENES DECLARADAS EN EL JATS
' ====================================================
Public Sub GenerarHtmlOjs()

  ' VERIFICAR QUE HAY UN PROYECTO ABIERTO
  If FMain.txtProyecto.Text = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay ningún proyecto abierto")
    Return
  Endif

  ' VERIFICAR QUE HAY UN ARTÍCULO SELECCIONADO EN EL EDITOR
  If FMain.id_articulo.Value = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay ningún artículo seleccionado en el editor.")
    Return
  Endif

  InicializarVariables()

  ' VERIFICAR QUE EL CANÓNICO EXISTE
  If Not Exist(sFileCanonico) Then
    Message.Error("No se encontró el canónico:" & Chr(10) & sFileCanonico & Chr(10) &
      "Generá primero el canónico (Paso 1.4).")
    Return
  Endif

  ' CONSTRUIR NOMBRE BASE: c-02-....xml → h-02-....
  Dim sNombreBase As String = "h" & Mid(File.Name(sFileCanonico), 2)
  sNombreBase = File.BaseName(sNombreBase)

  ' RUTAS DE TRABAJO
  Dim sRutaSalida As String = sRutaProyecto &/ "salidas" &/ "html"
  Dim sFileHtml As String = sRutaSalida &/ sNombreBase & ".html"
  Dim sFileZip As String = sRutaSalida &/ sNombreBase & ".zip"
  Dim sRutaMedia As String = sRutaProyecto &/ "media"
  Dim sXslHtml As String = "/home/alberto/.gbpublisher/xslt/jats-to-html.xsl"
  Dim sTapa As String = FMetadatosRevista.imagen_tapa.Text

  ' CREAR CARPETA DE SALIDA SI NO EXISTE
  If Not Exist(sRutaSalida) Then
    Shell "mkdir -p '" & sRutaSalida & "'" Wait
  Endif

  FMain.TerminalViewProyecto.Input("echo '--- GENERANDO HTML PARA OJS ---'" & Chr(10))

  ' ELIMINAR ARCHIVOS ANTERIORES SI EXISTEN
  If Exist(sFileHtml) Then Shell "rm '" & sFileHtml & "'" Wait
  If Exist(sFileZip) Then Shell "rm '" & sFileZip & "'" Wait

  ' EJECUTAR SAXON CON ruta_media VACÍO PARA OJS
  FMain.TerminalViewProyecto.Input(
    "java -Djavax.xml.accessExternalDTD=all -jar " & sSaxon & " " &
    "-s:'" & sFileCanonico & "' " &
    "-xsl:'" & sXslHtml & "' " &
    "-o:'" & sFileHtml & "' " &
    "imagen_tapa='" & sTapa & "'" & Chr(10))

  ' ESPERAR HASTA QUE SAXON GENERE EL HTML (MÁXIMO 60 SEGUNDOS)
  Dim iEspera As Integer = 0
  While Not Exist(sFileHtml) And iEspera < 600
    Wait 0.1
    Inc iEspera
  Wend

  If Not Exist(sFileHtml) Then
    FMain.TerminalViewProyecto.Input("echo 'ERROR: Saxon no generó el HTML'" & Chr(10))
    Message.Error("Saxon-HE no generó el HTML para OJS." & Chr(10) &
      "Revise los mensajes en la terminal.")
    Return
  Endif

  ' ESPERAR QUE SAXON TERMINE DE ESCRIBIR SU SALIDA EN LA TERMINAL
  Wait 5

  FMain.TerminalViewProyecto.Input("echo 'OK: HTML OJS generado'" & Chr(10))

  ' ====================================================
  ' EXTRAER NOMBRES DE IMÁGENES DECLARADAS EN EL JATS
  ' VÍA SCRIPT PYTHON TEMPORAL — EVITA PROBLEMAS DE ESCAPE
  ' ====================================================
  FMain.TerminalViewProyecto.Input("echo '--- EXTRAYENDO IMÁGENES DEL JATS ---'" & Chr(10))

  Dim aImagenes As New String[]
  Dim sFileImagenes As String = sRutaSalida &/ "_imagenes.tmp"
  Dim sScriptPy As String = sRutaSalida &/ "_extract.py"

  ' ESCRIBIR SCRIPT PYTHON AL DISCO (SIN PROBLEMAS DE ESCAPE EN GAMBAS)
  Dim sPy As String
  sPy = "import xml.etree.ElementTree as ET" & Chr(10)
  sPy &= "import os" & Chr(10)
  sPy &= "tree = ET.parse('" & sFileCanonico & "')" & Chr(10)
  sPy &= "root = tree.getroot()" & Chr(10)
  sPy &= "seen = set()" & Chr(10)
  sPy &= "for graphic in root.iter('graphic'):" & Chr(10)
  sPy &= "    href = graphic.get('{http://www.w3.org/1999/xlink}href', '')" & Chr(10)
  sPy &= "    if href and not href.startswith('http'):" & Chr(10)
  sPy &= "        name = os.path.basename(href)" & Chr(10)
  sPy &= "        if name not in seen:" & Chr(10)
  sPy &= "            seen.add(name)" & Chr(10)
  sPy &= "            print(name)" & Chr(10)
  File.Save(sScriptPy, sPy)

  ' EJECUTAR EL SCRIPT Y GUARDAR RESULTADO EN ARCHIVO TEMPORAL
  FMain.TerminalViewProyecto.Input(
    "python3 '" & sScriptPy & "' > '" & sFileImagenes & "'" & Chr(10))

  ' ESPERAR QUE SE GENERE EL ARCHIVO TEMPORAL
  Dim iEspera2 As Integer = 0
  While Not Exist(sFileImagenes) And iEspera2 < 100
    Wait 0.1
    Inc iEspera2
  Wend

  ' LEER EL RESULTADO
  If Exist(sFileImagenes) Then
    Dim sLineas As String = File.Load(sFileImagenes)
    Dim aLineas As String[] = Split(Trim(sLineas), Chr(10))
    Dim sLinea As String
    For Each sLinea In aLineas
      sLinea = Trim(sLinea)
      If sLinea <> "" Then
        If aImagenes.Find(sLinea) = -1 Then aImagenes.Add(sLinea)
      Endif
    Next
    Shell "rm '" & sFileImagenes & "' '" & sScriptPy & "'" Wait
  Endif

  ' AGREGAR TAPA SI NO ESTÁ YA EN LA LISTA
  ' Dim sTapa As String = FMetadatosRevista.imagen_tapa.Text
  If sTapa <> "" Then
    If aImagenes.Find(File.Name(sTapa)) = -1 Then
      aImagenes.Add(File.Name(sTapa))
    Endif
  Endif

  FMain.TerminalViewProyecto.Input(
    "echo 'Imágenes encontradas: " & aImagenes.Count & "'" & Chr(10))

  ' ====================================================
  ' ARMAR EL ZIP CON EL HTML + LAS IMÁGENES
  ' ====================================================
  FMain.TerminalViewProyecto.Input("echo '--- GENERANDO ZIP ---'" & Chr(10))

  ' CONSTRUIR COMANDO ZIP DESDE LA CARPETA /salidas/html
  ' PARA QUE EL ZIP NO INCLUYA RUTAS ABSOLUTAS
  Dim sZipCmd As String
  sZipCmd = "cd '" & sRutaSalida & "' && zip '" & sFileZip & "' '" & sNombreBase & ".html'"

  ' AGREGAR CADA IMAGEN QUE EXISTA EN /media
  Dim sImagen As String
  Dim sCopiaImg As String
  For Each sImagen In aImagenes
    Dim sOrigen As String = sRutaMedia &/ sImagen
    If Exist(sOrigen) Then
      ' COPIAR TEMPORALMENTE LA IMAGEN A /salidas/html PARA EL ZIP
      Shell "cp '" & sOrigen & "' '" & sRutaSalida & "/'" Wait
      sZipCmd &= " '" & sImagen & "'"
      FMain.TerminalViewProyecto.Input("echo '  + " & sImagen & "'" & Chr(10))
    Else
      FMain.TerminalViewProyecto.Input(
        "echo '  AVISO: imagen no encontrada: " & sImagen & "'" & Chr(10))
    Endif
  Next

  ' EJECUTAR EL ZIP
  FMain.TerminalViewProyecto.Input(sZipCmd & Chr(10))

  ' ESPERAR HASTA QUE SE GENERE EL ZIP (MÁXIMO 30 SEGUNDOS)
  iEspera = 0
  While Not Exist(sFileZip) And iEspera < 300
    Wait 0.1
    Inc iEspera
  Wend

  ' LIMPIAR COPIAS TEMPORALES DE IMÁGENES EN /salidas/html
  For Each sImagen In aImagenes
    sCopiaImg = sRutaSalida &/ sImagen
    If Exist(sCopiaImg) Then Shell "rm '" & sCopiaImg & "'" Wait
  Next

  If Not Exist(sFileZip) Then
    FMain.TerminalViewProyecto.Input("echo 'ERROR: no se generó el ZIP'" & Chr(10))
    Message.Error("No se pudo generar el ZIP para OJS." & Chr(10) &
      "Revise los mensajes en la terminal.")
    Return
  Endif

  FMain.TerminalViewProyecto.Input("echo 'OK: ZIP OJS generado'" & Chr(10))
  FMain.TerminalViewProyecto.Input("echo 'Ruta: " & sFileZip & "'" & Chr(10))

End

' ====================================================
' GENERAR INDEX.HTML PARA GITHUB PAGES (→ /docs)
' LISTA TODOS LOS ARTÍCULOS DEL PROYECTO CON TÍTULO Y AUTORES
' SE LLAMA AUTOMÁTICAMENTE DESDE GenerarHtmlControl()
' ====================================================
Public Sub GenerarIndiceHtml()

  ' VARIABLES DE RUTAS
  Dim sRutaDocs As String = File.Dir(FMain.txtProyecto.Text) &/ "docs"
  Dim sFileIndex As String = sRutaDocs &/ "index.html"

  ' METADATOS DE LA REVISTA
  Dim sRevista As String = FMetadatosRevista.titulo_revista.Text
  Dim sVolumen As String = FMetadatosRevista.volumen.Text
  Dim sNumero As String = FMetadatosRevista.numero.Text
  Dim sAnio As String = FMetadatosRevista.ano_publicacion.Text
  Dim sTapa As String = FMetadatosRevista.imagen_tapa.Text

  ' CREAR CARPETA docs SI NO EXISTE
  If Not Exist(sRutaDocs) Then
    Shell "mkdir -p '" & sRutaDocs & "'" Wait
  Endif

  FMain.TerminalViewProyecto.Input("echo '--- GENERANDO ÍNDICE GITHUB PAGES ---'" & Chr(10))

  ' ====================================================
  ' CONSULTAR ARTÍCULOS DEL PROYECTO ORDENADOS POR nombre_archivo
  ' ====================================================
  Dim sSQL As String
  Dim rArticulos As Result

  sSQL = "SELECT id_articulo, nombre_archivo, titulo_articulo " &
    "FROM articulos " &
    "WHERE id_proyecto = &1 " &
    "ORDER BY nombre_archivo ASC"
  rArticulos = m_ConexionBD.mConn.Exec(sSQL, FMain.id_proyecto.Value)

  ' ====================================================
  ' CONSTRUIR EL HTML
  ' ====================================================
  Dim sHtml As String
  Dim sTapaHtml As String

  ' CONSTRUIR TAG DE TAPA SI EXISTE
  If sTapa <> "" Then
    sTapaHtml = "<img src=" & Chr(34) & "media/" & File.Name(sTapa) & Chr(34) &
      " alt=" & Chr(34) & "Tapa " & sRevista & Chr(34) & " class=" & Chr(34) & "tapa" & Chr(34) & "/>"
  Else
    sTapaHtml = "<div class=" & Chr(34) & "tapa-placeholder" & Chr(34) & ">Sin tapa</div>"
  Endif

  ' CABECERA HTML
  sHtml = "<!DOCTYPE html>" & Chr(10)
  sHtml &= "<html lang=" & Chr(34) & "es" & Chr(34) & ">" & Chr(10)
  sHtml &= "<head>" & Chr(10)
  sHtml &= "<meta charset=" & Chr(34) & "UTF-8" & Chr(34) & "/>" & Chr(10)
  sHtml &= "<meta name=" & Chr(34) & "viewport" & Chr(34) & " content=" & Chr(34) & "width=device-width, initial-scale=1.0" & Chr(34) & "/>" & Chr(10)
  sHtml &= "<title>" & sRevista & " — Vol. " & sVolumen & " Núm. " & sNumero & " (" & sAnio & ")</title>" & Chr(10)
  sHtml &= "<link rel=" & Chr(34) & "preconnect" & Chr(34) & " href=" & Chr(34) & "https://fonts.googleapis.com" & Chr(34) & "/>" & Chr(10)
  sHtml &= "<link rel=" & Chr(34) & "preconnect" & Chr(34) & " href=" & Chr(34) & "https://fonts.gstatic.com" & Chr(34) & " crossorigin/>" & Chr(10)
  sHtml &= "<link href=" & Chr(34) & "https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,400&display=swap" & Chr(34) & " rel=" & Chr(34) & "stylesheet" & Chr(34) & "/>" & Chr(10)
  sHtml &= "<style>" & Chr(10)
  sHtml &= ":root{--color-bg:#fafaf8;--color-surface:#fff;--color-border:#e2e0db;--color-text:#1a1a18;--color-text-muted:#6b6860;--color-accent:#2d5a8e;--color-accent-soft:#eef3f9;--font-serif:'Noto Serif',Georgia,serif;--font-sans:'IBM Plex Sans',system-ui,sans-serif;}" & Chr(10)
  sHtml &= "*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}" & Chr(10)
  sHtml &= "body{background:var(--color-bg);color:var(--color-text);font-family:var(--font-sans);font-size:1.125rem;line-height:1.7;-webkit-font-smoothing:antialiased;}" & Chr(10)
  sHtml &= ".contenedor{max-width:860px;margin:0 auto;padding:3rem 1.5rem 5rem;}" & Chr(10)
  sHtml &= ".cabecera{display:flex;gap:2rem;align-items:flex-start;margin-bottom:3rem;padding-bottom:2rem;border-bottom:2px solid var(--color-border);}" & Chr(10)
  sHtml &= ".tapa{width:140px;min-width:140px;height:auto;border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,0.10);}" & Chr(10)
  sHtml &= ".tapa-placeholder{width:140px;min-width:140px;height:190px;background:var(--color-accent-soft);border:2px dashed var(--color-border);border-radius:4px;display:flex;align-items:center;justify-content:center;color:var(--color-text-muted);font-size:0.75rem;}" & Chr(10)
  sHtml &= ".info-revista{flex:1;}" & Chr(10)
  sHtml &= ".nombre-revista{font-family:var(--font-sans);font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-accent);margin-bottom:0.5rem;}" & Chr(10)
  sHtml &= ".datos-numero{font-family:var(--font-serif);font-size:1.75rem;font-weight:400;color:var(--color-text);line-height:1.3;margin-bottom:0.5rem;}" & Chr(10)
  sHtml &= ".anio-numero{font-size:0.875rem;color:var(--color-text-muted);}" & Chr(10)
  sHtml &= ".lista-articulos{list-style:none;}" & Chr(10)
  sHtml &= ".articulo-item{padding:1.25rem 0;border-bottom:1px solid var(--color-border);}" & Chr(10)
  sHtml &= ".articulo-item:last-child{border-bottom:none;}" & Chr(10)
  sHtml &= ".articulo-titulo a{font-family:var(--font-serif);font-size:1.125rem;font-weight:600;color:var(--color-text);text-decoration:none;line-height:1.4;}" & Chr(10)
  sHtml &= ".articulo-titulo a:hover{color:var(--color-accent);}" & Chr(10)
  sHtml &= ".articulo-autores{font-size:0.875rem;color:var(--color-text-muted);margin-top:0.35rem;}" & Chr(10)
  sHtml &= "footer{text-align:center;padding:1.25rem;background:#2a2a28;color:#c8c6c0;font-family:var(--font-sans);font-size:0.875rem;font-weight:300;margin-top:3rem;}" & Chr(10)
  sHtml &= "footer a{color:#8ab4d8;text-decoration:none;}" & Chr(10)
  sHtml &= "</style>" & Chr(10)
  sHtml &= "</head>" & Chr(10)
  sHtml &= "<body>" & Chr(10)
  sHtml &= "<div class=" & Chr(34) & "contenedor" & Chr(34) & ">" & Chr(10)

  ' CABECERA CON TAPA Y DATOS DEL NÚMERO
  sHtml &= "<div class=" & Chr(34) & "cabecera" & Chr(34) & ">" & Chr(10)
  sHtml &= sTapaHtml & Chr(10)
  sHtml &= "<div class=" & Chr(34) & "info-revista" & Chr(34) & ">" & Chr(10)
  sHtml &= "<div class=" & Chr(34) & "nombre-revista" & Chr(34) & ">" & sRevista & "</div>" & Chr(10)
  sHtml &= "<div class=" & Chr(34) & "datos-numero" & Chr(34) & ">Vol. " & sVolumen & ", Núm. " & sNumero & "</div>" & Chr(10)
  sHtml &= "<div class=" & Chr(34) & "anio-numero" & Chr(34) & ">" & sAnio & "</div>" & Chr(10)
  sHtml &= "</div>" & Chr(10)
  sHtml &= "</div>" & Chr(10)

  ' LISTA DE ARTÍCULOS
  sHtml &= "<ul class=" & Chr(34) & "lista-articulos" & Chr(34) & ">" & Chr(10)

  Dim rAutores As Result
  Dim sAutores As String
  Dim sNombreHtml As String
  Dim sFileHtmlArticulo As String

  While rArticulos.Available

    ' SOLO MOSTRAR ARTÍCULOS QUE YA TIENEN HTML GENERADO EN /docs
    sNombreHtml = "h" & Mid(rArticulos["nombre_archivo"], 2) & ".html"
    sFileHtmlArticulo = sRutaDocs &/ sNombreHtml

    If Exist(sFileHtmlArticulo) Then

      ' OBTENER AUTORES DEL ARTÍCULO ORDENADOS POR orden_autoria
      sSQL = "SELECT au.apellidos, au.nombre " &
        "FROM autores au " &
        "INNER JOIN articulo_autor aa ON aa.id_autor = au.id_autor " &
        "WHERE aa.id_articulo = &1 " &
        "AND aa.rol_autor IN ('autor','coautor','autor_correspondencia') " &
        "ORDER BY aa.orden_autoria ASC"
      rAutores = m_ConexionBD.mConn.Exec(sSQL, rArticulos["id_articulo"])

      ' CONSTRUIR CADENA DE AUTORES
      sAutores = ""
      While rAutores.Available
        If sAutores <> "" Then sAutores &= ", "
        sAutores &= rAutores["apellidos"] & ", " & rAutores["nombre"]
        rAutores.MoveNext()
      Wend

      ' AGREGAR ÍTEM A LA LISTA
      sHtml &= "<li class=" & Chr(34) & "articulo-item" & Chr(34) & ">" & Chr(10)
      sHtml &= "<div class=" & Chr(34) & "articulo-titulo" & Chr(34) & ">"
      sHtml &= "<a href=" & Chr(34) & sNombreHtml & Chr(34) & ">"
      sHtml &= rArticulos["titulo_articulo"]
      sHtml &= "</a></div>" & Chr(10)
      If sAutores <> "" Then
        sHtml &= "<div class=" & Chr(34) & "articulo-autores" & Chr(34) & ">" & sAutores & "</div>" & Chr(10)
      Endif
      sHtml &= "</li>" & Chr(10)

    Endif

    rArticulos.MoveNext()
  Wend

  sHtml &= "</ul>" & Chr(10)
  sHtml &= "</div>" & Chr(10)

  ' FOOTER
  sHtml &= "<footer>Generado con <a href=" & Chr(34) & "https://estudio2a.netlify.app/" & Chr(34) & " target=" & Chr(34) & "_blank" & Chr(34) & ">gbpublisher</a></footer>" & Chr(10)
  sHtml &= "</body>" & Chr(10)
  sHtml &= "</html>" & Chr(10)

  ' GUARDAR EL ARCHIVO
  File.Save(sFileIndex, sHtml)

  FMain.TerminalViewProyecto.Input("echo 'OK: índice generado → docs/index.html'" & Chr(10))

Catch
  FMain.TerminalViewProyecto.Input("echo 'ERROR al generar índice: " & Error.Text & "'" & Chr(10))

End
