' Gambas module file

Private ContenidoMeta As Result

' ════════════════════════════════════════════════════════════════════════════
' DEVUELVE LA DESCRIPCIÓN LEGIBLE DEL TIPO DE PROYECTO
' ════════════════════════════════════════════════════════════════════════════
Public Function ObtenerDescripcionTipo(valor As Integer) As String

  Select Case valor
    Case m_Constantes.TIPO_REVISTA_MD
      Return "Revista (Markdown)"
    Case m_Constantes.TIPO_LIBRO_MD
      Return "Libro (Markdown)"
    Case m_Constantes.TIPO_LIBRO_LATEX
      Return "Libro (LaTeX)"
    Case Else
      Return "Tipo desconocido"
  End Select

End

' ════════════════════════════════════════════════════════════════════════════
' CONVERTIR NULL A STRING VACÍO
' PARA CARGAR DATOS DE LA BASE DE DATOS A COMPONENTES
' ════════════════════════════════════════════════════════════════════════════
Public Function NullToString(valor As Variant) As String

  If IsNull(valor) Then
    Return ""
  Else
    Return CStr(valor)
  Endif

End

' ════════════════════════════════════════════════════════════════════════════
' NORMALIZA VALORES PARA ENVIAR A LA BASE DE DATOS (TRIM AL STRING)
' ════════════════════════════════════════════════════════════════════════════
Private Function StringToNull(valor As String) As String

  Return Trim(valor)

End

' ════════════════════════════════════════════════════════════════════════════
' HELPERS PRIVADOS PARA COMBOBOX DE ENUMS DE LIBROS
' ════════════════════════════════════════════════════════════════════════════

' SELECCIONA EN UN COMBOBOX DE ENUM EL ITEM CUYO ÍNDICE MAPEA AL VALOR DE BD.
' aValores ES EL ARRAY DE STRINGS DEL ENUM EN EL MISMO ORDEN QUE ESTÁN
' AGREGADOS LOS ITEMS EN EL COMBOBOX (VER FMetadatosLibro.Form_Open).
' SI EL VALOR NO COINCIDE CON NINGUNO, DEJA EL COMBOBOX EN ÍNDICE 0.
Private Sub SeleccionarComboEnum(oCombo As ComboBox, sValor As String, aValores As String[])

  Dim iIdx As Integer

  ' GUARD: SI EL COMBO ESTÁ VACÍO, NO HACER NADA
  If oCombo.Count <= 0 Then Return

  iIdx = aValores.Find(sValor)
  If iIdx >= 0 And iIdx < oCombo.Count Then
    oCombo.Index = iIdx
  Else
    oCombo.Index = 0
  Endif

End

' LEE EL VALOR DEL ENUM ASOCIADO AL ÍNDICE ACTUAL DEL COMBOBOX.
' SI EL ÍNDICE ESTÁ FUERA DE RANGO, DEVUELVE EL PRIMER VALOR (DEFAULT DEL ENUM).
Private Function ObtenerEnumDeCombo(oCombo As ComboBox, aValores As String[]) As String

  If oCombo.Index >= 0 And oCombo.Index < aValores.Count Then
    Return aValores[oCombo.Index]
  Endif
  Return aValores[0]

End

' ════════════════════════════════════════════════════════════════════════════
' CARGAR METADATOS DE REVISTA DESDE LA TABLA REVISTAS_MD
' BUSCA EL REGISTRO BASÁNDOSE EN EL ID_PROYECTO Y CARGA TODOS LOS CAMPOS
' EN LOS COMPONENTES DEL FORMULARIO FMetadatosRevista
' ════════════════════════════════════════════════════════════════════════════
Public Function CargarMetadatosDeRevista() As Boolean

  Dim sSQL As String
  Dim resultado As Result

  ' BUSCAR EN TABLA REVISTAS_MD USANDO EL ID_PROYECTO DE FMain
  sSQL = "SELECT * FROM revistas_md WHERE id_proyecto = &1"
  resultado = m_ConexionBD.mConn.Exec(sSQL, FMain.id_proyecto.Value)

  If Not resultado.Available Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron metadatos de revista para este proyecto.")
    Return False
  Endif

  ' CARGAR TODOS LOS CAMPOS EN LOS COMPONENTES DEL FORMULARIO FMetadatosRevista
  With FMetadatosRevista

    ' CAMPOS DE IDENTIFICACIÓN
    .id_revista.Value = resultado["id_revista"]
    .ror_editorial.Text = resultado["ror_editorial"]
    .id_proyecto.Value = FMain.id_proyecto.Value
    .issn_impreso.Text = NullToString(resultado["issn_impreso"])
    .e_issn.Text = NullToString(resultado["e_issn"])
    .acronimo_scielo.Text = NullToString(resultado["acronimo_scielo"])

    ' ESTILO DE CITA — BUSCAR EN EL COMBOBOX EL ITEM CON EL NOMBRE DE ARCHIVO
    Dim sEstiloCita As String = m_XML.TrimUTF8(resultado["estilo_cita"])
    FMetadatosRevista.cmb_tipo_csl.Text = ""
    If sEstiloCita <> "" Then
      Dim i As Integer
      For i = 0 To FMetadatosRevista.cmb_tipo_csl.Count - 1
        Dim sItem As String = FMetadatosRevista.cmb_tipo_csl.List[i]
        Dim sNombre As String = sItem
        Dim iAbre As Integer = 0
        Dim iCierra As Integer = 0
        Dim j As Integer
        For j = Len(sItem) To 1 Step -1
          If Mid(sItem, j, 1) = "]" And iCierra = 0 Then iCierra = j
          If Mid(sItem, j, 1) = "[" And iCierra > 0 Then
            iAbre = j
            Break
          Endif
        Next
        If iAbre > 0 And iCierra > iAbre Then
          sNombre = m_XML.TrimUTF8(Mid(sItem, iAbre + 1, iCierra - iAbre - 1))
        Endif
        If sNombre = sEstiloCita Then
          FMetadatosRevista.cmb_tipo_csl.Text = sItem
          Break
        Endif
      Next
    Endif

    ' TÍTULOS Y VARIANTES
    .titulo_revista.Text = NullToString(resultado["titulo_revista"])
    .titulo_abreviado.Text = NullToString(resultado["titulo_abreviado"])
    .titulo_alternativo.Text = NullToString(resultado["titulo_alternativo"])
    .subtitulo.Text = NullToString(resultado["subtitulo"])

    ' NUMERACIÓN Y FECHAS
    .volumen.Text = NullToString(resultado["volumen"])
    .numero.Text = NullToString(resultado["numero"])
    .suplemento.Text = NullToString(resultado["suplemento"])
    .numero_especial.Value = resultado["numero_especial"]
    .titulo_numero_especial.Text = NullToString(resultado["titulo_numero_especial"])
    .ano_publicacion.Text = NullToString(resultado["ano_publicacion"])
    .mes_publicacion.Text = NullToString(resultado["mes_publicacion"])
    .fecha_publicacion_completa.Value = resultado["fecha_publicacion_completa"]
    .estacion.Text = NullToString(resultado["estacion"])

    ' EDITORIAL E INSTITUCIÓN
    .editorial.Text = NullToString(resultado["editorial"])
    .institucion_editora.Text = NullToString(resultado["institucion_editora"])
    .ciudad_publicacion.Text = NullToString(resultado["ciudad_publicacion"])
    .pais_publicacion.Text = NullToString(resultado["pais_publicacion"])
    .direccion_editorial.Text = NullToString(resultado["direccion_editorial"])
    .email_editorial.Text = NullToString(resultado["email_editorial"])

    ' CLASIFICACIÓN TEMÁTICA
    .area_conocimiento.Text = NullToString(resultado["area_conocimiento"])
    .disciplina.Text = NullToString(resultado["disciplina"])
    .subdisciplina.Text = NullToString(resultado["subdisciplina"])
    .palabras_clave_revista.Text = NullToString(resultado["palabras_clave_revista"])
    .clasificacion_unesco.Text = NullToString(resultado["clasificacion_unesco"])
    .clasificacion_oecd.Text = NullToString(resultado["clasificacion_oecd"])

    ' PERIODICIDAD Y ESTADO
    .periodicidad.Text = NullToString(resultado["periodicidad"])
    .ano_inicio.Text = NullToString(resultado["ano_inicio"])
    .ano_fin.Text = NullToString(resultado["ano_fin"])
    .estado_publicacion.Text = NullToString(resultado["estado_publicacion"])
    .tipo_numeracion.Text = NullToString(resultado["tipo_numeracion"])

    ' URLS Y PERSISTENCIA
    .url_revista.Text = NullToString(resultado["url_revista"])
    .url_oai_pmh.Text = NullToString(resultado["url_oai_pmh"])
    .doi_prefix.Text = NullToString(resultado["doi_prefix"])
    .handle_prefix.Text = NullToString(resultado["handle_prefix"])
    .imagen_tapa.Text = NullToString(resultado["imagen_tapa"])

    ' REPOSITORIOS DE PRODUCCIÓN
    .repositorio_produccion_url.Text = NullToString(resultado["repositorio_produccion_url"])
    .repositorio_produccion_plataforma.Text = NullToString(resultado["repositorio_produccion_plataforma"])
    .repositorio_produccion_tipo.Text = NullToString(resultado["repositorio_produccion_tipo"])
    ' MANEJO DEFENSIVO DE BOOLEAN NULL
    If IsNull(resultado["repositorio_produccion_privado"]) Then
      .repositorio_produccion_privado.Value = False
    Else
      .repositorio_produccion_privado.Value = resultado["repositorio_produccion_privado"]
    Endif
    .sistema_gestion_contenidos.Text = NullToString(resultado["sistema_gestion_contenidos"])

    ' REPOSITORIOS DE PRESERVACIÓN
    .repositorio_preservacion_url.Text = NullToString(resultado["repositorio_preservacion_url"])
    .repositorio_preservacion_plataforma.Text = NullToString(resultado["repositorio_preservacion_plataforma"])

    ' ACCESO Y LICENCIAS
    .tipo_acceso.Text = NullToString(resultado["tipo_acceso"])
    .licencia_defecto.Text = NullToString(resultado["licencia_defecto"])
    .url_licencia.Text = NullToString(resultado["url_licencia"])
    .politica_acceso_abierto.Text = NullToString(resultado["politica_acceso_abierto"])
    .periodo_embargo.Text = NullToString(resultado["periodo_embargo"])

    ' INDEXACIÓN Y MÉTRICAS
    .indexada_en.Text = NullToString(resultado["indexada_en"])
    .categoria_scielo.Text = NullToString(resultado["categoria_scielo"])
    .categoria_latindex.Text = NullToString(resultado["categoria_latindex"])
    .cuartil_scimago.Text = NullToString(resultado["cuartil_scimago"])
    .factor_impacto.Text = NullToString(resultado["factor_impacto"])

    ' DESCRIPCIÓN Y POLÍTICAS
    .descripcion_revista.Text = NullToString(resultado["descripcion_revista"])
    .objetivos_alcance.Text = NullToString(resultado["objetivos_alcance"])
    .idiomas_publicacion.Text = NullToString(resultado["idiomas_publicacion"])
    .instrucciones_autores_url.Text = NullToString(resultado["instrucciones_autores_url"])
    .politica_revision.Text = NullToString(resultado["politica_revision"])
    .frecuencia_revision.Text = NullToString(resultado["frecuencia_revision"])

    ' METADATOS DEL SISTEMA
    .fecha_creacion.Value = resultado["fecha_creacion"]
    .fecha_actualizacion.Value = resultado["fecha_actualizacion"]
    .usuario_creacion.Text = NullToString(resultado["usuario_creacion"])
    .notas_internas.Text = NullToString(resultado["notas_internas"])

  End With

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error al cargar metadatos de revista:" & gb.NewLine &
    "Mensaje: " & Error.Text & gb.NewLine &
    "Lugar: " & Error.Where & gb.NewLine &
    "Código: " & Error.Code)
  Return False

End

' ════════════════════════════════════════════════════════════════════════════
' GUARDAR METADATOS DE REVISTA EN LA TABLA REVISTAS_MD
' ════════════════════════════════════════════════════════════════════════════
Public Function GuardarMetadatosDeRevista() As Boolean

  Dim resultado As Result
  Dim idProyecto As Integer
  Dim verificacion As Result

  idProyecto = FMain.id_proyecto.Value

  If idProyecto <= 0 Then
    m_Sonido.sonar("Error")
    Message.Error("No hay un proyecto válido abierto.")
    Return False
  Endif

  ' VERIFICAR QUE EXISTE EL REGISTRO EN REVISTAS_MD; SI NO, CREARLO
  verificacion = m_ConexionBD.mConn.Exec("SELECT id_revista FROM revistas_md WHERE id_proyecto = &1", idProyecto)

  If Not verificacion.Available Then
    m_ConexionBD.mConn.Exec("INSERT INTO revistas_md (" &
      "  id_proyecto, " &
      "  titulo_revista, " &
      "  estado_publicacion, " &
      "  tipo_numeracion, " &
      "  tipo_acceso, " &
      "  repositorio_produccion_privado, " &
      "  usuario_creacion" &
      ") VALUES (&1, &2, 'activa', 'por_volumen', 'abierto', 1, &3)",
      idProyecto,
      StringToNull(FMetadatosRevista.titulo_revista.Text),
      m_InicioCierre.UsuarioEnCurso)
    m_ConexionBD.mConn.Commit()
  Endif

  resultado = m_ConexionBD.mConn.Edit("revistas_md", "id_proyecto=" & idProyecto)

  If Not resultado.Available Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el registro de revista para editar.")
    Return False
  Endif

  With FMetadatosRevista

    ' CAMPOS DE IDENTIFICACIÓN
    resultado!issn_impreso = StringToNull(.issn_impreso.Text)
    resultado!e_issn = StringToNull(.e_issn.Text)
    resultado!estilo_cita = FMetadatosRevista.ExtraerNombreCSL(FMetadatosRevista.cmb_tipo_csl.Text)
    resultado!acronimo_scielo = StringToNull(.acronimo_scielo.Text)

    ' TÍTULOS Y VARIANTES
    resultado!titulo_revista = StringToNull(.titulo_revista.Text)
    resultado!titulo_abreviado = StringToNull(.titulo_abreviado.Text)
    resultado!titulo_alternativo = StringToNull(.titulo_alternativo.Text)
    resultado!subtitulo = StringToNull(.subtitulo.Text)

    ' NUMERACIÓN Y FECHAS
    resultado!volumen = StringToNull(.volumen.Text)
    resultado!numero = StringToNull(.numero.Text)
    resultado!suplemento = StringToNull(.suplemento.Text)
    resultado!numero_especial = .numero_especial.Value
    resultado!titulo_numero_especial = StringToNull(.titulo_numero_especial.Text)
    resultado!ano_publicacion = StringToNull(.ano_publicacion.Text)
    resultado!mes_publicacion = StringToNull(.mes_publicacion.Text)
    resultado!fecha_publicacion_completa = .fecha_publicacion_completa.Value
    resultado!estacion = StringToNull(.estacion.Text)

    ' EDITORIAL E INSTITUCIÓN
    resultado!editorial = StringToNull(.editorial.Text)
    resultado!ror_editorial = StringToNull(.ror_editorial.Text)
    resultado!institucion_editora = StringToNull(.institucion_editora.Text)
    resultado!ciudad_publicacion = StringToNull(.ciudad_publicacion.Text)
    resultado!pais_publicacion = StringToNull(.pais_publicacion.Text)
    resultado!direccion_editorial = StringToNull(.direccion_editorial.Text)
    resultado!email_editorial = StringToNull(.email_editorial.Text)

    ' CLASIFICACIÓN TEMÁTICA
    resultado!area_conocimiento = StringToNull(.area_conocimiento.Text)
    resultado!disciplina = StringToNull(.disciplina.Text)
    resultado!subdisciplina = StringToNull(.subdisciplina.Text)
    resultado!palabras_clave_revista = StringToNull(.palabras_clave_revista.Text)
    resultado!clasificacion_unesco = StringToNull(.clasificacion_unesco.Text)
    resultado!clasificacion_oecd = StringToNull(.clasificacion_oecd.Text)

    ' PERIODICIDAD Y ESTADO
    resultado!periodicidad = StringToNull(.periodicidad.Text)
    resultado!ano_inicio = StringToNull(.ano_inicio.Text)
    resultado!ano_fin = StringToNull(.ano_fin.Text)
    resultado!estado_publicacion = StringToNull(.estado_publicacion.Text)
    resultado!tipo_numeracion = StringToNull(.tipo_numeracion.Text)

    ' URLS Y PERSISTENCIA
    resultado!url_revista = StringToNull(.url_revista.Text)
    resultado!url_oai_pmh = StringToNull(.url_oai_pmh.Text)
    resultado!doi_prefix = StringToNull(.doi_prefix.Text)
    resultado!handle_prefix = StringToNull(.handle_prefix.Text)
    resultado!imagen_tapa = StringToNull(.imagen_tapa.Text)

    ' REPOSITORIOS DE PRODUCCIÓN
    resultado!repositorio_produccion_url = StringToNull(.repositorio_produccion_url.Text)
    resultado!repositorio_produccion_plataforma = StringToNull(.repositorio_produccion_plataforma.Text)
    resultado!repositorio_produccion_tipo = StringToNull(.repositorio_produccion_tipo.Text)
    ' BUG FIX: ANTES TENÍA UN BLOQUE DE CARGA (Else .CheckBox.Value = resultado[]),
    ' QUE NO CORRESPONDE EN GUARDAR. ACÁ ESCRIBIMOS EL VALOR DEL CHECKBOX A LA BD.
    resultado!repositorio_produccion_privado = .repositorio_produccion_privado.Value
    resultado!sistema_gestion_contenidos = StringToNull(.sistema_gestion_contenidos.Text)

    ' REPOSITORIOS DE PRESERVACIÓN
    resultado!repositorio_preservacion_url = StringToNull(.repositorio_preservacion_url.Text)
    resultado!repositorio_preservacion_plataforma = StringToNull(.repositorio_preservacion_plataforma.Text)

    ' ACCESO Y LICENCIAS
    resultado!tipo_acceso = StringToNull(.tipo_acceso.Text)
    resultado!licencia_defecto = StringToNull(.licencia_defecto.Text)
    resultado!url_licencia = StringToNull(.url_licencia.Text)
    resultado!politica_acceso_abierto = StringToNull(.politica_acceso_abierto.Text)
    resultado!periodo_embargo = StringToNull(.periodo_embargo.Text)

    ' INDEXACIÓN Y MÉTRICAS
    resultado!indexada_en = StringToNull(.indexada_en.Text)
    resultado!categoria_scielo = StringToNull(.categoria_scielo.Text)
    resultado!categoria_latindex = StringToNull(.categoria_latindex.Text)
    resultado!cuartil_scimago = StringToNull(.cuartil_scimago.Text)
    resultado!factor_impacto = StringToNull(.factor_impacto.Text)

    ' DESCRIPCIÓN Y POLÍTICAS
    resultado!descripcion_revista = StringToNull(.descripcion_revista.Text)
    resultado!objetivos_alcance = StringToNull(.objetivos_alcance.Text)
    resultado!idiomas_publicacion = StringToNull(.idiomas_publicacion.Text)
    resultado!instrucciones_autores_url = StringToNull(.instrucciones_autores_url.Text)
    resultado!politica_revision = StringToNull(.politica_revision.Text)
    resultado!frecuencia_revision = StringToNull(.frecuencia_revision.Text)

    ' NOTAS INTERNAS
    resultado!notas_internas = StringToNull(.notas_internas.Text)

  End With

  resultado.Update
  m_ConexionBD.mConn.Commit()
  resultado = Null

  m_Sonido.sonar("Info")
  Message.Info("Metadatos de revista guardados correctamente.")

  CargarMetadatosDeRevista()

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error al guardar metadatos de revista:" & gb.NewLine &
    "Mensaje: " & Error.Text & gb.NewLine &
    "Lugar: " & Error.Where & gb.NewLine &
    "Código: " & Error.Code)
  Return False

End

' ════════════════════════════════════════════════════════════════════════════
' CARGAR METADATOS DE LIBRO DESDE LA TABLA LIBROS_MD
' BUSCA EL REGISTRO POR ID_PROYECTO Y CARGA TODOS LOS CAMPOS EN
' LOS COMPONENTES DEL FORMULARIO FMetadatosLibro
' ════════════════════════════════════════════════════════════════════════════
Public Function CargarMetadatosDeLibro() As Boolean

  Dim sSQL As String
  Dim resultado As Result

  ' --- 1. CONSULTA A BASE DE DATOS ---
  sSQL = "SELECT * FROM libros_md WHERE id_proyecto = &1"
  resultado = m_ConexionBD.mConn.Exec(sSQL, FMain.id_proyecto.Value)

  If Not resultado.Available Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron metadatos de libro para este proyecto.")
    Return False
  Endif

  ' --- 2. ARRAYS DE ENUM (MISMO ORDEN QUE EL POBLADO EN FMetadatosLibro.Form_Open) ---
  Dim aTipoLibro As New String[]
  Dim aLugarBib As New String[]
  Dim aEstadoPub As New String[]
  Dim aTipoAcceso As New String[]

  aTipoLibro.Add("monografia")
  aTipoLibro.Add("obra_colectiva")
  aTipoLibro.Add("compilacion")
  aTipoLibro.Add("traduccion")
  aTipoLibro.Add("referencia")
  aTipoLibro.Add("manual")
  aTipoLibro.Add("actas")

  aLugarBib.Add("consolidada")
  aLugarBib.Add("por_capitulo")

  aEstadoPub.Add("en_preparacion")
  aEstadoPub.Add("publicado")
  aEstadoPub.Add("agotado")
  aEstadoPub.Add("descatalogado")

  aTipoAcceso.Add("abierto")
  aTipoAcceso.Add("venta")
  aTipoAcceso.Add("mixto")
  aTipoAcceso.Add("embargado")

  ' --- 3. CARGAR CAMPOS EN EL FORMULARIO FMetadatosLibro ---
  With FMetadatosLibro

    ' IDENTIFICACIÓN
    .id_libro.Value = resultado["id_libro"]
    .id_proyecto.Value = FMain.id_proyecto.Value

    ' CÓDIGOS
    .isbn_impreso.Text = NullToString(resultado["isbn_impreso"])
    .isbn_electronico.Text = NullToString(resultado["isbn_electronico"])
    .doi_libro.Text = NullToString(resultado["doi_libro"])
    .doi_prefix.Text = NullToString(resultado["doi_prefix"])
    .handle_prefix.Text = NullToString(resultado["handle_prefix"])
    .identificador_scielo.Text = NullToString(resultado["identificador_scielo"])

    ' TÍTULOS
    .titulo_libro.Text = NullToString(resultado["titulo_libro"])
    .subtitulo.Text = NullToString(resultado["subtitulo"])
    .titulo_abreviado.Text = NullToString(resultado["titulo_abreviado"])
    .titulo_original.Text = NullToString(resultado["titulo_original"])
    .idioma_titulo_original.Text = NullToString(resultado["idioma_titulo_original"])

    ' TIPOLOGÍA Y EDICIÓN (COMBOBOX ENUM)
    SeleccionarComboEnum(.tipo_libro, NullToString(resultado["tipo_libro"]), aTipoLibro)
    SeleccionarComboEnum(.lugar_bibliografia, NullToString(resultado["lugar_bibliografia"]), aLugarBib)
    .edicion.Text = NullToString(resultado["edicion"])
    .numero_edicion.Text = NullToString(resultado["numero_edicion"])
    .numero_paginas.Text = NullToString(resultado["numero_paginas"])

    ' COLECCIÓN Y SERIE (USAN ARRAYS PARALELOS EN EL FORMULARIO)
    Dim iIdCol As Integer = 0
    If Not IsNull(resultado["id_coleccion"]) Then iIdCol = CInt(resultado["id_coleccion"])
    .SeleccionarColeccionPorId(iIdCol)

    ' EL EVENT HANDLER POBLA EL COMBO DE SERIES SEGÚN LA COLECCIÓN ELEGIDA
    .id_coleccion_Click()

    Dim iIdSer As Integer = 0
    If Not IsNull(resultado["id_serie"]) Then iIdSer = CInt(resultado["id_serie"])
    .SeleccionarSeriePorId(iIdSer)

    .numero_en_coleccion.Text = NullToString(resultado["numero_en_coleccion"])
    .numero_en_serie.Text = NullToString(resultado["numero_en_serie"])

    ' PUBLICACIÓN
    .ano_publicacion.Text = NullToString(resultado["ano_publicacion"])
    .mes_publicacion.Text = NullToString(resultado["mes_publicacion"])
    .fecha_publicacion_completa.Value = resultado["fecha_publicacion_completa"]
    .idioma_principal.Text = NullToString(resultado["idioma_principal"])
    .idiomas_publicacion.Text = NullToString(resultado["idiomas_publicacion"])
    SeleccionarComboEnum(.estado_publicacion, NullToString(resultado["estado_publicacion"]), aEstadoPub)

    ' EDITORIAL
    .editorial.Text = NullToString(resultado["editorial"])
    .institucion_editora.Text = NullToString(resultado["institucion_editora"])
    .ror_editorial.Text = NullToString(resultado["ror_editorial"])
    .ciudad_publicacion.Text = NullToString(resultado["ciudad_publicacion"])
    .pais_publicacion.Text = NullToString(resultado["pais_publicacion"])
    .direccion_editorial.Text = NullToString(resultado["direccion_editorial"])
    .email_editorial.Text = NullToString(resultado["email_editorial"])

    ' DISCIPLINAS
    .area_conocimiento.Text = NullToString(resultado["area_conocimiento"])
    .disciplina.Text = NullToString(resultado["disciplina"])
    .subdisciplina.Text = NullToString(resultado["subdisciplina"])
    .palabras_clave_libro.Text = NullToString(resultado["palabras_clave_libro"])
    .clasificacion_unesco.Text = NullToString(resultado["clasificacion_unesco"])
    .clasificacion_oecd.Text = NullToString(resultado["clasificacion_oecd"])

    ' ACCESO Y LICENCIA
    SeleccionarComboEnum(.tipo_acceso, NullToString(resultado["tipo_acceso"]), aTipoAcceso)
    .licencia_defecto.Text = NullToString(resultado["licencia_defecto"])
    .url_licencia.Text = NullToString(resultado["url_licencia"])
    .politica_acceso_abierto.Text = NullToString(resultado["politica_acceso_abierto"])
    .periodo_embargo.Text = NullToString(resultado["periodo_embargo"])

    ' URLS Y ACTIVOS
    .url_libro.Text = NullToString(resultado["url_libro"])
    .url_oai_pmh.Text = NullToString(resultado["url_oai_pmh"])
    .url_logo.Text = NullToString(resultado["url_logo"])
    .imagen_tapa.Text = NullToString(resultado["imagen_tapa"])

    ' REPOSITORIOS DE PRODUCCIÓN
    .repositorio_produccion_url.Text = NullToString(resultado["repositorio_produccion_url"])
    .repositorio_produccion_plataforma.Text = NullToString(resultado["repositorio_produccion_plataforma"])
    .repositorio_produccion_tipo.Text = NullToString(resultado["repositorio_produccion_tipo"])
    ' MANEJO DEFENSIVO DE BOOLEAN NULL
    If IsNull(resultado["repositorio_produccion_privado"]) Then
      .repositorio_produccion_privado.Value = False
    Else
      .repositorio_produccion_privado.Value = resultado["repositorio_produccion_privado"]
    Endif
    .sistema_gestion_contenidos.Text = NullToString(resultado["sistema_gestion_contenidos"])

    ' REPOSITORIOS DE PRESERVACIÓN
    .repositorio_preservacion_url.Text = NullToString(resultado["repositorio_preservacion_url"])
    .repositorio_preservacion_plataforma.Text = NullToString(resultado["repositorio_preservacion_plataforma"])

    ' INDEXACIÓN
    .indexado_en.Text = NullToString(resultado["indexado_en"])

    ' RESUMEN Y DESCRIPCIÓN
    .resumen_libro.Text = NullToString(resultado["resumen_libro"])
    .resumen_traducido.Text = NullToString(resultado["resumen_traducido"])
    .idioma_resumen_traducido.Text = NullToString(resultado["idioma_resumen_traducido"])
    .descripcion_libro.Text = NullToString(resultado["descripcion_libro"])
    .objetivos_alcance.Text = NullToString(resultado["objetivos_alcance"])

    ' ESTILO DE CITA (COMBOBOX CON BÚSQUEDA POR NOMBRE DE ARCHIVO)
    Dim sEstiloCita As String = m_XML.TrimUTF8(NullToString(resultado["estilo_cita"]))
    FMetadatosLibro.cmb_tipo_csl.Text = ""
    If sEstiloCita <> "" Then
      Dim i As Integer
      For i = 0 To FMetadatosLibro.cmb_tipo_csl.Count - 1
        Dim sItem As String = FMetadatosLibro.cmb_tipo_csl.List[i]
        Dim sNombre As String = sItem
        Dim iAbre As Integer = 0
        Dim iCierra As Integer = 0
        Dim j As Integer
        For j = Len(sItem) To 1 Step -1
          If Mid(sItem, j, 1) = "]" And iCierra = 0 Then iCierra = j
          If Mid(sItem, j, 1) = "[" And iCierra > 0 Then
            iAbre = j
            Break
          Endif
        Next
        If iAbre > 0 And iCierra > iAbre Then
          sNombre = m_XML.TrimUTF8(Mid(sItem, iAbre + 1, iCierra - iAbre - 1))
        Endif
        If sNombre = sEstiloCita Then
          FMetadatosLibro.cmb_tipo_csl.Text = sItem
          Break
        Endif
      Next
    Endif

    ' AUDITORÍA (READONLY EN EL FORM)
    .usuario_creacion.Text = NullToString(resultado["usuario_creacion"])
    .notas_internas.Text = NullToString(resultado["notas_internas"])

  End With

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error al cargar metadatos de libro:" & gb.NewLine &
    "Mensaje: " & Error.Text & gb.NewLine &
    "Lugar: " & Error.Where & gb.NewLine &
    "Código: " & Error.Code)
  Return False

End

' ════════════════════════════════════════════════════════════════════════════
' GUARDAR METADATOS DE LIBRO EN LA TABLA LIBROS_MD
' SI NO EXISTE EL REGISTRO, LO CREA CON UN INSERT MÍNIMO Y LUEGO LO EDITA.
' ════════════════════════════════════════════════════════════════════════════
Public Function GuardarMetadatosDeLibro() As Boolean

  Dim resultado As Result
  Dim idProyecto As Integer
  Dim verificacion As Result

  ' --- 1. VALIDACIÓN: PROYECTO ABIERTO ---
  idProyecto = FMain.id_proyecto.Value

  If idProyecto <= 0 Then
    m_Sonido.sonar("Error")
    Message.Error("No hay un proyecto válido abierto.")
    Return False
  Endif

  ' --- 2. ARRAYS DE ENUM (MISMO ORDEN QUE EL POBLADO EN FMetadatosLibro.Form_Open) ---
  Dim aTipoLibro As New String[]
  Dim aLugarBib As New String[]
  Dim aEstadoPub As New String[]
  Dim aTipoAcceso As New String[]

  aTipoLibro.Add("monografia")
  aTipoLibro.Add("obra_colectiva")
  aTipoLibro.Add("compilacion")
  aTipoLibro.Add("traduccion")
  aTipoLibro.Add("referencia")
  aTipoLibro.Add("manual")
  aTipoLibro.Add("actas")

  aLugarBib.Add("consolidada")
  aLugarBib.Add("por_capitulo")

  aEstadoPub.Add("en_preparacion")
  aEstadoPub.Add("publicado")
  aEstadoPub.Add("agotado")
  aEstadoPub.Add("descatalogado")

  aTipoAcceso.Add("abierto")
  aTipoAcceso.Add("venta")
  aTipoAcceso.Add("mixto")
  aTipoAcceso.Add("embargado")

  ' --- 3. VERIFICAR QUE EXISTE EL REGISTRO; SI NO, CREARLO ---
  verificacion = m_ConexionBD.mConn.Exec("SELECT id_libro FROM libros_md WHERE id_proyecto = &1", idProyecto)

  If Not verificacion.Available Then
    ' INSERT MÍNIMO CON LOS DEFAULTS Y EL TÍTULO ACTUAL DEL FORMULARIO.
    ' INICIALIZA LAS TRES FECHAS (año, mes, fecha completa) AL MOMENTO DE
    ' CREACIÓN PARA EVITAR Null Y POR COHERENCIA EDITORIAL.
    m_ConexionBD.mConn.Exec("INSERT INTO libros_md (" &
      "  id_proyecto, " &
      "  titulo_libro, " &
      "  tipo_libro, " &
      "  lugar_bibliografia, " &
      "  estado_publicacion, " &
      "  tipo_acceso, " &
      "  repositorio_produccion_privado, " &
      "  idioma_principal, " &
      "  ano_publicacion, " &
      "  mes_publicacion, " &
      "  fecha_publicacion_completa, " &
      "  usuario_creacion" &
      ") VALUES (&1, &2, 'monografia', 'por_capitulo', 'en_preparacion', 'abierto', 1, 'es', " &
      "  YEAR(CURDATE()), " &
      "  ELT(MONTH(CURDATE()), 'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', " &
      "                        'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'), " &
      "  CURDATE(), " &
      "  &3)",
      idProyecto,
      StringToNull(FMetadatosLibro.titulo_libro.Text),
      m_InicioCierre.UsuarioEnCurso)
    m_ConexionBD.mConn.Commit()
  Endif

  ' --- 4. EDITAR EL REGISTRO ---
  resultado = m_ConexionBD.mConn.Edit("libros_md", "id_proyecto=" & idProyecto)

  If Not resultado.Available Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el registro de libro para editar.")
    Return False
  Endif

  With FMetadatosLibro

    ' CÓDIGOS
    resultado!isbn_impreso = StringToNull(.isbn_impreso.Text)
    resultado!isbn_electronico = StringToNull(.isbn_electronico.Text)
    resultado!doi_libro = StringToNull(.doi_libro.Text)
    resultado!doi_prefix = StringToNull(.doi_prefix.Text)
    resultado!handle_prefix = StringToNull(.handle_prefix.Text)
    resultado!identificador_scielo = StringToNull(.identificador_scielo.Text)

    ' TÍTULOS
    resultado!titulo_libro = StringToNull(.titulo_libro.Text)
    resultado!subtitulo = StringToNull(.subtitulo.Text)
    resultado!titulo_abreviado = StringToNull(.titulo_abreviado.Text)
    resultado!titulo_original = StringToNull(.titulo_original.Text)
    resultado!idioma_titulo_original = StringToNull(.idioma_titulo_original.Text)

    ' TIPOLOGÍA Y EDICIÓN
    resultado!tipo_libro = ObtenerEnumDeCombo(.tipo_libro, aTipoLibro)
    resultado!lugar_bibliografia = ObtenerEnumDeCombo(.lugar_bibliografia, aLugarBib)
    resultado!edicion = StringToNull(.edicion.Text)
    resultado!numero_edicion = StringToNull(.numero_edicion.Text)
    resultado!numero_paginas = StringToNull(.numero_paginas.Text)

    ' COLECCIÓN Y SERIE (FK) — IDs DESDE LOS HELPERS DEL FORMULARIO
    Dim iIdCol As Integer = .ObtenerIdColeccionSeleccionada()
    Dim iIdSer As Integer = .ObtenerIdSerieSeleccionada()
    If iIdCol > 0 Then
      resultado!id_coleccion = iIdCol
    Else
      resultado!id_coleccion = Null
    Endif
    If iIdSer > 0 Then
      resultado!id_serie = iIdSer
    Else
      resultado!id_serie = Null
    Endif
    resultado!numero_en_coleccion = StringToNull(.numero_en_coleccion.Text)
    resultado!numero_en_serie = StringToNull(.numero_en_serie.Text)

    ' PUBLICACIÓN
    resultado!ano_publicacion = StringToNull(.ano_publicacion.Text)
    resultado!mes_publicacion = StringToNull(.mes_publicacion.Text)
    resultado!fecha_publicacion_completa = .fecha_publicacion_completa.Value
    resultado!idioma_principal = StringToNull(.idioma_principal.Text)
    resultado!idiomas_publicacion = StringToNull(.idiomas_publicacion.Text)
    resultado!estado_publicacion = ObtenerEnumDeCombo(.estado_publicacion, aEstadoPub)

    ' EDITORIAL
    resultado!editorial = StringToNull(.editorial.Text)
    resultado!institucion_editora = StringToNull(.institucion_editora.Text)
    resultado!ror_editorial = StringToNull(.ror_editorial.Text)
    resultado!ciudad_publicacion = StringToNull(.ciudad_publicacion.Text)
    resultado!pais_publicacion = StringToNull(.pais_publicacion.Text)
    resultado!direccion_editorial = StringToNull(.direccion_editorial.Text)
    resultado!email_editorial = StringToNull(.email_editorial.Text)

    ' DISCIPLINAS
    resultado!area_conocimiento = StringToNull(.area_conocimiento.Text)
    resultado!disciplina = StringToNull(.disciplina.Text)
    resultado!subdisciplina = StringToNull(.subdisciplina.Text)
    resultado!palabras_clave_libro = StringToNull(.palabras_clave_libro.Text)
    resultado!clasificacion_unesco = StringToNull(.clasificacion_unesco.Text)
    resultado!clasificacion_oecd = StringToNull(.clasificacion_oecd.Text)

    ' ACCESO Y LICENCIA
    resultado!tipo_acceso = ObtenerEnumDeCombo(.tipo_acceso, aTipoAcceso)
    resultado!licencia_defecto = StringToNull(.licencia_defecto.Text)
    resultado!url_licencia = StringToNull(.url_licencia.Text)
    resultado!politica_acceso_abierto = StringToNull(.politica_acceso_abierto.Text)
    resultado!periodo_embargo = StringToNull(.periodo_embargo.Text)

    ' URLS Y ACTIVOS
    resultado!url_libro = StringToNull(.url_libro.Text)
    resultado!url_oai_pmh = StringToNull(.url_oai_pmh.Text)
    resultado!url_logo = StringToNull(.url_logo.Text)
    resultado!imagen_tapa = StringToNull(.imagen_tapa.Text)

    ' REPOSITORIOS DE PRODUCCIÓN
    resultado!repositorio_produccion_url = StringToNull(.repositorio_produccion_url.Text)
    resultado!repositorio_produccion_plataforma = StringToNull(.repositorio_produccion_plataforma.Text)
    resultado!repositorio_produccion_tipo = StringToNull(.repositorio_produccion_tipo.Text)
    ' BUG FIX: ACÁ ESCRIBIMOS EL CHECKBOX A LA BD (NO AL REVÉS)
    resultado!repositorio_produccion_privado = .repositorio_produccion_privado.Value
    resultado!sistema_gestion_contenidos = StringToNull(.sistema_gestion_contenidos.Text)

    ' REPOSITORIOS DE PRESERVACIÓN
    resultado!repositorio_preservacion_url = StringToNull(.repositorio_preservacion_url.Text)
    resultado!repositorio_preservacion_plataforma = StringToNull(.repositorio_preservacion_plataforma.Text)

    ' INDEXACIÓN
    resultado!indexado_en = StringToNull(.indexado_en.Text)

    ' RESUMEN Y DESCRIPCIÓN
    resultado!resumen_libro = StringToNull(.resumen_libro.Text)
    resultado!resumen_traducido = StringToNull(.resumen_traducido.Text)
    resultado!idioma_resumen_traducido = StringToNull(.idioma_resumen_traducido.Text)
    resultado!descripcion_libro = StringToNull(.descripcion_libro.Text)
    resultado!objetivos_alcance = StringToNull(.objetivos_alcance.Text)

    ' ESTILO DE CITA (EXTRAE EL NOMBRE DEL ARCHIVO DEL TEXTO MOSTRADO)
    resultado!estilo_cita = FMetadatosLibro.ExtraerNombreCSL(FMetadatosLibro.cmb_tipo_csl.Text)

    ' NOTAS INTERNAS
    resultado!notas_internas = StringToNull(.notas_internas.Text)

  End With

  ' --- 5. ACTUALIZAR Y CONFIRMAR ---
  resultado.Update
  m_ConexionBD.mConn.Commit()
  resultado = Null

  m_Sonido.sonar("Info")
  Message.Info("Metadatos de libro guardados correctamente.")

  ' RECARGAR PARA MOSTRAR EL id_libro ACTUALIZADO Y NORMALIZADOS
  CargarMetadatosDeLibro()

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error al guardar metadatos de libro:" & gb.NewLine &
    "Mensaje: " & Error.Text & gb.NewLine &
    "Lugar: " & Error.Where & gb.NewLine &
    "Código: " & Error.Code)
  Return False

End