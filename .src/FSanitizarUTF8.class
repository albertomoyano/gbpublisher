' Gambas class file

' ==============================================================================
' Formulario: FSanitizarUTF8
' Propósito : UI para seleccionar qué tipos de caracteres invisibles eliminar
'             de los archivos .md del proyecto. Al confirmar, llama a
'             m_SanitizarUTF8.SanitizarArchivos con la Collection de tipos
'             seleccionados. Todos los checkboxes vienen marcados por default
'             porque es el caso de uso del 99% — archivos sucios de Pandoc.
' ==============================================================================

' --- FLAG QUE PERMITE EL CIERRE DESDE LOS BOTONES Y BLOQUEA LA X DEL SISTEMA ---
Private bCierrePermitido As Boolean

' ============================================
' Función   : Form_Open
' Propósito : Inicializa los checkboxes con todos los tipos marcados.
' ============================================
Public Sub Form_Open()

  ' --- 1. MARCAR TODOS LOS TIPOS POR DEFAULT ---
  chkSoftHyphen.Value = True
  chkZWSP.Value = True
  chkZWNJ.Value = True
  chkZWJ.Value = True
  chkBOM.Value = True
  chkVariationSelectors.Value = True
  chkNBSP.Value = False   ' DESTILDADO POR DEFAULT — REQUIERE DECISIÓN EXPLÍCITA

End

' ============================================
' Función   : Form_Close
' Propósito : Si el cierre viene de los botones, permitirlo. Si viene de la
'             X del sistema, bloquearlo e informar al usuario.
' ============================================
Public Sub Form_Close()

  If bCierrePermitido Then Return
  m_Sonido.sonar("Info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) &
    "use el botón <b>Cancelar</b> o <b>Eliminar</b>.")
  Stop Event

End

' ============================================
' Función   : btnCancelar_Click
' Propósito : Cierra el formulario sin ejecutar la sanitización.
' ============================================
Public Sub btnCancelar_Click()

  bCierrePermitido = True
  Me.Close()

End

' ============================================
' Función   : btnEliminar_Click
' Propósito : Valida que haya al menos un tipo marcado, construye la Collection
'             de tipos seleccionados y ejecuta la sanitización. Cierra el
'             formulario al terminar.
' ============================================
Public Sub btnEliminar_Click()

  Dim cTipos As New Collection

  ' --- 1. VALIDAR QUE HAY AL MENOS UN TIPO MARCADO ---
  If Not chkSoftHyphen.Value And Not chkZWSP.Value And Not chkZWNJ.Value And
      Not chkZWJ.Value And Not chkBOM.Value And Not chkVariationSelectors.Value And
      Not chkNBSP.Value Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar al menos un tipo de caracter a eliminar.")
    Return
  Endif

  ' --- 2. CONSTRUIR LA COLLECTION DE TIPOS A SANITIZAR ---
  cTipos[m_SanitizarUTF8.TIPO_SOFT_HYPHEN] = chkSoftHyphen.Value
  cTipos[m_SanitizarUTF8.TIPO_ZWSP] = chkZWSP.Value
  cTipos[m_SanitizarUTF8.TIPO_ZWNJ] = chkZWNJ.Value
  cTipos[m_SanitizarUTF8.TIPO_ZWJ] = chkZWJ.Value
  cTipos[m_SanitizarUTF8.TIPO_BOM] = chkBOM.Value
  cTipos[m_SanitizarUTF8.TIPO_VARIATION_SELECTORS] = chkVariationSelectors.Value
  cTipos[m_SanitizarUTF8.TIPO_NBSP] = chkNBSP.Value

  ' --- 3. EJECUTAR SANITIZACIÓN ---
  m_SanitizarUTF8.SanitizarArchivos(cTipos)

  ' --- 4. CERRAR EL FORMULARIO ---
  bCierrePermitido = True
  Me.Close()

End