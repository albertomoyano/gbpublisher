' Gambas module file

' ============================================
' Módulo    : m_GitHub
' Propósito : Genera .estado-proyecto.json como puente
'             entre la BD MySQL y GitHub Actions para
'             el seguimiento editorial del director.
'             Los IDs de GitHub viven exclusivamente en
'             .github-ids.json, gestionado solo por el Action.
' Requiere  : gb.util.web (JSON, JSONCollection)
' ============================================

' ============================================
' Función   : GenerarEstadoProyecto
' Propósito : Consulta la BD y escribe .estado-proyecto.json
'             en la raíz del proyecto con el estado editorial
'             puro. No incluye ningún campo de GitHub —
'             esos viven en .github-ids.json exclusivamente.
' Parámetros: sRutaProyecto   As String  — raíz del proyecto
'             iIdProyecto     As Integer — ID del proyecto en BD
'             sNombreProyecto As String  — nombre legible
' Retorna   : Boolean — True si el archivo se generó sin error
' ============================================
Public Function GenerarEstadoProyecto(sRutaProyecto As String, iIdProyecto As Integer, sNombreProyecto As String) As Boolean

  ' --- 1. DEFINIR RUTA DEL ARCHIVO JSON ---
  Dim sRutaJSON As String = sRutaProyecto &/ ".estado-proyecto.json"

  ' --- 2. CONSULTAR ARTÍCULOS DEL PROYECTO EN LA BD ---
  Dim hDB As Result

  Try hDB = m_ConexionBD.mConn.Exec(
    "SELECT id_articulo, nombre_archivo, titulo_articulo, doi, " &
    "estado_articulo, tipo_articulo, " &
    "fecha_recepcion, fecha_aceptacion, fecha_publicacion_online, " &
    "responsable_edicion " &
    "FROM articulos WHERE id_proyecto = " & iIdProyecto &
    " ORDER BY nombre_archivo")
  If Error Then Return False

  ' PROYECTO SIN ARTÍCULOS AÚN: NO HAY NADA QUE REPORTAR
  If Not hDB.Available Then Return True

  ' --- 3. CONSTRUIR ARRAY DE ARTÍCULOS ---
  Dim aArticulos As New Variant[]

  While hDB.Available

    Dim jArticulo As New JSONCollection
    jArticulo["nombre_archivo"] = CStr(hDB["nombre_archivo"])
    jArticulo["titulo"] = CStr(hDB["titulo_articulo"])
    jArticulo["doi"] = ValorONull(hDB["doi"])
    jArticulo["tipo_articulo"] = ValorONull(hDB["tipo_articulo"])
    jArticulo["estado"] = CStr(hDB["estado_articulo"])
    jArticulo["fecha_recepcion"] = FechaONull(hDB["fecha_recepcion"])
    jArticulo["fecha_aceptacion"] = FechaONull(hDB["fecha_aceptacion"])
    jArticulo["fecha_publicacion_online"] = FechaONull(hDB["fecha_publicacion_online"])
    jArticulo["responsable_edicion"] = ValorONull(hDB["responsable_edicion"])
    jArticulo["autores"] = ObtenerAutoresArticulo(CInt(hDB["id_articulo"]))

    aArticulos.Add(jArticulo)
    hDB.MoveNext()

  Wend

  ' --- 4. CONSTRUIR JSON RAÍZ Y GUARDAR EN DISCO ---
  Dim jRaiz As New JSONCollection
  jRaiz["proyecto"] = sNombreProyecto
  jRaiz["generado"] = Format(Now(), "yyyy-mm-ddThh:nn:ss")
  jRaiz["articulos"] = aArticulos

  Try File.Save(sRutaJSON, JSON.Encode(jRaiz))
  Return Not Error

Catch
  Return False

End Function

' ============================================
' Función   : ObtenerAutoresArticulo
' Propósito : Devuelve Variant[] con los apellidos_nombre
'             de los autores del artículo ordenados por
'             orden de autoría.
' Parámetros: iIdArticulo As Integer
' Retorna   : Variant[] — ["Apellidos, Nombre", ...]
' ============================================
Private Function ObtenerAutoresArticulo(iIdArticulo As Integer) As Variant[]

  Dim aAutores As New Variant[]

  ' --- 1. CONSULTAR AUTORES ORDENADOS ---
  Dim hAut As Result

  Try hAut = m_ConexionBD.mConn.Exec(
    "SELECT a.apellidos_nombre " &
    "FROM autores a " &
    "JOIN articulo_autor aa ON a.id_autor = aa.id_autor " &
    "WHERE aa.id_articulo = " & iIdArticulo &
    " ORDER BY aa.orden_autoria")
  If Error Then Return aAutores

  ' --- 2. ACUMULAR NOMBRES NO NULOS ---
  While hAut.Available
    If Not IsNull(hAut["apellidos_nombre"]) Then
      aAutores.Add(CStr(hAut["apellidos_nombre"]))
    Endif
    hAut.MoveNext()
  Wend

  Return aAutores

Catch
  Return aAutores

End Function

' ============================================
' Función   : ValorONull
' Propósito : Devuelve el valor como String o JSON.Null
'             si es nulo o vacío. Centraliza la lógica
'             repetitiva de campos opcionales de la BD.
' Parámetros: vValor As Variant — valor proveniente de la BD
' Retorna   : Variant — String o JSON.Null
' ============================================
Private Function ValorONull(vValor As Variant) As Variant

  If IsNull(vValor) Then Return JSON.Null
  Dim sValor As String
  Try sValor = CStr(vValor)
  If Error Or sValor = "" Then Return JSON.Null
  Return sValor

End Function

' ============================================
' Función   : FechaONull
' Propósito : Convierte fecha de BD a string ISO 8601
'             (yyyy-mm-dd) o JSON.Null si es nula.
'             JSON no tiene tipo Date nativo; el formato
'             ISO 8601 es el estándar para intercambio.
' Parámetros: vFecha As Variant — valor de fecha de la BD
' Retorna   : Variant — String "yyyy-mm-dd" o JSON.Null
' ============================================
Private Function FechaONull(vFecha As Variant) As Variant

  If IsNull(vFecha) Then Return JSON.Null
  Try Return Format(CDate(vFecha), "yyyy-mm-dd")
  Return JSON.Null

Catch
  Return JSON.Null

End Function
