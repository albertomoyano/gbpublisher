' ============================================
' Función   : ContarCaracteresMD
' Propósito : Cuenta los caracteres de cada archivo .md del proyecto
'             y muestra los resultados en FEstructuraResultados
' Parámetros: ninguno
' Retorna   : nada
' ============================================
Public Sub ContarCaracteresMD()

  ' --- 1. Inicialización de variables ---
  Dim archivos As String[]
  Dim archivo As String
  Dim contenido As String
  Dim caracteres As Long        ' LONG PARA SOPORTAR ARCHIVOS GRANDES
  Dim rutaProyecto As String
  Dim rutaArticulos As String
  Dim rutaCompleta As String

  ' --- 2. Resolución de rutas del proyecto ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)
  rutaArticulos = rutaProyecto &/ "articulos"

  ' --- 3. Recolección de archivos y cálculo de caracteres ---
  ' LAS FILAS SE ACUMULAN COMO TSV PARA EL EVENTO Data DEL TABLEVIEW
  Dim aResultados As New String[]

  ' ARCHIVOS EN LA RAÍZ DEL PROYECTO
  If Exist(rutaProyecto) Then
    archivos = Dir(rutaProyecto, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      rutaCompleta = rutaProyecto &/ archivo
      Try contenido = File.Load(rutaCompleta)
      If Error Then
        aResultados.Add(archivo & Chr(9) & "Error")
      Else
        caracteres = Len(contenido)
        aResultados.Add(archivo & Chr(9) & Format(caracteres, "#,##0"))
      Endif
    Next
  Endif

  ' ARCHIVOS EN LA SUBCARPETA /ARTICULOS
  If Exist(rutaArticulos) Then
    archivos = Dir(rutaArticulos, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      rutaCompleta = rutaArticulos &/ archivo
      caracteres = 0
      Try contenido = File.Load(rutaCompleta)
      If Error Then
        aResultados.Add("articulos/" & archivo & Chr(9) & "Error")
      Else
        caracteres = Len(contenido)
        aResultados.Add("articulos/" & archivo & Chr(9) & Format(caracteres, "#,##0"))
      Endif
    Next
  Endif

  ' --- 4. Verificar que hay resultados ---
  If aResultados.Count = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron archivos .md en el proyecto.")
    Return
  Endif

  ' --- 5. Configurar FEstructuraResultados ---
  FEstructuraResultados.blTitulo.Text = "Estadísticas de caracteres por artículo"
  FEstructuraResultados.aResultados = aResultados

  With FEstructuraResultados.gvResultados
    .Rows.Count = aResultados.Count
    .Columns.Count = 3
    .ScrollBar = Scroll.Both
    .Resizable = True
    .Header = TableView.Horizontal
    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 600
    .Columns[0].Alignment = Align.Left
    .Columns[1].Title = "Caracteres"
    .Columns[1].Width = 100
    .Columns[1].Alignment = Align.Right
    .Columns[2].Title = ""
    .Columns[2].Width = 10
  End With

  ' --- 6. Presentación del formulario ---
  FEstructuraResultados.gvResultados.Refresh
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End Sub

' ============================================
' Función   : VerificarFootnotes
' Propósito : Analiza archivos .md verificando integridad de notas al pie
'             y muestra resultados en FEstructuraResultados
' Parámetros: ninguno
' Retorna   : nada
' ============================================
Public Sub VerificarFootnotes()

  ' --- 1. Inicialización de variables ---
  Dim archivos As String[]
  Dim archivo As String
  Dim rutaProyecto As String
  Dim rutaArticulos As String
  ' Dim rutaCompleta As String
  Dim infoArchivo As String[]
  Dim iFila As Integer

  ' ARRAYS AUXILIARES PARA ACUMULAR FILAS ANTES DE CONFIGURAR EL GRID
  Dim aEtiquetas As New String[]
  Dim aSerializados As New String[]

  ' --- 2. Resolución de rutas ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)
  rutaArticulos = rutaProyecto &/ "articulos"

  ' --- 3. Recolección de archivos y procesamiento ---
  ' ARCHIVOS EN LA RAÍZ DEL PROYECTO
  If Exist(rutaProyecto) Then
    archivos = Dir(rutaProyecto, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      infoArchivo = ProcesarArchivoFootnote(rutaProyecto &/ archivo)
      aEtiquetas.Add(archivo)
      ' SE SERIALIZA EL ARRAY CON PIPE COMO SEPARADOR PARA RECONSTRUIRLO EN EL LOOP
      aSerializados.Add(infoArchivo.Join("|"))
    Next
  Endif

  ' ARCHIVOS EN LA SUBCARPETA /ARTICULOS
  If Exist(rutaArticulos) Then
    archivos = Dir(rutaArticulos, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      infoArchivo = ProcesarArchivoFootnote(rutaArticulos &/ archivo)
      aEtiquetas.Add("articulos/" & archivo)
      aSerializados.Add(infoArchivo.Join("|"))
    Next
  Endif

  ' --- 4. Verificar que hay archivos ---
  If aEtiquetas.Count = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron archivos .md en el proyecto.")
    Return
  Endif

  ' --- 5. Construir aResultados y aColores para FEstructuraResultados ---
  ' SE RECONSTRUYE CADA FILA COMO TSV DESDE EL ARRAY SERIALIZADO CON PIPE
  Dim aResultadosTSV As New String[]
  Dim aColores As New Collection

  For iFila = 0 To aEtiquetas.Count - 1
    infoArchivo = Split(aSerializados[iFila], "|")
    ' TSV: ARCHIVO + ESTADO + 4 COLUMNAS DE CONTEO
    Dim sLinea As String = aEtiquetas[iFila]
    Dim iCampo As Integer
    For iCampo = 0 To infoArchivo.Max
      sLinea &= Chr(9) & infoArchivo[iCampo]
    Next
    aResultadosTSV.Add(sLinea)
    ' COLOREAR COLUMNA DE ESTADO EN ROJO SI NO ES OK NI OK (reorg)
    If infoArchivo[0] <> "OK" And infoArchivo[0] <> "OK (reorg)" Then
      aColores[CStr(iFila) & ",1"] = Color.RGB(255, 180, 180)
    Endif
  Next

  ' --- 6. Configurar FEstructuraResultados ---
  FEstructuraResultados.blTitulo.Text = "Verificación de notas al pie (footnotes)"
  FEstructuraResultados.aResultados = aResultadosTSV
  FEstructuraResultados.aColores = aColores

  With FEstructuraResultados.gvResultados
    .Rows.Count = aResultadosTSV.Count
    .Columns.Count = 7
    .ScrollBar = Scroll.Both
    .Resizable = True
    .Header = TableView.Horizontal
    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 330
    .Columns[0].Alignment = Align.Left
    .Columns[1].Title = "Estado"
    .Columns[1].Width = 100
    .Columns[1].Alignment = Align.Center
    .Columns[2].Title = "Ref. s/definición"
    .Columns[2].Width = 140
    .Columns[2].Alignment = Align.Center
    .Columns[3].Title = "Def. s/referencia"
    .Columns[3].Width = 140
    .Columns[3].Alignment = Align.Center
    .Columns[4].Title = "Ref. duplicada"
    .Columns[4].Width = 140
    .Columns[4].Alignment = Align.Center
    .Columns[5].Title = "Def. duplicada"
    .Columns[5].Width = 140
    .Columns[5].Alignment = Align.Center
    .Columns[6].Title = ""
    .Columns[6].Width = 5
  End With

  ' --- 7. Presentación del formulario ---
  FEstructuraResultados.gvResultados.Refresh
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End

' ============================================
' Función   : VerificarEstructuraMD
' Propósito : Verifica que la jerarquía de encabezados de cada archivo .md
'             sea correcta y que todos comiencen con H2
' Parámetros: ninguno
' Retorna   : nada
' ============================================
Public Sub VerificarEstructuraMD()

  ' --- 1. Inicialización de variables ---
  Dim archivos As String[]
  Dim archivo As String
  Dim contenido As String
  Dim lineas As String[]
  Dim lineaLimpia As String
  Dim numLinea As Integer
  Dim nivelActual As Integer
  Dim nivelAnterior As Integer
  Dim textoEncabezado As String
  Dim i As Integer
  Dim char As String
  Dim sErroresArchivo As String
  Dim rutaProyecto As String
  Dim rutaArticulos As String
  Dim rutaCompleta As String
  Dim iFila As Integer

  ' ARRAYS AUXILIARES PARA ACUMULAR DATOS ANTES DE CONFIGURAR EL GRID
  Dim aEtiquetas As New String[]
  Dim aEstado As New String[]
  Dim aLineas As New String[]

  ' --- 2. Resolución de rutas ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)
  rutaArticulos = rutaProyecto &/ "articulos"

  ' --- 3. Procesamiento de archivos ---

  ' FUNCIÓN INTERNA DE ANÁLISIS — SE REPITE POR BLOQUE DE CARPETA
  ' ARCHIVOS EN LA RAÍZ DEL PROYECTO
  If Exist(rutaProyecto) Then
    archivos = Dir(rutaProyecto, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      rutaCompleta = rutaProyecto &/ archivo
      Try contenido = File.Load(rutaCompleta)
      If Error Then
        aEtiquetas.Add(archivo)
        aEstado.Add("Error lectura")
        aLineas.Add("")
      Else
        sErroresArchivo = ""
        nivelAnterior = 0
        lineas = Split(contenido, "\n")

        For numLinea = 0 To lineas.Max
          lineaLimpia = Trim(lineas[numLinea])

          ' SALTAR LÍNEAS QUE NO SON ENCABEZADOS
          If Left(lineaLimpia, 1) <> "#" Then Continue

          ' CONTAR EL NIVEL DEL ENCABEZADO
          nivelActual = 0
          For i = 1 To Len(lineaLimpia)
            char = Mid(lineaLimpia, i, 1)
            If char = "#" Then
              nivelActual += 1
            Else
              Break
            Endif
          Next

          ' IGNORAR NIVELES FUERA DE RANGO
          If nivelActual < 1 Or nivelActual > 6 Then Continue

          textoEncabezado = Trim(Mid(lineaLimpia, nivelActual + 1))

          If nivelAnterior = 0 Then
            ' PRIMER ENCABEZADO DEL ARCHIVO — DEBE SER H2
            If nivelActual <> 2 Then
              If sErroresArchivo <> "" Then sErroresArchivo &= " | "
              sErroresArchivo &= Str(numLinea + 1) & " (primer H es H" & nivelActual & ", debe ser H2)"
            Endif
          Else
            ' VERIFICAR QUE NO HAY SALTO DE NIVEL
            If nivelActual - nivelAnterior > 1 Then
              If sErroresArchivo <> "" Then sErroresArchivo &= " | "
              sErroresArchivo &= Str(numLinea + 1) & " (H" & nivelAnterior & "→H" & nivelActual & ")"
            Endif
          Endif

          nivelAnterior = nivelActual
        Next

        aEtiquetas.Add(archivo)
        If sErroresArchivo = "" Then
          aEstado.Add("OK")
          aLineas.Add("")
        Else
          aEstado.Add("Error")
          aLineas.Add(sErroresArchivo)
        Endif
      Endif
    Next
  Endif

  ' ARCHIVOS EN LA SUBCARPETA /ARTICULOS
  If Exist(rutaArticulos) Then
    archivos = Dir(rutaArticulos, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      rutaCompleta = rutaArticulos &/ archivo
      Try contenido = File.Load(rutaCompleta)
      If Error Then
        aEtiquetas.Add("articulos/" & archivo)
        aEstado.Add("Error lectura")
        aLineas.Add("")
      Else
        sErroresArchivo = ""
        nivelAnterior = 0
        lineas = Split(contenido, "\n")

        For numLinea = 0 To lineas.Max
          lineaLimpia = Trim(lineas[numLinea])

          If Left(lineaLimpia, 1) <> "#" Then Continue

          nivelActual = 0
          For i = 1 To Len(lineaLimpia)
            char = Mid(lineaLimpia, i, 1)
            If char = "#" Then
              nivelActual += 1
            Else
              Break
            Endif
          Next

          If nivelActual < 1 Or nivelActual > 6 Then Continue

          If nivelAnterior = 0 Then
            If nivelActual <> 2 Then
              If sErroresArchivo <> "" Then sErroresArchivo &= " | "
              sErroresArchivo &= Str(numLinea + 1) & " (primer H es H" & nivelActual & ", debe ser H2)"
            Endif
          Else
            If nivelActual - nivelAnterior > 1 Then
              If sErroresArchivo <> "" Then sErroresArchivo &= " | "
              sErroresArchivo &= Str(numLinea + 1) & " (H" & nivelAnterior & "→H" & nivelActual & ")"
            Endif
          Endif

          nivelAnterior = nivelActual
        Next

        aEtiquetas.Add("articulos/" & archivo)
        If sErroresArchivo = "" Then
          aEstado.Add("OK")
          aLineas.Add("")
        Else
          aEstado.Add("Error")
          aLineas.Add(sErroresArchivo)
        Endif
      Endif
    Next
  Endif

  ' --- 4. Verificar que hay archivos ---
  If aEtiquetas.Count = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron archivos .md en el proyecto.")
    Return
  Endif

  ' --- 5. Construir aResultados y aColores ---
  Dim aResultados As New String[]
  Dim aColores As New Collection

  For iFila = 0 To aEtiquetas.Count - 1
    aResultados.Add(aEtiquetas[iFila] & Chr(9) & aEstado[iFila] & Chr(9) & aLineas[iFila])
    ' COLOREAR COLUMNA DE ESTADO EN ROJO SI HAY ERROR
    If aEstado[iFila] <> "OK" Then
      aColores[CStr(iFila) & ",1"] = Color.RGB(255, 180, 180)
    Endif
  Next

  ' --- 6. Configurar FEstructuraResultados ---
  FEstructuraResultados.blTitulo.Text = "Verificación de estructura de encabezados Markdown"
  FEstructuraResultados.aResultados = aResultados
  FEstructuraResultados.aColores = aColores

  With FEstructuraResultados.gvResultados
    .Rows.Count = aResultados.Count
    .Columns.Count = 4
    .ScrollBar = Scroll.Both
    .Resizable = True
    .Header = TableView.Horizontal
    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 400
    .Columns[0].Alignment = Align.Left
    .Columns[1].Title = "Estructura"
    .Columns[1].Width = 100
    .Columns[1].Alignment = Align.Center
    .Columns[2].Title = "Línea / Error"
    .Columns[2].Width = 400
    .Columns[2].Alignment = Align.Left
    .Columns[3].Title = ""
    .Columns[3].Width = 5
  End With

  ' --- 7. Presentación del formulario ---
  FEstructuraResultados.gvResultados.Refresh
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End

' ============================================
' Función   : ButtonInfoPC
' Propósito : Muestra información del sistema y de la aplicación
'             en FEstructuraResultados con dos columnas: Info y Valor
' Parámetros: ninguno
' Retorna   : nada
' ============================================
Public Sub ButtonInfoPC()

  ' --- 1. Inicialización ---
  ' LAS FILAS SE CONSTRUYEN COMO TSV PARA EL EVENTO Data DEL TABLEVIEW
  Dim aResultados As New String[]

  ' --- 2. Construcción de filas ---
  ' SECCIÓN APLICACIÓN
  aResultados.Add("Aplicación" & Chr(9) & "gbpublisher v" & Application.Version)
  aResultados.Add("Desarrollada por" & Chr(9) & "Alberto Moyano")
  aResultados.Add("LinkedIn" & Chr(9) & "https://www.linkedin.com/in/edicion-cientifica/")
  aResultados.Add("Estudio 2A" & Chr(9) & "https://estudio2a.netlify.app/")
  aResultados.Add("Documentación" & Chr(9) & "https://albertomoyano.github.io/gbpublisher-docs/")
  ' SECCIÓN SISTEMA
  aResultados.Add("Motor gráfico" & Chr(9) & Desktop.Platform)
  aResultados.Add("Entorno gráfico" & Chr(9) & Desktop.Type)
  aResultados.Add("Nombre del equipo" & Chr(9) & System.Host)
  ' SECCIÓN GAMBAS
  aResultados.Add("Versión de Gambas" & Chr(9) & System.FullVersion)
  aResultados.Add("Codificación del sistema" & Chr(9) & System.Charset)
  ' SECCIÓN HARDWARE
  aResultados.Add("Arquitectura" & Chr(9) & System.Architecture)
  If Exist("/proc/cpuinfo") Then
    aResultados.Add("Procesador" & Chr(9) & GetCPUInfo())
  Endif
  aResultados.Add("Memoria total" & Chr(9) & GetMemoryInfo())
  aResultados.Add("Resolución de pantalla" & Chr(9) & CStr(Desktop.W) & "x" & CStr(Desktop.H))

  ' --- 3. Configurar FEstructuraResultados ---
  FEstructuraResultados.blTitulo.Text = "Información del sistema"
  FEstructuraResultados.aResultados = aResultados
  FEstructuraResultados.aColores = New Collection  ' SIN COLORES ESPECIALES EN ESTA FUNCIÓN

  With FEstructuraResultados.gvResultados
    .Rows.Count = aResultados.Count
    .Columns.Count = 3
    .ScrollBar = Scroll.Both
    .Resizable = True
    .Header = TableView.Horizontal
    .Columns[0].Title = "Información"
    .Columns[0].Width = 300
    .Columns[0].Alignment = Align.Left
    .Columns[1].Title = "Valor"
    .Columns[1].Width = 600
    .Columns[1].Alignment = Align.Left
    .Columns[2].Title = ""
    .Columns[2].Width = 5
  End With

  ' --- 4. Presentación del formulario ---
  FEstructuraResultados.gvResultados.Refresh
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End Sub

' ============================================
' Función   : IntegridadSistema
' Propósito : Verifica que todas las dependencias externas y componentes
'             de Gambas necesarios para gbpublisher estén disponibles
' Parámetros: ninguno
' Retorna   : nada
'
' CÓMO AGREGAR NUEVAS DEPENDENCIAS:
'   Existen tres helpers disponibles según el tipo de dependencia:
'
'   1. VerificarPaquete(sNombre, sDescripcion, sAccion, aX, aY, aZ)
'      Para paquetes .deb instalados con apt.
'      Ejemplo: VerificarPaquete("pandoc", "Pandoc", "sudo apt install pandoc", ...)
'
'   2. VerificarComando(sComando, sDescripcion, sAccion, aX, aY, aZ)
'      Para comandos del sistema (java, xmllint, etc.)
'      Ejemplo: VerificarComando("xmllint", "xmllint", "sudo apt install libxml2-utils", ...)
'
'   3. VerificarJar(sDirectorio, sPatron, sDescripcion, sAccion, aX, aY, aZ)
'      Para archivos JAR instalados manualmente.
'      Ejemplo: VerificarJar("/opt/Saxon-HE", "saxon-he-*.jar", "Saxon-HE", "Ver docs", ...)
'
'   En los tres casos, los últimos tres parámetros son siempre los mismos arrays
'   acumuladores: aNombres, aEstados, aComentarios
'   Si el estado es OK el comentario queda vacío automáticamente.
' ============================================
Public Function IntegridadSistema(bMostrarModal As Boolean) As Integer

  ' --- 1. Inicialización de arrays acumuladores ---
  Dim aNombres As New String[]
  Dim aEstados As New String[]
  Dim aComentarios As New String[]
  Dim iFila As Integer

  ' ============================================================
  ' --- 2. VERIFICACIÓN DE BASE DE DATOS ---
  ' ============================================================
  VerificarPaquete("mysql-server", "MySQL Server",
    "sudo apt install mysql-server",
    aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- 3. VERIFICACIÓN DE JAVA (requerido por Saxon-HE) ---
  ' ============================================================
  VerificarComando("java", "Java Runtime Environment",
    "sudo apt install default-jre",
    aNombres, aEstados, aComentarios)
  VerificarJar("/opt/verapdf", "verapdf", "veraPDF (validador PDF/A)",
    "Descargar desde verapdf.org/software → sudo ./verapdf-install → instalar en /opt/verapdf",
    aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- 4. VERIFICACIÓN DE SAXON-HE (instalación manual en /opt) ---
  ' Estructura obligatoria:
  '   /opt/Saxon-HE/saxon-he-[version].jar  — JAR principal
  '   /opt/Saxon-HE/lib/xmlresolver-*.jar   — dependencias obligatorias
  ' Descargar ZIP desde: https://www.saxonica.com/download/download_page.xml
  ' COPIAR AMBOS: el JAR principal Y la carpeta lib/ completa
  ' ============================================================
  VerificarJar("/opt/Saxon-HE", "saxon-he-*.jar", "Saxon-HE — JAR principal",
    "Descargar ZIP desde saxonica.com → sudo mkdir -p /opt/Saxon-HE → sudo cp saxon-he-*.jar /opt/Saxon-HE/",
    aNombres, aEstados, aComentarios)
  VerificarJar("/opt/Saxon-HE/lib", "xmlresolver-*.jar", "Saxon-HE — dependencias lib/xmlresolver",
    "Copiar carpeta lib/ del ZIP de Saxon → sudo mkdir -p /opt/Saxon-HE/lib → sudo cp lib/xmlresolver-*.jar /opt/Saxon-HE/lib/",
    aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- 5. VERIFICACIÓN DE PROCESADORES DE DOCUMENTOS ---
  ' ============================================================
  VerificarPaquete("chromium", "Chromium", "sudo apt install chromium", aNombres, aEstados, aComentarios)
  VerificarPaquete("pandoc", "Pandoc", "sudo apt install pandoc", aNombres, aEstados, aComentarios)
  VerificarPaquete("imagemagick", "ImageMagick (convertidor)", "sudo apt install imagemagick", aNombres, aEstados, aComentarios)
  VerificarPaquete("texlive-full", "TeX Live (completo)", "sudo apt install texlive-full", aNombres, aEstados, aComentarios)
  VerificarComando("lua", "Lua (intérprete)", "sudo apt install lua", aNombres, aEstados, aComentarios)
  VerificarPaquete("epubcheck", "epubcheck (validador EPUB)", "sudo apt install epubcheck", aNombres, aEstados, aComentarios)
  VerificarPaquete("calibre", "Calibre (visualizar EPUB)", "sudo apt install calibre", aNombres, aEstados, aComentarios)
  VerificarPaquete("libimage-exiftool-perl", "exiftool (herramienta)", "sudo apt install libimage-exiftool-perl", aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- 6. VERIFICACIÓN DE VALIDADORES XML ---
  ' ============================================================
  VerificarComando("xmllint", "xmllint (validador XML)", "sudo apt install libxml2-utils", aNombres, aEstados, aComentarios)
  VerificarComando("xsltproc", "xsltproc (XSLT processor)", "sudo apt install xsltproc", aNombres, aEstados, aComentarios)

  ' PACKTOOLS: LIBRERÍA PYTHON — NO TIENE EJECUTABLE EN PATH
  ' SE VERIFICA CON python3 -c "import packtools"
  Dim sPacktools As String
  Shell "python3 -c 'import packtools' 2>/dev/null && echo OK || echo FALLO" To sPacktools
  aNombres.Add("packtools (validador SciELO PS)")
  If Trim(sPacktools) = "OK" Then
    aEstados.Add("OK")
    aComentarios.Add("")
  Else
    aEstados.Add("Fallo")
    aComentarios.Add("pip install packtools --break-system-packages")
  Endif

  ' ============================================================
  ' --- 7. VERIFICACIÓN DE CONTROL DE VERSIONES ---
  ' ============================================================
  VerificarComando("git", "Git (control de versiones)", "sudo apt install git", aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- 7b. VERIFICACIÓN DE COMPONENTES GAMBAS ---
  ' Para agregar un componente: copiar cualquiera de estas líneas
  ' y reemplazar nombre y descripción. La acción es siempre apt install.
  ' ============================================================
  VerificarPaquete("gambas3-runtime", "Gambas3 Runtime", "sudo apt install gambas3-runtime", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-complex", "Gambas3 gb.complex", "sudo apt install gambas3-gb-complex", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-crypt", "Gambas3 gb.crypt", "sudo apt install gambas3-gb-crypt", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-db2", "Gambas3 gb.db2", "sudo apt install gambas3-gb-db2", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-db2-mysql", "Gambas3 gb.db2.mysql", "sudo apt install gambas3-gb-db2-mysql", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-db2-sqlite3", "Gambas3 gb.db2.sqlite3", "sudo apt install gambas3-gb-db2-sqlite3", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-dbus", "Gambas3 gb.dbus", "sudo apt install gambas3-gb-dbus", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-desktop", "Gambas3 gb.desktop", "sudo apt install gambas3-gb-desktop", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-eval-highlight", "Gambas3 gb.eval / gb.eval.highlight", "sudo apt install gambas3-gb-eval-highlight", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-form", "Gambas3 gb.form", "sudo apt install gambas3-gb-form", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-form-dialog", "Gambas3 gb.form.dialog", "sudo apt install gambas3-gb-form-dialog", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-form-editor", "Gambas3 gb.form.editor", "sudo apt install gambas3-gb-form-editor", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-form-htmlview", "Gambas3 gb.form.htmlview", "sudo apt install gambas3-gb-form-htmlview", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-form-terminal", "Gambas3 gb.form.terminal", "sudo apt install gambas3-gb-form-terminal", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-highlight", "Gambas3 gb.highlight", "sudo apt install gambas3-gb-highlight", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-image", "Gambas3 gb.image", "sudo apt install gambas3-gb-image", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-markdown", "Gambas3 gb.markdown", "sudo apt install gambas3-gb-markdown", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-net", "Gambas3 gb.net", "sudo apt install gambas3-gb-net", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-net-curl", "Gambas3 gb.net.curl", "sudo apt install gambas3-gb-net-curl", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-openssl", "Gambas3 gb.openssl", "sudo apt install gambas3-gb-openssl", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-pcre", "Gambas3 gb.pcre", "sudo apt install gambas3-gb-pcre", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-qt5", "Gambas3 gb.qt5", "sudo apt install gambas3-gb-qt5", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-qt5-ext", "Gambas3 gb.qt5.ext", "sudo apt install gambas3-gb-qt5-ext", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-sdl2-audio", "Gambas3 gb.sdl2.audio", "sudo apt install gambas3-gb-sdl2-audio", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-settings", "Gambas3 gb.settings", "sudo apt install gambas3-gb-settings", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-term", "Gambas3 gb.term", "sudo apt install gambas3-gb-term", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-util", "Gambas3 gb.util", "sudo apt install gambas3-gb-util", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-util-web", "Gambas3 gb.util.web", "sudo apt install gambas3-gb-util-web", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-xml", "Gambas3 gb.xml", "sudo apt install gambas3-gb-xml", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-xml-html", "Gambas3 gb.xml.html", "sudo apt install gambas3-gb-xml-html", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-xml-rpc", "Gambas3 gb.xml.rpc", "sudo apt install gambas3-gb-xml-rpc", aNombres, aEstados, aComentarios)
  VerificarPaquete("gambas3-gb-xml-xslt", "Gambas3 gb.xml.xslt", "sudo apt install gambas3-gb-xml-xslt", aNombres, aEstados, aComentarios)

  ' ============================================================
  ' --- ZONA DE EXTENSIÓN — AGREGAR NUEVAS DEPENDENCIAS AQUÍ ---
  ' ============================================================
  ' VerificarPaquete("nombre-paquete", "Descripción", "sudo apt install nombre-paquete", aNombres, aEstados, aComentarios)
  ' VerificarComando("comando", "Descripción", "instrucción de instalación", aNombres, aEstados, aComentarios)
  ' VerificarJar("/opt/Dir", "archivo-*.jar", "Descripción", "instrucción", aNombres, aEstados, aComentarios)
  ' ============================================================

  ' --- 8. Contar fallos ---
  Dim iFallos As Integer = 0
  For iFila = 0 To aEstados.Count - 1
    If aEstados[iFila] = "Fallo" Then Inc iFallos
  Next

  ' --- 9. Mostrar modal solo si fue solicitado ---
  If bMostrarModal Then
    ' CONSTRUIR aResultados Y aColores DESDE LOS ARRAYS ACUMULADORES
    Dim aResultados As New String[]
    Dim aColores As New Collection

    For iFila = 0 To aNombres.Count - 1
      aResultados.Add(aNombres[iFila] & Chr(9) & aEstados[iFila] & Chr(9) & aComentarios[iFila])
      ' COLOREAR COLUMNA DE ESTADO EN ROJO SI ES FALLO
      If aEstados[iFila] = "Fallo" Then
        aColores[CStr(iFila) & ",1"] = Color.RGB(255, 180, 180)
      Endif
    Next

    FEstructuraResultados.blTitulo.Text = "Integridad del sistema — dependencias de gbpublisher"
    FEstructuraResultados.aResultados = aResultados
    FEstructuraResultados.aColores = aColores

    With FEstructuraResultados.gvResultados
      .Rows.Count = aResultados.Count
      .Columns.Count = 4
      .ScrollBar = Scroll.Both
      .Resizable = True
      .Header = TableView.Horizontal
      .Columns[0].Title = "Programa / Librería"
      .Columns[0].Width = 400
      .Columns[0].Alignment = Align.Left
      .Columns[1].Title = "Estado"
      .Columns[1].Width = 80
      .Columns[1].Alignment = Align.Center
      .Columns[2].Title = "Cómo se soluciona"
      .Columns[2].Width = 420
      .Columns[2].Alignment = Align.Left
      .Columns[3].Title = ""
      .Columns[3].Width = 5
    End With

    FEstructuraResultados.gvResultados.Refresh
    m_Sonido.sonar("Info")
    FEstructuraResultados.ShowModal
  Endif

  Return iFallos

End Function

' ============================================
' Función   : VerificarPaquete
' Propósito : Comprueba si un paquete .deb está instalado via dpkg
' Parámetros: sNombre      As String   — nombre exacto del paquete en apt
'             sDescripcion As String   — texto legible para mostrar en el grid
'             sAccion      As String   — comando de instalación si falla
'             aNombres     As String[] — acumulador columna Programa
'             aEstados     As String[] — acumulador columna Estado
'             aComentarios As String[] — acumulador columna Comentarios
' Retorna   : nada
' ============================================
Private Sub VerificarPaquete(sNombre As String, sDescripcion As String, sAccion As String, aNombres As String[], aEstados As String[], aComentarios As String[])

  Dim sSalida As String

  ' DPKG DEVUELVE "1" SI EL PAQUETE ESTÁ INSTALADO EN ESTADO ii, "0" SI NO
  Shell "dpkg -l " & sNombre & " 2>/dev/null | grep -c '^ii'" To sSalida

  aNombres.Add(sDescripcion)
  If Trim(sSalida) = "1" Then
    aEstados.Add("OK")
    aComentarios.Add("")
  Else
    aEstados.Add("Fallo")
    aComentarios.Add(sAccion)
  Endif

End

' ============================================
' Función   : VerificarComando
' Propósito : Comprueba si un comando está disponible en el PATH del sistema
' Parámetros: sComando     As String   — nombre del ejecutable a buscar
'             sDescripcion As String   — texto legible para mostrar en el grid
'             sAccion      As String   — instrucción de instalación si falla
'             aNombres     As String[] — acumulador columna Programa
'             aEstados     As String[] — acumulador columna Estado
'             aComentarios As String[] — acumulador columna Comentarios
' Retorna   : nada
' ============================================
Private Sub VerificarComando(sComando As String, sDescripcion As String, sAccion As String, aNombres As String[], aEstados As String[], aComentarios As String[])

  Dim sSalida As String

  ' WHICH DEVUELVE LA RUTA DEL COMANDO SI EXISTE, VACÍO SI NO ESTÁ EN EL PATH
  Shell "which " & sComando & " 2>/dev/null" To sSalida

  aNombres.Add(sDescripcion)
  If Trim(sSalida) <> "" Then
    aEstados.Add("OK")
    aComentarios.Add("")
  Else
    aEstados.Add("Fallo")
    aComentarios.Add(sAccion)
  Endif

End

' ============================================
' Función   : VerificarJar
' Propósito : Comprueba si existe un archivo JAR en un directorio dado,
'             usando un patrón con wildcard para tolerar distintas versiones
' Parámetros: sDirectorio  As String   — ruta del directorio donde buscar
'             sPatron      As String   — patrón de nombre (ej: "saxon-he-*.jar")
'             sDescripcion As String   — texto legible para mostrar en el grid
'             sAccion      As String   — instrucción de instalación si falla
'             aNombres     As String[] — acumulador columna Programa
'             aEstados     As String[] — acumulador columna Estado
'             aComentarios As String[] — acumulador columna Comentarios
' Retorna   : nada
' ============================================
Private Sub VerificarJar(sDirectorio As String, sPatron As String, sDescripcion As String, sAccion As String, aNombres As String[], aEstados As String[], aComentarios As String[])

  Dim aJars As String[]
  ' Dim bEncontrado As Boolean

  aNombres.Add(sDescripcion)

  ' PRIMERO VERIFICAR QUE EXISTA EL DIRECTORIO
  If Not Exist(sDirectorio) Then
    aEstados.Add("Fallo")
    aComentarios.Add(sAccion)
    Return
  Endif

  ' --- BUSCAR ARCHIVOS QUE COINCIDAN CON EL PATRÓN DENTRO DEL DIRECTORIO ---
  ' Try + If Error EXPLÍCITO PORQUE And EN GAMBAS NO ES SHORT-CIRCUIT.
  ' SI Dir FALLA, aJars QUEDA EN ESTADO INCIERTO Y EVALUAR aJars.Count
  ' EN UNA EXPRESIÓN COMBINADA PODRÍA LANZAR EXCEPCIÓN
  Try aJars = Dir(sDirectorio, sPatron)
  If Error Then
    aEstados.Add("Fallo")
    aComentarios.Add(sAccion)
    Return
  Endif

  If aJars.Count > 0 Then
    aEstados.Add("OK")
    aComentarios.Add("")
  Else
    aEstados.Add("Fallo")
    aComentarios.Add(sAccion)
  Endif

End

' ============================================
' Función   : CrearBuscadorPy
' Propósito : Verifica si el script buscador.py existe en el directorio
'             de configuración de la app; si no existe, lo crea escribiendo
'             su contenido directamente desde el código (sin archivo externo)
' Parámetros: (ninguno)
' Retorna   : Boolean — True si el archivo ya existía o fue creado con éxito
'                       False si ocurrió un error al escribirlo
' ============================================
Public Function CrearBuscadorPy() As Boolean

  ' --- 1. INICIALIZACIÓN DE VARIABLES ---
  Dim sRuta As String = User.Home &/ ".gbpublisher/buscador.py"
  Dim sContenido As String
  Dim q As String = Chr(34)   ' COMILLA DOBLE — NECESARIA PARA INCRUSTAR EN STRINGS PYTHON
  Dim n As String = Chr(10)   ' SALTO DE LÍNEA UNIX

  ' --- 2. VERIFICACIÓN DE EXISTENCIA ---
  ' SI EL ARCHIVO YA EXISTE NO SE SOBREESCRIBE
  If Exist(sRuta) Then Return True

  ' --- 3. CONSTRUCCIÓN DEL CONTENIDO DEL SCRIPT PYTHON ---
  ' SE USA CONCATENACIÓN ESTÁNDAR DE PYTHON EN LUGAR DE F-STRINGS
  ' PARA EVITAR QUE LAS LLAVES {} SEAN INTERPRETADAS POR EL IDE DE GAMBAS
  sContenido = "import os" & n
  sContenido &= "import sys" & n
  sContenido &= "import re" & n
  sContenido &= "from pathlib import Path" & n
  sContenido &= "def buscar_frase_en_archivos(directorio_base, frase):" & n
  sContenido &= "    coincidencia_encontrada = False" & n
  sContenido &= "    # Crear patron para busqueda insensible a mayusculas" & n
  sContenido &= "    patron = re.compile(re.escape(frase), re.IGNORECASE)" & n
  sContenido &= "    # Construir rutas de busqueda" & n
  sContenido &= "    carpeta_base = Path(directorio_base)" & n
  sContenido &= "    carpeta_articulos = carpeta_base / " & q & "articulos" & q & n
  sContenido &= "    # Listar archivos a analizar (.md y .tex) en ambos lugares" & n
  sContenido &= "    archivos_en_base = list(carpeta_base.glob(" & q & "*.md" & q & ")) + list(carpeta_base.glob(" & q & "*.tex" & q & "))" & n
  sContenido &= "    archivos_en_articulos = []" & n
  sContenido &= "    if carpeta_articulos.exists() and carpeta_articulos.is_dir():" & n
  sContenido &= "        archivos_en_articulos = list(carpeta_articulos.rglob(" & q & "*.md" & q & ")) + list(carpeta_articulos.rglob(" & q & "*.tex" & q & "))" & n
  sContenido &= "    # Unir ambos conjuntos" & n
  sContenido &= "    archivos_a_analizar = archivos_en_base + archivos_en_articulos" & n
  sContenido &= "    if not archivos_a_analizar:" & n
  sContenido &= "        print(" & q & "No se encontraron archivos .md ni .tex en la carpeta del proyecto ni en 'articulos'" & q & ")" & n
  sContenido &= "        return" & n
  sContenido &= "    print(" & q & "Buscando '" & q & " + frase + " & q & "' en archivos .md y .tex..." & q & ")" & n
  sContenido &= "    print(" & q & "Analizando " & q & " + str(len(archivos_a_analizar)) + " & q & " archivo(s)..." & q & ")" & n
  sContenido &= "    print()" & n
  sContenido &= "    for archivo_path in archivos_a_analizar:" & n
  sContenido &= "        try:" & n
  sContenido &= "            with open(archivo_path, 'r', encoding='utf-8') as f:" & n
  sContenido &= "                for num_linea, linea in enumerate(f, 1):" & n
  sContenido &= "                    if patron.search(linea):" & n
  sContenido &= "                        ruta_relativa = archivo_path.relative_to(directorio_base)" & n
  sContenido &= "                        print(" & q & "Encontrada en: " & q & " + str(ruta_relativa) + " & q & ", linea " & q & " + str(num_linea))" & n
  sContenido &= "                        print(" & q & "   Contexto: " & q & " + linea.strip())" & n
  sContenido &= "                        print()" & n
  sContenido &= "                        coincidencia_encontrada = True" & n
  sContenido &= "        except Exception as e:" & n
  sContenido &= "            ruta_relativa = archivo_path.relative_to(directorio_base)" & n
  sContenido &= "            print(" & q & "No se pudo leer el archivo " & q & " + str(ruta_relativa) + " & q & ": " & q & " + str(e))" & n
  sContenido &= "    if not coincidencia_encontrada:" & n
  sContenido &= "        print(" & q & "No se encontraron coincidencias para '" & q & " + frase + " & q & "' en los archivos .md o .tex" & q & ")" & n
  sContenido &= "    else:" & n
  sContenido &= "        print(" & q & "Busqueda completada" & q & ")" & n
  sContenido &= "if __name__ == " & q & "__main__" & q & ":" & n
  sContenido &= "    if len(sys.argv) < 2:" & n
  sContenido &= "        print(" & q & "Error: No se proporciono ninguna frase para buscar." & q & ")" & n
  sContenido &= "        print(" & q & "Uso: python3 buscador.py <frase_a_buscar>" & q & ")" & n
  sContenido &= "        sys.exit(1)" & n
  sContenido &= "    frase = " & q & " " & q & ".join(sys.argv[1:])" & n
  sContenido &= "    directorio_actual = os.getcwd()" & n
  sContenido &= "    print(" & q & "Directorio base: " & q & " + directorio_actual)" & n
  sContenido &= "    buscar_frase_en_archivos(directorio_actual, frase)" & n

  ' --- 4. ESCRITURA DEL ARCHIVO EN DISCO ---
  Try File.Save(sRuta, sContenido)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo crear el archivo buscador.py:" & Chr(10) & Error.Text)
    Return False
  Endif

  Return True

End

' ============================================
' Función   : BotonesLibroRevista
' Propósito : Alterna visibilidad de botones según tipo de proyecto
' Parámetros: bEsRevista As Boolean — True = revista, False = libro
' Retorna   : (nada)
' ============================================
Public Sub BotonesLibroRevista(bEsRevista As Boolean)

  FMain.btnMetadatosRevista.Visible = bEsRevista
  FMain.btnMetadatosArticulos.Visible = bEsRevista
  FMain.btnGenerarXMLcanonico.Visible = bEsRevista
  FMain.btnSiglas.Visible = bEsRevista

  FMain.btnMetadatosLibro.Visible = Not bEsRevista
  FMain.btnMetadatosCapitulos.Visible = Not bEsRevista
  FMain.btnGenerarDocBookcanonico.Visible = Not bEsRevista
  FMain.btnSiglas.Visible = Not bEsRevista

End

' ============================================
' Función   : VerificarAccesoSSHGitHub
' Propósito : Confirma que el usuario tiene clave SSH funcional
'             contra GitHub antes de intentar un push
' Parámetros: ninguno
' Retorna   : Boolean — True si la autenticación SSH es exitosa
' ============================================
Public Function VerificarAccesoSSHGitHub() As Boolean

  ' --- 1. Verificación rápida: ¿existe alguna clave SSH? ---
  If Not Exist(User.Home &/ ".ssh/id_ed25519.pub") And Not Exist(User.Home &/ ".ssh/id_rsa.pub") Then
    Message.Warning("No se encontró ninguna clave SSH en ~/.ssh/\n\nPara generar una:\n  ssh-keygen -t ed25519\n\nLuego agregar la clave pública en:\n  GitHub → Settings → SSH and GPG keys")
    Return False
  Endif

  ' --- 2. Verificación real: ¿GitHub acepta la clave? ---
  Dim sSalida As String
  Shell "ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -T git@github.com 2>&1" To sSalida
  Wait

  If InStr(sSalida, "successfully authenticated") > 0 Then
    ' AUTENTICACIÓN EXITOSA
    Return True
  Endif

  ' --- 3. Diagnóstico del fallo ---
  If InStr(sSalida, "Permission denied") > 0 Then
    Message.Warning("La clave SSH existe pero GitHub la rechazó.\n\nVerificá que la clave pública esté cargada en:\n  GitHub → Settings → SSH and GPG keys")
  Else
    Message.Warning("No se pudo conectar con GitHub.\n\nVerificá la conexión a internet.\n\nDetalle: " & sSalida)
  Endif

  Return False

End Function

' ============================================
' Función   : VerificarProtocoloRemoto
' Propósito : Detecta si el remote origin usa HTTPS y lo
'             corrige automáticamente a SSH
' Parámetros: sRutaProyecto As String — ruta del repo git
' Retorna   : Boolean — True si el remote usa SSH (o fue corregido)
' ============================================
Public Function VerificarProtocoloRemoto(sRutaProyecto As String) As Boolean

  ' --- 1. Obtener la URL actual del remote ---
  Dim sUrl As String

  Shell "cd " & Chr(34) & sRutaProyecto & Chr(34) & " && git remote get-url origin 2>&1" To sUrl
  Wait
  sUrl = Trim(sUrl)

  ' --- 2. Si ya usa SSH, no hay nada que corregir ---
  If Left(sUrl, 4) = "git@" Then
    Return True
  Endif

  ' --- 3. Si usa HTTPS, ofrecer corrección automática ---
  If Left(sUrl, 8) = "https://" Then
    ' EXTRAER USUARIO/REPO DE LA URL HTTPS
    ' FORMATO: https://github.com/usuario/repo.git
    Dim sRuta As String
    sRuta = Replace(sUrl, "https://github.com/", "")
    ' ASEGURAR QUE TERMINE EN .git
    If Not Right(sRuta, 4) = ".git" Then
      sRuta = sRuta & ".git"
    Endif
    Dim sUrlSSH As String
    sUrlSSH = "git@github.com:" & sRuta

    Select Case Message.Question("El remote está configurado con HTTPS:\n\n" & sUrl & "\n\nEsto provoca que pida usuario y clave.\n¿Corregir automáticamente a SSH?\n\n" & sUrlSSH, "Corregir", "Cancelar")
      Case 1
        ' CAMBIAR EL REMOTE A SSH
        Shell "cd " & Chr(34) & sRutaProyecto & Chr(34) & " && git remote set-url origin " & Chr(34) & sUrlSSH & Chr(34) & " 2>&1" To sUrl
        Wait
        If Error Then
          Message.Error("No se pudo cambiar el remote:\n" & sUrl)
          Return False
        Endif
        Message.Info("Remote corregido a SSH.\nEl push ahora usará la clave SSH.")
        Return True
      Case 2
        Return False
    End Select
  Endif

  ' --- 4. Protocolo no reconocido ---
  Message.Warning("El remote tiene una URL no reconocida:\n\n" & sUrl)
  Return False

End Function

' ============================================================================
' Función   : BuscarEnTexto
' Propósito : Buscar todas las ocurrencias de un término en un texto UTF-8
'             y devolver tres arrays paralelos con número de línea, posición
'             en la línea (en caracteres) y texto desde la posición al fin
'             de línea. Lógica pura: NO toca UI, NO emite sonidos, NO muestra
'             mensajes. Reusable desde cualquier formulario.
' Parámetros: sContenido           As String     — texto donde buscar (UTF-8)
'             sTermino             As String     — término literal a buscar
'             bDistingueMayusculas As Boolean    — True = case-sensitive
'             bPalabraExacta       As Boolean    — True = palabra completa
'             aNumerosLinea        As Integer[]  — OUT: números de línea base 1
'             aPosiciones          As Integer[]  — OUT: posiciones base 1 (caracteres)
'             aTextosCoincidencia  As String[]   — OUT: texto desde la posición a fin de línea
' Retorna   : Integer — cantidad de coincidencias encontradas
' Notas     : Los arrays de salida se LLENAN con Add, no se limpian. Esto
'             permite acumular resultados de varios contenidos sucesivos
'             (caso de uso: FBuscarReemplazar barriendo varios archivos).
'             El caller debe limpiarlos antes si quiere un resultado fresco.
' ============================================================================
Public Function BuscarEnTexto(sContenido As String, sTermino As String, bDistingueMayusculas As Boolean, bPalabraExacta As Boolean, aNumerosLinea As Integer[], aPosiciones As Integer[], aTextosCoincidencia As String[]) As Integer

  Dim aLineas As String[]
  Dim sLinea As String
  Dim iLinea As Integer
  Dim iPosicion As Integer
  Dim iLongTermino As Integer
  Dim iModoBusqueda As Integer
  Dim iResultados As Integer

  ' --- 1. VALIDACIÓN DE ENTRADA ---
  ' SE EVITA ENTRAR AL ALGORITMO CON DATOS QUE GARANTIZAN CERO MATCHES
  iResultados = 0
  If sContenido = "" Then Return 0
  If sTermino = "" Then Return 0

  ' --- 2. NORMALIZACIÓN DE FINES DE LÍNEA ---
  ' SE FUERZA LF (Chr(10)) PARA OBTENER UN ESQUEMA ÚNICO Y CONTEOS DE LÍNEA
  ' CONSISTENTES INDEPENDIENTEMENTE DEL ORIGEN DEL CONTENIDO (SC-01).
  ' Replace ES SEGURO SOBRE BYTES PORQUE CR Y LF SON ASCII QUE NUNCA APARECEN
  ' COMO BYTE INTERNO DE UNA SECUENCIA UTF-8 MULTIBYTE
  sContenido = Replace(sContenido, Chr(13) & Chr(10), Chr(10))
  sContenido = Replace(sContenido, Chr(13), Chr(10))

  ' --- 3. PARTICIÓN EN LÍNEAS USANDO LF EXPLÍCITO ---
  aLineas = Split(sContenido, Chr(10))

  ' --- 4. PREPARACIÓN DE PARÁMETROS DE BÚSQUEDA ---
  ' EL TOGGLE EN TRUE EXIGE CASE-SENSITIVE; EN FALSE SE USA gb.IgnoreCase
  ' QUE SÍ MANEJA Ñ↔ñ, Á↔á, ETC. SOBRE UTF-8 (LCase ESTÁNDAR ES ASCII-ONLY)
  If bDistingueMayusculas Then
    iModoBusqueda = 0
  Else
    iModoBusqueda = gb.IgnoreCase
  Endif

  iLongTermino = String.Len(sTermino)

  ' --- 5. RECORRIDO LÍNEA POR LÍNEA ---
  For iLinea = 0 To aLineas.Max
    sLinea = aLineas[iLinea]

    ' --- 6. BÚSQUEDA DE TODAS LAS OCURRENCIAS EN LA LÍNEA ---
    ' String.InStr USA POSICIÓN BASE 1 EN CARACTERES UTF-8 (NO BYTES)
    iPosicion = 1
    Do
      iPosicion = String.InStr(sLinea, sTermino, iPosicion, iModoBusqueda)
      ' SIN MÁS COINCIDENCIAS EN ESTA LÍNEA: SALIDA DEL BUCLE INTERNO
      If iPosicion = 0 Then Break

      ' DESCARTA SI NO ES PALABRA COMPLETA Y EL TOGGLE LO EXIGE
      If bPalabraExacta Then
        If Not EsPalabraCompleta(sLinea, iPosicion, iLongTermino) Then
          iPosicion = iPosicion + 1
          Continue
        Endif
      Endif

      ' REGISTRO DE LA COINCIDENCIA EN LOS ARRAYS DE SALIDA
      aNumerosLinea.Add(iLinea + 1)
      aPosiciones.Add(iPosicion)
      aTextosCoincidencia.Add(String.Mid(sLinea, iPosicion))
      iResultados = iResultados + 1

      ' AVANCE A LA SIGUIENTE POSIBLE OCURRENCIA EN LA MISMA LÍNEA
      iPosicion = iPosicion + iLongTermino
    Loop
  Next

  Return iResultados

End

' ============================================================================
' Función   : EsPalabraCompleta
' Propósito : Determinar si una coincidencia hallada representa una palabra
'             completa, evaluando los caracteres adyacentes en UTF-8.
' Parámetros: sLinea    As String  — línea donde se halló la coincidencia
'             iPosicion As Integer — posición (en CARACTERES, base 1)
'             iLongitud As Integer — longitud del término en CARACTERES
' Retorna   : Boolean — True si está delimitada por no-palabra a ambos lados
' Visibilidad: Private — auxiliar interno de BuscarEnTexto. Si en el futuro
'             algún caller externo la necesita, cambiar a Public.
' ============================================================================
Private Function EsPalabraCompleta(sLinea As String, iPosicion As Integer, iLongitud As Integer) As Boolean

  Dim sCarAntes As String
  Dim sCarDespues As String

  ' --- 1. CHEQUEO DEL CARÁCTER PREVIO ---
  If iPosicion > 1 Then
    sCarAntes = String.Mid(sLinea, iPosicion - 1, 1)
    If EsCaracterPalabra(sCarAntes) Then Return False
  Endif

  ' --- 2. CHEQUEO DEL CARÁCTER POSTERIOR ---
  If iPosicion + iLongitud <= String.Len(sLinea) Then
    sCarDespues = String.Mid(sLinea, iPosicion + iLongitud, 1)
    If EsCaracterPalabra(sCarDespues) Then Return False
  Endif

  Return True

End

' ============================================================================
' Función   : EsCaracterPalabra
' Propósito : Determinar si un carácter UTF-8 forma parte de una palabra
'             (letras ASCII, dígitos, guion bajo y rango Latin-1 acentuado
'             que cubre Á-ÿ incluyendo Ñ, ñ y todas las vocales acentuadas).
' Parámetros: sCar As String — un único carácter UTF-8 a evaluar
' Retorna   : Boolean — True si pertenece al conjunto de caracteres de palabra
' Visibilidad: Private — auxiliar interno de EsPalabraCompleta.
' Notas     : Se usa String.Code para obtener el codepoint Unicode real,
'             no el byte. Se excluyen explícitamente × (215) y ÷ (247) del
'             rango Latin-1 por no ser letras.
' ============================================================================
Private Function EsCaracterPalabra(sCar As String) As Boolean

  Dim iCodigo As Integer

  If String.Len(sCar) = 0 Then Return False

  iCodigo = String.Code(sCar)

  ' --- 1. EXCLUSIONES PUNTUALES DENTRO DEL RANGO LATIN-1 ---
  ' × (MULTIPLICACIÓN) Y ÷ (DIVISIÓN) NO SON LETRAS
  If iCodigo = 215 Then Return False
  If iCodigo = 247 Then Return False

  ' --- 2. RANGOS DE CARACTERES DE PALABRA ---
  If (iCodigo >= 65 And iCodigo <= 90) Then Return True     ' A-Z
  If (iCodigo >= 97 And iCodigo <= 122) Then Return True    ' a-z
  If (iCodigo >= 48 And iCodigo <= 57) Then Return True     ' 0-9
  If iCodigo = 95 Then Return True                           ' _
  If (iCodigo >= 192 And iCodigo <= 255) Then Return True    ' LATIN-1 ACENTUADAS

  Return False

End

' ============================================================================
' Función   : BuscarEnTextoRegex
' Propósito : Buscar todas las ocurrencias de un patrón PCRE en un texto
'             UTF-8 y devolver arrays paralelos con número de línea, offset
'             en bytes (base 0), texto desde el match al fin de línea, y
'             longitud en bytes del match. Retorna -1 si el patrón es inválido.
'             Lógica pura: NO toca UI, NO emite sonidos, NO muestra mensajes.
' Parámetros: sContenido           As String    — texto donde buscar (UTF-8)
'             sPatron              As String    — patrón PCRE
'             bDistingueMayusculas As Boolean   — True = case-sensitive
'             aNumerosLinea        As Integer[] — OUT: números de línea base 1
'             aPosiciones          As Integer[] — OUT: offsets en bytes base 0
'             aTextosCoincidencia  As String[]  — OUT: texto desde el match a fin de línea
'             aLongitudes          As Integer[] — OUT: longitudes en bytes del match
' Retorna   : Integer — cantidad de coincidencias, o -1 si patrón inválido
' Notas     : aPosiciones contiene BYTES (base 0), no caracteres. El caller
'             debe usar Left()/Mid() byte-oriented para slicing en el reemplazo.
'             Los arrays de salida se LLENAN con Add, no se limpian.
' ============================================================================
Public Function BuscarEnTextoRegex(sContenido As String, sPatron As String, bDistingueMayusculas As Boolean, aNumerosLinea As Integer[], aPosiciones As Integer[], aTextosCoincidencia As String[], aLongitudes As Integer[]) As Integer

  Dim aLineas As String[]
  Dim sLinea As String
  Dim sSub As String
  Dim iLinea As Integer
  Dim iResultados As Integer
  Dim iStart As Integer
  Dim iCharPos As Integer
  Dim sPatronFinal As String
  Dim oReg As Regexp

  iResultados = 0
  If sContenido = "" Or sPatron = "" Then Return 0

  ' INCRUSTAR FLAG (?i) EN EL PATRÓN PARA MANEJO CASE-INSENSITIVE SIN FLAGS EXTERNOS
  sPatronFinal = If(Not bDistingueMayusculas, "(?i)" & sPatron, sPatron)

  ' COMPILAR PATRÓN UNA SOLA VEZ — Compile es método de instancia, no estático
  oReg = New Regexp
  Try oReg.Compile(sPatronFinal)
  If Error Then Return -1

  sContenido = Replace(sContenido, Chr(13) & Chr(10), Chr(10))
  sContenido = Replace(sContenido, Chr(13), Chr(10))
  aLineas = Split(sContenido, Chr(10))

  For iLinea = 0 To aLineas.Max
    sLinea = aLineas[iLinea]
    iStart = 0
    Do
      ' Exec ES UN Sub VOID — ejecuta el match sobre la subcadena y actualiza propiedades
      sSub = Mid(sLinea, iStart + 1)
      If sSub = "" Then Break
      oReg.Exec(sSub)
      If oReg.Text = "" Then Break

      aNumerosLinea.Add(iLinea + 1)
      aPosiciones.Add(iStart + oReg.Offset)
      aLongitudes.Add(Len(oReg.Text))

      ' CONVERTIR OFFSET DE BYTES A POSICIÓN EN CARACTERES PARA EL TEXTO DE CONTEXTO
      iCharPos = String.Len(Left(sLinea, iStart + oReg.Offset)) + 1
      aTextosCoincidencia.Add(String.Mid(sLinea, iCharPos))

      Inc iResultados

      ' AVANZAR PASANDO EL MATCH; SI FUE VACÍO AVANZAR UN BYTE
      iStart = iStart + oReg.Offset + Len(oReg.Text)
      If Len(oReg.Text) = 0 Then Inc iStart
    Loop
  Next

  Return iResultados

End
' ============================================
' Variable pública para retorno de FCreditRoles
' El formulario llamador lee este valor después
' de ShowModal()
' ============================================
Public sCreditSeleccionado As String

' ============================================
' Función   : ContarCaracteresPares
' Propósito : Cuenta en cada archivo .md del proyecto la cantidad de
'             caracteres de apertura/cierre. Para pares asimétricos (¿?, ¡!,
'             «», paréntesis...) compara cantidad de aperturas vs cierres
'             y marca rojo si no coinciden. Para self-paired (comilla recta)
'             verifica que el conteo total sea par.
' Parámetros: (ninguno)
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub ContarCaracteresPares()

  ' --- 1. INICIALIZACIÓN DE VARIABLES ---
  Dim archivos As String[]
  Dim archivo As String
  Dim contenido As String
  Dim rutaProyecto As String
  ' Dim rutaArticulos As String
  Dim rutaCompleta As String
  Dim iFila As Integer
  Dim iPar As Integer
  Dim iColTabla As Integer
  Dim sLinea As String
  Dim cantA As Integer
  Dim cantB As Integer
  Dim aAperturas As String[]
  Dim aCierres As String[]
  Dim aRutas As New String[]
  Dim aEtiquetas As New String[]
  Dim aResultados As New String[]
  Dim aColores As New Collection
  Dim iTotalColumnasConteo As Integer
  Dim sSubcarpeta As String
  Dim sRuta As String
  Dim sPrefijo As String
  Dim aSubcarpetas As String[]

  ' --- 2. DEFINIR PARES DE CARACTERES A CONTAR ---
  ' aAperturas[i] Y aCierres[i] FORMAN UN PAR. SI SON IGUALES, EL PAR ES
  ' SELF-PAIRED (LA COMILLA RECTA): GENERA UNA SOLA COLUMNA Y SE VERIFICA
  ' QUE EL CONTEO TOTAL SEA PAR. SI SON DISTINTOS, GENERA DOS COLUMNAS Y
  ' SE VERIFICA QUE LOS CONTEOS COINCIDAN.
  ' COMILLAS TIPOGRÁFICAS CURVAS PUESTAS CON String.Chr$ PARA EVITAR PROBLEMAS
  ' DE CODIFICACIÓN AL COPIAR/PEGAR EL .module
  ' COMILLA RECTA PUESTA CON Chr(34) POR SC-01
  aAperturas = ["¿", "¡", "«", String.Chr$(8220), "(", "[", "{", Chr(34)]
  aCierres = ["?", "!", "»", String.Chr$(8221), ")", "]", "}", Chr(34)]

  ' CALCULAR EL TOTAL DE COLUMNAS DE CONTEO PARA DIMENSIONAR LA TABLA
  iTotalColumnasConteo = 0
  For iPar = 0 To aAperturas.Count - 1
    If aAperturas[iPar] = aCierres[iPar] Then
      iTotalColumnasConteo += 1
    Else
      iTotalColumnasConteo += 2
    Endif
  Next

  ' --- 3. RESOLUCIÓN DE LA RUTA RAÍZ DEL PROYECTO ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)

  ' --- 4. RECOLECCIÓN DE RUTAS ---
  ' EL ORDEN DE aSubcarpetas DETERMINA EL ORDEN DE LOS ARCHIVOS EN LA TABLA.
  ' SE SIGUE EL ORDEN NATURAL DE LECTURA DEL LIBRO/REVISTA:
  '   "" = RAÍZ (METADATOS) → front-matter → articulos → back-matter
  ' LA CADENA VACÍA REPRESENTA LA RAÍZ DEL PROYECTO Y NO LLEVA PREFIJO EN
  ' LA ETIQUETA. LAS SUBCARPETAS LLEVAN "nombre/" COMO PREFIJO.
  aSubcarpetas = ["", "front-matter", "articulos", "back-matter"]

  For Each sSubcarpeta In aSubcarpetas
    If sSubcarpeta = "" Then
      sRuta = rutaProyecto
      sPrefijo = ""
    Else
      sRuta = rutaProyecto &/ sSubcarpeta
      sPrefijo = sSubcarpeta & "/"
    Endif

    If Exist(sRuta) Then
      archivos = Dir(sRuta, "*.md")
      archivos.Sort()
      For Each archivo In archivos
        aRutas.Add(sRuta &/ archivo)
        aEtiquetas.Add(sPrefijo & archivo)
      Next
    Endif
  Next

  ' --- 5. VERIFICAR QUE HAY ARCHIVOS ---
  If aRutas.Count = 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontraron archivos .md en el proyecto.")
    Return
  Endif

  ' --- 6. PROCESAR CADA ARCHIVO Y CONSTRUIR aResultados Y aColores ---
  For iFila = 0 To aRutas.Count - 1
    rutaCompleta = aRutas[iFila]
    Try contenido = File.Load(rutaCompleta)
    If Error Then
      ' FILA DE ERROR: SOLO NOMBRE, RESTO VACÍO — CELDA DE NOMBRE EN ROJO
      aResultados.Add(aEtiquetas[iFila])
      aColores[CStr(iFila) & ",0"] = Color.RGB(255, 180, 180)
      Continue
    Endif

    ' CONSTRUIR LÍNEA TSV: ETIQUETA + CONTEOS DE CADA PAR
    sLinea = aEtiquetas[iFila]
    iColTabla = 1  ' COLUMNA 0 ES "Archivo"; LAS DE CONTEO EMPIEZAN EN 1
    For iPar = 0 To aAperturas.Count - 1
      cantA = ContarCaracter(contenido, aAperturas[iPar])

      If aAperturas[iPar] = aCierres[iPar] Then
        ' SELF-PAIRED: UNA SOLA COLUMNA, ERROR SI EL CONTEO ES IMPAR
        sLinea &= Chr(9) & Str(cantA)
        If cantA Mod 2 <> 0 Then
          aColores[CStr(iFila) & "," & CStr(iColTabla)] = Color.RGB(255, 180, 180)
        Endif
        iColTabla += 1
      Else
        ' ASIMÉTRICO: DOS COLUMNAS, ERROR SI APERTURA <> CIERRE
        cantB = ContarCaracter(contenido, aCierres[iPar])
        sLinea &= Chr(9) & Str(cantA) & Chr(9) & Str(cantB)
        If cantA <> cantB Then
          aColores[CStr(iFila) & "," & CStr(iColTabla)] = Color.RGB(255, 180, 180)
          aColores[CStr(iFila) & "," & CStr(iColTabla + 1)] = Color.RGB(255, 180, 180)
        Endif
        iColTabla += 2
      Endif
    Next
    aResultados.Add(sLinea)
  Next

  ' --- 7. CONFIGURAR FEstructuraResultados ---
  FEstructuraResultados.blTitulo.Text = "Conteo de caracteres de apertura y cierre"
  FEstructuraResultados.aResultados = aResultados
  FEstructuraResultados.aColores = aColores

  With FEstructuraResultados.gvResultados
    .Rows.Count = aResultados.Count
    .Columns.Count = iTotalColumnasConteo + 2  ' ARCHIVO + CONTEOS + FANTASMA
    .ScrollBar = Scroll.Both
    .Resizable = True
    .Header = TableView.Horizontal

    ' COLUMNA "Archivo"
    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 400
    .Columns[0].Alignment = Align.Left

    ' COLUMNAS DE CONTEO: TÍTULO = CARACTER, ANCHO 53, ALINEADO CENTRO
    iColTabla = 1
    For iPar = 0 To aAperturas.Count - 1
      If aAperturas[iPar] = aCierres[iPar] Then
        ' SELF-PAIRED: UNA COLUMNA
        .Columns[iColTabla].Title = aAperturas[iPar]
        .Columns[iColTabla].Width = 53
        .Columns[iColTabla].Alignment = Align.Center
        iColTabla += 1
      Else
        ' ASIMÉTRICO: DOS COLUMNAS
        .Columns[iColTabla].Title = aAperturas[iPar]
        .Columns[iColTabla].Width = 53
        .Columns[iColTabla].Alignment = Align.Center
        .Columns[iColTabla + 1].Title = aCierres[iPar]
        .Columns[iColTabla + 1].Width = 53
        .Columns[iColTabla + 1].Alignment = Align.Center
        iColTabla += 2
      Endif
    Next

    ' COLUMNA FANTASMA QUE ABSORBE EL ESPACIO SOBRANTE
    .Columns[iTotalColumnasConteo + 1].Title = ""
    .Columns[iTotalColumnasConteo + 1].Width = 10
  End With

  ' --- 8. PRESENTACIÓN DEL FORMULARIO ---
  FEstructuraResultados.gvResultados.Refresh
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End

' ============================================
' Función   : ObtenerArchivosMD
' Propósito : Recolecta todos los archivos .md del proyecto actual desde las
'             subcarpetas relevantes (raíz, front-matter, articulos,
'             back-matter) en el orden natural de lectura. Devuelve dos
'             arrays paralelos por referencia: rutas absolutas y etiquetas
'             con prefijo de subcarpeta para mostrar al usuario.
'             Las carpetas inexistentes se ignoran silenciosamente, lo que
'             permite que la misma función sirva para revistas (sin front-/
'             back-matter) y libros (con las cuatro carpetas).
' Parámetros: aRutas      As String[] — array destino para rutas absolutas
'             aEtiquetas  As String[] — array destino para etiquetas
' Retorna   : (Sub, sin retorno)
' ============================================
Public Sub ObtenerArchivosMD(aRutas As String[], aEtiquetas As String[])

  Dim rutaProyecto As String
  Dim aSubcarpetas As String[]
  Dim sSubcarpeta As String
  Dim sRuta As String
  Dim sPrefijo As String
  Dim archivos As String[]
  Dim archivo As String

  ' --- 1. LIMPIAR ARRAYS POR SI VENÍAN CON CONTENIDO PREVIO ---
  aRutas.Clear
  aEtiquetas.Clear

  ' --- 2. RUTA RAÍZ DEL PROYECTO ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)

  ' --- 3. ORDEN NATURAL DE LECTURA ---
  aSubcarpetas = ["", "front-matter", "articulos", "back-matter"]

  For Each sSubcarpeta In aSubcarpetas
    If sSubcarpeta = "" Then
      sRuta = rutaProyecto
      sPrefijo = ""
    Else
      sRuta = rutaProyecto &/ sSubcarpeta
      sPrefijo = sSubcarpeta & "/"
    Endif

    If Not Exist(sRuta) Then Continue

    archivos = Dir(sRuta, "*.md")
    archivos.Sort()
    For Each archivo In archivos
      aRutas.Add(sRuta &/ archivo)
      aEtiquetas.Add(sPrefijo & archivo)
    Next
  Next

End
