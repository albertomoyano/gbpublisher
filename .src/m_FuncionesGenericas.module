  FMain.PanelOTimprenta.Visible = False
  FMain.MenuButtonSalidas.Menu = ""
  FMain.MenuButtonSalidas.Visible = False
  FMain.btnAbrirDirectorio.Visible = False
  FMain.PanelBibTeX.Visible = True

  ElementosLibro()

End

