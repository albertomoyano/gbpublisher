' ==============================================================================
' EVENTO: btnBuscarTapa_Click
' DESCRIPCIÓN: ABRE DIÁLOGO DE SELECCIÓN DE IMAGEN DE TAPA,
'              COPIA AL DIRECTORIO /media DEL PROYECTO CON EL
'              NOMBRE NORMALIZADO foto-tapa.EXT (jpg o png)
'              Y ESCRIBE EL NOMBRE EN imagen_tapa (readonly)
' ==============================================================================
Public Sub btnBuscarTapa_Click()

  ' --- 1. Abrir diálogo de selección ---
  Dialog.Title = "Seleccionar imagen de tapa"
  Dialog.Filter = ["*.jpg;*.jpeg;*.png", "Imágenes (JPG, PNG)"]
  If Dialog.OpenFile() Then Return

  Dim sOrigen As String = Dialog.Path
  Dim sExtOrig As String = LCase(File.Ext(sOrigen))
  Dim sDirectorioMedia As String = File.Dir(FMain.txtProyecto.Text) &/ "media"

  ' --- 2. Normalizar extensión: jpeg → jpg ---
  Dim sExt As String
  If sExtOrig = "jpeg" Then
    sExt = "jpg"
  Else
    sExt = sExtOrig
  Endif

  Dim sNombreDestino As String = "foto-tapa." & sExt
  Dim sDestino As String = sDirectorioMedia &/ sNombreDestino

  ' --- 3. Detectar si el origen ya ES el destino ---
  ' OCURRE CUANDO EL USUARIO ELIGE foto-tapa.jpg DESDE /media
  ' NO HAY ARCHIVO QUE COPIAR, PERO SÍ HAY QUE PERSISTIR EN BD
  ' (PUEDE SER QUE EL ARCHIVO YA ESTUVIERA EN DISCO PERO LA BD NO LO REGISTRARA)
  If sOrigen = sDestino Then
    Message.Info("La imagen '" & sNombreDestino & "' ya está en el directorio /media." &
      Chr(10) & "No es necesario copiarla.")
    imagen_tapa.Text = sNombreDestino
    PersistirImagenTapa(sNombreDestino)
    Return
  Endif

  ' --- 4. Verificar que el directorio /media existe ---
  If Not Exist(sDirectorioMedia) Then
    Try Mkdir sDirectorioMedia
    If Error Then
      Message.Error("No se pudo crear el directorio /media:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- 5. Advertir si ya existe foto-tapa en /media ---
  If Exist(sDestino) Then
    If Message.Question("Ya existe '" & sNombreDestino & "' en /media." & Chr(10) &
        "¿Deseás reemplazarla?", "Sí", "No") <> 1 Then
      Return
    Endif
    Try Kill sDestino
    If Error Then
      Message.Error("Error al eliminar archivo anterior:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- 6. Copiar con nombre normalizado ---
  Try Copy sOrigen To sDestino
  If Error Then
    Message.Error("Error al copiar la imagen:" & Chr(10) & Error.Text)
    Return
  Endif

  ' --- 7. Registrar nombre normalizado en el campo ---
  imagen_tapa.Text = sNombreDestino

  ' --- 8. Persistir el nombre en BD (RC-GM-03) ---
  PersistirImagenTapa(sNombreDestino)

End Sub

' ============================================
' FUNCIÓN  : PersistirImagenTapa
' PROPÓSITO: GUARDA EL NOMBRE DE LA IMAGEN DE TAPA EN LA TABLA
'            revistas_md PARA EL PROYECTO ACTUALMENTE EN EDICIÓN.
'            APLICA RC-GM-03 (GUARDAR EN EL EVENTO, NO EN EL BOTÓN GENERAL)
'            PARA EVITAR QUE LA SELECCIÓN DE TAPA QUEDE SOLO EN UI Y SE
'            PIERDA SI EL USUARIO NO PRESIONA "GUARDAR CAMBIOS".
' PARÁMETROS: sNombre As String — NOMBRE NORMALIZADO DEL ARCHIVO
'                                  (ej. "foto-tapa.jpg")
' RETORNA   : (nada)
' ============================================
Private Sub PersistirImagenTapa(sNombre As String)

  ' --- 1. PERSISTIR EN BD ---
  ' revistas_md.id_proyecto ES UNIQUE, IDENTIFICA UNÍVOCAMENTE EL REGISTRO
  ' SOLO 2 PLACEHOLDERS: NO ENTRA EN EL PROBLEMA DE Connection.Exec CON &10+ (RC-GM-15)
  Try m_ConexionBD.mConn.Exec(
    "UPDATE revistas_md SET imagen_tapa = &1 WHERE id_proyecto = &2",
    sNombre,
    CInt(id_proyecto.Value))
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al guardar el nombre de la tapa en la base de datos:" &
      Chr(10) & Error.Text)
    Return
  Endif

End

' FUNCIÓN AUXILIAR PRIVADA — agregar al formulario
' Extrae "apa.csl" de "American Psychological... [apa.csl]"

Public Function ExtraerNombreCSL(sTexto As String) As String

  ' --- 1. Buscar el último [ y el último ] ---
  Dim iAbre As Integer = 0
  Dim iCierra As Integer = 0
  Dim i As Integer

  For i = Len(sTexto) To 1 Step -1
    If Mid(sTexto, i, 1) = "]" And iCierra = 0 Then iCierra = i
    If Mid(sTexto, i, 1) = "[" And iCierra > 0 Then
      iAbre = i
      Break
    Endif
  Next

  ' --- 2. Extraer el contenido entre los corchetes ---
  If iAbre > 0 And iCierra > iAbre Then
    Return m_XML.TrimUTF8(Mid(sTexto, iAbre + 1, iCierra - iAbre - 1))
  Endif

  ' --- 3. Fallback: ya es solo el nombre del archivo ---
  Return m_XML.TrimUTF8(sTexto)

End Function

' FLAG PARA PERMITIR EL CIERRE DESDE EL BOTÓN
Private bCierrePermitido As Boolean

Public Sub btnCerrar_Click()
  ' HABILITAR EL CIERRE Y CERRAR

  bCierrePermitido = True
  Me.Close()

End

Public Sub Form_Close()
  ' SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO

  If bCierrePermitido Then Return
  ' BLOQUEAR EL CIERRE DESDE LA X DEL SISTEMA
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End
