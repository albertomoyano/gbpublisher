' Gambas module file

' ============================================
' Módulo   : m_CercaniaTipografica
' Propósito: Detecta palabras de 5+ caracteres repetidas dentro de
'            76 caracteres en el mismo párrafo, en todos los .md del proyecto
' ============================================

Const DISTANCIA_MAXIMA As Integer = 76
Const LONGITUD_MINIMA_PALABRA As Integer = 5

' ============================================
' Función   : MostrarControlCercania
' Propósito : Punto de entrada desde el menú. Itera los archivos .md,
'             delega el análisis y puebla FEstructuraResultados
' Parámetros: ninguno
' Retorna   : nada
' ============================================
Public Sub MostrarControlCercania()

  ' --- 1. Inicialización de variables ---
  Dim archivos As String[]
  Dim archivo As String
  Dim contenido As String
  Dim lineas As String[]
  Dim rutaProyecto As String
  Dim rutaArticulos As String
  Dim rutaCompleta As String
  Dim sEtiqueta As String
  Dim sTextoParrafo As String
  Dim iLineaInicio As Integer
  Dim iNumLinea As Integer
  Dim iFila As Integer

  ' ARRAYS ACUMULADORES DE FILAS — SOLO SE AGREGAN COINCIDENCIAS
  Dim aArchivos As New String[]
  Dim aLineas As New String[]
  Dim aPalabras As New String[]
  Dim aContextos As New String[]

  ' --- 2. Resolución de rutas ---
  rutaProyecto = File.Dir(FMain.txtProyecto.Text)
  rutaArticulos = rutaProyecto &/ "articulos"

  ' --- 3. Verificar que el archivo activo es un artículo ---
  Dim sArchivoActivo As String = FMain.cmbArticulosRevista.Text
  Dim sNombreArchivo As String = File.Name(sArchivoActivo)

  If Not (sNombreArchivo Begins "a-") Then
    m_Sonido.sonar("Warning")
    Message.Warning("El archivo activo no es un artículo." & Chr(10) &
      "Seleccioná un archivo que comience con a- en el editor.")
    Return
  Endif

  rutaCompleta = rutaArticulos &/ sNombreArchivo
  If Not Exist(rutaCompleta) Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el archivo:" & Chr(10) & rutaCompleta)
    Return
  Endif

  ' PROCESAR SOLO EL ARTÍCULO ACTIVO
  Try contenido = File.Load(rutaCompleta)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo leer el archivo:" & Chr(10) & rutaCompleta)
    Return
  Endif

  sEtiqueta = sArchivoActivo
  lineas = Split(contenido, "\n")
  sTextoParrafo = ""
  iLineaInicio = 0

  For iNumLinea = 0 To lineas.Max
    If Trim(lineas[iNumLinea]) = "" Then
      If Trim(sTextoParrafo) <> "" Then
        AnalizarParrafo(sTextoParrafo, sEtiqueta, iLineaInicio, lineas, aArchivos, aLineas, aPalabras, aContextos)
      Endif
      sTextoParrafo = ""
      iLineaInicio = iNumLinea + 1
    Else
      If sTextoParrafo = "" Then
        sTextoParrafo = lineas[iNumLinea]
        iLineaInicio = iNumLinea
      Else
        sTextoParrafo &= " " & lineas[iNumLinea]
      Endif
    Endif
  Next

  ' ÚLTIMO PÁRRAFO SIN LÍNEA EN BLANCO FINAL
  If Trim(sTextoParrafo) <> "" Then
    AnalizarParrafo(sTextoParrafo, sEtiqueta, iLineaInicio, lineas, aArchivos, aLineas, aPalabras, aContextos)
  Endif

  ' --- 4. Configuración del formulario ---
  FEstructuraResultados.blTitulo.Text = "Control de cercanía — " & sNombreArchivo &
    " (repetidas en ≤" & DISTANCIA_MAXIMA & " caracteres)"

  ' --- 5. Configuración de columnas del GridView ---
  With FEstructuraResultados.gvResultados
    .Rows.Count = 0
    .Columns.Count = 5
    .Header = GridView.Horizontal
    .ScrollBar = GridView.Both

    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 400
    .Columns[0].Alignment = Align.Left

    .Columns[1].Title = "L (p1/p2)"
    .Columns[1].Width = 120
    .Columns[1].Alignment = Align.Left

    .Columns[2].Title = "Palabra"
    .Columns[2].Width = 150
    .Columns[2].Alignment = Align.Left

    .Columns[3].Title = "Contexto"
    .Columns[3].Width = 700
    .Columns[3].Alignment = Align.Left

    ' COLUMNA FANTASMA QUE ABSORBE EL ESPACIO SOBRANTE
    .Columns[4].Title = ""
    .Columns[4].Width = 10
  End With

  ' --- 6. Carga de datos ---
  ' SI NO HAY COINCIDENCIAS SE AGREGA UNA FILA INFORMATIVA
  If aArchivos.Count = 0 Then
    FEstructuraResultados.gvResultados.Rows.Count = 1
    FEstructuraResultados.gvResultados[0, 0].Text = "Sin coincidencias"
    FEstructuraResultados.gvResultados[0, 3].Text = "No se encontraron repeticiones de cercanía en ningún archivo"
  Else
    FEstructuraResultados.gvResultados.Rows.Count = aArchivos.Count
    For iFila = 0 To aArchivos.Count - 1
      FEstructuraResultados.gvResultados[iFila, 0].Text = aArchivos[iFila]
      FEstructuraResultados.gvResultados[iFila, 1].Text = aLineas[iFila]
      FEstructuraResultados.gvResultados[iFila, 2].Text = aPalabras[iFila]
      FEstructuraResultados.gvResultados[iFila, 3].Text = aContextos[iFila]
    Next
  Endif

  ' --- 7. Presentación del formulario ---
  m_Sonido.sonar("Info")
  FEstructuraResultados.ShowModal

End

' ============================================
' Función   : AnalizarParrafo
' Propósito : Busca palabras repetidas dentro del rango de distancia
'             y agrega cada coincidencia a los arrays acumuladores
' Parámetros: sParrafo       As String  — texto del párrafo normalizado
'             sEtiqueta      As String  — nombre del archivo para la columna
'             iLineaInicio   As Integer — línea base del párrafo en el documento
'             aLineasDoc     As String[]— todas las líneas del documento
'             aArchivos      As String[]— acumulador: columna Archivo
'             aLineas        As String[]— acumulador: columna L
'             aPalabras      As String[]— acumulador: columna Palabra
'             aContextos     As String[]— acumulador: columna Contexto
' Retorna   : nada (modifica los arrays ByRef)
' ============================================
Private Sub AnalizarParrafo(sParrafo As String, sEtiqueta As String, iLineaInicio As Integer, aLineasDoc As String[], aArchivos As String[], aLineas As String[], aPalabras As String[], aContextos As String[])

  ' --- 1. Inicialización ---
  Dim sParrafoLimpio As String
  Dim aPalabrasArr As String[]
  Dim aInfoPalabras As New Collection   ' CLAVE = índice como string, VALOR = Variant[]
  Dim colProcesadas As New Collection
  Dim i As Integer
  Dim j As Integer
  Dim sPalabra As String
  Dim sPalabraLower As String
  Dim sPalabraComp As String
  Dim iPosAnterior As Integer
  Dim iPosicion As Integer
  Dim iDistancia As Integer
  Dim iLineaEncontrada As Integer
  Dim sContexto As String
  Dim iPosActual As Integer
  Dim iTotal As Integer

  ' --- 2. Normalización del párrafo para tokenización ---
  ' SE REEMPLAZAN SIGNOS DE PUNTUACIÓN POR ESPACIOS PARA AISLAR PALABRAS
  sParrafoLimpio = sParrafo
  sParrafoLimpio = Replace(sParrafoLimpio, ",", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, ".", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, ";", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, ":", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "!", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "?", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "¡", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "¿", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "(", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, ")", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "[", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "]", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "«", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "»", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "\"", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "'", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "—", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "–", " ")
  sParrafoLimpio = Replace(sParrafoLimpio, "-", " ")

  ' --- 3. Tokenización con posición real en el párrafo ---
  aPalabrasArr = Split(sParrafoLimpio, " ")
  iPosActual = 1
  iTotal = 0

  For i = 0 To aPalabrasArr.Max
    sPalabra = Trim(aPalabrasArr[i])
    If sPalabra = "" Then
      iPosActual += Len(aPalabrasArr[i]) + 1
      Continue
    Endif
    iPosicion = InStr(sParrafoLimpio, sPalabra, iPosActual)
    If iPosicion > 0 Then
      ' CADA ENTRADA: [PALABRA_ORIGINAL, POSICION_EN_PARRAFO]
      aInfoPalabras.Add([sPalabra, iPosicion], Str(iTotal))
      iTotal += 1
      iPosActual = iPosicion + Len(sPalabra)
    Endif
  Next

  ' --- 4. Búsqueda de repeticiones por pares ---
  For i = 0 To iTotal - 1
    sPalabra = aInfoPalabras[Str(i)][0]
    sPalabraLower = Lower(sPalabra)

    ' IGNORAR PALABRAS CORTAS
    If Len(sPalabra) < LONGITUD_MINIMA_PALABRA Then Continue

    ' IGNORAR PALABRAS YA PROCESADAS COMO PRIMERA OCURRENCIA
    If colProcesadas.Exist(sPalabraLower) Then Continue

    iPosAnterior = aInfoPalabras[Str(i)][1]

    For j = i + 1 To iTotal - 1
      sPalabraComp = Lower(aInfoPalabras[Str(j)][0])
      If sPalabraComp <> sPalabraLower Then Continue

      iPosicion = aInfoPalabras[Str(j)][1]
      iDistancia = iPosicion - (iPosAnterior + Len(sPalabra))

      If iDistancia < 0 Or iDistancia > DISTANCIA_MAXIMA Then Continue

      ' --- 5. Construcción del contexto desde la primera ocurrencia ---
      ' EL CONTEXTO ARRANCA EN LA PRIMERA PALABRA Y LLEGA HASTA EL FINAL
      ' DE LA SEGUNDA MÁS UN MARGEN, PARA QUE LA PALABRA SEA LO PRIMERO QUE SE LEE
      Dim iCtxFin As Integer = Min(Len(sParrafoLimpio), iPosicion + Len(sPalabra) + 15)
      sContexto = Mid(sParrafoLimpio, iPosAnterior, iCtxFin - iPosAnterior + 1)
      If iCtxFin < Len(sParrafoLimpio) Then sContexto &= "…"

      ' --- 6. Línea y posición de columna para cada ocurrencia ---
      ' SE CALCULA LA LÍNEA DE CADA OCURRENCIA Y SU POSICIÓN DENTRO DE ESA LÍNEA
      Dim iLineaP1 As Integer
      Dim iLineaP2 As Integer
      Dim iColP1 As Integer
      Dim iColP2 As Integer
      Dim iAcum As Integer
      Dim k As Integer

      ' POSICIÓN DE LA PRIMERA OCURRENCIA
      iLineaP1 = CalcularLineaDePosicion(aLineasDoc, iLineaInicio, iPosAnterior)
      iAcum = 0
      For k = iLineaInicio To iLineaP1 - 1
        iAcum += Len(aLineasDoc[k]) + 1
      Next
      iColP1 = iPosAnterior - iAcum

      ' POSICIÓN DE LA SEGUNDA OCURRENCIA
      iLineaP2 = CalcularLineaDePosicion(aLineasDoc, iLineaInicio, iPosicion)
      iAcum = 0
      For k = iLineaInicio To iLineaP2 - 1
        iAcum += Len(aLineasDoc[k]) + 1
      Next
      iColP2 = iPosicion - iAcum

      ' --- 7. Acumulación de la fila ---
      ' FORMATO: "línea (col1/col2)" SI ESTÁN EN LA MISMA LÍNEA
      '          "L1:col1 / L2:col2" SI ESTÁN EN LÍNEAS DISTINTAS
      Dim sPosicion As String
      If iLineaP1 = iLineaP2 Then
        sPosicion = Str(iLineaP1 + 1) & " (" & iColP1 & "/" & iColP2 & ")"
      Else
        sPosicion = Str(iLineaP1 + 1) & ":" & iColP1 & " / " & Str(iLineaP2 + 1) & ":" & iColP2
      Endif

      aArchivos.Add(sEtiqueta)
      aLineas.Add(sPosicion)
      aPalabras.Add(sPalabra)
      aContextos.Add(sContexto)

    Next

    colProcesadas.Add(True, sPalabraLower)
  Next

End

' ============================================
' Función   : CalcularLineaDePosicion
' Propósito : Estima el número de línea del documento a partir de la
'             posición de un carácter dentro del párrafo concatenado
' Parámetros: aLineas      As String[] — todas las líneas del documento
'             iLineaInicio As Integer  — línea donde comienza el párrafo
'             iPosicion    As Integer  — posición del carácter en el párrafo
' Retorna   : Integer — número de línea base 0
' ============================================
Private Function CalcularLineaDePosicion(aLineas As String[], iLineaInicio As Integer, iPosicion As Integer) As Integer

  Dim iAcumulado As Integer
  Dim i As Integer

  iAcumulado = 0

  For i = iLineaInicio To aLineas.Max
    If Trim(aLineas[i]) = "" Then Return iLineaInicio
    iAcumulado += Len(aLineas[i]) + 1  ' +1 POR EL ESPACIO QUE SE AGREGA AL CONCATENAR
    If iAcumulado >= iPosicion Then Return i
  Next

  Return iLineaInicio

End
