' Gambas class file

' ============================================
' Formulario : FSysAdmin
' Propósito  : Panel de administración del sistema para el
'              editor de la editorial. Permite gestionar
'              usuarios MySQL, proyectos, credenciales de API
'              y respaldos de base de datos.
'              Autenticación en dos capas:
'              1) SQLite local (.superuser.sqlite)
'              2) MySQL con credenciales de aplicación
' ============================================

Private $idSeleccionado As Integer
Public $claveSeleccionada As String
Public hConn As Connection           ' CONEXIÓN SQLITE LOCAL PARA ADMIN
Public hConnServidor As Connection   ' CONEXIÓN AL SERVIDOR MYSQL
Public sUsuarioActual As String
Public sRolActual As String
Public sServidorActual As String
Private $aColumnas As String[]
Private $aRegistros As String[][]
Private $bModoEdicion As Boolean     ' CONTROLA SI ESTAMOS EN MODO EDICIÓN O NUEVO

' ============================================
' Función   : Form_Open
' Propósito : Inicializa el formulario, conecta a la base
'             SQLite local y carga los datos iniciales
' ============================================
Public Sub Form_Open()

  ' --- 1. Verificar y conectar base SQLite local ---
  Dim sRuta As String = User.Home &/ ".gbpublisher/.superuser.sqlite"

  If Not Exist(sRuta) Then
    CreateDataBase()
  Endif

  If Not Conectar(sRuta) Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo conectar a la base local.")
    Me.Close()
    Return
  Endif

  ' --- 2. Cargar IPs disponibles ---
  m_FuncionesGenericas.CargarComboBoxIP(ComboBoxIP)

  ' --- 3. Mostrar paneles de validación inicial ---
  HBox1a.Visible = True
  TableViewUsuarios.Visible = True
  HBox2a.Visible = True
  HBox3a.Visible = True
  HBox4a.Visible = True

  txtAdministrador.SetFocus()

  ' --- 4. Cargar lista de respaldos disponibles ---
  CargarListaRespaldos()

End

' ============================================
' Función   : CreateDataBase
' Propósito : Crea la base de datos SQLite local para el
'             administrador si no existe, con usuario por
'             defecto admin/admin123
' ============================================
Public Sub CreateDataBase()

  ' --- 1. Inicialización de variables ---
  Dim sHost As String = User.Home &/ ".gbpublisher"
  Dim sDbName As String = ".superuser.sqlite"
  Dim sTablas As String

  ' --- 2. Verificar que el directorio base existe ---
  If Not Exist(sHost) Then Mkdir sHost

  ' --- 3. Evitar recrear si ya existe ---
  If Exist(sHost &/ sDbName) Then Return

  ' --- 4. Crear y conectar la base ---
  hConn = New Connection
  hConn.Type = "sqlite3"
  hConn.Host = sHost
  hConn.Open()

  hConn.Databases.Add(sDbName)
  Wait 0.5

  hConn.Close()

  ' --- 5. Reconectar con la base creada ---
  hConn.Name = sDbName
  hConn.Open()

  ' --- 6. Crear estructura y datos iniciales ---
  sTablas = "CREATE TABLE superuser (" &
    "id INTEGER PRIMARY KEY AUTOINCREMENT, " &
    "usuario TEXT NOT NULL UNIQUE, " &
    "clave TEXT NOT NULL, " &
    "email TEXT);"
  hConn.Exec(sTablas)

  hConn.Exec("INSERT INTO superuser (usuario, clave, email) VALUES " &
    "('admin', '" & Hash.SHA256("admin123") & "', NULL);")

  hConn.Close()

  m_Sonido.sonar("Info")
  Message.Info("Base de datos local creada." & Chr(10) & Chr(10) &
    "Usuario inicial:" & Chr(10) &
    "Usuario: admin" & Chr(10) &
    "Contraseña: admin123" & Chr(10) & Chr(10) &
    "¡Cámbiela inmediatamente!")

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error creando la base: " & Error.Text & " (" & Error.Where & ")")

End

' ============================================
' Función   : Conectar
' Propósito : Abre la conexión a la base SQLite local
' Parámetros: sRuta As String — ruta absoluta al archivo .sqlite
' Retorna   : Boolean — True si la conexión fue exitosa
' ============================================
Public Function Conectar(sRuta As String) As Boolean

  ' --- 1. Configurar y abrir conexión ---
  hConn = New Connection
  hConn.Type = "sqlite3"
  hConn.Host = File.Dir(sRuta)
  hConn.Name = File.Name(sRuta)

  Try hConn.Open()
  If Not hConn.Opened Then Return False

  ' --- 2. Activar integridad referencial ---
  hConn.Exec("PRAGMA foreign_keys = ON;")
  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error conectando a la base: " & Error.Text & " (" & Error.Where & ")")
  Return False

End

' ============================================
' Función   : btnValidarSuperuser_Click
' Propósito : Valida al administrador en dos pasos:
'             1) SQLite local, 2) MySQL con credenciales de app
' ============================================
Public Sub btnValidarSuperuser_Click()

  ' --- 1. Obtener valores del formulario ---
  Dim sUsuario As String = Trim(txtAdministrador.Text)
  Dim sClave As String = Trim(txtClaveAdministrador.Text)
  Dim sIP As String = Trim(ComboBoxIP.Text)

  ' --- 2. Validaciones básicas ---
  If Not sUsuario Or Not sClave Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe ingresar usuario y contraseña.")
    Return
  Endif

  If Not sIP Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar una IP de servidor.")
    Return
  Endif

  ' --- 3. Validar contra SQLite local ---
  If Not ValidarAdminLocal(sUsuario, sClave) Then
    txtAdministrador.Text = ""
    txtClaveAdministrador.Text = ""
    Return
  Endif

  ' --- 4. Conectar a MySQL ---
  If Not ConectarMySQL(sIP) Then
    m_Sonido.sonar("Error")
    Message.Error("Admin válido, pero no se pudo conectar al servidor MySQL.")
    Return
  Endif

  ' --- 5. Habilitar panel de gestión ---
  sUsuarioActual = sUsuario
  sServidorActual = sIP
  sRolActual = "superadmin"

  m_Sonido.sonar("Info")
  Message.Info("Acceso concedido como SUPERADMINISTRADOR.")

  HabilitarABMUsuarios()
  PanelAdmin.Visible = False

  ' --- 6. Limpiar campos de acceso ---
  txtAdministrador.Text = ""
  txtClaveAdministrador.Text = ""
  txtEmailAdministrador.Text = ""

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error: " & Error.Text & " (" & Error.Where & ")")

End

' ============================================
' Función   : ValidarAdminLocal
' Propósito : Verifica las credenciales del administrador
'             contra la base SQLite local
' Parámetros: sUsuario As String — nombre de usuario
'             sClave   As String — contraseña en texto plano
' Retorna   : Boolean — True si las credenciales son válidas
' ============================================
Private Function ValidarAdminLocal(sUsuario As String, sClave As String) As Boolean

  ' --- 1. Generar hash de la clave ---
  Dim r As Result
  Dim sHash As String = Hash.SHA256(sClave)

  ' --- 2. Consultar en SQLite ---
  r = hConn.Exec("SELECT id FROM superuser " &
    "WHERE usuario = '" & sUsuario & "' " &
    "AND clave = '" & sHash & "';")

  If Not r.Available Then
    m_Sonido.sonar("Warning")
    Message.Warning("Usuario o contraseña de administrador incorrectos.")
    Return False
  Endif

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error validando administrador local: " & Error.Text)
  Return False

End

' ============================================
' Función   : ConectarMySQL
' Propósito : Abre la conexión al servidor MySQL usando
'             las credenciales fijas de la aplicación
' Parámetros: sIP As String — dirección IP del servidor MySQL
' Retorna   : Boolean — True si la conexión fue exitosa
' ============================================
Private Function ConectarMySQL(sIP As String) As Boolean

  ' --- 1. Configurar y abrir conexión ---
  hConnServidor = New Connection
  hConnServidor.Type = "mysql"
  hConnServidor.Host = sIP
  hConnServidor.Port = 3306
  hConnServidor.Name = "gbpublisher"
  hConnServidor.User = "app_user"
  hConnServidor.Password = "AppUser2024!"

  Try hConnServidor.Open()

  If Not hConnServidor.Opened Then Return False

  Return True

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error conectando a MySQL: " & Error.Text)
  Return False

End

' ============================================
' Función   : HabilitarABMUsuarios
' Propósito : Muestra el panel de gestión tras autenticación
'             exitosa y carga los datos del servidor
' ============================================
Private Sub HabilitarABMUsuarios()

  ' --- 1. Mostrar panel y configurar botones ---
  PanelAdminUsuarios.Visible = True
  btnCrearUsuario.Visible = True
  btnGuardarUsuario.Visible = False
  btnGuardarCambiosUsuario.Visible = False

  LabelSesion.Text = "Conectado como administrador: " & sUsuarioActual & " @ " & sServidorActual

  ' --- 2. Cargar datos del servidor ---
  CargarUsuariosDelServidor()
  CargarProyectosDelServidor()

  ' --- 3. Inicializar módulo de APIs ---
  m_ApiCredenciales.EstablecerConexion(hConnServidor)
  ConfigurarGridView()
  txtApiKey.Password = True
  CargarCredenciales()
  LimpiarFormulario()

End

' ============================================
' Función   : CargarUsuariosDelServidor
' Propósito : Consulta y muestra todos los usuarios MySQL
'             en el TableView de usuarios
' ============================================
Private Sub CargarUsuariosDelServidor()

  ' --- 1. Limpiar y configurar TableView ---
  Dim rUsuarios As Result
  Dim iRow As Integer

  TableViewUsuarios.Clear()
  TableViewUsuarios.Rows.Count = 0
  TableViewUsuarios.Columns.Count = 6

  TableViewUsuarios.Columns[0].Title = "ID"
  TableViewUsuarios.Columns[0].Width = 50
  TableViewUsuarios.Columns[1].Title = "Usuario"
  TableViewUsuarios.Columns[1].Width = 150
  TableViewUsuarios.Columns[2].Title = "Email"
  TableViewUsuarios.Columns[2].Width = 400
  TableViewUsuarios.Columns[3].Title = "Activo"
  TableViewUsuarios.Columns[3].Width = 70
  TableViewUsuarios.Columns[4].Title = "Fecha Creación"
  TableViewUsuarios.Columns[4].Width = 200
  TableViewUsuarios.Columns[5].Title = "En Línea"
  TableViewUsuarios.Columns[5].Width = 70

  ' --- 2. Consultar y llenar datos ---
  rUsuarios = hConnServidor.Exec("SELECT id, usuario, email, activo, fecha_creacion, en_linea " &
    "FROM usuarios ORDER BY usuario;")

  While rUsuarios.Available
    TableViewUsuarios.Rows.Count += 1
    iRow = TableViewUsuarios.Rows.Count - 1

    TableViewUsuarios[iRow, 0].Text = rUsuarios["id"]
    TableViewUsuarios[iRow, 1].Text = rUsuarios["usuario"]
    TableViewUsuarios[iRow, 2].Text = If(rUsuarios["email"], rUsuarios["email"], "")
    TableViewUsuarios[iRow, 3].Text = If(rUsuarios["activo"], "Sí", "No")
    TableViewUsuarios[iRow, 4].Text = Format(rUsuarios["fecha_creacion"], "dd/mm/yyyy hh:nn")
    TableViewUsuarios[iRow, 5].Text = If(rUsuarios["en_linea"], "Sí", "No")

    rUsuarios.MoveNext()
  Wend

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error al cargar usuarios: " & Error.Text)

End

' ============================================
' Función   : btnCrearAdmin_Click
' Propósito : Crea o modifica las credenciales del
'             administrador local en SQLite
' ============================================
Public Sub btnCrearAdmin_Click()

  ' --- 1. Obtener y validar datos del formulario ---
  Dim sUsuario As String = Trim(txtAdministrador.Text)
  Dim sClave As String = Trim(txtClaveAdministrador.Text)
  Dim sEmail As String = Trim(txtEmailAdministrador.Text)
  Dim sClaveHash As String
  Dim sSQL As String
  Dim rCheck As Result

  If Not sUsuario Or Not sClave Then
    m_Sonido.sonar("Warning")
    Message.Warning("Usuario y contraseña son obligatorios.")
    Return
  Endif

  If Len(sClave) < 8 Then
    m_Sonido.sonar("Warning")
    Message.Warning("La contraseña debe tener al menos 8 caracteres.")
    Return
  Endif

  ' --- 2. Verificar si el admin ya existe ---
  sClaveHash = Hash.SHA256(sClave)
  rCheck = hConn.Exec("SELECT id FROM superuser WHERE usuario = '" & sUsuario & "';")

  If rCheck.Available Then
    ' ACTUALIZAR ADMIN EXISTENTE
    sSQL = "UPDATE superuser SET clave = '" & sClaveHash & "'"
    If sEmail And sEmail <> "@." Then
      sSQL &= ", email = '" & sEmail & "'"
    Endif
    sSQL &= " WHERE usuario = '" & sUsuario & "';"
    hConn.Exec(sSQL)
    m_Sonido.sonar("Info")
    Message.Info("Contraseña del administrador '" & sUsuario & "' actualizada.")
  Else
    ' CREAR NUEVO ADMIN
    If Not sEmail Or sEmail = "@." Then
      sSQL = "INSERT INTO superuser (usuario, clave, email) VALUES ('" &
        sUsuario & "', '" & sClaveHash & "', NULL);"
    Else
      sSQL = "INSERT INTO superuser (usuario, clave, email) VALUES ('" &
        sUsuario & "', '" & sClaveHash & "', '" & sEmail & "');"
    Endif
    hConn.Exec(sSQL)
    m_Sonido.sonar("Info")
    Message.Info("Administrador local '" & sUsuario & "' creado exitosamente.")
  Endif

  ' --- 3. Limpiar campos ---
  txtAdministrador.Text = ""
  txtClaveAdministrador.Text = ""
  txtEmailAdministrador.Text = ""

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error: " & Error.Text & " (" & Error.Where & ")")

End

' ============================================
' Función   : btnGuardarUsuario_Click
' Propósito : Inserta un nuevo usuario en la tabla MySQL
'             con los datos ingresados en el formulario
' ============================================
Public Sub btnGuardarUsuario_Click()

  ' --- 1. Verificar conexión activa ---
  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe validarse primero como administrador.")
    Return
  Endif

  ' --- 2. Obtener y validar datos ---
  Dim sUsuario As String = Trim(txtUsuario.Text)
  Dim sClave As String = Trim(txtClaveUsuario.Text)
  Dim sEmail As String = Trim(txtEmailUsuario.Text)
  Dim bActivo As Boolean = RadioButtonSi.Value
  Dim sHash As String

  If Not sUsuario Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe ingresar un nombre de usuario.")
    txtUsuario.SetFocus()
    Return
  Endif

  If Len(sUsuario) > 12 Then
    m_Sonido.sonar("Warning")
    Message.Warning("El usuario no puede tener más de 12 caracteres.")
    txtUsuario.SetFocus()
    Return
  Endif

  If Not sClave Or Len(sClave) < 8 Then
    m_Sonido.sonar("Warning")
    Message.Warning("La contraseña debe tener al menos 8 caracteres, una mayúscula y un número.")
    txtClaveUsuario.SetFocus()
    Return
  Endif

  If Not sEmail Then
    m_Sonido.sonar("Warning")
    Message.Warning("El email es obligatorio.")
    txtEmailUsuario.SetFocus()
    Return
  Endif

  ' --- 3. Insertar usuario ---
  sHash = Hash.SHA256(sClave)
  hConnServidor.Exec("INSERT INTO usuarios (usuario, clave, email, activo, metodo, fecha_creacion) " &
    "VALUES ('" & sUsuario & "', '" & sHash & "', '" & sEmail & "', " &
    If(bActivo, "TRUE", "FALSE") & ", 'local', NOW());")

    m_Sonido.sonar("Info")
    Message.Info("Usuario <b>'" & sUsuario & "'</b> creado exitosamente.")

    ' --- 4. Restaurar estado del formulario ---
    LimpiarControlesUsuario()
    btnCrearUsuario.Visible = True
    btnGuardarUsuario.Visible = False
    btnGuardarCambiosUsuario.Visible = False
    CargarUsuariosDelServidor()

  Catch
    m_Sonido.sonar("Error")
    Message.Error("Error creando usuario: " & Error.Text)

End

' ============================================
' Función   : btnGuardarCambiosUsuario_Click
' Propósito : Actualiza los datos de un usuario MySQL
'             existente, incluyendo el estado en_linea
'             para resolver bloqueos por corte de energía
'             o cuelgue de la aplicación
' ============================================
Public Sub btnGuardarCambiosUsuario_Click()

  ' --- 1. Verificar selección y conexión ---
  If TableViewUsuarios.Row < 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar un usuario de la tabla para modificar.")
    Return
  Endif

  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay conexión al servidor.")
    Return
  Endif

  ' --- 2. Obtener datos del formulario ---
  Dim iID As Integer = Val(TableViewUsuarios[TableViewUsuarios.Row, 0].Text)
  Dim sNuevoUsuario As String = Trim(txtUsuario.Text)
  Dim sNuevaClave As String = Trim(txtClaveUsuario.Text)
  Dim sNuevoEmail As String = Trim(txtEmailUsuario.Text)
  Dim bActivo As Boolean = RadioButtonSi.Value
  Dim sHash As String

  ' --- 3. Validaciones ---
  If Not sNuevoUsuario Then
    m_Sonido.sonar("Warning")
    Message.Warning("El nombre de usuario no puede estar vacío.")
    txtUsuario.SetFocus()
    Return
  Endif

  If Len(sNuevoUsuario) > 12 Then
    m_Sonido.sonar("Warning")
    Message.Warning("El usuario no puede tener más de 12 caracteres.")
    txtUsuario.SetFocus()
    Return
  Endif

  If Not sNuevoEmail Then
    m_Sonido.sonar("Warning")
    Message.Warning("El email es obligatorio.")
    txtEmailUsuario.SetFocus()
    Return
  Endif

  ' --- 4. Actualizar con o sin cambio de contraseña ---
  ' EN_LINEA SE INCLUYE SIEMPRE PARA PERMITIR LIBERAR USUARIOS BLOQUEADOS
  If sNuevaClave And Len(sNuevaClave) > 0 Then
    If Len(sNuevaClave) < 8 Then
      m_Sonido.sonar("Warning")
      Message.Warning("La contraseña debe tener al menos 8 caracteres.")
      txtClaveUsuario.SetFocus()
      Return
    Endif
    sHash = Hash.SHA256(sNuevaClave)
    hConnServidor.Exec("UPDATE usuarios SET usuario = '" & sNuevoUsuario &
      "', clave = '" & sHash &
      "', email = '" & sNuevoEmail &
      "', activo = " & If(bActivo, "TRUE", "FALSE") &
      ", en_linea = " & If(chkEnLinea.Value, "1", "0") &
      " WHERE id = " & iID & ";")
  Else
    hConnServidor.Exec("UPDATE usuarios SET usuario = '" & sNuevoUsuario &
      "', email = '" & sNuevoEmail &
      "', activo = " & If(bActivo, "TRUE", "FALSE") &
      ", en_linea = " & If(chkEnLinea.Value, "1", "0") &
      " WHERE id = " & iID & ";")
  Endif

  m_Sonido.sonar("Info")
  Message.Info("Cambios guardados correctamente.")

  ' --- 5. Restaurar estado del formulario ---
  btnCrearUsuario.Visible = True
  btnGuardarUsuario.Visible = False
  btnGuardarCambiosUsuario.Visible = False
  LimpiarControlesUsuario()
  CargarUsuariosDelServidor()

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error guardando cambios: " & Error.Text)

End

' ============================================
' Función   : TableViewUsuarios_Click
' Propósito : Carga en los controles del formulario los datos
'             del usuario seleccionado, incluyendo el estado
'             en_linea leído directamente desde la BD
' ============================================
Public Sub TableViewUsuarios_Click()

  ' --- 1. Obtener fila seleccionada ---
  Dim iRow As Integer = TableViewUsuarios.Row
  Dim sFechaCreacion As String

  btnCrearUsuario.Visible = False
  btnGuardarUsuario.Visible = False
  btnGuardarCambiosUsuario.Visible = True

  If iRow < 0 Then Return

  ' --- 2. Cargar datos básicos del usuario ---
  txtUsuario.Text = TableViewUsuarios[iRow, 1].Text
  txtEmailUsuario.Text = TableViewUsuarios[iRow, 2].Text
  txtClaveUsuario.Text = ""  ' NO SE MUESTRA LA CONTRASEÑA POR SEGURIDAD

  If TableViewUsuarios[iRow, 3].Text = "Sí" Then
    RadioButtonSi.Value = True
  Else
    RadioButtonNo.Value = True
  Endif

  sFechaCreacion = TableViewUsuarios[iRow, 4].Text
  If sFechaCreacion Then
    Try DateBoxCreacion.Value = CDate(sFechaCreacion)
  Endif

  ' --- 3. Cargar estado en_linea desde BD (estado real) ---
  ' SE LEE DESDE BD Y NO DEL GRID PARA REFLEJAR EL ESTADO REAL
  ' ESPECIALMENTE ÚTIL TRAS CORTES DE ENERGÍA O CUELGUES DE LA APP
  Dim rEnLinea As Result
  rEnLinea = hConnServidor.Exec("SELECT en_linea FROM usuarios WHERE id = &1",
    Val(TableViewUsuarios[iRow, 0].Text))
  If rEnLinea.Available Then
    chkEnLinea.Value = rEnLinea["en_linea"] = True
  Endif

  ' --- 4. Cargar fecha de último acceso ---
  CargarUltimoAcceso(Val(TableViewUsuarios[iRow, 0].Text))

Catch

End

' ============================================
' Función   : CargarUltimoAcceso
' Propósito : Lee la fecha de último acceso desde la BD
'             y la muestra en el DateBox correspondiente
' Parámetros: iUsuarioID As Integer — ID del usuario a consultar
' ============================================
Private Sub CargarUltimoAcceso(iUsuarioID As Integer)

  Dim r As Result

  r = hConnServidor.Exec("SELECT ultimo_acceso FROM usuarios WHERE id = " & iUsuarioID & ";")

  If r.Available And r["ultimo_acceso"] Then
    Try DateBoxUltimoAcceso.Value = r["ultimo_acceso"]
  Else
    DateBoxUltimoAcceso.Value = Null
  Endif

Catch

End

' ============================================
' Función   : LimpiarControlesUsuario
' Propósito : Limpia todos los controles del formulario
'             de usuario y los deja en estado inicial
' ============================================
Private Sub LimpiarControlesUsuario()

  txtUsuario.Text = ""
  txtClaveUsuario.Text = ""
  txtEmailUsuario.Text = ""
  RadioButtonSi.Value = True
  chkEnLinea.Value = False   ' ESTADO INICIAL: NO EN LÍNEA
  DateBoxCreacion.Value = Now()
  DateBoxUltimoAcceso.Value = Null
  TableViewUsuarios.Row = -1

End

' ============================================
' Función   : btnNuevoUsuario_Click
' Propósito : Prepara el formulario para crear un usuario nuevo
' ============================================
Public Sub btnNuevoUsuario_Click()

  LimpiarControlesUsuario()
  txtUsuario.SetFocus()

End

' ============================================
' Función   : ToggleButtonMostrar_Click
' Propósito : Alterna la visibilidad de la contraseña
'             del administrador local
' ============================================
Public Sub ToggleButtonMostrar_Click()

  txtClaveAdministrador.Password = Not ToggleButtonMostrar.Value
  txtClaveAdministrador.Refresh()
  txtClaveAdministrador.SetFocus()

End

' ============================================
' Función   : btnNuevaIP_Click
' Propósito : Abre el formulario de edición de IPs y
'             recarga el combo al volver
' ============================================
Public Sub btnNuevaIP_Click()

  FEditarIPs.ShowModal()
  m_FuncionesGenericas.CargarComboBoxIP(ComboBoxIP)

End

' ============================================
' Función   : btnCerrar_Click
' Propósito : Cierra las conexiones abiertas y el formulario
' ============================================
Public Sub btnCerrar_Click()

  m_ApiCredenciales.LiberarConexion()

  If hConnServidor And hConnServidor.Opened Then hConnServidor.Close()
  If hConn And hConn.Opened Then hConn.Close()

  Me.Close()

End

' ============================================
' Función   : btnCrearUsuario_Click
' Propósito : Prepara el formulario para ingresar un usuario nuevo
' ============================================
Public Sub btnCrearUsuario_Click()

  btnCrearUsuario.Visible = False
  btnGuardarUsuario.Visible = True
  btnGuardarCambiosUsuario.Visible = False

  txtUsuario.Text = ""
  txtClaveUsuario.Text = ""
  DateBoxCreacion.Value = Now

End

' ============================================
' Función   : btnProyectosTodos_Click
' Propósito : Recarga todos los proyectos en el TableView
' ============================================
Public Sub btnProyectosTodos_Click()

  CargarProyectosDelServidor()

End

' ============================================
' Función   : btnProyectosEnCurso_Click
' Propósito : Filtra y muestra solo los proyectos activos
' ============================================
Public Sub btnProyectosEnCurso_Click()

  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay conexión al servidor.")
    Return
  Endif

  ConfigurarTableViewProyectos()

  Dim rs As Result = hConnServidor.Exec("SELECT * FROM proyectos " &
    "WHERE activo = 1 ORDER BY fecha_creacion DESC;")

  LlenarTableViewProyectos(rs)

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error cargando proyectos en curso: " & Error.Text)

End

' ============================================
' Función   : btnProyectosArchivados_Click
' Propósito : Filtra y muestra solo los proyectos archivados
' ============================================
Public Sub btnProyectosArchivados_Click()

  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay conexión al servidor.")
    Return
  Endif

  ConfigurarTableViewProyectos()

  Dim rs As Result = hConnServidor.Exec("SELECT * FROM proyectos " &
    "WHERE activo = 0 ORDER BY fecha_creacion DESC;")

  LlenarTableViewProyectos(rs)

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error cargando proyectos archivados: " & Error.Text)

End

' ============================================
' Función   : ConfigurarTableViewProyectos
' Propósito : Establece la estructura de columnas del
'             TableView de proyectos
' ============================================
Private Sub ConfigurarTableViewProyectos()

  With TableViewProyectos
    .Clear
    .Rows.Count = 0
    .Columns.Count = 7

    .Columns[0].Title = "ID"
    .Columns[0].Width = 0
    .Columns[1].Title = "Proyecto"
    .Columns[1].Width = 250
    .Columns[2].Title = "Activo"
    .Columns[2].Width = 0
    .Columns[3].Title = "Ocupado"
    .Columns[3].Width = 80
    .Columns[4].Title = "Tipo"
    .Columns[4].Width = 200
    .Columns[5].Title = "Fecha Creación"
    .Columns[5].Width = 150
    .Columns[6].Title = "Última Modificación"
    .Columns[6].Width = 150

    .Mode = Select.Single
    .Header = True
  End With

End

' ============================================
' Función   : LlenarTableViewProyectos
' Propósito : Llena el TableView de proyectos con los
'             datos del Result recibido
' Parámetros: rs As Result — resultado de la consulta
' ============================================
Private Sub LlenarTableViewProyectos(rs As Result)

  Dim i As Integer

  If Not rs.Available Then
    TableViewProyectos.Rows.Count = 0
    Return
  Endif

  TableViewProyectos.Rows.Count = rs.Count
  i = 0

  While rs.Available
    TableViewProyectos[i, 0].Text = rs["id"]
    TableViewProyectos[i, 1].Text = rs["nombre"]
    TableViewProyectos[i, 2].Text = rs["activo"]

    Select Case rs["tipo_producto"]
      Case 1
        TableViewProyectos[i, 4].Text = "Revista en markdown"
      Case 2
        TableViewProyectos[i, 4].Text = "Libro en markdown"
      Case 3
        TableViewProyectos[i, 4].Text = "Libro en LaTeX"
      Default
        TableViewProyectos[i, 4].Text = "Desconocido"
    End Select

    ' COLUMNA OCUPADO CON INDICADOR VISUAL DE COLOR
    If rs["ocupado"] = True Or rs["ocupado"] = 1 Then
      TableViewProyectos[i, 3].Text = "SÍ"
      TableViewProyectos[i, 3].Background = Color.RGB(255, 200, 200)
    Else
      TableViewProyectos[i, 3].Text = "NO"
      TableViewProyectos[i, 3].Background = Color.RGB(200, 255, 200)
    Endif

    If rs["fecha_creacion"] Then
      Try TableViewProyectos[i, 5].Text = Format(rs["fecha_creacion"], "dd/mm/yyyy hh:nn")
    Endif

    If rs["fecha_modificacion"] Then
      Try TableViewProyectos[i, 6].Text = Format(rs["fecha_modificacion"], "dd/mm/yyyy hh:nn")
    Endif

    i += 1
    rs.MoveNext()
  Wend

End

' ============================================
' Función   : CargarProyectosDelServidor
' Propósito : Consulta todos los proyectos del servidor
'             y los muestra en el TableView
' ============================================
Private Sub CargarProyectosDelServidor()

  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay conexión al servidor.")
    Return
  Endif

  ConfigurarTableViewProyectos()

  Dim rs As Result = hConnServidor.Exec(
    "SELECT * FROM proyectos ORDER BY fecha_creacion DESC;")

  LlenarTableViewProyectos(rs)

Catch
  m_Sonido.sonar("Error")
  Message.Error("Error cargando proyectos: " & Error.Text)

End

' ============================================
' Función   : TableViewProyectos_Click
' Propósito : Carga el estado del proyecto seleccionado,
'             incluyendo el estado ocupado leído desde la BD
'             para reflejar el estado real tras accidentes
' ============================================
Public Sub TableViewProyectos_Click()

  ' --- 1. Obtener fila seleccionada ---
  Dim iRow As Integer = TableViewProyectos.Row

  If iRow < 0 Then Return
  If Not hConnServidor Or Not hConnServidor.Opened Then Return

  ' --- 2. Consultar estado real desde BD ---
  ' SE LEEN ACTIVO Y OCUPADO EN UNA SOLA CONSULTA
  ' OCUPADO SE LEE DESDE BD Y NO DEL GRID PARA REFLEJAR EL ESTADO REAL
  ' ESPECIALMENTE ÚTIL TRAS CORTES DE ENERGÍA O CUELGUES DE LA APP
  Dim iProyectoID As Integer = Val(TableViewProyectos[iRow, 0].Text)
  Dim rs As Result

  rs = hConnServidor.Exec("SELECT activo, ocupado FROM proyectos WHERE id = " & iProyectoID & ";")

  If rs.Available Then
    Dim bActivo As Boolean = rs["activo"]
    RadioButtonEnCurso.Value = bActivo
    RadioButtonArchivar.Value = Not bActivo
    ' CARGAR ESTADO OCUPADO EN EL CHECKBOX
    chkOcupado.Value = rs["ocupado"] = True
  Endif

Catch

End

' ============================================
' Función   : btnGuardarCambiosProyecto_Click
' Propósito : Actualiza el estado de un proyecto, incluyendo
'             el campo ocupado para liberar proyectos bloqueados
'             por cortes de energía o cuelgues de la app
' ============================================
Public Sub btnGuardarCambiosProyecto_Click()

  ' --- 1. Verificar selección y conexión ---
  Dim iRow As Integer = TableViewProyectos.Row

  If iRow < 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar un proyecto de la tabla para modificar.")
    Return
  Endif

  If Not hConnServidor Or Not hConnServidor.Opened Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay conexión al servidor.")
    Return
  Endif

  ' --- 2. Obtener datos del proyecto ---
  Dim iProyectoID As Integer = Val(TableViewProyectos[iRow, 0].Text)
  Dim sNombreProyecto As String = TableViewProyectos[iRow, 1].Text
  Dim bNuevoEstado As Boolean = RadioButtonEnCurso.Value

  ' --- 3. Actualizar activo y ocupado en la BD ---
  ' OCUPADO SE INCLUYE SIEMPRE PARA PERMITIR LIBERAR PROYECTOS BLOQUEADOS
  hConnServidor.Exec("UPDATE proyectos SET activo = " &
    If(bNuevoEstado, "TRUE", "FALSE") &
      ", ocupado = " & If(chkOcupado.Value, "1", "0") &
      ", fecha_modificacion = NOW() " &
      "WHERE id = " & iProyectoID & ";")

    m_Sonido.sonar("Info")
    Message.Info("Estado del proyecto <b>'" & sNombreProyecto & "'</b> actualizado correctamente.")

    CargarProyectosDelServidor()

  Catch
    m_Sonido.sonar("Error")
    Message.Error("Error guardando cambios: " & Error.Text)

End

' ============================================
' Función   : CargarListaRespaldos
' Propósito : Lista los archivos .sql del directorio de
'             respaldo en el ListBox correspondiente
' ============================================
Private Sub CargarListaRespaldos()

  ' --- 1. Obtener archivos SQL del directorio de respaldo ---
  Dim sRutaRespaldo As String = User.Home &/ ".gbpublisher/respaldo"
  Dim aArchivos As String[] = RDir(sRutaRespaldo, "*.sql")

  If aArchivos.Count = 0 Then Return

  ' --- 2. Ordenar y mostrar los más recientes primero ---
  aArchivos.Sort(gb.Descent)

  ListarBases.Clear()
  Dim sArchivo As String
  For Each sArchivo In aArchivos
    ListarBases.Add(sArchivo, sArchivo)
  Next

End

' ============================================
' Función   : ListarBases_Select
' Propósito : Al seleccionar un archivo de respaldo, extrae
'             y muestra las tablas que contiene
' ============================================
Public Sub ListarBases_Select()

  ' --- 1. Verificar selección ---
  If Not ListarBases.Current Then Return

  ' --- 2. Leer y parsear el archivo SQL ---
  Dim sRutaRespaldo As String = User.Home &/ ".gbpublisher/respaldo"
  Dim sArchivoSQL As String = sRutaRespaldo &/ ListarBases.Current.Key
  Dim sContenido As String = File.Load(sArchivoSQL)
  Dim aLineas As String[] = Split(sContenido, "\n")

  ListarTablas.Clear()

  ' --- 3. Buscar y extraer nombres de tablas ---
  Dim sLinea As String
  Dim sNombreTabla As String
  Dim iPos As Integer

  For Each sLinea In aLineas
    sLinea = Trim(sLinea)
    If InStr(UCase(sLinea), "CREATE TABLE") > 0 Then
      sLinea = Replace(sLinea, "`", "")
      iPos = InStr(UCase(sLinea), "CREATE TABLE ")
      If iPos > 0 Then
        sNombreTabla = Trim(Mid(sLinea, iPos + 13))
        iPos = InStr(sNombreTabla, " ")
        If iPos > 0 Then sNombreTabla = Left(sNombreTabla, iPos - 1)
        iPos = InStr(sNombreTabla, "(")
        If iPos > 0 Then sNombreTabla = Left(sNombreTabla, iPos - 1)
        If Trim(sNombreTabla) <> "" Then ListarTablas.Add(Trim(sNombreTabla))
      Endif
    Endif
  Next

  ' --- 4. Limpiar el TableView de contenido ---
  ListarContenido.Rows.Count = 0
  ListarContenido.Columns.Count = 0

End

' ============================================
' Función   : ListarTablas_Select
' Propósito : Al seleccionar una tabla, muestra su contenido
' ============================================
Public Sub ListarTablas_Select()

  LlenaGrid()

End

' ============================================
' Función   : LlenaGrid
' Propósito : Extrae la estructura y datos de la tabla
'             seleccionada y los muestra en el TableView
' ============================================
Private Sub LlenaGrid()

  If ListarTablas.Index < 0 Then Return
  If Not ListarBases.Current Then Return

  Dim sTablaSeleccionada As String = ListarTablas[ListarTablas.Index].Text
  Dim sRutaRespaldo As String = User.Home &/ ".gbpublisher/respaldo"
  Dim sArchivoSQL As String = sRutaRespaldo &/ ListarBases.Current.Key
  Dim sContenido As String = File.Load(sArchivoSQL)

  ExtraerEstructuraYDatos(sContenido, sTablaSeleccionada)

  ListarContenido.Clear()

  If $aColumnas.Count = 0 Then Return

  ' --- CONFIGURAR COLUMNAS ---
  ListarContenido.Columns.Count = $aColumnas.Count
  Dim i As Integer
  For i = 0 To $aColumnas.Max
    ListarContenido.Columns[i].Title = $aColumnas[i]
    ListarContenido.Columns[i].Width = -1
  Next

  ' --- LLENAR FILAS ---
  If $aRegistros.Count > 0 Then
    ListarContenido.Rows.Count = $aRegistros.Count
    Dim j As Integer
    For i = 0 To $aRegistros.Max
      For j = 0 To Min($aRegistros[i].Max, $aColumnas.Max)
        ListarContenido[i, j].Text = $aRegistros[i][j]
      Next
    Next
  Endif

End

' ============================================
' Función   : ExtraerEstructuraYDatos
' Propósito : Parsea el SQL del respaldo extrayendo columnas
'             e INSERTs de la tabla indicada
' Parámetros: sContenido As String — contenido del archivo SQL
'             sTabla     As String — nombre de la tabla a extraer
' ============================================
Private Sub ExtraerEstructuraYDatos(sContenido As String, sTabla As String)

  Dim aLineas As String[] = Split(sContenido, "\n")
  Dim sLinea As String
  Dim bDentroCreate As Boolean = False
  Dim iPosInicio As Integer
  Dim iPosFin As Integer
  Dim sCampo As String

  $aColumnas = New String[]
  $aRegistros = New String[][]

  For Each sLinea In aLineas
    sLinea = Trim(sLinea)

    ' DETECTAR INICIO DE CREATE TABLE
    If InStr(UCase(sLinea), "CREATE TABLE") > 0 And InStr(sLinea, "`" & sTabla & "`") > 0 Then
      bDentroCreate = True
      Continue
    Endif

    If bDentroCreate Then
      ' EXTRAER DEFINICIONES DE COLUMNAS
      If Left(Trim(sLinea), 1) = "`" Then
        If Not InStr(UCase(sLinea), "PRIMARY KEY") And
            Not InStr(UCase(sLinea), "UNIQUE KEY") And
            Not InStr(UCase(sLinea), "CONSTRAINT") And
            Not InStr(UCase(sLinea), "FOREIGN KEY") And
            Not InStr(UCase(sLinea), "KEY `") Then
          iPosInicio = InStr(sLinea, "`")
          If iPosInicio > 0 Then
            iPosFin = InStr(sLinea, "`", iPosInicio + 1)
            If iPosFin > iPosInicio Then
              sCampo = Mid(sLinea, iPosInicio + 1, iPosFin - iPosInicio - 1)
              $aColumnas.Add(sCampo)
            Endif
          Endif
        Endif
      Endif
      ' DETECTAR FIN DE CREATE TABLE
      If InStr(sLinea, ") ENGINE=") > 0 Then bDentroCreate = False
    Endif

    ' EXTRAER DATOS DE INSERT INTO
    If InStr(UCase(sLinea), "INSERT INTO") > 0 Then
      If InStr(sLinea, "`" & sTabla & "`") > 0 Then
        If InStr(UCase(sLinea), "VALUES") > 0 Then
          ExtraerDatosInsert(sLinea)
        Endif
      Endif
    Endif
  Next

End

' ============================================
' Función   : ExtraerDatosInsert
' Propósito : Extrae los grupos de valores de un INSERT INTO
' Parámetros: sLinea As String — línea completa del INSERT
' ============================================
Private Sub ExtraerDatosInsert(sLinea As String)

  Dim iPosValues As Integer = InStr(UCase(sLinea), "VALUES")

  If iPosValues = 0 Then Return

  Dim sValores As String = Trim(Mid(sLinea, iPosValues + 6))
  Dim aGrupos As String[] = DividirRegistros(sValores)

  Dim sGrupo As String
  For Each sGrupo In aGrupos
    $aRegistros.Add(ParsearValores(sGrupo))
  Next

End

' ============================================
' Función   : DividirRegistros
' Propósito : Separa los grupos de valores de un INSERT
'             respetando comillas y paréntesis anidados
' Parámetros: sValores As String — parte VALUES del INSERT
' Retorna   : String[] — array con un elemento por registro
' ============================================
Private Function DividirRegistros(sValores As String) As String[]

  Dim aResultado As New String[]
  Dim sRegistro As String = ""
  Dim bDentroComilla As Boolean = False
  Dim iParentesis As Integer = 0
  Dim cAnterior As String = ""
  Dim i As Integer
  Dim c As String

  sValores = Trim(sValores)
  If Right(sValores, 1) = ";" Then sValores = Left(sValores, Len(sValores) - 1)

  For i = 1 To Len(sValores)
    c = Mid(sValores, i, 1)

    If c = "'" And cAnterior <> "\\" Then
      bDentroComilla = Not bDentroComilla
      sRegistro &= c
    Else If c = "(" And Not bDentroComilla Then
      Inc iParentesis
      If iParentesis > 1 Then sRegistro &= c
    Else If c = ")" And Not bDentroComilla Then
      Dec iParentesis
      If iParentesis > 0 Then
        sRegistro &= c
      Else
        If Trim(sRegistro) <> "" Then
          aResultado.Add(sRegistro)
          sRegistro = ""
        Endif
      Endif
    Else If c = "," And Not bDentroComilla And iParentesis = 0 Then
      Continue
    Else
      sRegistro &= c
    Endif

    cAnterior = c
  Next

  If Trim(sRegistro) <> "" Then aResultado.Add(sRegistro)

  Return aResultado

End

' ============================================
' Función   : ParsearValores
' Propósito : Separa los valores individuales de un registro
'             respetando comillas simples
' Parámetros: sRegistro As String — un grupo de valores
' Retorna   : String[] — array con un elemento por valor
' ============================================
Private Function ParsearValores(sRegistro As String) As String[]

  Dim aResultado As New String[]
  Dim sValor As String = ""
  Dim bDentroComilla As Boolean = False
  Dim cAnterior As String = ""
  Dim i As Integer
  Dim c As String

  For i = 1 To Len(sRegistro)
    c = Mid(sRegistro, i, 1)
    If c = "'" And cAnterior <> "\\" Then
      bDentroComilla = Not bDentroComilla
    Else If c = "," And Not bDentroComilla Then
      aResultado.Add(LimpiarValor(sValor))
      sValor = ""
    Else
      sValor &= c
    Endif
    cAnterior = c
  Next

  aResultado.Add(LimpiarValor(sValor))
  Return aResultado

End

' ============================================
' Función   : LimpiarValor
' Propósito : Elimina comillas y decodifica caracteres
'             escapados de un valor SQL
' Parámetros: sValor As String — valor crudo del SQL
' Retorna   : String — valor limpio y legible
' ============================================
Private Function LimpiarValor(sValor As String) As String

  sValor = Trim(sValor)

  If UCase(sValor) = "NULL" Then Return ""

  If Left(sValor, 1) = "'" And Right(sValor, 1) = "'" Then
    sValor = Mid(sValor, 2, Len(sValor) - 2)
  Endif

  sValor = Replace(sValor, "\\'", "'")
  sValor = Replace(sValor, "\\n", "\n")
  sValor = Replace(sValor, "\\t", "\t")
  sValor = Replace(sValor, "\\\\", "\\")

  Return sValor

End

' ============================================
' Función   : btnEliminarBase_Click
' Propósito : Elimina el archivo de respaldo seleccionado
'             tras confirmación del usuario
' ============================================
Public Sub btnEliminarBase_Click()

  ' --- 1. Verificar selección ---
  If Not ListarBases.Current Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar un archivo de respaldo para eliminar.")
    Return
  Endif

  ' --- 2. Confirmar eliminación ---
  m_Sonido.sonar("Question")
  Dim iRespuesta As Integer = Message.Question(
    "¿Está seguro de que desea eliminar el archivo de respaldo?" & Chr(10) & Chr(10) &
    ListarBases.Current.Key & Chr(10) & Chr(10) &
    "Esta acción no se puede deshacer.",
    "Sí", "No")

  If iRespuesta <> 1 Then Return

  ' --- 3. Eliminar y actualizar vista ---
  Dim sRutaRespaldo As String = User.Home &/ ".gbpublisher/respaldo"
  Dim sArchivoSQL As String = sRutaRespaldo &/ ListarBases.Current.Key

  Try Kill sArchivoSQL
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al eliminar el archivo:" & Chr(10) & Error.Text)
    Return
  Endif

  CargarListaRespaldos()
  ListarTablas.Clear()
  ListarContenido.Rows.Count = 0
  ListarContenido.Columns.Count = 0

  m_Sonido.sonar("Info")
  Message.Info("Archivo de respaldo eliminado correctamente.")

End

' ============================================
' SECCIÓN: GESTIÓN DE CREDENCIALES DE API
' Las siguientes funciones gestionan el ABM de API Keys
' en la tabla api_credenciales de MySQL
' ============================================

' ============================================
' Función   : ConfigurarGridView
' Propósito : Establece la estructura del GridView de APIs
' ============================================
Private Sub ConfigurarGridView()

  With gvAPIkeys
    .Header = GridView.Horizontal
    .Grid = True
    .Mode = Select.Single
    .Columns.Count = 6

    .Columns[0].Title = "ID"
    .Columns[0].Width = 40
    .Columns[0].Alignment = Align.Center
    .Columns[1].Title = "Proveedor"
    .Columns[1].Width = 150
    .Columns[2].Title = "Identificador"
    .Columns[2].Width = 150
    .Columns[3].Title = "Región"
    .Columns[3].Width = 150
    .Columns[4].Title = "Activo"
    .Columns[4].Width = 50
    .Columns[4].Alignment = Align.Center
    .Columns[5].Title = "Última modificación"
    .Columns[5].Width = 150

    .Rows.Count = 0
  End With

End

' ============================================
' Función   : CargarCredenciales
' Propósito : Carga todas las credenciales de API en el GridView
' ============================================
Private Sub CargarCredenciales()

  Dim hResult As Result = m_ApiCredenciales.ListarCredenciales(False)

  If hResult = Null Then
    gvAPIkeys.Rows.Count = 0
    Return
  Endif

  gvAPIkeys.Rows.Count = hResult.Count
  If hResult.Count = 0 Then Return

  Dim iRow As Integer = 0
  For Each hResult
    gvAPIkeys[iRow, 0].Text = Str$(hResult!id)
    gvAPIkeys[iRow, 1].Text = hResult!proveedor
    gvAPIkeys[iRow, 2].Text = If(hResult!identificador, hResult!identificador, "")
    gvAPIkeys[iRow, 3].Text = If(hResult!region, hResult!region, "")
    gvAPIkeys[iRow, 4].Text = If(hResult!activo, "Sí", "No")
    gvAPIkeys[iRow, 5].Text = Format$(hResult!date_modif, "dd/mm/yyyy hh:nn")

    ' FILAS INACTIVAS CON FONDO GRIS
    If Not hResult!activo Then
      Dim k As Integer
      For k = 0 To 5
        gvAPIkeys[iRow, k].Background = Color.LightGray
      Next
    Endif

    Inc iRow
  Next

End

' ============================================
' Función   : LimpiarFormulario
' Propósito : Limpia el formulario de API Keys y lo prepara
'             para una nueva entrada
' ============================================
Private Sub LimpiarFormulario()

  $bModoEdicion = False
  ID_apis.Value = 0
  txtProveedor.Text = ""
  txtApiKey.Text = ""
  txtIdentificador.Text = ""
  txtRegion.Text = ""
  txtComentarios.Text = ""
  ckbActivo.Value = True
  btnGuardarAPI.Enabled = True
  btnGuardarCambiosAPI.Enabled = False
  txtProveedor.SetFocus()

End

' ============================================
' Función   : CargarCredencialEnFormulario
' Propósito : Carga los datos de una credencial existente
'             en el formulario para su edición
' Parámetros: iId As Integer — ID de la credencial a cargar
' ============================================
Private Sub CargarCredencialEnFormulario(iId As Integer)

  Dim hResult As Result = m_ApiCredenciales.ObtenerCredencialPorId(iId)

  If hResult = Null Or Not hResult.Available Then
    Message.Error("No se pudo cargar la credencial seleccionada.")
    Return
  Endif

  $bModoEdicion = True
  ID_apis.Value = hResult!id
  txtProveedor.Text = hResult!proveedor
  txtApiKey.Text = ""  ' NO SE MUESTRA LA API KEY POR SEGURIDAD
  txtIdentificador.Text = If(hResult!identificador, hResult!identificador, "")
  txtRegion.Text = If(hResult!region, hResult!region, "")
  txtComentarios.Text = If(hResult!comentarios, hResult!comentarios, "")
  ckbActivo.Value = hResult!activo
  btnGuardarAPI.Enabled = False
  btnGuardarCambiosAPI.Enabled = True

End

' ============================================
' Función   : ValidarFormulario
' Propósito : Verifica que los campos obligatorios del
'             formulario de API estén completos
' Retorna   : Boolean — True si la validación es correcta
' ============================================
Private Function ValidarFormulario() As Boolean

  If Not Trim$(txtProveedor.Text) Then
    Message.Warning("El nombre del proveedor es obligatorio.")
    txtProveedor.SetFocus()
    Return False
  Endif

  If Not $bModoEdicion And Not Trim$(txtApiKey.Text) Then
    Message.Warning("La API Key es obligatoria para nuevas credenciales.")
    txtApiKey.SetFocus()
    Return False
  Endif

  Return True

End

' ============================================
' Función   : btnNuevaAPI_Click
' Propósito : Prepara el formulario para una nueva credencial
' ============================================
Public Sub btnNuevaAPI_Click()

  LimpiarFormulario()

End

' ============================================
' Función   : btnGuardarAPI_Click
' Propósito : Guarda una nueva credencial de API en la BD
' ============================================
Public Sub btnGuardarAPI_Click()

  If Not ValidarFormulario() Then Return

  If m_ApiCredenciales.ExisteProveedor(Trim$(txtProveedor.Text)) Then
    Message.Warning("Ya existe una credencial para el proveedor: " & txtProveedor.Text)
    txtProveedor.SetFocus()
    Return
  Endif

  Dim iId As Integer = m_ApiCredenciales.GuardarNuevaAPI(
    Trim$(txtProveedor.Text), Trim$(txtApiKey.Text),
    Trim$(txtIdentificador.Text), Trim$(txtRegion.Text),
    Trim$(txtComentarios.Text))

  If iId > 0 Then
    Message.Info("Credencial guardada correctamente con ID: " & Str$(iId))
    CargarCredenciales()
    LimpiarFormulario()
  Else
    Message.Error("Error al guardar la credencial.")
  Endif

End

' ============================================
' Función   : btnGuardarCambiosAPI_Click
' Propósito : Actualiza una credencial de API existente
' ============================================
Public Sub btnGuardarCambiosAPI_Click()

  If Not ValidarFormulario() Then Return

  Dim iId As Integer = ID_apis.Value

  If iId <= 0 Then
    Message.Error("No hay una credencial seleccionada para actualizar.")
    Return
  Endif

  If m_ApiCredenciales.ExisteProveedor(Trim$(txtProveedor.Text), iId) Then
    Message.Warning("Ya existe otra credencial con el proveedor: " & txtProveedor.Text)
    txtProveedor.SetFocus()
    Return
  Endif

  If Not ckbActivo.Value Then
    If Message.Question("¿Está seguro de desactivar esta credencial?" & Chr(10) & Chr(10) &
        "Los servicios que la utilicen dejarán de funcionar.", "Sí", "No") = 2 Then
      Return
    Endif
  Endif

  If m_ApiCredenciales.ActualizarAPI(iId, Trim$(txtProveedor.Text), Trim$(txtApiKey.Text),
      Trim$(txtIdentificador.Text), Trim$(txtRegion.Text),
      Trim$(txtComentarios.Text), ckbActivo.Value) Then
    Message.Info("Credencial actualizada correctamente.")
    CargarCredenciales()
    LimpiarFormulario()
  Else
    Message.Error("Error al actualizar la credencial.")
  Endif

End

' ============================================
' Función   : gvAPIkeys_Click
' Propósito : Carga la credencial seleccionada en el formulario
' ============================================
Public Sub gvAPIkeys_Click()

  Dim iRow As Integer = gvAPIkeys.Row

  If iRow < 0 Or iRow >= gvAPIkeys.Rows.Count Then Return

  Dim iId As Integer = Val(gvAPIkeys[iRow, 0].Text)
  If iId > 0 Then CargarCredencialEnFormulario(iId)

End

' ============================================
' Función   : gvAPIkeys_DblClick
' Propósito : Doble clic carga la credencial (igual que clic)
' ============================================
Public Sub gvAPIkeys_DblClick()

  gvAPIkeys_Click()

End

' ============================================
' Función   : txtApiKey_Enter
' Propósito : Muestra tooltip contextual al entrar en el
'             campo de API Key según el modo activo
' ============================================
Public Sub txtApiKey_Enter()

  If $bModoEdicion Then
    txtApiKey.ToolTip = "Dejar vacío para mantener la API Key actual."
  Else
    txtApiKey.ToolTip = "Ingrese la API Key del proveedor."
  Endif

End
