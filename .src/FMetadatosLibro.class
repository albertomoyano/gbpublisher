' ════════════════════════════════════════════════════════════════════════════
' BUSCAR IMAGEN DE TAPA
' ABRE DIÁLOGO DE SELECCIÓN, COPIA AL DIRECTORIO /media DEL PROYECTO CON EL
' NOMBRE NORMALIZADO foto-tapa.EXT (jpg o png) Y ESCRIBE EL NOMBRE EN
' imagen_tapa (readonly)
' ════════════════════════════════════════════════════════════════════════════
Public Sub btnBuscarTapa_Click()

  ' --- 1. ABRIR DIÁLOGO DE SELECCIÓN ---
  Dialog.Title = "Seleccionar imagen de tapa"
  Dialog.Filter = ["*.jpg;*.jpeg;*.png", "Imágenes (JPG, PNG)"]
  If Dialog.OpenFile() Then Return

  Dim sOrigen As String = Dialog.Path
  Dim sExtOrig As String = LCase(File.Ext(sOrigen))
  Dim sDirectorioMedia As String = File.Dir(FMain.txtProyecto.Text) &/ "media"

  ' --- 2. NORMALIZAR EXTENSIÓN: jpeg → jpg ---
  Dim sExt As String
  If sExtOrig = "jpeg" Then
    sExt = "jpg"
  Else
    sExt = sExtOrig
  Endif

  Dim sNombreDestino As String = "foto-tapa." & sExt
  Dim sDestino As String = sDirectorioMedia &/ sNombreDestino

  ' --- 3. DETECTAR SI EL ORIGEN YA ES EL DESTINO ---
  If sOrigen = sDestino Then
    Message.Info("La imagen '" & sNombreDestino & "' ya está en el directorio /media." &
      Chr(10) & "No es necesario copiarla.")
    imagen_tapa.Text = sNombreDestino
    Return
  Endif

  ' --- 4. VERIFICAR QUE EL DIRECTORIO /media EXISTE ---
  If Not Exist(sDirectorioMedia) Then
    Try Mkdir sDirectorioMedia
    If Error Then
      Message.Error("No se pudo crear el directorio /media:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- 5. ADVERTIR SI YA EXISTE foto-tapa EN /media ---
  If Exist(sDestino) Then
    If Message.Question("Ya existe '" & sNombreDestino & "' en /media." & Chr(10) &
        "¿Deseás reemplazarla?", "Sí", "No") <> 1 Then
      Return
    Endif
    Try Kill sDestino
    If Error Then
      Message.Error("Error al eliminar archivo anterior:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  ' --- 6. COPIAR CON NOMBRE NORMALIZADO ---
  Try Copy sOrigen To sDestino
  If Error Then
    Message.Error("Error al copiar la imagen:" & Chr(10) & Error.Text)
    Return
  Endif

  ' --- 7. REGISTRAR NOMBRE NORMALIZADO EN EL CAMPO ---
  imagen_tapa.Text = sNombreDestino

End

' ════════════════════════════════════════════════════════════════════════════
' FUNCIÓN AUXILIAR PÚBLICA
' EXTRAE "apa.csl" DE "American Psychological... [apa.csl]"
' USADA TAMBIÉN POR m_Metadatos PARA GUARDAR SOLO EL NOMBRE DEL ARCHIVO
' ════════════════════════════════════════════════════════════════════════════
Public Function ExtraerNombreCSL(sTexto As String) As String

  Dim iAbre As Integer = 0
  Dim iCierra As Integer = 0
  Dim i As Integer

  ' --- 1. BUSCAR EL ÚLTIMO [ Y EL ÚLTIMO ] ---
  For i = Len(sTexto) To 1 Step -1
    If Mid(sTexto, i, 1) = "]" And iCierra = 0 Then iCierra = i
    If Mid(sTexto, i, 1) = "[" And iCierra > 0 Then
      iAbre = i
      Break
    Endif
  Next

  ' --- 2. EXTRAER EL CONTENIDO ENTRE LOS CORCHETES ---
  If iAbre > 0 And iCierra > iAbre Then
    Return m_XML.TrimUTF8(Mid(sTexto, iAbre + 1, iCierra - iAbre - 1))
  Endif

  ' --- 3. FALLBACK: YA ES SOLO EL NOMBRE DEL ARCHIVO ---
  Return m_XML.TrimUTF8(sTexto)

End Function

' ════════════════════════════════════════════════════════════════════════════
' CIERRE DEL FORMULARIO — PATRÓN bCierrePermitido
' ════════════════════════════════════════════════════════════════════════════

Public Sub btnCerrar_Click()

  bCierrePermitido = True
  Me.Close()

End

Public Sub Form_Close()
  ' SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO

  If bCierrePermitido Then Return
  ' BLOQUEAR EL CIERRE DESDE LA X DEL SISTEMA
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End

' ════════════════════════════════════════════════════════════════════════════
' HELPERS PARA LEER Y SETEAR LOS COMBOS DE FK POR ID NUMÉRICO
' USADOS POR m_Metadatos PARA CARGAR Y GUARDAR
' ════════════════════════════════════════════════════════════════════════════

Public Function ObtenerIdColeccionSeleccionada() As Integer

  If id_coleccion.Index < 0 Or id_coleccion.Index >= aIdsColeccion.Count Then Return 0
  Return aIdsColeccion[id_coleccion.Index]

End Function

Public Sub SeleccionarColeccionPorId(iId As Integer)

  Dim i As Integer

  If iId <= 0 Then
    id_coleccion.Index = 0
    Return
  Endif

  For i = 1 To aIdsColeccion.Count - 1
    If aIdsColeccion[i] = iId Then
      id_coleccion.Index = i
      Return
    Endif
  Next

  id_coleccion.Index = 0

End

Public Function ObtenerIdSerieSeleccionada() As Integer

  If id_serie.Index < 0 Or id_serie.Index >= aIdsSerie.Count Then Return 0
  Return aIdsSerie[id_serie.Index]

End Function

Public Sub SeleccionarSeriePorId(iId As Integer)

  Dim i As Integer

  If iId <= 0 Then
    id_serie.Index = 0
    Return
  Endif

  For i = 1 To aIdsSerie.Count - 1
    If aIdsSerie[i] = iId Then
      id_serie.Index = i
      Return
    Endif
  Next

  id_serie.Index = 0

End

Public Sub btnChequearISBN_Click()

  Dim ISBN As String = isbn_impreso.Text

  If m_FuncionesGenericas.EsISBNValido(ISBN) Then
    m_Sonido.sonar("Info")
    Message.Info("El ISBN es válido.")
  Else
    m_Sonido.sonar("Warning")
    Message.Warning("El ISBN no es válido.")
  End If

End

Public Sub btnChequearEISBN_Click()

  Dim eISBN As String = isbn_electronico.Text

  If m_FuncionesGenericas.EsISBNValido(eISBN) Then
    m_Sonido.sonar("Info")
    Message.Info("El eISBN es válido.")
  Else
    m_Sonido.sonar("Warning")
    Message.Warning("El eISBN no es válido.")
  End If

End

Public Sub licencia_defecto_Click()

  Select Case licencia_defecto.Text
    Case "CC BY 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by/4.0/"
    Case "CC BY-SA 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-sa/4.0/"
    Case "CC BY-NC 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc/4.0/"
    Case "CC BY-NC-SA 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc-sa/4.0/"
    Case "CC BY-ND 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nd/4.0/"
    Case "CC BY-NC-ND 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc-nd/4.0/"
    Case "CC0 1.0"
      url_licencia.Text = "https://creativecommons.org/publicdomain/zero/1.0/"
    Case "MIT"
      url_licencia.Text = "https://opensource.org/licenses/MIT"
    Case "GPL v3"
      url_licencia.Text = "https://www.gnu.org/licenses/gpl-3.0.html"
    Case "Apache 2.0"
      url_licencia.Text = "https://www.apache.org/licenses/LICENSE-2.0"
    Case "BSD 3-Clause"
      url_licencia.Text = "https://opensource.org/licenses/BSD-3-Clause"
    Case "Todos los derechos reservados"
      url_licencia.Text = ""
    Case "Otra"
      url_licencia.Text = ""
      url_licencia.SetFocus
  End Select

End
