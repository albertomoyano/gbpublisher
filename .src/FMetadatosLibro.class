' ════════════════════════════════════════════════════════════════════════════
' HELPER PRIVADO PARA VALIDAR FORMATO ISBN AL PERDER FOCO
' OPERA SOBRE Last
' ════════════════════════════════════════════════════════════════════════════
Private Sub ValidarISBN()

  Dim sText As String = Trim(Last.Text)
  Dim iDigitos As Integer = 0
  Dim iGuiones As Integer = 0
  Dim i As Integer
  Dim sChar As String

  ' --- 1. SI ESTÁ VACÍO, PERMITIR (ES OPCIONAL) ---
  If sText = "" Then
    Last.Background = Color.White
    Return
  Endif

  ' --- 2. VERIFICAR LONGITUD TOTAL ACEPTABLE (13 A 17) ---
  If Len(sText) < 13 Or Len(sText) > 17 Then
    Last.Background = Color.Pink
    m_Sonido.sonar("Warning")
    Message.Warning("El ISBN debe tener entre 13 y 17 caracteres" & gb.NewLine &
      "(13 dígitos, con 0 a 4 guiones opcionales).")
    Last.SetFocus()
    Return
  Endif

  ' --- 3. CONTAR DÍGITOS Y GUIONES, VERIFICAR QUE NO HAYA OTRA COSA ---
  For i = 1 To Len(sText)
    sChar = Mid(sText, i, 1)
    If IsDigit(sChar) Then
      Inc iDigitos
    Else If sChar = "-" Then
      Inc iGuiones
    Else
      Last.Background = Color.Pink
      m_Sonido.sonar("Warning")
      Message.Warning("El ISBN solo puede contener dígitos y guiones.")
      Last.SetFocus()
      Return
    Endif
  Next

  ' --- 4. DEBE HABER EXACTAMENTE 13 DÍGITOS ---
  If iDigitos <> 13 Then
    Last.Background = Color.Pink
    m_Sonido.sonar("Warning")
    Message.Warning("El ISBN debe contener exactamente 13 dígitos" & gb.NewLine &
      "(actualmente tiene " & iDigitos & ").")
    Last.SetFocus()
    Return
  Endif

  ' --- 5. ISBN-13 DEBE EMPEZAR CON 978 O 979 ---
  Dim sPrefijo As String = ""
  Dim j As Integer
  For j = 1 To Len(sText)
    sChar = Mid(sText, j, 1)
    If IsDigit(sChar) Then
      sPrefijo = sPrefijo & sChar
      If Len(sPrefijo) = 3 Then Break
    Endif
  Next

  If sPrefijo <> "978" And sPrefijo <> "979" Then
    Last.Background = Color.Pink
    m_Sonido.sonar("Warning")
    Message.Warning("El ISBN-13 debe empezar con 978 o 979" & gb.NewLine &
      "(actualmente empieza con " & sPrefijo & ").")
    Last.SetFocus()
    Return
  Endif

  ' --- 6. TODO VÁLIDO ---
  Last.Background = Color.White

End

