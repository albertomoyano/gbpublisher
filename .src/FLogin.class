' Gambas class file

Public Sub Form_Open()

  ' LIMPIAR CAMPOS AL INICIAR
  TextBoxUsuario.Text = ""
  TextBoxClave.Text = ""
  TextBoxUsuario.SetFocus

  ' COMPROBAR SI YA EXISTE UNA CONEXIÓN ACTIVA
  If Object.IsValid(m_ConexionBD) And Object.IsValid(m_ConexionBD.mConn) Then
    If m_ConexionBD.mConn.Opened Then
      ' HAY UNA CONEXIÓN ACTIVA
      m_Sonido.sonar("Error")
      Message.Error("Ya existe una conexión activa al servidor <b>" & FMain.TextBoxServidor.Text & "</b>" & Chr(10) &
        "Debe desconectarse antes de conectarse a un nuevo servidor.")

      ' MOSTRAR BOTÓN DE DESCONEXIÓN
      btnConectarServer.Visible = False
      btnDesconectarServer.Visible = True

      ' DESHABILITAR CAMPOS PARA EVITAR NUEVA CONEXIÓN
      TextBoxUsuario.Enabled = False
      TextBoxClave.Enabled = False
      TextBoxIP.Enabled = False
    Else
      ' NO HAY CONEXIÓN ACTIVA
      btnConectarServer.Visible = True
      btnDesconectarServer.Visible = False
      TextBoxUsuario.Enabled = True
      TextBoxClave.Enabled = True
      TextBoxIP.Enabled = True
    Endif
  Else
    ' No existe aún el módulo o la conexión
    btnConectarServer.Visible = True
    btnDesconectarServer.Visible = False
    TextBoxUsuario.Enabled = True
    TextBoxClave.Enabled = True
    TextBoxIP.Enabled = True
  Endif

  ' CARGAR IPS DISPONIBLES
  m_FuncionesGenericas.CargarComboBoxIP(TextBoxIP)

End

' FLAG PARA PERMITIR EL CIERRE DESDE EL BOTÓN
Private bCierrePermitido As Boolean

Public Sub btnCerrar_Click()
  ' HABILITAR EL CIERRE Y CERRAR

  bCierrePermitido = True
  Me.Close()

End

Public Sub Form_Close()
  ' SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO

  If bCierrePermitido Then Return
  ' BLOQUEAR EL CIERRE DESDE LA X DEL SISTEMA
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End

Public Sub ToggleButtonMostrar_Click()

  If ToggleButtonMostrar.Value Then
    TextBoxClave.Password = False
  Else
    TextBoxClave.Password = True
  Endif
  TextBoxClave.Refresh()
  TextBoxClave.SetFocus()

End

Public Sub btnConectarServer_Click()

  Dim ip As String = TextBoxIP.Text
  Dim usuario As String = TextBoxUsuario.Text
  Dim clave As String = TextBoxClave.Text
  Dim iResultado As Integer
  Dim sErroresEsquema As String

  ' VALIDACIONES BÁSICAS
  If Trim(ip) = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("Ingrese una IP correcta")
    Return
  End If

  If Trim(usuario) = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("Ingrese el nombre de usuario")
    TextBoxUsuario.SetFocus()
    Return
  End If

  If Trim(clave) = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("Ingrese la contraseña")
    TextBoxClave.SetFocus()
    Return
  End If

  ' ENCRIPTAR CLAVE
  Dim sClaveEncriptada As String = Hash.SHA256(clave)

  ' VERIFICAR CONECTIVIDAD
  If Not ValidarConectividad(ip) Then
    m_Sonido.sonar("Error")
    Message.Error("No se puede conectar al servidor " & ip & Chr(10) &
      "Verifique que el servidor esté encendido y la red funcione correctamente.")
    Return
  End If

  ' INTENTAR CONEXIÓN
  iResultado = m_ConexionBD.ConexionAbierta(ip, usuario, sClaveEncriptada)

  Select Case iResultado
      ' --- 1. Validar estructura del esquema ---
      ' ANTES DE HABILITAR FMAIN VERIFICAMOS QUE LA BD TIENE
      ' EL ESQUEMA CORRECTO PARA ESTA VERSIÓN DE GBPUBLISHER
    Case 1
      sErroresEsquema = m_ConexionBD.ValidarEsquemaBD()
      If sErroresEsquema <> "" Then
        m_Sonido.sonar("Error")
        Message.Error("La base de datos en <b>" & ip & "</b> tiene " &
          "un esquema incompatible con esta versión de gbpublisher." &
          Chr(10) & Chr(10) & sErroresEsquema & Chr(10) &
          "Contacte al área de IT.")
        ' LIBERAR AL USUARIO — PATRÓN IDÉNTICO A btnDesconectarServer_Click
        ' EL Commit ES OBLIGATORIO: SIN ÉL MYSQL HACE ROLLBACK AL CERRAR
        ' Y en_linea VUELVE A 1 DEJANDO AL USUARIO BLOQUEADO
        m_ConexionBD.mConn.Exec(
          "UPDATE usuarios SET en_linea = 0 WHERE usuario = &1", usuario)
        m_ConexionBD.mConn.Commit
        Try m_ConexionBD.mConn.Close()
        Return
      Endif
      ' --- 2. Esquema válido: iniciar sesión ---
      m_Sonido.sonar("Info")
      Message.Info("Conexión exitosa al servidor " & ip)
      m_InicioCierre.UsuarioEnCurso = usuario
      FMain.MenuInicio.Enabled = True
      FMain.menuHerramientas.Enabled = True
      FMain.ButtonCerrarApp.Visible = False
      FMain.menuAcercaAyuda.Enabled = True
      FMain.tbMostrarPanelInferior.Visible = True
      FMain.TextBoxUsuario.Text = usuario
      FMain.TextBoxServidor.Text = ip
      FMain.TableViewUsuarios.Visible = True
      FMain.tbMostrarPanelInferior.Visible = False
      m_InicioCierre.CargarUsuarios()
      ' --- 3. Cargar combobox ---
      m_Bibtex.RellenarEditorTypes([FMain.cmbEditorType])
      m_Bibtex.RellenarEditorTypes([FMain.cmbEditorTypeA])
      m_Bibtex.RellenarEditorTypes([FMain.cmbEditorTypeB])
      m_Bibtex.RellenarEditorTypes([FMain.cmbEditorTypeC])
      m_Bibtex.RellenarPagination([FMain.cmbPagination])
      m_Bibtex.RellenarPagination([FMain.cmbBookPagination])
      m_Bibtex.RellenarIdiomas([FMain.cmbHyphenation])
      m_Bibtex.RellenarIdiomas([FMain.cmbLanguage])
      m_Bibtex.RellenarIdiomas([FMain.cmbOrigLanguage])
      m_Bibtex.RellenarIdiomas([FMain.cmbLangId])
      m_Bibtex.RellenarEprint([FMain.cmbEprintType])
      m_Bibtex.RellenarPubState([FMain.cmbPubState])
      m_Bibtex.RellenarRelatedType([FMain.cmbRelatedType])
      m_Bibtex.RellenarTipoDeTesis([FMain.cmbTipoDeTesis])
      m_Bibtex.RellenarTipoDeEntrada([FMain.cmbTipoDeEntrada])
      bCierrePermitido = True
      Me.Close()
    Case 2
      m_Sonido.sonar("Error")
      Message.Error("El usuario ya está conectado o está inactivo.")
    Case 3
      m_Sonido.sonar("Error")
      Message.Error("Usuario y/o clave incorrectos.")
    Case Else
      m_Sonido.sonar("Error")
      Message.Error("Error al intentar conectar al servidor.")
  End Select

End

Public Sub btnDesconectarServer_Click()

  m_InicioCierre.CerrarProyecto()

  ' CONFIRMAR DESCONEXIÓN
  m_Sonido.sonar("Question")
  If Message.Question("¿Desea desconectarse del servidor actual?", "Sí", "No") = 1 Then

    ' LIBERAR AL USUARIO
    Dim sUsuarioEnCurso As String = m_InicioCierre.UsuarioEnCurso
    If sUsuarioEnCurso <> "" Then
      m_ConexionBD.mConn.Exec("UPDATE usuarios SET en_linea = 0 WHERE usuario = &1", sUsuarioEnCurso)
      m_ConexionBD.mConn.Commit
    End If

    Try m_ConexionBD.mConn.Close

    If Not Error Then
      m_Sonido.sonar("Info")
      Message.Info("Se ha desconectado correctamente del servidor.")

      ' ACTUALIZAR BOTONES
      btnConectarServer.Visible = True
      btnDesconectarServer.Visible = False

      ' LIMPIAR DATOS Y HABILITAR CAMPOS
      TextBoxUsuario.Enabled = True
      TextBoxClave.Enabled = True
      TextBoxIP.Enabled = True
      TextBoxUsuario.Text = ""
      TextBoxClave.Text = ""

      ' LIMPIAR EN FMAIN
      FMain.TextBoxServidor.Text = ""
      FMain.TextBoxUsuario.Text = ""
      FMain.MenuInicio.Enabled = False
      FMain.ButtonCerrarApp.Visible = True
      FMain.TableViewUsuarios.Visible = False

      ' DESHABILITAR BOTONES DEL MENÚ
      FMain.menuHerramientas.Enabled = False
      FMain.menuAcercaAyuda.Enabled = False
    Else
      m_Sonido.sonar("Error")
      Message.Error("No se pudo cerrar la conexión correctamente: " & Error.Text)
    End If

  End If

End

Private Function ValidarConectividad(ip As String) As Boolean

  Dim archivo As String = "/tmp/ping_result_" & CStr(Timer)
  Dim comando As String
  Dim contenido As String

  comando = "ping -c 1 -W 3 " & ip & " > " & archivo & " 2>&1; echo $? >> " & archivo

  Try Shell comando Wait
  If Error Then Return False

  If Exist(archivo) Then
    Try contenido = File.Load(archivo)
    If Not Error Then
      Dim lineas As String[] = Split(contenido, "\n")
      Dim codigoSalida As String = ""
      If lineas.Count > 0 Then
        codigoSalida = Trim(lineas[lineas.Count - 1])
        If codigoSalida = "" And lineas.Count > 1 Then
          codigoSalida = Trim(lineas[lineas.Count - 2])
        End If
      End If
      Try Kill archivo
      Return codigoSalida = "0"
    End If
    Try Kill archivo
  End If

  Return False

End

Public Sub TextBoxClave_KeyPress()

  If Key.Code = Key.Return Then
    Stop Event
    btnConectarServer_Click()
  Endif

End

Public Sub btnNuevaIP_Click()

  ' --- VERIFICAR Y CREAR ARCHIVO DE IPS SI NO EXISTE ---
  Dim sRutaIPs As String = User.Home &/ ".gbpublisher/.ips.txt"

  If Not Exist(sRutaIPs) Then
    Try File.Save(sRutaIPs, "127.0.0.1" & Chr(10))
    If Error Then
      m_Sonido.sonar("Error")
      Message.Error("No se pudo crear el archivo de IPs:" & Chr(10) & Error.Text)
      Return
    Endif
  Endif

  FEditarIPs.ShowModal()
  m_FuncionesGenericas.CargarComboBoxIP(TextBoxIP)

End Sub
