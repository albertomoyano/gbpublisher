' Gambas class file

' Gambas class file

' ══════════════════════════════════════════════════════════════════════
' FORMULARIO: FArticuloRelacionado
' DESCRIPCIÓN: GESTIONA LOS METADATOS DEL ARTÍCULO RELACIONADO
'              (JATS: <related-article>) PARA EL ARTÍCULO ACTIVO
'              EN FMetadatosArticulos. EL ID DEL ARTÍCULO SE LEE
'              DESDE FMetadatosArticulos.id_articulo.Value
' ══════════════════════════════════════════════════════════════════════

Public Sub Form_Open()

  Me.Center

  Dim iIdArticulo As Integer
  Dim $result As Result
  Dim sQuery As String

  ' ═══════════════════════════════════════════════════════════════
  ' OBTENER ID DEL ARTÍCULO ACTIVO DESDE EL FORMULARIO PADRE
  ' ═══════════════════════════════════════════════════════════════

  iIdArticulo = FMetadatosArticulos.id_articulo.Value

  If iIdArticulo <= 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay un artículo activo. Guarde el artículo antes de usar esta función.")
    Me.Close
    Return
  Endif

  ' ═══════════════════════════════════════════════════════════════
  ' POBLAR COMBOBOX CON TIPOS JATS DE ARTÍCULOS RELACIONADOS
  ' ═══════════════════════════════════════════════════════════════

  related_article_type.Clear()
  related_article_type.List = [
    "companion",
    "corrected-article",
    "retracted-article",
    "part-of-series",
    "commentary-article"
  ]
  related_article_type.ReadOnly = False  ' PERMITE INGRESAR TIPOS NO LISTADOS

  ' ═══════════════════════════════════════════════════════════════
  ' CARGAR DATOS EXISTENTES DESDE LA BASE DE DATOS
  ' ═══════════════════════════════════════════════════════════════

  sQuery = "SELECT related_article_type, related_article_journal, " &
    "related_article_doi, related_article_anio, " &
    "related_article_volume, related_article_issue, " &
    "related_article_fpage, related_article_lpage " &
    "FROM articulos WHERE id_articulo = &1"

  Try $result = m_ConexionBD.mConn.Exec(sQuery, iIdArticulo)

  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al cargar datos del artículo relacionado:" & Chr(10) & Error.Text)
    Me.Close
    Return
  Endif

  If Not $result.Available Then
    m_Sonido.sonar("Warning")
    Message.Warning("No se encontró el artículo en la base de datos.")
    Me.Close
    Return
  Endif

  ' CARGAR VALORES EN LOS COMPONENTES (RESPETAR NULL)
  related_article_type.Text = If(IsNull($result["related_article_type"]), "", CStr($result["related_article_type"]))
  related_article_journal.Text = If(IsNull($result["related_article_journal"]), "", CStr($result["related_article_journal"]))
  related_article_doi.Text = If(IsNull($result["related_article_doi"]), "", CStr($result["related_article_doi"]))
  related_article_anio.Text = If(IsNull($result["related_article_anio"]), "", CStr($result["related_article_anio"]))
  related_article_volume.Text = If(IsNull($result["related_article_volume"]), "", CStr($result["related_article_volume"]))
  related_article_issue.Text = If(IsNull($result["related_article_issue"]), "", CStr($result["related_article_issue"]))
  related_article_fpage.Text = If(IsNull($result["related_article_fpage"]), "", CStr($result["related_article_fpage"]))
  related_article_lpage.Text = If(IsNull($result["related_article_lpage"]), "", CStr($result["related_article_lpage"]))

End

' ══════════════════════════════════════════════════════════════════════
' BOTÓN: APLICAR — GUARDAR DATOS EN LA BASE DE DATOS
' ══════════════════════════════════════════════════════════════════════

Public Sub btnAplicar_Click()

  Dim iIdArticulo As Integer
  Dim sQuery As String
  Dim $result As Result

  ' ═══════════════════════════════════════════════════════════════
  ' OBTENER ID DEL ARTÍCULO ACTIVO
  ' ═══════════════════════════════════════════════════════════════

  iIdArticulo = FMetadatosArticulos.id_articulo.Value

  If iIdArticulo <= 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay un artículo activo.")
    Return
  Endif

  ' ═══════════════════════════════════════════════════════════════
  ' VALIDACIÓN MÍNIMA: EL TIPO ES OBLIGATORIO
  ' ═══════════════════════════════════════════════════════════════

  If Trim(related_article_type.Text) = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar o ingresar el tipo de relación.")
    related_article_type.SetFocus
    Return
  Endif

  ' ═══════════════════════════════════════════════════════════════
  ' GUARDAR EN LA BASE DE DATOS
  ' ═══════════════════════════════════════════════════════════════

  sQuery = "UPDATE articulos SET " &
    "related_article_type    = &1, " &
    "related_article_journal = &2, " &
    "related_article_doi     = &3, " &
    "related_article_anio    = &4, " &
    "related_article_volume  = &5, " &
    "related_article_issue   = &6, " &
    "related_article_fpage   = &7, " &
    "related_article_lpage   = &8 " &
    "WHERE id_articulo = &9"

  Try m_ConexionBD.mConn.Exec(sQuery,
    related_article_type.Text,
    If(Trim(related_article_journal.Text) <> "", related_article_journal.Text, Null),
      If(Trim(related_article_doi.Text) <> "", related_article_doi.Text, Null),
        If(Trim(related_article_anio.Text) <> "", related_article_anio.Text, Null),
          If(Trim(related_article_volume.Text) <> "", related_article_volume.Text, Null),
            If(Trim(related_article_issue.Text) <> "", related_article_issue.Text, Null),
              If(Trim(related_article_fpage.Text) <> "", related_article_fpage.Text, Null),
                If(Trim(related_article_lpage.Text) <> "", related_article_lpage.Text, Null),
                  iIdArticulo)

                If Error Then
                  m_Sonido.sonar("Error")
                  Message.Error("Error al guardar el artículo relacionado:" & Chr(10) & Error.Text)
                  Return
                Endif

                ' ═══════════════════════════════════════════════════════════════
                ' GUARDADO EXITOSO: CERRAR EL FORMULARIO
                ' ═══════════════════════════════════════════════════════════════

                m_Sonido.sonar("Success")
                Me.Close

End

' ══════════════════════════════════════════════════════════════════════
' BOTÓN: CERRAR — SALIR SIN GUARDAR
' ══════════════════════════════════════════════════════════════════════

Public Sub btnCerrar_Click()

  Me.Close

End

Public Sub btnVerificarDOI_Click()

  m_DOI.VerificarDOI(related_article_doi)

End
