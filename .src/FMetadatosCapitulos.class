' ════════════════════════════════════════════════════════════════════════════
' Función   : ObtenerIdParteSeleccionada
' Propósito : Devolver el id_parte real (de la BD) que corresponde al
'             item seleccionado en el ComboBox id_parte. Devuelve 0 si
'             la selección es "(sin parte)" o el combo está vacío.
' Retorna   : Integer
' ════════════════════════════════════════════════════════════════════════════
Public Function ObtenerIdParteSeleccionada() As Integer

  If id_parte.Index < 0 Then Return 0
  If id_parte.Index >= aIdsParte.Count Then Return 0
  Return aIdsParte[id_parte.Index]

End

' ════════════════════════════════════════════════════════════════════════════
' Función   : SeleccionarPartePorId
' Propósito : Posicionar el ComboBox id_parte en la fila cuyo id_parte
'             coincide con el parámetro. Si no se encuentra, deja
'             seleccionado "(sin parte)".
' Parámetros: iId As Integer — id_parte real a buscar
' ════════════════════════════════════════════════════════════════════════════
Public Sub SeleccionarPartePorId(iId As Integer)

  Dim i As Integer

  For i = 0 To aIdsParte.Max
    If aIdsParte[i] = iId Then
      id_parte.Index = i
      Return
    Endif
  Next
  ' SI NO SE ENCONTRÓ, "(sin parte)" ES EL DEFAULT
  id_parte.Index = 0

End

' ════════════════════════════════════════════════════════════════════════════
' EVENTOS DE CIERRE (heredados del .class original)
' ════════════════════════════════════════════════════════════════════════════

Public Sub btnCerrar_Click()
  ' HABILITAR EL CIERRE Y CERRAR

  bCierrePermitido = True
  Me.Close()

End

Public Sub Form_Close()
  ' SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO

  If bCierrePermitido Then Return
  ' BLOQUEAR EL CIERRE DESDE LA X DEL SISTEMA
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End

Public Sub hbCapitulos_Resize()

  hbCapitulos.Layout = [1, 1]

End
