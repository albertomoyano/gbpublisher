' Parámetros: bSi As Boolean — True para habilitar, False para deshabilitar
' ════════════════════════════════════════════════════════════════════════════
Private Sub HabilitarBotonesCapitulo(bSi As Boolean)

  btnGuardarCambiosMetadatosCapitulo.Enabled = bSi
  btnCapituloBorrar.Enabled = bSi
  btnVincularAutor.Enabled = bSi
  btnDesvincularAutor.Enabled = bSi
  ' btnCreditRoles SE GESTIONA EN LA SEGUNDA PASADA (CON SELECCIÓN DE AUTOR)

End

