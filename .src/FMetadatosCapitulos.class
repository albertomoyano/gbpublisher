  FTXTextendido.ShowModal

End

Public Sub btnNotasInternas_Click()

  FTXTextendido.OriginalTextBox = notas_internas
  FTXTextendido.ShowModal

End

Public Sub licencia_Click()

  Select Case licencia.Text
    Case "CC BY 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by/4.0/"
    Case "CC BY-SA 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-sa/4.0/"
    Case "CC BY-NC 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc/4.0/"
    Case "CC BY-NC-SA 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc-sa/4.0/"
    Case "CC BY-ND 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nd/4.0/"
    Case "CC BY-NC-ND 4.0"
      url_licencia.Text = "https://creativecommons.org/licenses/by-nc-nd/4.0/"
    Case "CC0 1.0"
      url_licencia.Text = "https://creativecommons.org/publicdomain/zero/1.0/"
    Case "MIT"
      url_licencia.Text = "https://opensource.org/licenses/MIT"
    Case "GPL v3"
      url_licencia.Text = "https://www.gnu.org/licenses/gpl-3.0.html"
    Case "Apache 2.0"
      url_licencia.Text = "https://www.apache.org/licenses/LICENSE-2.0"
    Case "BSD 3-Clause"
      url_licencia.Text = "https://opensource.org/licenses/BSD-3-Clause"
    Case "Todos los derechos reservados"
      url_licencia.Text = ""
    Case "Otra"
      url_licencia.Text = ""
      url_licencia.SetFocus
  End Select

End

' EVENTO YA EXISTENTE, REEMPLAZAR CONTENIDO POR:
Public Sub btnPartes_Click()

  If iLibroActual <= 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("No hay libro activo.")
    Return
  Endif

  Dim fp As New FPartesLibro
  fp.iLibroActual = iLibroActual
  fp.ShowModal()

  ' AL VOLVER, REPOBLAR EL COMBO POR SI HUBO CAMBIOS
  PoblarComboIdParte()

End

' ════════════════════════════════════════════════════════════════════════════
' Función   : btnSeleccionArchivo_Click
' Propósito : Abrir un diálogo de selección de archivo .md desde la raíz del
'             proyecto activo. Validar que el archivo esté en una de las 3
'             carpetas canónicas (front-matter, articulos, back-matter) y que
'             su prefijo coincida con la carpeta (fm-, a-, bm-). Asignar el
'             nombre sin extensión al TextBox nombre_archivo y disparar
'             AjustarEstadoComboIdParte() para que el combo id_parte reaccione
'             al nuevo prefijo.
' ════════════════════════════════════════════════════════════════════════════
Public Sub btnSeleccionArchivo_Click()

  Dim sRutaArchivo As String
  Dim sCarpeta As String
  Dim sNombreSinExt As String
  Dim sNombreLower As String
  Dim sPrefijoEsperado As String

  ' --- 1. CONFIGURAR EL DIÁLOGO ---
  Dialog.Title = "Seleccionar archivo MD"
  Dialog.Filter = ["*.md", "Documentos (MD)",
    "*.md", "Archivos Markdown",
    "*", "Todos los archivos"]
  Dialog.AutoExt = True
  Dialog.Path = File.Dir(FMain.txtProyecto.Text)

  ' --- 2. ABRIR EL DIÁLOGO ---
  ' Dialog.OpenFile() RETORNA True SI EL USUARIO CANCELÓ.
  If Dialog.OpenFile() Then Return

  sRutaArchivo = Dialog.Path

  ' --- 3. DETERMINAR LA CARPETA INMEDIATA QUE CONTIENE AL ARCHIVO ---
  ' File.Dir DEVUELVE EL DIRECTORIO COMPLETO; File.Name SOBRE ESE DIRECTORIO
  ' DEVUELVE SOLO EL NOMBRE DE LA CARPETA FINAL.
  ' Ej: /home/x/libro1/front-matter/fm-01.md → "front-matter"
  sCarpeta = LCase(File.Name(File.Dir(sRutaArchivo)))

  ' --- 4. EXTRAER NOMBRE SIN EXTENSIÓN ---
  sNombreSinExt = File.BaseName(sRutaArchivo)
  sNombreLower = LCase(sNombreSinExt)

  ' --- 5. DETERMINAR PREFIJO ESPERADO SEGÚN LA CARPETA ---
  Select Case sCarpeta
    Case "front-matter"
      sPrefijoEsperado = "fm-"
    Case "articulos"
      sPrefijoEsperado = "a-"
    Case "back-matter"
      sPrefijoEsperado = "bm-"
    Case Else
      m_Sonido.sonar("Warning")
      Message.Warning(
        "El archivo debe estar en una de estas carpetas del proyecto:" & Chr(10) & Chr(10) &
        "  • front-matter (archivos fm-*)" & Chr(10) &
        "  • articulos (archivos a-*)" & Chr(10) &
        "  • back-matter (archivos bm-*)" & Chr(10) & Chr(10) &
        "Carpeta detectada: " & sCarpeta)
      Return
  End Select

  ' --- 6. VALIDAR COINCIDENCIA PREFIJO-CARPETA ---
  If Not (sNombreLower Begins sPrefijoEsperado) Then
    m_Sonido.sonar("Warning")
    Message.Warning(
      "El archivo está en la carpeta '" & sCarpeta & "'," & Chr(10) &
      "pero su nombre no empieza con el prefijo '" & sPrefijoEsperado & "'." & Chr(10) & Chr(10) &
      "Archivo: " & sNombreSinExt)
    Return
  Endif

  ' --- 7. ASIGNAR EL NOMBRE AL TEXTBOX ---
  nombre_archivo.Text = sNombreSinExt

  ' --- 8. AJUSTAR EL COMBO id_parte SEGÚN EL NUEVO PREFIJO ---
  ' EL COMBO SE BLOQUEA SI EL ARCHIVO ES fm-/bm-, SE HABILITA SI ES a-.
  AjustarEstadoComboIdParte()

End
