' Gambas class file

' ============================================
' Formulario : FAplicarCrossRef
' Propósito  : Permite al editor seleccionar mediante checkboxes
'              qué valores devueltos por Crossref se aplicarán
'              sobre los TextBox de FMain. Es invocado únicamente
'              desde FEstructuraResultados.btnAplicar_Click cuando
'              el modo activo es MODO_RESULTADOS_CROSSREF.
' ============================================

' --- VARIABLES PÚBLICAS DEL FORMULARIO ---

' bAplicado: TRUE SI EL EDITOR CONFIRMÓ APLICAR; FALSE SI CERRÓ SIN APLICAR.
'            LA LEE FEstructuraResultados AL VOLVER DEL ShowModal PARA
'            DECIDIR SI AUTOCIERRA.
Public bAplicado As Boolean

' bCierrePermitido: REGLA DEL PROYECTO — IMPIDE QUE LA X DE LA VENTANA
'                    CIERRE EL FORMULARIO. SE PONE TRUE INMEDIATAMENTE
'                    ANTES DE CADA Me.Close.
Public bCierrePermitido As Boolean

' ============================================
' Evento    : Form_Open
' Propósito : Carga en el .Text de cada CheckBox el valor que
'             Crossref devolvió para ese campo. Todos los CheckBox
'             arrancan destildados para obligar al editor a tomar
'             una decisión explícita en cada caso (evita inercia).
' ============================================
Public Sub Form_Open()

  ' --- 1. Inicialización de variables ---
  bAplicado = False
  bCierrePermitido = False

  ' --- 2. Validación de entrada ---
  ' LA COLLECTION DEBE HABER SIDO POBLADA POR EL LLAMADOR
  If IsNull(FEstructuraResultados.cValoresAplicar) Then
    bCierrePermitido = True
    Me.Close
    Return
  Endif

  ' --- 3. Asignar valores de Crossref al .Text de cada CheckBox ---
  ' EL EDITOR VE QUÉ VALOR ESPECÍFICO VA A APLICAR SI MARCA LA CASILLA
  chkTitle.Text = "Título: " & ObtenerValor("titulo")
  chkAuthor.Text = "Autor: " & ObtenerValor("autor")
  chkYear.Text = "Año: " & ObtenerValor("anio")
  chkPages.Text = "Páginas: " & ObtenerValor("paginas")
  chkIssn.Text = "ISSN: " & ObtenerValor("issn")
  chkDoi.Text = "DOI: " & ObtenerValor("doi")

  ' --- 4. Garantizar estado destildado por default ---
  ' REGLA DE UX DEL PROYECTO: NO ARRASTRAR INERCIA DE INVOCACIONES PREVIAS
  chkTitle.Value = False
  chkAuthor.Value = False
  chkYear.Value = False
  chkPages.Value = False
  chkIssn.Value = False
  chkDoi.Value = False

End

' ============================================
' Función   : ObtenerValor
' Propósito : Lee de FEstructuraResultados.cValoresAplicar el valor
'             correspondiente a una clave canónica. Devuelve cadena
'             vacía si la clave no existe o el valor es nulo.
' Parámetros: sClave As String — clave canónica del campo
'                                ("titulo", "autor", "anio",
'                                 "paginas", "issn", "doi")
' Retorna   : String — valor de Crossref para esa clave, o "" si no existe
' ============================================
Private Function ObtenerValor(sClave As String) As String

  ' --- 1. Inicialización ---
  Dim vRetorno As Variant

  ' --- 2. Validación de entrada ---
  If IsNull(FEstructuraResultados.cValoresAplicar) Then Return ""
  If Not FEstructuraResultados.cValoresAplicar.Exist(sClave) Then Return ""

  ' --- 3. Lectura defensiva ---
  ' Try ESTÁ SEGUIDO DE If Error PORQUE Try NO INTERRUMPE LA EJECUCIÓN (RC-GM-02)
  Try vRetorno = FEstructuraResultados.cValoresAplicar[sClave]
  If Error Then Return ""
  If IsNull(vRetorno) Then Return ""

  Return CStr(vRetorno)

End

' ============================================
' Evento    : btnAplicar_Click
' Propósito : Para cada CheckBox tildado, escribe el valor de Crossref
'             en el TextBox correspondiente de FMain. Los CheckBox
'             destildados dejan el TextBox intacto. Marca bAplicado=True
'             y cierra el formulario; FEstructuraResultados leerá esa
'             marca para autocerrarse. El guardado a BD queda delegado
'             al botón ya existente en FMain — aquí no se persiste nada.
' ============================================
Public Sub btnAplicar_Click()

  ' --- 1. Aplicar selectivamente sobre los TextBox de FMain ---
  ' SOLO SE SOBRESCRIBEN LOS CAMPOS TILDADOS POR EL EDITOR
  If chkTitle.Value Then FMain.txtTitle.Text = ObtenerValor("titulo")
  If chkAuthor.Value Then FMain.txtAuthor.Text = ObtenerValor("autor")
  If chkYear.Value Then FMain.txtYear.Text = ObtenerValor("anio")
  If chkPages.Value Then FMain.txtPages.Text = ObtenerValor("paginas")
  If chkIssn.Value Then FMain.txtIssn.Text = ObtenerValor("issn")
  If chkDoi.Value Then FMain.txtDoi.Text = ObtenerValor("doi")

  ' --- 2. Marcar aplicado y cerrar ---
  ' bAplicado=True INDICA A FEstructuraResultados QUE DEBE AUTOCERRARSE
  bAplicado = True
  bCierrePermitido = True
  Me.Close

End

' ============================================
' Evento    : btnCerrar_Click
' Propósito : Cierra el formulario sin aplicar cambios. bAplicado queda
'             en False, por lo que FEstructuraResultados permanece abierto
'             para que el editor pueda volver a revisar el grid.
' ============================================
Public Sub btnCerrar_Click()

  ' --- 1. Cerrar sin aplicar ---
  bAplicado = False
  bCierrePermitido = True
  Me.Close

End

' ============================================
' Evento    : Form_Close
' Propósito : Guarda contra cierres no autorizados (botón X de la ventana).
'             Sólo permite cerrar si la lógica del formulario marcó
'             bCierrePermitido = True. Cumple la regla del proyecto.
' ============================================
Public Sub Form_Close()

  ' --- 1. Bloquear cierres no permitidos ---
  If Not bCierrePermitido Then Stop Event

End