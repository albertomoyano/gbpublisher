# Gambas Form File 3.0

{ Form Form
  Move(0,0,960,600)
  #Scaled = False
  #Translate = False
  Resizable = False
  Arrangement = Arrange.Vertical
  Centered = True
  Spacing = True
  Margin = True
  Padding = 4
  { hbAceptar2 HBox
    Move(9,9,891,36)
    #Translate = False
    { lblArticulo Label
      Move(0,0,126,36)
      Foreground = Color.Blue
      Expand = True
      Alignment = Align.Center
    }
  }
  { hbAceptar HBox
    Move(27,63,891,36)
    #Translate = False
    { btnImportarCSV Button
      Move(9,0,36,36)
      ToolTip = ("Abrir un archivo CSV")
      Picture = Picture["iconos/abrirBuscar.png"]
    }
    { btnEditarCSV Button
      Move(45,0,36,36)
      ToolTip = ("Editar archivo CSV")
      Picture = Picture["iconos/textnormal.png"]
    }
    { btnEditarCSVconOffice Button
      Move(81,0,36,36)
      ToolTip = ("Editar archivo CSV con Libre Office")
      Picture = Picture["iconos/calc.png"]
    }
    { btnBorrarArchivoCSV Button
      Move(117,0,36,36)
      ToolTip = ("Borrar archivo CSV y figuras asociadas")
      Picture = Picture["iconos/borrar.png"]
    }
    { cmbCargarDatos ComboBox
      Move(198,0,144,36)
      Expand = True
      ReadOnly = True
    }
    { Spring1 Spring
      Move(522,0,36,36)
    }
  }
  { gvDatos TableView
    Move(207,117,243,108)
    ShowCursor = True
  }
  { hbAceptar3 HBox
    Move(9,279,891,36)
    #Translate = False
    { cmbTipoGrafico ComboBox
      Move(0,0,144,36)
      Expand = True
      ReadOnly = True
    }
    { cmbTipoDatos ComboBox
      Move(144,0,144,36)
      Expand = True
      ReadOnly = True
    }
    { cmbColorPaleta ComboBox
      Move(288,0,144,36)
      Expand = True
      ReadOnly = True
    }
    { btnDibujar Button
      Move(522,0,36,36)
      Picture = Picture["iconos/ok.png"]
    }
    { PictureBox1 PictureBox
      Move(693,0,36,36)
    }
    { chkLeyenda CheckBox
      Move(765,0,45,36)
      AutoResize = True
      Text = ("Leyenda")
    }
  }
  { wvFigura WebView
    Move(27,324,144,144)
    Expand = True
  }
  { HBoxBotonCerrarTerminos HBox
    Move(9,549,891,36)
    #Translate = False
    { TextLabel1 TextLabel
      Move(27,0,144,36)
      Text = ("Título: ")
      Alignment = Align.Right
    }
    { txtNombreFigura TextBox
      Move(216,0,144,36)
      Expand = True
      Placeholder = ("El título es opcional")
    }
    { btnGenerar Button
      Move(585,0,144,36)
      Font = Font["Bold"]
      Background = &H9FFF7F
      Text = ("Generar")
      Picture = Picture["iconos/enviar.png"]
    }
    { !btnCerrar Button
      Move(738,0,144,36)
      #Public = True
      Text = ("Cerrar")
      Picture = Picture["iconos/salir.png"]
    }
  }
}
