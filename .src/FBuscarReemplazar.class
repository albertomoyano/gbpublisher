' Gambas class file

' ============================================================================
' Clase     : FBuscarReemplazar
' Propósito : Formulario de búsqueda y reemplazo de texto sobre el archivo
'             principal del proyecto y todos los .md y .tex dentro de la
'             carpeta /articulos del proyecto activo. NO orientado a autores;
'             es una herramienta de producción editorial.
' Origen    : Invocado desde FMain. Depende de:
'               - FMain.RutaProyecto            (String, ruta del proyecto)
'               - FMain.txtProyecto.Text         (String, ruta archivo principal)
'               - FMain.sRutaArchivoAbierto      (String, archivo abierto en editor)
'               - FMain.txtEditorProyecto.Text   (String, contenido del editor)
' Componentes formulario:
'               - btnMayusculaMinuscula  ToggleButton  distingue may/min
'               - btnExacta              ToggleButton  palabra completa
'               - txtBuscarPalabra       TextBox       término a buscar
'               - btnMostrarBuscar       Button        ejecuta búsqueda
'               - txtReemplazar          TextBox       texto de reemplazo
'               - gvBuscarReemplazar     GridView      listado de resultados
'               - btnAplicar             Button        reemplazo en fila seleccionada
'               - btnAplicarTodo         Button        reemplazo en todas las filas
'               - btnCerrar              Button        único cierre legítimo
'
' UTF-8       : Toda manipulación de texto usa la clase String.* porque las
'               funciones estándar (InStr, Len, Mid$, LCase, etc.) solo
'               trabajan sobre ASCII según la documentación oficial de Gambas.
' ============================================================================

' --- ARRAYS PARALELOS DE COINCIDENCIAS ---
' CADA ÍNDICE REPRESENTA UNA FILA DEL GRIDVIEW Y AGRUPA LOS DATOS NECESARIOS
' PARA APLICAR UN REEMPLAZO PUNTUAL SIN VOLVER A BUSCAR
' LAS POSICIONES SON EN CARACTERES (NO EN BYTES) PARA SER COMPATIBLES CON String.*
Private $aRutaArchivo As New String[]
Private $aNumeroLinea As New Integer[]
Private $aPosicionEnLinea As New Integer[]

' --- BLOQUEO DE CIERRE POR LA X DEL SISTEMA ---
' SOLO btnCerrar_Click PUEDE PONERLO EN TRUE
Private bCierrePermitido As Boolean

' ============================================================================
' Función   : Form_Open
' Propósito : Inicializar el GridView, limpiar los campos de entrada y
'             resetear el flag de cierre en cada apertura del formulario.
' ============================================================================
Public Sub Form_Open()

  ' --- 1. RESET DE FLAGS DE INSTANCIA ---
  ' EVITA ARRASTRAR EL PERMISO DE CIERRE SI LA INSTANCIA SE REUSA
  bCierrePermitido = False

  ' --- 2. CONFIGURACIÓN DEL GRIDVIEW ---
  With gvBuscarReemplazar
    .Columns.Count = 3
    .Rows.Count = 0
    .Header = GridView.Horizontal
    .Grid = True
    .Mode = Select.Single

    .Columns[0].Title = "Archivo"
    .Columns[0].Width = 200
    .Columns[1].Title = "Línea"
    .Columns[1].Width = 100
    .Columns[2].Title = "Coincidencia"
    .Columns[2].Width = 400
  End With

  ' --- 3. LIMPIEZA DE CAMPOS DE ENTRADA ---
  txtBuscarPalabra.Text = ""
  txtReemplazar.Text = ""

  ' --- 4. INICIALIZACIÓN DE ARRAYS DE RESULTADO ---
  LimpiarArrays()

End

' ============================================================================
' Función   : LimpiarArrays
' Propósito : Vaciar los tres arrays paralelos que almacenan las
'             coincidencias del último resultado de búsqueda.
' ============================================================================
Private Sub LimpiarArrays()

  $aRutaArchivo.Clear()
  $aNumeroLinea.Clear()
  $aPosicionEnLinea.Clear()

End

' ============================================================================
' Función   : btnMostrarBuscar_Click
' Propósito : Ejecutar la búsqueda del término en el archivo principal del
'             proyecto y en todos los .md/.tex de /articulos, respetando
'             los toggles de mayúsculas y palabra exacta.
' ============================================================================
Public Sub btnMostrarBuscar_Click()

  Dim sTermino As String
  Dim sRutaProyecto As String
  Dim sArchivoPrincipal As String
  Dim aCarpetasContenido As New String[]
  Dim sNombreCarpeta As String
  Dim sCarpetaActual As String
  Dim aArchivos As String[]
  Dim sArchivo As String

  ' --- 1. VALIDACIÓN DEL TÉRMINO DE BÚSQUEDA ---
  sTermino = Trim(txtBuscarPalabra.Text)
  If sTermino = "" Then
    Message.Warning("Debe ingresar un término de búsqueda.")
    txtBuscarPalabra.SetFocus()
    Return
  Endif

  ' --- 2. LIMPIEZA DE RESULTADOS PREVIOS ---
  gvBuscarReemplazar.Rows.Count = 0
  LimpiarArrays()

  ' --- 3. OBTENCIÓN DE RUTAS DESDE FMAIN ---
  sRutaProyecto = FMain.RutaProyecto
  sArchivoPrincipal = FMain.txtProyecto.Text

  ' --- 4. VALIDACIÓN DEL PROYECTO ACTIVO ---
  ' CONDICIONES SEPARADAS EN IF ANIDADOS PARA NO MEZCLAR CONDICIONES
  ' INDEPENDIENTES Y PARA DAR MENSAJE PRECISO SEGÚN EL FALLO
  If sRutaProyecto = "" Then
    Message.Warning("No hay un proyecto cargado.")
    Return
  Endif
  If Not Exist(sArchivoPrincipal) Then
    Message.Warning("El archivo principal del proyecto no existe.")
    Return
  Endif

  ' --- 5. BÚSQUEDA EN EL ARCHIVO PRINCIPAL ---
  BuscarEnArchivo(sArchivoPrincipal, sTermino)

  ' --- 6. BÚSQUEDA EN LAS CARPETAS DE CONTENIDO ---
  ' SE EXPLORAN LAS TRES CARPETAS CONVENCIONALES EN ORDEN EDITORIAL:
  ' FRONT-MATTER (fm-*) → CUERPO (a-*) → BACK-MATTER (bm-*).
  ' SI ALGUNA NO EXISTE EN EL PROYECTO ACTUAL (CASO TÍPICO DE UNA REVISTA
  ' SIN PARATEXTOS DE LIBRO) SE OMITE SIN GENERAR ERROR.
  aCarpetasContenido.Add("front-matter")
  aCarpetasContenido.Add("articulos")
  aCarpetasContenido.Add("back-matter")

  For Each sNombreCarpeta In aCarpetasContenido
    sCarpetaActual = sRutaProyecto &/ sNombreCarpeta
    ' SE FILTRA POR EXISTENCIA Y POR TIPO DIRECTORIO ANTES DE LISTAR
    If Not Exist(sCarpetaActual) Then Continue
    If Stat(sCarpetaActual).Type <> gb.Directory Then Continue

    aArchivos = ObtenerArchivos(sCarpetaActual)
    For Each sArchivo In aArchivos
      BuscarEnArchivo(sArchivo, sTermino)
    Next
  Next

  ' --- 7. NOTIFICACIÓN AL USUARIO SI NO HUBO COINCIDENCIAS ---
  If $aRutaArchivo.Count = 0 Then
    Message.Info("No se encontraron coincidencias.")
  Endif

End

' ============================================================================
' Función   : ObtenerArchivos
' Propósito : Listar las rutas de los archivos con extensión .md o .tex
'             dentro de una carpeta (no recursivo).
' Parámetros: sCarpeta As String — ruta absoluta de la carpeta a explorar
' Retorna   : String[] — rutas completas de los archivos encontrados
' ============================================================================
Private Function ObtenerArchivos(sCarpeta As String) As String[]

  Dim aResultado As New String[]
  Dim sNombre As String
  Dim sExtension As String

  ' --- 1. RECORRIDO DE ENTRADAS DEL DIRECTORIO ---
  ' SOLO INTERESAN MARKDOWN (FUENTE EDITORIAL) Y FUENTES LATEX GENERADAS
  ' LCase BYTE-ORIENTED ALCANZA AQUÍ PORQUE LAS EXTENSIONES SON ASCII
  For Each sNombre In Dir(sCarpeta)
    sExtension = LCase(File.Ext(sNombre))
    If sExtension = "md" Or sExtension = "tex" Then
      aResultado.Add(sCarpeta &/ sNombre)
    Endif
  Next

  Return aResultado

End

' ============================================================================
' Función   : BuscarEnArchivo
' Propósito : Buscar todas las coincidencias del término dentro de un
'             archivo y volcarlas al GridView junto con sus arrays paralelos.
' Parámetros: sRutaArchivo As String — ruta absoluta del archivo
'             sTermino     As String — término literal a buscar (UTF-8)
' Notas     : Delega la lógica de búsqueda en m_FuncionesGenericas.BuscarEnTexto.
'             Esta función solo agrega el contexto del archivo (ruta + alta
'             en el GridView de este formulario).
' ============================================================================
Private Sub BuscarEnArchivo(sRutaArchivo As String, sTermino As String)

  Dim sContenido As String
  Dim sNombreArchivo As String
  Dim aNumerosLinea As New Integer[]
  Dim aPosiciones As New Integer[]
  Dim aTextos As New String[]
  Dim iResultados As Integer
  Dim iFila As Integer
  Dim i As Integer

  ' --- 1. VALIDACIÓN DE EXISTENCIA DEL ARCHIVO ---
  If Not Exist(sRutaArchivo) Then Return

  ' --- 2. LECTURA CONTROLADA DEL ARCHIVO ---
  ' SI LA LECTURA FALLA SE ABORTA ESTE ARCHIVO SIN ROMPER LA BÚSQUEDA GLOBAL
  Try sContenido = File.Load(sRutaArchivo)
  If Error Then Return

  ' --- 3. INVOCACIÓN DE LA BÚSQUEDA GENÉRICA ---
  ' LOS ARRAYS LOCALES SE LLENAN POR REFERENCIA DENTRO DE BuscarEnTexto
  iResultados = m_FuncionesGenericas.BuscarEnTexto(sContenido, sTermino, btnMayusculaMinuscula.Value, btnExacta.Value, aNumerosLinea, aPosiciones, aTextos)

  ' --- 4. VOLCADO DE RESULTADOS A LOS ARRAYS DEL FORM Y AL GRIDVIEW ---
  ' LOS ARRAYS DEL FORM SUMAN LA RUTA DEL ARCHIVO (DATO PROPIO DE ESTE FORM)
  sNombreArchivo = File.Name(sRutaArchivo)
  For i = 0 To iResultados - 1
    $aRutaArchivo.Add(sRutaArchivo)
    $aNumeroLinea.Add(aNumerosLinea[i])
    $aPosicionEnLinea.Add(aPosiciones[i])

    iFila = gvBuscarReemplazar.Rows.Count
    gvBuscarReemplazar.Rows.Count = iFila + 1
    gvBuscarReemplazar[iFila, 0].Text = sNombreArchivo
    gvBuscarReemplazar[iFila, 1].Text = Str(aNumerosLinea[i])
    gvBuscarReemplazar[iFila, 2].Text = aTextos[i]
  Next

End

' ============================================================================
' Función   : btnAplicar_Click
' Propósito : Aplicar el reemplazo solo en la coincidencia seleccionada del
'             GridView y eliminar esa fila junto con su entrada en los arrays.
' ============================================================================
Public Sub btnAplicar_Click()

  Dim sReemplazo As String
  Dim iFilaSeleccionada As Integer

  ' --- 1. VALIDACIÓN DEL TEXTO DE REEMPLAZO ---
  sReemplazo = txtReemplazar.Text
  If sReemplazo = "" Then
    Message.Warning("Debe ingresar el texto de reemplazo.")
    txtReemplazar.SetFocus()
    Return
  Endif

  ' --- 2. VALIDACIÓN DE LA FILA SELECCIONADA ---
  iFilaSeleccionada = gvBuscarReemplazar.Row
  If iFilaSeleccionada < 0 Then
    Message.Warning("Debe seleccionar una fila del listado.")
    Return
  Endif
  If iFilaSeleccionada > $aRutaArchivo.Max Then
    Message.Warning("La fila seleccionada está fuera del rango de resultados.")
    Return
  Endif

  ' --- 3. APLICACIÓN DEL REEMPLAZO ---
  AplicarReemplazoEnArchivo(iFilaSeleccionada, txtBuscarPalabra.Text, sReemplazo)

  ' --- 4. ELIMINACIÓN DE LA FILA Y SU ENTRADA EN LOS ARRAYS ---
  gvBuscarReemplazar.Rows.Remove(iFilaSeleccionada)
  $aRutaArchivo.Remove(iFilaSeleccionada)
  $aNumeroLinea.Remove(iFilaSeleccionada)
  $aPosicionEnLinea.Remove(iFilaSeleccionada)

End

' ============================================================================
' Función   : btnAplicarTodo_Click
' Propósito : Aplicar el reemplazo a todas las coincidencias listadas.
'             El recorrido es inverso para que los desplazamientos de cada
'             reemplazo no invaliden las posiciones de los restantes.
' ============================================================================
Public Sub btnAplicarTodo_Click()

  Dim sReemplazo As String
  Dim i As Integer

  ' --- 1. VALIDACIÓN DEL TEXTO DE REEMPLAZO ---
  sReemplazo = txtReemplazar.Text
  If sReemplazo = "" Then
    Message.Warning("Debe ingresar el texto de reemplazo.")
    txtReemplazar.SetFocus()
    Return
  Endif

  ' --- 2. VALIDACIÓN DE COINCIDENCIAS DISPONIBLES ---
  If $aRutaArchivo.Count = 0 Then
    Message.Warning("No hay coincidencias para reemplazar.")
    Return
  Endif

  ' --- 3. APLICACIÓN EN ORDEN INVERSO ---
  ' DE ABAJO HACIA ARRIBA PARA PRESERVAR POSICIONES VÁLIDAS EN CADA LÍNEA
  For i = $aRutaArchivo.Max To 0 Step -1
    AplicarReemplazoEnArchivo(i, txtBuscarPalabra.Text, sReemplazo)
  Next

  ' --- 4. LIMPIEZA TOTAL DEL GRID Y LOS ARRAYS ---
  gvBuscarReemplazar.Rows.Count = 0
  LimpiarArrays()

End

' ============================================================================
' Función   : AplicarReemplazoEnArchivo
' Propósito : Aplicar un reemplazo puntual usando los datos almacenados en
'             los arrays paralelos. Si el archivo está abierto en el editor
'             de FMain, modifica el editor; si no, modifica el archivo en
'             disco.
' Parámetros: iIndice    As Integer — índice en los arrays paralelos
'             sTermino   As String  — término original a reemplazar
'             sReemplazo As String  — texto que sustituye al término
' ============================================================================
Private Sub AplicarReemplazoEnArchivo(iIndice As Integer, sTermino As String, sReemplazo As String)

  Dim sContenido As String
  Dim aLineas As String[]
  Dim sLinea As String
  Dim sNuevaLinea As String
  Dim iIndiceLinea As Integer
  Dim sRutaArchivo As String
  Dim iPosicion As Integer

  ' --- 1. EXTRACCIÓN DE DATOS DE LOS ARRAYS ---
  sRutaArchivo = $aRutaArchivo[iIndice]
  iIndiceLinea = $aNumeroLinea[iIndice] - 1   ' CONVERTIR A BASE 0 PARA ÍNDICE DE ARRAY
  iPosicion = $aPosicionEnLinea[iIndice]

  ' --- 2. CAMINO ALTERNATIVO: ARCHIVO ABIERTO EN EL EDITOR ---
  ' SE EVITA MODIFICAR EL DISCO PARA QUE LOS CAMBIOS QUEDEN EN MEMORIA Y
  ' EL USUARIO CONSERVE EL CONTROL DEL GUARDADO DESDE FMAIN
  If sRutaArchivo = FMain.sRutaArchivoAbierto Then
    ModificarEnEditor(iIndiceLinea, iPosicion, sTermino, sReemplazo)
    Return
  Endif

  ' --- 3. CARGA DEL ARCHIVO EN DISCO ---
  Try sContenido = File.Load(sRutaArchivo)
  If Error Then Return

  ' --- 4. NORMALIZACIÓN Y SPLIT POR LF ---
  sContenido = Replace(sContenido, Chr(13) & Chr(10), Chr(10))
  sContenido = Replace(sContenido, Chr(13), Chr(10))
  aLineas = Split(sContenido, Chr(10))

  ' --- 5. REEMPLAZO EN LA LÍNEA OBJETIVO ---
  If iIndiceLinea >= 0 And iIndiceLinea <= aLineas.Max Then
    sLinea = aLineas[iIndiceLinea]
    sNuevaLinea = ReemplazarEnPosicion(sLinea, sTermino, sReemplazo, iPosicion)
    aLineas[iIndiceLinea] = sNuevaLinea

    ' --- 6. PERSISTENCIA EN DISCO ---
    sContenido = aLineas.Join(Chr(10))
    Try File.Save(sRutaArchivo, sContenido)
    If Error Then
      Message.Warning("No se pudo guardar el archivo:" & Chr(10) & sRutaArchivo)
    Endif
  Endif

End

' ============================================================================
' Función   : ModificarEnEditor
' Propósito : Aplicar el reemplazo sobre el contenido del TextEditor de
'             FMain cuando el archivo objetivo es el que el usuario está
'             editando en ese momento.
' Parámetros: iIndiceLinea As Integer — índice de la línea (base 0)
'             iPosicion    As Integer — posición en CARACTERES (base 1)
'             sTermino     As String  — término a reemplazar
'             sReemplazo   As String  — texto sustituto
' ============================================================================
Private Sub ModificarEnEditor(iIndiceLinea As Integer, iPosicion As Integer, sTermino As String, sReemplazo As String)

  Dim sContenido As String
  Dim aLineas As String[]
  Dim sLinea As String
  Dim sNuevaLinea As String

  ' --- 1. LECTURA DEL CONTENIDO ACTUAL DEL EDITOR ---
  sContenido = FMain.txtEditorProyecto.Text

  ' --- 2. NORMALIZACIÓN Y SPLIT POR LF ---
  sContenido = Replace(sContenido, Chr(13) & Chr(10), Chr(10))
  sContenido = Replace(sContenido, Chr(13), Chr(10))
  aLineas = Split(sContenido, Chr(10))

  ' --- 3. REEMPLAZO EN LA LÍNEA OBJETIVO ---
  If iIndiceLinea >= 0 And iIndiceLinea <= aLineas.Max Then
    sLinea = aLineas[iIndiceLinea]
    sNuevaLinea = ReemplazarEnPosicion(sLinea, sTermino, sReemplazo, iPosicion)
    aLineas[iIndiceLinea] = sNuevaLinea

    ' --- 4. VOLCADO DE VUELTA AL EDITOR ---
    FMain.txtEditorProyecto.Text = aLineas.Join(Chr(10))
  Endif

End

' ============================================================================
' Función   : ReemplazarEnPosicion
' Propósito : Reconstruir una línea reemplazando el término en una posición
'             específica (en caracteres UTF-8), preservando el resto.
' Parámetros: sLinea     As String  — línea original
'             sTermino   As String  — término a reemplazar
'             sReemplazo As String  — texto sustituto
'             iPosicion  As Integer — posición en CARACTERES (base 1)
' Retorna   : String — línea con el reemplazo aplicado
' Notas     : Todo el slicing se hace con String.Left y String.Mid para
'             que las posiciones se interpreten en caracteres y no en bytes.
' ============================================================================
Private Function ReemplazarEnPosicion(sLinea As String, sTermino As String, sReemplazo As String, iPosicion As Integer) As String

  Dim sAntes As String
  Dim sDespues As String
  Dim iLongitud As Integer

  iLongitud = String.Len(sTermino)

  ' --- 1. VALIDACIÓN DE POSICIÓN ---
  If iPosicion < 1 Or iPosicion > String.Len(sLinea) Then Return sLinea

  ' --- 2. PARTICIÓN ANTES / DESPUÉS DEL TÉRMINO ---
  sAntes = String.Left(sLinea, iPosicion - 1)
  sDespues = String.Mid(sLinea, iPosicion + iLongitud)

  ' --- 3. RECONSTRUCCIÓN CON EL REEMPLAZO INTERCALADO ---
  Return sAntes & sReemplazo & sDespues

End

' ============================================================================
' Función   : btnCerrar_Click
' Propósito : Único punto de salida legítimo del formulario. Habilita el
'             cierre controlado seteando el flag y dispara Form_Close.
' ============================================================================
Public Sub btnCerrar_Click()

  bCierrePermitido = True
  Me.Close()

End

' ============================================================================
' Función   : Form_Close
' Propósito : Interceptar el cierre del formulario. Si proviene del botón
'             Cerrar (bCierrePermitido = True), libera arrays y permite el
'             cierre. Cualquier otro origen (X del sistema, Alt+F4) queda
'             bloqueado con aviso al usuario.
' ============================================================================
Public Sub Form_Close()

  ' --- 1. CIERRE AUTORIZADO POR EL BOTÓN ---
  If bCierrePermitido Then
    LimpiarArrays()
    Return
  Endif

  ' --- 2. CIERRE NO AUTORIZADO: AVISO Y BLOQUEO ---
  m_Sonido.sonar("info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End
