' Gambas class file

' ==============================================================================
' Formulario: FBlockNotas
' Propósito : Sistema de "Block de Notas" con funcionalidades CRUD y búsqueda.
'             Las notas se guardan asociadas al usuario que las creó. Todos los
'             usuarios pueden leer todas las notas, pero solo el autor puede
'             modificar o borrar las propias.
' Dependencias: m_ConexionBD, m_InicioCierre, m_Sonido, FMain.
' ==============================================================================

' --- OBJETO Result QUE ALMACENA LOS REGISTROS DE NOTAS CARGADOS DESDE LA BD ---
Private Contenido As Result

' --- FLAG QUE PERMITE EL CIERRE DESDE EL BOTÓN Y BLOQUEA EL CIERRE DESDE LA X ---
' PATRÓN CANÓNICO DEL PROYECTO PARA FORMULARIOS MODALES
Private bCierrePermitido As Boolean

' ============================================
' Función   : Form_Open
' Propósito : Inicializa los controles y la apariencia del formulario al
'             abrirse. La carga de notas se delega a Form_Activate (que se
'             dispara después de Form_Open y también en cada vuelta al foco).
' ============================================
Public Sub Form_Open()

  ' --- 1. TÍTULO DEL FORMULARIO CON EL USUARIO LOGUEADO ---
  FBlockNotas.Title = "Block de notas (usuario en curso: " & m_InicioCierre.UsuarioEnCurso & ")"

  ' --- 2. CONFIGURACIÓN INICIAL DE LA GRILLA ---
  With gridNotas
    .Header = True
    .Grid = True
    .Columns.Count = 2
    .Columns[0].Title = "id"
    .Columns[0].Width = 0     ' COLUMNA ID OCULTA
    .Columns[1].Title = "Asunto"
  End With

  ' --- 3. ESTADO INICIAL: MODO VISUALIZACIÓN ---
  EstablecerModoVisualizacion()

End

' ============================================
' Función   : Form_Activate
' Propósito : Carga (o recarga) las notas desde la BD. Se dispara al abrir
'             el formulario y cada vez que recupera el foco, lo que permite
'             ver notas agregadas por otros usuarios sin reabrir el form.
' ============================================
Public Sub Form_Activate()

  CargarNotas()

End

' ============================================
' Función   : Form_Close
' Propósito : Si el cierre viene del botón Cerrar, permitirlo. Si viene de
'             la X del sistema, bloquearlo e informar al usuario.
' ============================================
Public Sub Form_Close()

  ' --- 1. SI EL CIERRE VIENE DEL BOTÓN, PERMITIRLO ---
  If bCierrePermitido Then Return

  ' --- 2. SI VIENE DE LA X DEL SISTEMA, BLOQUEAR Y AVISAR ---
  m_Sonido.sonar("Info")
  Message.Info("Para cerrar el formulario correctamente," & Chr(10) & "use el botón <b>Cerrar</b>.")
  Stop Event

End

' ============================================
' Función   : btnCerrar_Click
' Propósito : Habilita el flag de cierre permitido y cierra el formulario.
' ============================================
Public Sub btnCerrar_Click()

  bCierrePermitido = True
  Me.Close()

End

' ============================================
' Función   : CargarNotas
' Propósito : Carga todas las notas de la base de datos en el objeto Contenido,
'             ordenadas por ID descendente (más recientes primero). Hace JOIN
'             con la tabla usuarios para mostrar el nombre del autor.
' ============================================
Public Sub CargarNotas()

  ' --- 1. CONSULTA CON JOIN PARA OBTENER ASUNTO Y NOMBRE DE AUTOR ---
  Try Contenido = m_ConexionBD.mConn.Exec(
    "SELECT b.*, u.usuario FROM block_notas b " &
    "JOIN usuarios u ON b.id_usuario = u.id " &
    "ORDER BY b.id DESC")
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudieron cargar las notas:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 2. AJUSTAR EL CONTEO DE FILAS Y REFRESCAR LA GRILLA ---
  gridNotas.Rows.Count = Contenido.Count
  gridNotas.Refresh()

End

' ============================================
' Función   : LimpiarCamposNotas
' Propósito : Limpia el contenido de los campos de detalle y búsqueda.
'             No toca el control de fecha (DateBoxBlockNotas) ni los botones.
' ============================================
Public Sub LimpiarCamposNotas()

  txtBuscar.Text = ""
  ID_block.Value = ""
  txtAsunto.Text = ""
  txtContenido.Text = ""
  txtUsuario.Text = ""

End

' ============================================
' Función   : EstablecerModoVisualizacion
' Propósito : Devuelve el formulario al estado de visualización pura: campos
'             deshabilitados, búsqueda habilitada, solo el botón Nuevo visible.
'             Centraliza la configuración de UI que aparecía duplicada en varios
'             handlers (guardar, modificar, borrar, refrescar, buscar).
' ============================================
Private Sub EstablecerModoVisualizacion()

  ' --- 1. DESHABILITAR CAMPOS DE EDICIÓN ---
  txtAsunto.Enabled = False
  txtContenido.Enabled = False

  ' --- 2. HABILITAR BÚSQUEDA ---
  txtBuscar.Enabled = True

  ' --- 3. CONFIGURAR VISIBILIDAD DE BOTONES ---
  btnNuevo.Visible = True
  btnBorrar.Visible = False
  btnGuardar.Visible = False
  btnGuardarMod.Visible = False

End

' ============================================
' Función   : gridNotas_Click
' Propósito : Carga la nota seleccionada en los campos de detalle y configura
'             qué botones de acción están disponibles según la autoría.
'             La validación se hace por ID de usuario, no por nombre.
' ============================================
Public Sub gridNotas_Click()

  ' --- 1. VALIDAR FILA SELECCIONADA ---
  If gridNotas.Row < 0 Then Return

  ' --- 2. CARGAR DATOS DE LA NOTA EN LOS CAMPOS DE DETALLE ---
  Contenido.MoveTo(gridNotas.Row)
  ID_block.Value = Contenido["id"]
  txtAsunto.Text = Contenido["asunto"]
  txtContenido.Text = Contenido["contenido"]
  txtUsuario.Text = Contenido["usuario"]
  DateBoxBlockNotas.Value = Contenido["fecha"]

  ' --- 3. HABILITAR EDICIÓN DE LOS CAMPOS DE TEXTO ---
  txtAsunto.Enabled = True
  txtContenido.Enabled = True
  txtContenido.ReadOnly = False

  ' --- 4. CONFIGURACIÓN BASE DE BOTONES ---
  btnNuevo.Visible = True
  btnGuardar.Visible = False

  ' --- 5. HABILITAR MODIFICACIÓN Y BORRADO SOLO SI EL USUARIO ES EL AUTOR ---
  ' VALIDACIÓN POR ID, NO POR NOMBRE DE USUARIO
  If m_InicioCierre.IdUsuarioEnCurso = 0 Then Return

  If Contenido["id_usuario"] = m_InicioCierre.IdUsuarioEnCurso Then
    btnGuardarMod.Visible = True
    btnBorrar.Visible = True
  Else
    btnGuardarMod.Visible = False
    btnBorrar.Visible = False
    m_Sonido.sonar("Warning")
    Message.Warning("Solo puede modificar sus propias notas.")
  Endif

End

' ============================================
' Función   : gridNotas_Data
' Propósito : Rellena las celdas de la grilla con datos cuando el control lo
'             requiere. Se utiliza el objeto Contenido cargado previamente
'             por CargarNotas o por una búsqueda.
' ============================================
Public Sub gridNotas_Data(Row As Integer, Column As Integer)

  ' --- 1. VALIDAR QUE HAY DATOS Y FILA VÁLIDA ---
  If Contenido = Null Then Return
  If Row < 0 Then Return

  ' --- 2. MOVER PUNTERO Y ASIGNAR VALOR A LA CELDA ---
  ' SE USA Try POR SEGURIDAD: Contenido[Column] PUEDE NO SER STRING NI
  ' SIQUIERA EXISTIR SEGÚN LA CONFIGURACIÓN DEL GRID
  Contenido.MoveTo(Row)
  Try gridNotas.Data.Text = Str(Contenido[Column])
  If Error Then gridNotas.Data.Text = ""

End

' ============================================
' Función   : btnNuevo_Click
' Propósito : Prepara la interfaz para crear una nueva nota: habilita campos,
'             muestra el botón Guardar, calcula el siguiente ID disponible
'             usando el MÁXIMO (RC-GM-09) para evitar colisiones por borrados
'             intermedios.
' ============================================
Public Sub btnNuevo_Click()

  Dim resultado As Result
  Dim iSiguienteId As Integer

  ' --- 1. LIMPIAR CAMPOS Y PREPARAR LA UI ---
  LimpiarCamposNotas()
  txtAsunto.Enabled = True
  txtContenido.Enabled = True
  txtBuscar.Enabled = False
  DateBoxBlockNotas.Value = Now

  btnNuevo.Visible = False
  btnBorrar.Visible = False
  btnGuardar.Visible = True
  btnGuardarMod.Visible = False

  ' --- 2. CALCULAR EL SIGUIENTE ID USANDO IFNULL EN SQL ---
  ' DEVUELVE 0 SI LA TABLA ESTÁ VACÍA, EVITANDO COMPARACIÓN CON Null EN GAMBAS
  Try resultado = m_ConexionBD.mConn.Exec("SELECT IFNULL(MAX(id), 0) AS max_id FROM block_notas")
  If Error Or If Not resultado.Available Then
    m_Sonido.sonar("Error")
    Message.Error("No se pudo calcular el ID de la nueva nota:" & gb.NewLine & Error.Text)
    Return
  Endif

  iSiguienteId = resultado["max_id"] + 1
  ID_block.Value = iSiguienteId

  ' --- 3. FOCO EN EL CAMPO DE ASUNTO PARA EMPEZAR A TIPEAR ---
  txtAsunto.SetFocus

End

' ============================================
' Función   : btnGuardar_Click
' Propósito : Guarda una nueva nota en la tabla block_notas con el usuario
'             logueado como autor.
' ============================================
Public Sub btnGuardar_Click()

  Dim miCreate As Result

  ' --- 1. VALIDAR QUE EL ID DE USUARIO ESTÉ DISPONIBLE ---
  If m_InicioCierre.IdUsuarioEnCurso = 0 Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el usuario actual en la base de datos.")
    Return
  Endif

  ' --- 2. CREAR REGISTRO Y ASIGNAR CAMPOS ---
  Try miCreate = m_ConexionBD.mConn.Create("block_notas")
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al crear el registro:" & gb.NewLine & Error.Text)
    Return
  Endif

  miCreate!id = ID_block.Value
  miCreate!asunto = txtAsunto.Text
  miCreate!contenido = txtContenido.Text
  miCreate!id_usuario = m_InicioCierre.IdUsuarioEnCurso
  miCreate!fecha = Now

  Try miCreate.Update()
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al guardar la nota:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 3. RECARGAR LISTADO Y AVISAR AL USUARIO ---
  CargarNotas()
  m_Sonido.sonar("Info")
  Message.Info("Nueva entrada guardada.")
  LimpiarCamposNotas()

  ' --- 4. RESTABLECER ESTADO DE LA INTERFAZ ---
  EstablecerModoVisualizacion()

End

' ============================================
' Función   : btnGuardarMod_Click
' Propósito : Modifica una nota existente. Valida que el usuario logueado sea
'             el autor antes de aplicar cambios. Validación por ID, no nombre.
' ============================================
Public Sub btnGuardarMod_Click()

  Dim miEdit As Result

  ' --- 1. VALIDAR QUE EL ID DE USUARIO ESTÉ DISPONIBLE ---
  If m_InicioCierre.IdUsuarioEnCurso = 0 Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el usuario actual en la base de datos.")
    Return
  Endif

  ' --- 2. VALIDAR FILA SELECCIONADA EN EL GRID ---
  If gridNotas.Row < 0 Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe seleccionar una nota del listado.")
    Return
  Endif

  ' --- 3. VERIFICAR AUTORÍA DE LA NOTA POR ID, NO POR NOMBRE ---
  Contenido.MoveTo(gridNotas.Row)
  If Contenido["id_usuario"] <> m_InicioCierre.IdUsuarioEnCurso Then
    m_Sonido.sonar("Warning")
    Message.Warning("No puede modificar notas de otros usuarios.")
    Return
  Endif

  ' --- 4. OBTENER REGISTRO PARA EDICIÓN Y APLICAR CAMBIOS ---
  Try miEdit = m_ConexionBD.mConn.Edit("block_notas", "id=&1", ID_block.Value)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al editar la nota:" & gb.NewLine & Error.Text)
    Return
  Endif

  miEdit!asunto = txtAsunto.Text
  miEdit!contenido = txtContenido.Text

  Try miEdit.Update()
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al actualizar la nota:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 5. RECARGAR LISTADO Y AVISAR AL USUARIO ---
  CargarNotas()
  LimpiarCamposNotas()
  m_Sonido.sonar("Info")
  Message.Info("Los cambios se guardaron con éxito.")

  ' --- 6. RESTABLECER ESTADO DE LA INTERFAZ ---
  EstablecerModoVisualizacion()

End

' ============================================
' Función   : btnBorrar_Click
' Propósito : Elimina la nota seleccionada. Valida autoría por ID antes de
'             borrar. Defensa en profundidad: aunque el botón no se muestra
'             para notas ajenas, el handler valida igual por las dudas.
' ============================================
Public Sub btnBorrar_Click()

  ' --- 1. VALIDAR QUE HAYA UNA ENTRADA SELECCIONADA ---
  If ID_block.Text = "" Then
    m_Sonido.sonar("Info")
    Message.Info("Debe primero seleccionar la entrada a borrar.")
    Return
  Endif

  ' --- 2. VALIDAR QUE EL ID DE USUARIO ESTÉ DISPONIBLE ---
  If m_InicioCierre.IdUsuarioEnCurso = 0 Then
    m_Sonido.sonar("Error")
    Message.Error("No se encontró el usuario actual en la base de datos.")
    Return
  Endif

  ' --- 3. VALIDAR AUTORÍA POR ID (DEFENSA EN PROFUNDIDAD) ---
  If gridNotas.Row >= 0 Then
    Contenido.MoveTo(gridNotas.Row)
    If Contenido["id_usuario"] <> m_InicioCierre.IdUsuarioEnCurso Then
      m_Sonido.sonar("Error")
      Message.Error("No tiene permiso para eliminar esta nota. Solo el autor puede hacerlo.")
      Return
    Endif
  Endif

  ' --- 4. CONFIRMAR LA ELIMINACIÓN ---
  If Message.Question("¿Desea borrar la entrada?", "Sí", "No") <> 1 Then Return

  ' --- 5. EJECUTAR EL DELETE PARAMETRIZADO ---
  Try m_ConexionBD.mConn.Exec("DELETE FROM block_notas WHERE id = &1", CInt(ID_block.Text))
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al eliminar la nota:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 6. RECARGAR LISTADO, AVISAR Y RESTABLECER UI ---
  CargarNotas()
  m_Sonido.sonar("Info")
  Message.Info("Entrada eliminada correctamente.")
  LimpiarCamposNotas()
  EstablecerModoVisualizacion()

End

' ============================================
' Función   : btnBuscar_Click
' Propósito : Busca notas cuyo asunto o contenido contenga el texto del campo
'             de búsqueda. Los caracteres % y _ se tratan como literales,
'             no como wildcards SQL (escapados con backslash).
' ============================================
Public Sub btnBuscar_Click()

  Dim sBusqueda As String
  Dim sConsulta As String

  ' --- 1. RESTABLECER BOTONES AL ESTADO DE VISUALIZACIÓN ---
  EstablecerModoVisualizacion()

  ' --- 2. VALIDAR QUE HAY TEXTO A BUSCAR ---
  If txtBuscar.Text = "" Then
    m_Sonido.sonar("Warning")
    Message.Warning("Debe introducir contenido a buscar.")
    Return
  Endif

  ' --- 3. ESCAPAR WILDCARDS PARA TRATARLOS COMO LITERALES ---
  ' SE USA "!" COMO CARÁCTER DE ESCAPE (DEFINIDO MÁS ABAJO CON ESCAPE '!')
  ' ASÍ EVITAMOS USAR BACKSLASHES EN EL CÓDIGO GAMBAS, QUE ALGUNOS EDITORES
  ' E IDES INTERPRETAN COMO CONTINUACIÓN DE LÍNEA O ESCAPE DE COMILLAS
  sBusqueda = txtBuscar.Text
  sBusqueda = Replace(sBusqueda, "!", "!!")
  sBusqueda = Replace(sBusqueda, "%", "!%")
  sBusqueda = Replace(sBusqueda, "_", "!_")
  sBusqueda = "%" & sBusqueda & "%"

  ' --- 4. CONSULTA PARAMETRIZADA CON LIKE EN ASUNTO Y CONTENIDO ---
  ' ESCAPE '!' INDICA A MySQL QUE EL "!" ES EL CARÁCTER DE ESCAPE EN ESTE LIKE
  sConsulta = "SELECT b.*, u.usuario FROM block_notas b " &
    "JOIN usuarios u ON b.id_usuario = u.id " &
    "WHERE b.asunto LIKE &1 ESCAPE '!' OR b.contenido LIKE &1 ESCAPE '!' " &
    "ORDER BY b.id DESC"

  Try Contenido = m_ConexionBD.mConn.Exec(sConsulta, sBusqueda)
  If Error Then
    m_Sonido.sonar("Error")
    Message.Error("Error al realizar la búsqueda:" & gb.NewLine & Error.Text)
    Return
  Endif

  ' --- 5. PROCESAR RESULTADOS ---
  If Contenido.Count = 0 Then
    m_Sonido.sonar("Info")
    Message.Info("No se ha encontrado ningún resultado.")
    gridNotas.Rows.Count = 0
    gridNotas.Refresh()
    Return
  Endif

  ' LIMPIAR CAMPOS DE DETALLE Y RECARGAR LA GRILLA CON LO ENCONTRADO
  txtAsunto.Text = ""
  txtContenido.Text = ""
  txtUsuario.Text = ""
  gridNotas.Rows.Count = Contenido.Count
  gridNotas.Refresh()

End

' ============================================
' Función   : btnRefrescarGridNotas_Click
' Propósito : Restablece el estado de los campos, botones y recarga todas
'             las notas desde la BD (descartando filtros de búsqueda activos).
' ============================================
Public Sub btnRefrescarGridNotas_Click()

  ' --- 1. LIMPIAR CAMPOS DE DETALLE ---
  txtAsunto.Text = ""
  txtContenido.Text = ""
  txtUsuario.Text = ""

  ' --- 2. RESTABLECER ESTADO DE LA INTERFAZ ---
  EstablecerModoVisualizacion()

  ' --- 3. RECARGAR TODAS LAS NOTAS ---
  gridNotas.Clear
  CargarNotas()

End